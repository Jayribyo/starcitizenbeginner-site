---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReferralBanner from "../../components/ReferralBanner.astro";
import OnThisPage from "../../components/OnThisPage.astro";
import FaqSchema from "../../components/FaqSchema.astro";
import HowToSchema from "../../components/HowToSchema.astro";

const referralCode = "STAR-FSRJ-5N7Z";
const referralBonusUEC = "50,000";
const referralLink = `https://www.robertsspaceindustries.com/enlist?referral=${referralCode}`;

const heroImg = "/assets/img/star-citizen-performance-guide/star-citizen-best-settings-performance-optimization-hero.webp";
const sectionImg = "/assets/img/star-citizen-performance-guide/star-citizen-best-settings-performance.webp";

const tocItems = [
  { label: "Requirements explained", href: "#requirements" },
  { label: "Can your PC run it?", href: "#pc-ready" },
  { label: "Recommended settings", href: "#settings" },
  { label: "Fix stutter & low FPS", href: "#stutter" },
  { label: "CPU vs GPU bottleneck", href: "#bottleneck" },
  { label: "Crash fixes", href: "#crashes" },
  { label: "Upgrades that matter", href: "#upgrades" },
  { label: "FAQ", href: "#faq" },
];

const faqItems = [
  {
    q: "What PC specs do I actually need for Star Citizen?",
    a: "Think in outcomes, not marketing labels: you want enough CPU headroom for busy areas, enough RAM to avoid stutters and crashes, and a fast SSD to stream assets smoothly. If any one of those is missing, you’ll feel it — even with a strong GPU.",
  },
  {
    q: "Why does Star Citizen run worse in cities?",
    a: "Cities combine dense geometry, lots of lighting, and heavy streaming. That stresses CPU scheduling, RAM, and storage at the same time. A stable baseline setup reduces the spikes that feel like stutter.",
  },
  {
    q: "Do settings really matter for FPS?",
    a: "Yes, but not every setting is equal. A few options can dramatically increase GPU load (and frame-time spikes). The goal is stable frame-times, not just a high FPS number.",
  },
  {
    q: "Is stutter normal on the first session?",
    a: "Some stutter can happen while shaders compile and assets cache. After a couple of sessions, it usually improves. Persistent stutter usually means a storage, RAM, or background-process issue.",
  },
  {
    q: "Should I cap FPS or use V-Sync?",
    a: "A cap can smooth frame-times by preventing wild swings. V-Sync can reduce tearing but may add input latency. Start with the recommended baseline and adjust only one thing at a time.",
  },
  {
    q: "What is the single biggest performance upgrade?",
    a: "A fast SSD and enough memory headroom. These two reduce the worst stutter and loading spikes for most players. After that, CPU headroom becomes the limiter in busy hubs.",
  },
  {
    q: "Do I need a high-end PC to enjoy the game?",
    a: "Not necessarily. Many players get a good experience with a sensible baseline setup and realistic expectations in the most demanding locations. The key is stability: avoid crashes and heavy stutter first.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: { "@type": "Answer", text: item.a },
  })),
};

const howToJsonLd = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: "How to optimize Star Citizen performance (beginner checklist)",
  description:
    "A safe, step-by-step checklist to check PC readiness, apply baseline settings, reduce stutter, and fix common crashes.",
  totalTime: "PT20M",
  step: [
    {
      "@type": "HowToStep",
      name: "Check PC readiness",
      text: "Confirm you have SSD storage, enough free disk space, and enough memory headroom for smooth streaming.",
    },
    {
      "@type": "HowToStep",
      name: "Apply baseline in-game settings",
      text: "Use the recommended baseline settings first, then change only one setting at a time.",
    },
    {
      "@type": "HowToStep",
      name: "Fix stutter sources",
      text: "Reduce background overlays, allow shader caching to settle, and ensure Windows has enough virtual memory headroom.",
    },
    {
      "@type": "HowToStep",
      name: "Stabilize crashes",
      text: "Verify files, remove unstable overclocks, and test without overlays or capture tools.",
    },
  ],
};
---

<BaseLayout
  title="Star Citizen Performance Guide: Requirements, Settings & FPS Fixes"
  description="Check if your PC can run Star Citizen, then fix stutter, low FPS, and crashes with a beginner-safe baseline: recommended settings, stability tweaks, and upgrade priorities."
  canonicalPath="/star-citizen-performance-guide/"
  ogImage={heroImg}
  ogImageAlt="Star Citizen performance guide hero image"
  activeNav="guides"
>
  <link slot="head" rel="preload" as="image" href={heroImg} fetchpriority="high" />
  <FaqSchema slot="head" json={faqJsonLd} />
  <HowToSchema slot="head" json={howToJsonLd} />

  <main>
    <!-- HERO -->
    <section class="hero">
      <img
        class="hero__img"
        src={heroImg}
        alt="Cinematic Star Citizen scene representing performance optimization and smooth gameplay"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1536"
        height="1024"
      />
      <div class="hero__overlay"></div>

      <div class="hero__content">
        <div class="kicker"><span class="dot"></span> Starter Guide</div>
        <h1 class="h1">Star Citizen Performance Guide</h1>
        <p class="lead">
          Check if your PC is ready — then fix stutter, low FPS, and crashes with a beginner-safe baseline.
        </p>

        <div class="btnrow" style="margin-top: 14px;">
          <a class="btn primary" href="#pc-ready">Check PC readiness</a>
          <a class="btn secondary" href="#settings">Recommended settings</a>
        </div>
      </div>

      <OnThisPage variant="hero" title="On this page" items={tocItems} />
    </section>

    <!-- Referral banner (consistent site-wide) -->
    <ReferralBanner
      code={referralCode}
      bonus={`${referralBonusUEC} UEC`}
      ctaHref={referralLink}
      howItWorksHref="/star-citizen-referral-code/#how-to-use"
      sublineHtml="Enter during signup — or within <b>24 hours</b> after account creation."
      ariaLabel="Referral bonus callout"
    />

    <!-- REQUIREMENTS -->
    <section id="requirements" class="section">
      <div class="card pad">
        <h2 class="section__title">Requirements explained (what matters in real play)</h2>
        <p>
          Star Citizen performance is shaped less by one “magic” part and more by how well your system handles <strong>streaming</strong>.
          The game constantly loads assets, shaders, and data — especially in busy hubs. That’s why the best approach is to build a stable baseline:
          <strong>SSD + memory headroom + CPU breathing room</strong>.
        </p>

        <div class="tableWrap" style="margin-top:12px;">
          <table class="table">
            <thead>
              <tr>
                <th>Target experience</th>
                <th>What to expect</th>
                <th>What matters most</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th>Minimum (playable)</th>
                <td>You can play, but expect stutter in large cities and big fights.</td>
                <td>SSD streaming + enough memory headroom to avoid spikes.</td>
              </tr>
              <tr>
                <th>Recommended (smooth)</th>
                <td>Comfortable sessions in most areas with fewer frame-time spikes.</td>
                <td>CPU headroom + stable drivers + baseline settings.</td>
              </tr>
              <tr>
                <th>High-end (best feel)</th>
                <td>Better consistency in demanding hubs and heavy activity.</td>
                <td>CPU + memory + strong GPU for higher resolution settings.</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="card pad" style="margin-top:12px; display:flex; gap:12px; flex-wrap:wrap; align-items:center; justify-content:space-between;">
          <div>
            <strong>Considering buying the game?</strong>
            <div style="color: rgba(255,255,255,.74);">Use the readiness check below to see whether your current PC will be enjoyable.</div>
          </div>
          <a class="btn secondary" href="#pc-ready">Run the quick check</a>
        </div>
      </div>
    </section>

    <!-- SECTION IMAGE -->
    <section class="section" aria-label="Performance guide image">
      <div class="card pad" style="padding:0; overflow:hidden;">
        <img
          src={sectionImg}
          alt="Star Citizen settings and performance optimization illustration"
          loading="lazy"
          decoding="async"
          width="1536"
          height="1024"
          style="width:100%; height:auto; display:block;"
        />
      </div>
    </section>

    <!-- PC READY -->
    <section id="pc-ready" class="section">
      <div class="card pad">
        <h2 class="section__title">Can your PC run Star Citizen? (2-minute checklist)</h2>
        <p>
          Use this quick checklist before you spend time tweaking settings. It’s designed for beginners: you don’t need benchmark apps — just a realistic
          picture of what’s likely holding you back.
        </p>

        <div class="tableWrap" style="margin-top:12px;">
          <table class="table table--steps">
            <thead>
              <tr>
                <th>Step</th>
                <th>Check</th>
                <th>Why it matters</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><b>1</b></td>
                <td><b>SSD installed</b> (game on SSD)</td>
                <td>Most “micro-stutter” is asset streaming. SSD is the biggest quality-of-life baseline.</td>
              </tr>
              <tr>
                <td><b>2</b></td>
                <td><b>Free disk space</b> on the SSD</td>
                <td>Low free space can worsen streaming and caching behavior.</td>
              </tr>
              <tr>
                <td><b>3</b></td>
                <td><b>Memory headroom</b> while playing</td>
                <td>If you hit memory pressure, you get stutter spikes and sometimes crashes.</td>
              </tr>
              <tr>
                <td><b>4</b></td>
                <td><b>Stable drivers</b> (no experimental tweaks)</td>
                <td>Driver instability is a top cause of random crashes and hitching.</td>
              </tr>
              <tr>
                <td><b>5</b></td>
                <td><b>Overlays off</b> for testing (Discord, capture tools)</td>
                <td>Overlays can add frame-time spikes and cause crashes. Test baseline first.</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="grid2" style="margin-top:12px;">
          <div class="card pad">
            <h3 style="margin:0 0 8px;">If you’re testing during Free Fly</h3>
            <p style="margin:0;">
              Judge your system by consistency, not perfect FPS in cities. Busy hubs are the worst-case scenario.
              If your baseline is stable, the game becomes far more enjoyable.
            </p>
          </div>
          <div class="card pad">
            <h3 style="margin:0 0 8px;">If you plan to buy</h3>
            <p style="margin:0;">
              Once your PC passes the baseline, the next step is choosing a beginner-friendly starter pack.
              Don’t overbuy — you can upgrade later.
            </p>
            <a class="btn primary" href="/star-citizen-starter-packs/" style="margin-top:10px;">See starter packs</a>
          </div>
        </div>
      </div>
    </section>

    <!-- SETTINGS -->
    <section id="settings" class="section">
      <div class="card pad">
        <h2 class="section__title">Recommended settings (beginner-safe baseline)</h2>
        <p>
          The goal is <strong>stable frame-times</strong> — not chasing a single “max FPS” number. Apply this baseline first, then adjust slowly.
          If you change ten things at once, you’ll never know what helped.
        </p>

        <div class="tableWrap" style="margin-top:12px;">
          <table class="table">
            <thead>
              <tr>
                <th>Setting</th>
                <th>Recommended</th>
                <th>Why</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th>Quality approach</th>
                <td>Start balanced, then tune 1–2 heavy settings</td>
                <td>Most gains come from a few options. Keep the rest stable.</td>
              </tr>
              <tr>
                <th>Volumetric clouds</th>
                <td>Lower for smoother performance</td>
                <td>High impact in atmospheres and cities.</td>
              </tr>
              <tr>
                <th>Motion blur / film grain</th>
                <td>Off</td>
                <td>Reduces visual noise and can improve perceived clarity.</td>
              </tr>
              <tr>
                <th>V-Sync</th>
                <td>Off for troubleshooting</td>
                <td>Removes one variable and avoids added input latency while testing.</td>
              </tr>
              <tr>
                <th>FPS cap</th>
                <td>Use a sensible cap if you get big swings</td>
                <td>Smoother frame-times can feel better than uncapped peaks.</td>
              </tr>
              <tr>
                <th>Resolution scaling</th>
                <td>Lower only if you’re GPU-bound</td>
                <td>If lowering resolution doesn’t help, your bottleneck is likely CPU/streaming.</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="card pad" style="margin-top:12px; display:flex; gap:12px; flex-wrap:wrap; align-items:center; justify-content:space-between;">
          <div>
            <strong>New account tip:</strong>
            <div style="color: rgba(255,255,255,.74);">When you sign up, you can start with extra credits via a referral code.</div>
          </div>
          <a class="btn secondary" href="/star-citizen-referral-code/">Claim the signup bonus</a>
        </div>
      </div>
    </section>

    <!-- STUTTER -->
    <section id="stutter" class="section">
      <div class="card pad">
        <h2 class="section__title">Fix stutter & low FPS (in the safest order)</h2>
        <p>
          Stutter usually comes from <strong>streaming + shaders + background hooks</strong>. Use this order to avoid endless tinkering.
        </p>

        <div class="grid2" style="margin-top:12px;">
          <div class="card pad">
            <h3 style="margin:0 0 8px;">1) Let shaders settle</h3>
            <p style="margin:0;">
              The first sessions after a major update or a fresh install can include shader compilation hitches.
              If the stutter improves after a couple of sessions, you’re likely fine.
            </p>
          </div>
          <div class="card pad">
            <h3 style="margin:0 0 8px;">2) Reduce background hooks</h3>
            <p style="margin:0;">Disable overlays and capture tools while testing. Add them back one by one later.</p>
          </div>
          <div class="card pad">
            <h3 style="margin:0 0 8px;">3) Ensure virtual memory headroom</h3>
            <p style="margin:0;">Windows needs breathing room. If memory pressure hits, frame-times spike and crashes become more likely.</p>
          </div>
          <div class="card pad">
            <h3 style="margin:0 0 8px;">4) Keep SSD free space</h3>
            <p style="margin:0;">Low SSD space can worsen caching and streaming. Keep comfortable free space for stability.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- BOTTLENECK -->
    <section id="bottleneck" class="section">
      <div class="card pad">
        <h2 class="section__title">CPU-bound or GPU-bound? Use this simple test</h2>
        <p>
          You don’t need deep benchmarking. A quick observation tells you what to change — and what to ignore.
        </p>

        <div class="grid2" style="margin-top:12px;">
          <div class="card pad">
            <h3 style="margin:0 0 8px;">Likely GPU-bound</h3>
            <ul class="bullets">
              <li>Lowering resolution noticeably increases FPS.</li>
              <li>Lowering heavy visual settings increases FPS.</li>
              <li>Performance is worse in atmospheres or with lots of effects.</li>
            </ul>
          </div>
          <div class="card pad">
            <h3 style="margin:0 0 8px;">Likely CPU / streaming-bound</h3>
            <ul class="bullets">
              <li>Lowering resolution barely changes FPS.</li>
              <li>Stutter spikes happen during movement/loading.</li>
              <li>Cities feel inconsistent even on low settings.</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- CRASHES -->
    <section id="crashes" class="section">
      <div class="card pad">
        <h2 class="section__title">Crash fixes (common causes)</h2>
        <p>Use this order. It solves most crashes without guesswork.</p>

        <div class="tableWrap" style="margin-top:12px;">
          <table class="table table--steps">
            <thead>
              <tr>
                <th>Step</th>
                <th>Action</th>
                <th>Why it helps</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><b>1</b></td>
                <td>Verify game files in the launcher</td>
                <td>Fixes corrupted/partial downloads and missing assets.</td>
              </tr>
              <tr>
                <td><b>2</b></td>
                <td>Disable overlays and capture tools</td>
                <td>Removes a frequent crash source while troubleshooting.</td>
              </tr>
              <tr>
                <td><b>3</b></td>
                <td>Remove unstable overclocks / undervolts</td>
                <td>Star Citizen can be sensitive to borderline stability.</td>
              </tr>
              <tr>
                <td><b>4</b></td>
                <td>Update to a stable GPU driver</td>
                <td>Eliminates driver-level instability and rendering errors.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- UPGRADES -->
    <section id="upgrades" class="section">
      <div class="card pad">
        <h2 class="section__title">Upgrades that matter (highest ROI first)</h2>
        <p>
          If you’re checking requirements before buying, or you’re disappointed by performance, these upgrades give the most consistent improvement.
          Think “reduce stutter and crashes first” — then chase higher visuals.
        </p>

        <div class="tableWrap" style="margin-top:12px;">
          <table class="table">
            <thead>
              <tr>
                <th>Upgrade</th>
                <th>Impact</th>
                <th>When it’s worth it</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th>SSD (fast storage)</th>
                <td>Huge stutter reduction</td>
                <td>If the game is on HDD or a slow drive.</td>
              </tr>
              <tr>
                <th>More memory headroom</th>
                <td>Fewer spikes + fewer crashes</td>
                <td>If you see heavy hitching or background apps push you into memory pressure.</td>
              </tr>
              <tr>
                <th>CPU headroom</th>
                <td>Better consistency in hubs</td>
                <td>If lowering resolution doesn’t help and cities feel choppy.</td>
              </tr>
              <tr>
                <th>GPU</th>
                <td>Higher visuals / resolution</td>
                <td>If you’re clearly GPU-bound and want a sharper image.</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="card pad" style="margin-top:12px; display:flex; gap:12px; flex-wrap:wrap; align-items:center; justify-content:space-between;">
          <div>
            <strong>Next step:</strong>
            <div style="color: rgba(255,255,255,.74);">If your PC meets the baseline, pick a beginner-friendly starter pack and start playing.</div>
          </div>
          <a class="btn primary" href="/star-citizen-starter-packs/">Choose a starter pack</a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq" class="section">
      <div class="card pad">
        <h2 class="section__title">FAQ</h2>
        <div class="faq" style="margin-top:10px;">
          {faqItems.map((item) => (
            <details class="faq__item">
              <summary class="faq__q">{item.q}</summary>
              <div class="faq__a">{item.a}</div>
            </details>
          ))}
        </div>

        <div class="card pad" style="margin-top:12px; display:flex; gap:12px; flex-wrap:wrap; align-items:center; justify-content:space-between;">
          <div>
            <strong>Ready to start?</strong>
            <div style="color: rgba(255,255,255,.74);">Use a referral code before signup, then pick a starter pack that fits your playstyle.</div>
          </div>
          <div style="display:flex; gap:10px; flex-wrap:wrap;">
            <a class="btn secondary" href="/star-citizen-referral-code/">Claim signup bonus</a>
            <a class="btn primary" href="/star-citizen-starter-packs/">See starter packs</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
