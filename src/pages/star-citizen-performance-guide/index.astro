---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReferralBanner from "../../components/ReferralBanner.astro";
import OnThisPage from "../../components/OnThisPage.astro";
import FaqSchema from "../../components/FaqSchema.astro";
import HowToSchema from "../../components/HowToSchema.astro";

const referralCode = "STAR-FSRJ-5N7Z";
const referralBonusUEC = "50,000";
const referralLink = `https://www.robertsspaceindustries.com/enlist?referral=${referralCode}`;

const heroImg = "/assets/img/star-citizen-performance-guide/star-citizen-best-settings-performance-optimization-hero.webp";
const sectionImg = "/assets/img/star-citizen-performance-guide/star-citizen-best-settings-performance.webp";

const tocItems = [
  { label: "Requirements: min / recommended / optimal", href: "#requirements" },
  { label: "2-minute readiness check", href: "#pc-ready" },
  { label: "Best settings for performance", href: "#settings" },
  { label: "Fix stutter & low FPS", href: "#stutter" },
  { label: "CPU vs GPU bottleneck", href: "#bottleneck" },
  { label: "Crash fixes", href: "#crashes" },
  { label: "Upgrades that matter", href: "#upgrades" },
  { label: "FAQ", href: "#faq" },
];

const faqItems = [
  {
    q: "What PC specs do I actually need for Star Citizen?",
    a: "Official minimum is 16 GB RAM + 4 GB VRAM + SSD. For a smooth beginner experience, aim for 32 GB RAM, an 8 GB+ VRAM GPU, and a modern CPU with strong single-thread performance (cities expose weak CPUs fast).",
  },
  {
    q: "Why does Star Citizen run worse in cities?",
    a: "Cities are the worst-case mix: heavy streaming + lots of objects + lighting + simulation. If you’re on the edge (16 GB RAM, low SSD space, weak CPU), cities expose it immediately.",
  },
  {
    q: "Do settings really matter for FPS?",
    a: "Yes. A few settings do most of the work: Resolution/Upscaling, Volumetric Clouds, and Shadows. Start with the baseline and change one lever at a time.",
  },
  {
    q: "Is stutter normal on the first session?",
    a: "Some hitching can happen on a fresh install or after major driver/graphics-setting changes while shaders/assets settle. If it stays bad after 2–3 repeat runs in the same spot, it’s usually SSD/RAM/pagefile headroom or overlays.",
  },
  {
    q: "Should I cap FPS or use V-Sync?",
    a: "For troubleshooting: V-Sync OFF first. If you get big FPS swings, add a cap (60/75/90) to stabilize frame-times. Change one variable, then retest in the same location.",
  },
  {
    q: "What is the single biggest performance upgrade?",
    a: "Moving the game to a fast SSD/NVMe and going from 16 GB to 32 GB RAM. That often removes the worst streaming stutter and reduces crash risk.",
  },
  {
    q: "Do I need a high-end PC to enjoy the game?",
    a: "No — but you do need the right basics: SSD + enough RAM + a decent CPU. If your baseline is stable, you can enjoy most content even if city FPS isn’t perfect.",
  },

  {
    q: "Should I use Vulkan or DirectX?",
    a: "Start with the option that is stable on your system. If Vulkan gives crashes or severe stutter, switch back to DirectX and retest in the same location. Stability beats a tiny FPS gain.",
  },
  {
    q: "How much free disk space do I need on the SSD?",
    a: "Keep meaningful headroom. As a rule-of-thumb, aim for ~20% free space on the drive that holds the game. Low free space can worsen caching and increase stutter or crashes.",
  },
  {
    q: "Will more RAM reduce stutter?",
    a: "Often, yes. 16 GB can work, but it’s easier to hit memory pressure (pagefile spikes, hitching, out-of-memory errors). 32 GB is the most consistent beginner baseline.",
  },
  {
    q: "Should I reinstall the game if performance is bad?",
    a: "Only after you’ve done the basics: SSD install, enough free space, pagefile set safely, overlays off, and a stable driver. Reinstalling rarely fixes a hardware bottleneck or memory pressure.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: { "@type": "Answer", text: item.a },
  })),
};

const howToJsonLd = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: "How to optimize Star Citizen performance (beginner checklist)",
  description:
    "A safe, step-by-step checklist to check PC readiness, apply baseline settings, reduce stutter, and fix common crashes.",
  totalTime: "PT20M",
  step: [
    {
      "@type": "HowToStep",
      name: "Check PC readiness",
      text: "Confirm SSD install, enough free disk space, and enough RAM/pagefile headroom (16GB minimum, 32GB recommended).",
    },
    {
      "@type": "HowToStep",
      name: "Apply baseline in-game settings",
      text: "Set upscaling and the top performance levers (resolution, clouds, shadows). Then change one setting at a time.",
    },
    {
      "@type": "HowToStep",
      name: "Fix stutter sources",
      text: "Disable overlays while testing, keep SSD free space, and set Windows pagefile to automatic (or a safe custom size if you run 16GB RAM).",
    },
    {
      "@type": "HowToStep",
      name: "Stabilize crashes",
      text: "Verify files, remove unstable overclocks/undervolts, and test without overlays or capture tools.",
    },
  ],
};
---

<BaseLayout
  title="Star Citizen Performance Guide: Requirements, Best Settings & FPS Fixes"
  description="Concrete Star Citizen performance help: official min/recommended specs, practical PC builds, best settings for smooth frame-times, and a safe stutter/crash fix checklist."
  canonicalPath="/star-citizen-performance-guide/"
  ogImage={heroImg}
  ogImageAlt="Star Citizen performance guide hero image"
  stickyCtaLabel="Claim +50k UEC start bonus"
  stickyCtaHref={referralLink}
  stickyCtaExternal={true}
  activeNav="guides"
>
  <link slot="head" rel="preload" as="image" href={heroImg} fetchpriority="high" />
  <FaqSchema slot="head" json={faqJsonLd} />
  <HowToSchema slot="head" json={howToJsonLd} />

  <main>
    <!-- HERO -->
    <section class="hero guideHero">
      <img
        class="hero__img"
        src={heroImg}
        alt="Cinematic Star Citizen scene representing performance optimization and smooth gameplay"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1536"
        height="1024"
      />
      <div class="hero__overlay"></div>

      <div class="hero__content">
        <div class="guideHero__content">
          <div class="kicker"><span class="dot"></span> Starter Guide</div>
          <h1 class="h1">Star Citizen Performance Guide</h1>
          <p class="lead" style="max-width: 820px;">
            No more guessing: <b>official specs</b>, <b>practical build tiers</b>, and the <b>exact settings</b> that give you the biggest FPS wins.
          </p>

          <div class="btnrow" style="margin-top: 14px;">
            <a class="btn primary" href="#pc-ready">Run the 2-minute check</a>
</div>
        </div>
      </div>

      <OnThisPage variant="hero" title="On this page" items={tocItems} />
    </section>

    <!-- Referral banner (consistent site-wide) -->
    <ReferralBanner
      code={referralCode}
      bonus={`${referralBonusUEC} UEC`}
            ctaLabel="Claim your start bonus (+UEC)"
ctaHref={referralLink}
      howItWorksHref="/star-citizen-referral-code/#how-to-use"
      sublineHtml="Enter during signup — or within <b>24 hours</b> after account creation."
      ariaLabel="Referral bonus callout"
    />

    <!-- REQUIREMENTS -->
    <section id="requirements" class="section">
      <div class="card pad">
        <h2 class="section__title">Requirements: min / recommended / optimal</h2>
        <p>
          Star Citizen is a <strong>streaming-heavy</strong> game. If one pillar is weak, you’ll feel it even with a strong GPU:
          <strong>SSD</strong> (asset streaming), <strong>RAM + pagefile headroom</strong> (stutter/crash prevention), and <strong>CPU headroom</strong> (cities + big fights).
        </p>

        <div class="card pad" style="margin-top:12px;">
          <strong>Evidence labels used on this page</strong>
          <ul class="bullets" style="margin-top:8px;">
            <li><b>Official</b> = RSI support docs</li>
            <li><b>Rule-of-thumb</b> = practical targets that consistently feel good for most players</li>
          </ul>
        </div>

        <div class="tableWrap" style="margin-top:12px;">
          <table class="table">
            <thead>
              <tr>
                <th>Tier</th>
                <th>CPU</th>
                <th>GPU</th>
                <th>RAM</th>
                <th>Storage</th>
                <th>Who it’s for</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th>Minimum <span style="opacity:.75; font-weight:600;">(Official)</span></th>
                <td>Intel i7 (Haswell+) / AMD Excavator+</td>
                <td>DX11.1 GPU, <b>4 GB VRAM</b> (example: GTX 1060)</td>
                <td><b>16 GB</b></td>
                <td><b>150+ GB SSD required</b></td>
                <td>It runs. Expect stutter in cities + heavy scenes.</td>
              </tr>
              <tr>
                <th>Recommended <span style="opacity:.75; font-weight:600;">(Official)</span></th>
                <td>Intel i7 (Haswell+) / AMD Ryzen 5+</td>
                <td>DX12 GPU, <b>8 GB VRAM</b></td>
                <td><b>32 GB</b> DDR4</td>
                <td><b>150+ GB SSD required</b></td>
                <td>Good beginner baseline. Fewer spikes, fewer crashes.</td>
              </tr>
              <tr>
                <th>Optimal <span style="opacity:.75; font-weight:600;">(Rule-of-thumb)</span></th>
                <td>Strong modern 8-core-class CPU</td>
                <td><b>12–16 GB VRAM</b> for high settings / 1440p+</td>
                <td><b>32–64 GB</b></td>
                <td><b>NVMe SSD</b> + 20% free space</td>
                <td>Best “feels good” setup for cities + big events.</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="card pad" style="margin-top:12px; display:flex; gap:12px; flex-wrap:wrap; align-items:center; justify-content:space-between;">
          <div>
            <strong>Official source</strong>
            <div style="color: rgba(255,255,255,.74);">Requirements can change during development. Check the latest RSI spec page.</div>
          </div>
          <a
            class="btn secondary"
            href="https://support.robertsspaceindustries.com/hc/en-us/articles/360042417374-Star-Citizen-Minimum-System-Requirements"
            target="_blank"
            rel="noopener"
            >RSI minimum + recommended</a>
        </div>

        <h3 style="margin:14px 0 8px;">Example PC builds (Rule-of-thumb)</h3>
        <p style="margin-top:0;">Pick the tier that matches your monitor resolution. This is about <b>stability first</b>, then visuals.</p>

        <div class="tableWrap" style="margin-top:12px;">
          <table class="table">
            <thead>
              <tr>
                <th>Tier</th>
                <th>Target</th>
                <th>CPU examples</th>
                <th>GPU examples</th>
                <th>RAM</th>
                <th>Notes</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th>Budget (1080p)</th>
                <td>Playable + stable baseline</td>
                <td>Ryzen 5 5600 / i5-12400F+</td>
                <td>RTX 3060 12GB / RX 6700 XT</td>
                <td>32 GB</td>
                <td>Use upscaling + Low clouds in cities.</td>
              </tr>
              <tr>
                <th>Balanced (1440p)</th>
                <td>Best value “smooth”</td>
                <td>Ryzen 5 7600 / i5-13400+</td>
                <td>RTX 4070 / RX 7800 XT</td>
                <td>32–64 GB</td>
                <td>Great all-rounder for events and daily play.</td>
              </tr>
              <tr>
                <th>High-end (1440p/4K)</th>
                <td>Best “feels good”</td>
                <td>Ryzen 7 7800X3D / Ryzen 7 5800X3D</td>
                <td>RTX 4070 Ti Super / RTX 4080 / RX 7900 XT</td>
                <td>64 GB</td>
                <td>City consistency improves most from CPU + RAM headroom.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- SECTION IMAGE -->
    <section class="section" aria-label="Performance guide image">
      <div class="card pad" style="padding:0; overflow:hidden;">
        <img
          src={sectionImg}
          alt="Star Citizen settings and performance optimization illustration"
          loading="lazy"
          decoding="async"
          width="1536"
          height="1024"
          style="width:100%; height:auto; display:block;"
        />
      </div>
    </section>

    <!-- PC READY -->
    <section id="pc-ready" class="section">
      <div class="card pad">
        <h2 class="section__title">2-minute readiness check (concrete thresholds)</h2>
        <p>This is the fastest way to predict your experience. If you fail one item, fix that first.</p>

        <div class="tableWrap" style="margin-top:12px;">
          <table class="table table--steps">
            <thead>
              <tr>
                <th>Step</th>
                <th>Check (what you need)</th>
                <th>What it tells you</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><b>1</b></td>
                <td><b>Game is on SSD/NVMe</b> (not HDD)</td>
                <td>SSD is the baseline for streaming. HDD = constant hitching.</td>
              </tr>
              <tr>
                <td><b>2</b></td>
                <td><b>Free SSD space:</b> ideally 20% free (minimum: 30+ GB)</td>
                <td>Low space worsens caching and can break pagefile headroom.</td>
              </tr>
              <tr>
                <td><b>3</b></td>
                <td><b>RAM:</b> 16 GB minimum, <b>32 GB recommended</b></td>
                <td>16 GB often relies on pagefile (more stutter/crash risk).</td>
              </tr>
              <tr>
                <td><b>4</b></td>
                <td><b>VRAM:</b> 4 GB minimum, <b>8 GB+ recommended</b></td>
                <td>VRAM overrun causes big FPS drops and hitching.</td>
              </tr>
              <tr>
                <td><b>5</b></td>
                <td><b>Baseline test:</b> stable driver, overlays OFF</td>
                <td>Removes avoidable variables while you measure the baseline.</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="card pad" style="margin-top:12px;">
          <strong>Do this now (10 minutes)</strong>
          <ul class="bullets" style="margin-top:8px;">
            <li><b>Move Star Citizen to SSD/NVMe</b> if it isn’t already.</li>
            <li><b>Close overlays</b> for your first test (Discord overlay, GeForce/AMD overlay, capture tools).</li>
            <li>
              <b>Pagefile:</b> set to <b>Windows-managed</b> (recommended by RSI). If you’re on <b>16 GB RAM</b>, consider a safe custom size.
              <a href="https://support.robertsspaceindustries.com/hc/en-us/articles/360000083387-Out-of-memory-errors-set-your-pagefile" target="_blank" rel="noopener">(Official pagefile guide)</a>
            </li>
            <li><b>Retest in the same spot</b> before/after (same city + same direction) to compare fairly.</li>
          </ul>
        </div>

        <div class="grid2" style="margin-top:12px;">
          <div class="card pad">
            <h3 style="margin:0 0 8px;">If you’re testing during Free Fly</h3>
            <p style="margin:0;">
              Free Fly servers can be overloaded. Judge your system by <b>stability</b> (crashes + stutter), not perfect city FPS.
            </p>
          </div>
          <div class="card pad">
            <h3 style="margin:0 0 8px;">If you plan to buy</h3>
            <p style="margin:0;">Once you pass the baseline, the next step is picking a beginner-friendly starter pack.</p>
            <a class="btn primary" href="/star-citizen-starter-packs/" style="margin-top:10px;">See starter packs</a>
          </div>
        </div>
      </div>
    </section>

    <!-- SETTINGS -->
    <section id="settings" class="section">
      <div class="card pad">
        <h2 class="section__title">Best settings for performance (beginner-safe baseline)</h2>
        <p>
          Goal: <strong>stable frame-times</strong> before you chase “max FPS”. Apply the baseline, then change <b>one lever at a time</b>.
        </p>

        <div class="card pad" style="margin-top:12px;">
          <strong>If you only change 3 things</strong>
          <ol style="margin:8px 0 0 18px;">
            <li><b>Upscaling</b> (DLSS / CIG-TSR) + choose a mode</li>
            <li><b>Volumetric Clouds</b> (biggest “city killer” for many PCs)</li>
            <li><b>Shadows</b> (high cost + affects frame pacing)</li>
          </ol>
        </div>

        <div class="tableWrap" style="margin-top:12px;">
          <table class="table">
            <thead>
              <tr>
                <th>Setting</th>
                <th>Recommended value</th>
                <th>Impact</th>
                <th>Trade-off</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th>Graphics Renderer <span style="opacity:.7;">(Official)</span></th>
                <td>Try <b>Vulkan</b> first. If unstable, switch back to DirectX.</td>
                <td>High</td>
                <td>Vulkan can be driver sensitive.</td>
              </tr>
              <tr>
                <th>Upscaling Technique <span style="opacity:.7;">(Official)</span></th>
                <td><b>DLSS</b> (NVIDIA) / otherwise <b>CIG-TSR</b></td>
                <td>High</td>
                <td>Lower modes look softer.</td>
              </tr>
              <tr>
                <th>Upscaling Quality</th>
                <td><b>Quality</b> for 1080p/1440p, <b>Balanced</b> if GPU-bound</td>
                <td>High</td>
                <td>Balanced/Performance can look blurrier.</td>
              </tr>
              <tr>
                <th>Volumetric Clouds</th>
                <td><b>Low</b> (or Off if you need a big boost)</td>
                <td>High</td>
                <td>Sky/atmosphere looks flatter.</td>
              </tr>
              <tr>
                <th>Shadow Quality</th>
                <td><b>Medium</b> (drop to Low in cities if needed)</td>
                <td>High</td>
                <td>Less detailed shadows.</td>
              </tr>
              <tr>
                <th>Textures Quality</th>
                <td><b>High</b> if you have <b>8–12GB VRAM</b>; Medium if VRAM is tight</td>
                <td>Medium</td>
                <td>Lower textures can look muddy.</td>
              </tr>
              <tr>
                <th>Motion Blur / Film Grain / Chromatic Aberration</th>
                <td><b>Off</b></td>
                <td>Low</td>
                <td>Purely preference (clarity vs style).</td>
              </tr>
              <tr>
                <th>V-Sync</th>
                <td><b>Off</b> while troubleshooting</td>
                <td>Medium</td>
                <td>Possible tearing; V-Sync can add latency.</td>
              </tr>
              <tr>
                <th>FPS Cap</th>
                <td>Cap at <b>60 / 75 / 90</b> if you get wild swings</td>
                <td>Medium</td>
                <td>Lowers peaks, improves consistency.</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="card pad" style="margin-top:12px; display:flex; gap:12px; flex-wrap:wrap; align-items:center; justify-content:space-between;">
          <div>
            <strong>Official note on upscaling</strong>
            <div style="color: rgba(255,255,255,.74);">RSI recommends DLSS (NVIDIA) or CIG-TSR otherwise.</div>
          </div>
          <a
            class="btn secondary"
            href="https://support.robertsspaceindustries.com/hc/en-us/articles/37500283848983-Optimizing-Graphics-Settings"
            target="_blank"
            rel="noopener"
            >RSI graphics settings article</a>
        </div>
      </div>
    </section>

    <!-- STUTTER -->
    <section id="stutter" class="section">
      <div class="card pad">
        <h2 class="section__title">Fix stutter & low FPS (in the safest order)</h2>
        <p>Stutter usually comes from <strong>streaming + memory pressure + background hooks</strong>. Fix it in this order.</p>

        <div class="tableWrap" style="margin-top:12px;">
          <table class="table table--steps">
            <thead>
              <tr>
                <th>Order</th>
                <th>Do this</th>
                <th>Why it works</th>
                <th>Verify</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><b>1</b></td>
                <td><b>SSD/NVMe + free space</b> (aim 20% free)</td>
                <td>Streaming stutter is the #1 beginner pain point.</td>
                <td>Retest the same city route; hitching should reduce.</td>
              </tr>
              <tr>
                <td><b>2</b></td>
                <td><b>Pagefile: Windows-managed</b> <span style="opacity:.7;">(Official)</span></td>
                <td>Prevents out-of-memory spikes/crashes when RAM is tight.</td>
                <td>Fewer hard freezes + fewer sudden FPS collapses.</td>
              </tr>
              <tr>
                <td><b>3</b></td>
                <td><b>Disable overlays</b> while testing (Discord / NVIDIA / AMD)</td>
                <td>Overlays hook rendering and can spike frame-time.</td>
                <td>Compare frame pacing in the same spot.</td>
              </tr>
              <tr>
                <td><b>4</b></td>
                <td><b>Repeat the same route 2–3 times</b> before judging</td>
                <td>Streaming + shader caching can look worse on the first run.</td>
                <td>Later runs should feel smoother in the same route.</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="card pad" style="margin-top:12px; display:flex; gap:12px; flex-wrap:wrap; align-items:center; justify-content:space-between;">
          <div>
            <strong>Official help: out-of-memory + pagefile</strong>
            <div style="color: rgba(255,255,255,.74);">If you crash or hard-stutter on 16 GB, pagefile setup is often the fix.</div>
          </div>
          <a
            class="btn secondary"
            href="https://support.robertsspaceindustries.com/hc/en-us/articles/360000083387-Out-of-memory-errors-set-your-pagefile"
            target="_blank"
            rel="noopener"
            >Open RSI pagefile guide</a>
        </div>
      </div>
    </section>

    <!-- BOTTLENECK -->
    <section id="bottleneck" class="section">
      <div class="card pad">
        <h2 class="section__title">CPU-bound or GPU-bound? Use this 60-second test</h2>
        <p>Don’t guess. This tells you what to change — and what to ignore.</p>

        <div class="card pad" style="margin-top:12px;">
          <strong>Do this now (60 seconds)</strong>
          <ol style="margin:8px 0 0 18px;">
            <li>Stand still in a demanding spot (city hub is fine).</li>
            <li>Lower <b>Resolution</b> (or switch Upscaling to a stronger mode) and set <b>Volumetric Clouds</b> to Low.</li>
            <li>If FPS rises <b>~15%+</b>, you’re likely <b>GPU-bound</b>. If FPS barely changes, you’re likely <b>CPU/streaming-bound</b>.</li>
          </ol>
        </div>

        <div class="grid2" style="margin-top:12px;">
          <div class="card pad">
            <h3 style="margin:0 0 8px;">Likely GPU-bound</h3>
            <ul class="bullets">
              <li>Lowering resolution / stronger upscaling increases FPS a lot.</li>
              <li>Clouds and shadows have a big FPS impact.</li>
              <li>Performance is worse in atmospheres or with lots of effects.</li>
            </ul>
          </div>
          <div class="card pad">
            <h3 style="margin:0 0 8px;">Likely CPU / streaming-bound</h3>
            <ul class="bullets">
              <li>Lowering resolution barely changes FPS.</li>
              <li>Stutter spikes happen while moving/loading assets.</li>
              <li>Cities feel inconsistent even on low settings.</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- CRASHES -->
    <section id="crashes" class="section">
      <div class="card pad">
        <h2 class="section__title">Crash fixes (common causes)</h2>
        <p>Use this order. It solves most crashes without guesswork.</p>

        <div class="tableWrap" style="margin-top:12px;">
          <table class="table table--steps">
            <thead>
              <tr>
                <th>Step</th>
                <th>Action</th>
                <th>Why it helps</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><b>1</b></td>
                <td>Verify game files in the launcher</td>
                <td>Fixes corrupted/partial downloads and missing assets.</td>
              </tr>
              <tr>
