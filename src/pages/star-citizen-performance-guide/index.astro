---
import BaseLayout from "../../layouts/BaseLayout.astro";
import OnThisPage from "../../components/OnThisPage.astro";
import FaqSchema from "../../components/FaqSchema.astro";
import ReferralBanner from "../../components/ReferralBanner.astro";

const title = "Star Citizen Performance Guide";
const description = "Check the current Star Citizen PC requirements, verify if your rig is ready, then apply the most effective settings and fixes for stutter, low FPS, and crashes.";

const toc = [
  { id: "requirements", label: "Requirements explained" },
  { id: "pc-ready", label: "Can your PC run it?" },
  { id: "settings", label: "Recommended settings" },
  { id: "stutter", label: "Fix stutter & low FPS" },
  { id: "bottleneck", label: "CPU vs GPU bottleneck" },
  { id: "crashes", label: "Crash fixes" },
  { id: "upgrades", label: "Upgrades that matter" },
  { id: "faq", label: "FAQ" },
];

const faqItems = [
  {
    q: "What are the current minimum requirements for Star Citizen?",
    a: `The official minimum target is a quad‑core CPU, 16 GB RAM, a dedicated GPU with at least 4 GB VRAM, and an SSD with roughly 100 GB free. Use the table above and treat it as “can launch and play” — not “smooth everywhere.”`,
  },
  {
    q: "Is 16 GB RAM enough?",
    a: `It can launch, but 32 GB is the practical sweet spot for smoother cities, fewer stalls, and fewer crash‑like hitches under memory pressure. If you only upgrade one thing for stability, RAM is often the best value.`,
  },
  {
    q: "Why does lowering graphics sometimes not increase FPS?",
    a: `Star Citizen is often CPU‑limited in busy areas. Lowering overall quality can shift more work to the CPU. A beginner‑safe approach: keep overall quality “High”, then reduce the known heavy hitters (clouds, shadows, reflections).`,
  },
  {
    q: "What’s the fastest single setting to improve FPS?",
    a: `Volumetric clouds. Dropping clouds from High to Medium/Low (or Off where possible) is usually the quickest way to claw back frames during storms and in atmospheric locations.`,
  },
  {
    q: "Do I need a referral code to play?",
    a: `No. But using one during account creation starts you with the bonus credits — which makes early gear and ship rentals easier. If you’re new, that quality‑of‑life boost matters.`,
  },
];
---

<BaseLayout
  lang="en"
  title={title}
  description={description}
  canonicalPath="/star-citizen-performance-guide/"
  ogImage="/assets/img/star-citizen-performance-guide/star-citizen-best-settings-performance-optimization-hero.webp"
>
  <section class="hero" aria-label="Star Citizen performance guide">
    <img class="hero__img" src="/assets/img/star-citizen-performance-guide/star-citizen-best-settings-performance-optimization-hero.webp" alt="Star Citizen performance dashboard style background" loading="eager" decoding="async" />
    <div class="hero__overlay"></div>

    <div class="hero__content">
      <div class="container hero__grid">
        <div class="hero__main">
          <div class="hero__kicker">STARTER GUIDE</div>
          <h1 class="hero__title">Star Citizen Performance Guide</h1>
          <p class="hero__lead">Check if your PC is ready — then fix stutter, low FPS, and crashes with a beginner‑safe baseline.</p>

          <div class="hero__actions">
            <a class="btn primary" href="#pc-ready">CHECK PC READINESS</a>
            <a class="btn" href="#settings">RECOMMENDED SETTINGS</a>
          </div>
        </div>

        <OnThisPage items={toc} />
      </div>
    </div>
  </section>

  <ReferralBonusStrip />

  <!-- Requirements -->
  <section id="requirements" class="section">
    <div class="container">
      <div class="card pad">
        <h2 class="section__title">Star Citizen PC requirements (what they actually mean)</h2>
        <p class="muted">
          The official specs answer one question: <strong>can you run the game?</strong> Your real goal as a new player is different:
          <strong>stable sessions</strong> (no stutters, no random crashes) — then smooth out FPS.
        </p>

        <div class="tableWrap" style="margin-top: 14px;">
          <table class="table">
            <thead>
              <tr>
                <th>Tier</th>
                <th>CPU</th>
                <th>RAM</th>
                <th>GPU</th>
                <th>Storage</th>
                <th>What to expect</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th>Minimum (official)</th>
                <td>Quad‑core CPU (~3.0 GHz)</td>
                <td>16 GB</td>
                <td>Dedicated GPU (4 GB VRAM)</td>
                <td>SSD, ~100 GB free</td>
                <td>Playable, but cities can feel rough; avoid heavy multitasking.</td>
              </tr>
              <tr>
                <th>Recommended (official)</th>
                <td>Intel i7 / Ryzen 5 or better</td>
                <td>16 GB (32 GB strongly recommended)</td>
                <td>Dedicated GPU (6 GB+ VRAM)</td>
                <td>SSD, ~100 GB free</td>
                <td>Much smoother baseline; fewer stalls and fewer “fake crashes”.</td>
              </tr>
              <tr>
                <th>Beginner‑smooth target</th>
                <td>Modern 6–8 cores (strong single‑core)</td>
                <td><strong>32 GB</strong></td>
                <td>8–12 GB VRAM</td>
                <td>NVMe SSD preferred</td>
                <td>Best “first impression”: smoother cities, less hitching, faster streaming.</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="grid2" style="margin-top: 16px;">
          <div class="card pad" style="background: rgba(255,255,255,.03);">
            <h3 style="margin:0 0 8px;">The #1 stability rule</h3>
            <p class="muted" style="margin:0;">Install on an SSD, keep headroom free, and avoid background memory hogs. Star Citizen streams assets constantly — storage and memory pressure create most “broken game” first impressions.</p>
          </div>
          <div class="card pad" style="background: rgba(255,255,255,.03);">
            <h3 style="margin:0 0 8px;">The #1 FPS rule</h3>
            <p class="muted" style="margin:0;">In busy hubs you’re often CPU‑limited. Don’t chase ultra‑low graphics. Start with a balanced preset and reduce the biggest GPU hitters (clouds, shadows, reflections).</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PC readiness -->
  <section id="pc-ready" class="section">
    <div class="container">
      <div class="card pad">
        <h2 class="section__title">Can your PC run Star Citizen? (fast checklist)</h2>
        <p class="muted">If you only do one thing: hit these baselines first. Most performance complaints come from missing one of these items.</p>

        <div class="tableWrap" style="margin-top: 14px;">
          <table class="table table--steps">
            <thead>
              <tr>
                <th>Step</th>
                <th>Check</th>
                <th>Minimum</th>
                <th>Recommended</th>
                <th>Why it matters</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th>1</th>
                <td><strong>SSD install</strong></td>
                <td>SSD required</td>
                <td>NVMe SSD</td>
                <td>Prevents asset streaming stalls (“micro‑stutter”).</td>
              </tr>
              <tr>
                <th>2</th>
                <td><strong>Free space</strong></td>
                <td>~100 GB free</td>
                <td>150+ GB headroom</td>
                <td>Low disk space increases hitching and can break patches.</td>
              </tr>
              <tr>
                <th>3</th>
                <td><strong>RAM headroom</strong></td>
                <td>16 GB</td>
                <td><strong>32 GB</strong></td>
                <td>Memory pressure causes stutters and “random” crashes.</td>
              </tr>
              <tr>
                <th>4</th>
                <td><strong>GPU VRAM</strong></td>
                <td>4 GB</td>
                <td>8 GB+</td>
                <td>Too little VRAM forces swapping and tanks frame pacing.</td>
              </tr>
              <tr>
                <th>5</th>
                <td><strong>Drivers + overlays</strong></td>
                <td>Stable drivers</td>
                <td>Overlays off while testing</td>
                <td>Overlays can cause frame spikes and crashes. Test clean.</td>
              </tr>
            </tbody>
          </table>
        </div>

        <p class="muted" style="margin-top: 12px;">If you’re below recommended: you can still play — but use the settings below and avoid expecting smooth hubs. Free Fly is a great way to test before buying.</p>
      </div>
    </div>
  </section>

  <!-- Settings -->
  <section id="settings" class="section">
    <div class="container">
      <div class="card pad">
        <h2 class="section__title">Recommended Star Citizen settings (beginner‑safe baseline)</h2>
        <p class="muted">Start here, play for 20 minutes, then change <em>one thing at a time</em>. This avoids the classic trap of changing ten sliders and never knowing what helped.</p>

        <div class="grid2" style="margin-top: 14px;">
          <div class="card pad" style="background: rgba(255,255,255,.03);">
            <h3 style="margin:0 0 8px;">Fast wins (change these first)</h3>
            <ul class="muted" style="margin:0; padding-left: 18px; line-height:1.7;">
              <li><strong>Volumetric Clouds:</strong> Medium / Low (or Off where possible)</li>
              <li><strong>Shadows:</strong> Medium</li>
              <li><strong>Screen Space Reflections:</strong> Low / Off</li>
              <li><strong>Motion Blur / Film Grain / Chromatic Aberration:</strong> Off</li>
              <li><strong>V‑Sync:</strong> Off (test baseline first)</li>
            </ul>
          </div>
          <div class="card pad" style="background: rgba(255,255,255,.03);">
            <h3 style="margin:0 0 8px;">Good defaults (don’t overthink)</h3>
            <ul class="muted" style="margin:0; padding-left: 18px; line-height:1.7;">
              <li><strong>Overall Quality:</strong> High (often smoother than Low in CPU‑limited areas)</li>
              <li><strong>Textures:</strong> High if you have VRAM; otherwise Medium</li>
              <li><strong>Anisotropic Filtering:</strong> 8×</li>
              <li><strong>Sharpening:</strong> low to taste</li>
              <li><strong>Resolution:</strong> native first; use upscaling only if needed</li>
            </ul>
          </div>
        </div>

        <div class="tableWrap" style="margin-top: 16px;">
          <table class="table">
            <thead>
              <tr>
                <th>Setting</th>
                <th>Baseline</th>
                <th>If you need more FPS</th>
                <th>Trade‑off</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th>Volumetric Clouds</th>
                <td>Medium</td>
                <td>Low / Off</td>
                <td>Less atmosphere in storms; big FPS gain.</td>
              </tr>
              <tr>
                <th>Shadows</th>
                <td>Medium</td>
                <td>Low</td>
                <td>Flatter lighting; moderate FPS gain.</td>
              </tr>
              <tr>
                <th>Reflections (SSR)</th>
                <td>Low</td>
                <td>Off</td>
                <td>Less shiny surfaces; good stability gain.</td>
              </tr>
              <tr>
                <th>Overall Quality</th>
                <td>High</td>
                <td>Keep High, reduce the items above</td>
                <td>Lowering too far can increase CPU load.</td>
              </tr>
              <tr>
                <th>Textures</th>
                <td>High (8 GB+ VRAM)</td>
                <td>Medium</td>
                <td>Less crisp surfaces; reduces VRAM pressure.</td>
              </tr>
              <tr>
                <th>V‑Sync</th>
                <td>Off</td>
                <td>Off</td>
                <td>Use later only if you hate tearing.</td>
              </tr>
            </tbody>
          </table>
        </div>

        <p class="muted" style="margin-top: 12px;">Want to test before buying? Free Fly lets you verify performance on your real machine — then decide with confidence (and still use a referral code during signup).</p>
      </div>
    </div>
  </section>

  <!-- Stutter -->
  <section id="stutter" class="section">
    <div class="container">
      <div class="card pad">
        <h2 class="section__title">Fix stutter & low FPS (the real beginner troubleshooting order)</h2>
        <p class="muted">Do these in order. Most people jump straight to graphics tweaks and miss the actual cause (storage, memory, overlays).</p>

        <div class="tableWrap" style="margin-top: 14px;">
          <table class="table table--steps">
            <thead>
              <tr>
                <th>Step</th>
                <th>Do this</th>
                <th>Why it works</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th>1</th>
                <td><strong>Close overlays</strong> (Discord, Steam, GeForce/Adrenalin capture, browsers)</td>
                <td>Removes frame‑time spikes and unstable hooks.</td>
              </tr>
              <tr>
                <th>2</th>
                <td><strong>Verify SSD + free space</strong> (don’t fill the drive)</td>
                <td>Prevents asset streaming stalls and patch issues.</td>
              </tr>
              <tr>
                <th>3</th>
                <td><strong>Increase RAM headroom</strong> (close apps; 32 GB if possible)</td>
                <td>Stops hitching when the game hits memory pressure.</td>
              </tr>
              <tr>
                <th>4</th>
                <td><strong>Lower clouds</strong> first, then shadows, then reflections</td>
                <td>Hits the biggest GPU costs with the least gameplay impact.</td>
              </tr>
              <tr>
                <th>5</th>
                <td><strong>Reset “mystery tweaks”</strong> (overclocks, experimental driver features)</td>
                <td>Stability > peak FPS. Get a stable baseline first.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- Bottleneck -->
  <section id="bottleneck" class="section">
    <div class="container">
      <div class="card pad">
        <h2 class="section__title">CPU vs GPU bottleneck (what to do with the result)</h2>
        <div class="grid2" style="margin-top: 14px;">
          <div class="card pad" style="background: rgba(255,255,255,.03);">
            <h3 style="margin:0 0 8px;">Signs you’re CPU‑limited</h3>
            <ul class="muted" style="margin:0; padding-left: 18px; line-height:1.7;">
              <li>FPS is similar on Low vs High</li>
              <li>Busy cities tank FPS even on low resolution</li>
              <li>GPU usage often below ~80%</li>
            </ul>
            <p class="muted" style="margin:10px 0 0;">Focus on <strong>stability</strong> and reduce CPU pressure: avoid ultra‑low settings, lower crowd/extra effects, keep background apps closed.</p>
          </div>
          <div class="card pad" style="background: rgba(255,255,255,.03);">
            <h3 style="margin:0 0 8px;">Signs you’re GPU‑limited</h3>
            <ul class="muted" style="margin:0; padding-left: 18px; line-height:1.7;">
              <li>FPS improves when you drop resolution</li>
              <li>GPU usage stays high (90–100%)</li>
              <li>Clouds/shadows/reflections hit hard</li>
            </ul>
            <p class="muted" style="margin:10px 0 0;">Reduce GPU hitters first: <strong>clouds → shadows → reflections</strong>. Consider upscaling only after you’ve tested these.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Crashes -->
  <section id="crashes" class="section">
    <div class="container">
      <div class="card pad">
        <h2 class="section__title">Crash fixes (most common causes)</h2>
        <div class="tableWrap" style="margin-top: 14px;">
          <table class="table">
            <thead>
              <tr>
                <th>Symptom</th>
                <th>Try this first</th>
                <th>Why it helps</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th>Crashes after a long session</th>
                <td>Close background apps; ensure enough RAM/pagefile headroom</td>
                <td>Memory pressure looks like “random crashes”.</td>
              </tr>
              <tr>
                <th>Crashes on launch or patching</th>
                <td>Verify game files; check SSD space; avoid external drives</td>
                <td>Partial installs and disk errors are common.</td>
              </tr>
              <tr>
                <th>Crash in specific locations</th>
                <td>Lower clouds/shadows; reduce VRAM pressure (textures)</td>
                <td>Heavy scenes can spike VRAM and frame times.</td>
              </tr>
              <tr>
                <th>Crashes while streaming/recording</th>
                <td>Disable overlays; test without capture; try a stable driver</td>
                <td>Overlays/hooks can be unstable.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- Upgrades -->
  <section id="upgrades" class="section">
    <div class="container">
      <div class="card pad">
        <h2 class="section__title">Upgrades that matter (highest impact first)</h2>
        <div class="tableWrap" style="margin-top: 14px;">
          <table class="table">
            <thead>
              <tr>
                <th>Upgrade</th>
                <th>Who should do it</th>
                <th>Impact</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th>32 GB RAM</th>
                <td>Anyone on 16 GB who gets stutter/crash‑like hitches</td>
                <td>Huge stability and smoother streaming.</td>
              </tr>
              <tr>
                <th>NVMe SSD</th>
                <td>Anyone on a slow SSD / external drive</td>
                <td>Fewer stalls, faster patching, better first impression.</td>
              </tr>
              <tr>
                <th>CPU with strong single‑core</th>
                <td>Players stuck in city CPU bottlenecks</td>
                <td>More consistent FPS where it matters (hubs).</td>
              </tr>
              <tr>
                <th>GPU with more VRAM</th>
                <td>Players hitting VRAM limits at higher resolution</td>
                <td>Better frame pacing; fewer drops in heavy scenes.</td>
              </tr>
            </tbody>
          </table>
        </div>

        <p class="muted" style="margin-top: 12px;">If you’re here because you’re unsure about buying: validate performance during Free Fly — then decide on a starter pack with confidence (and don’t forget the referral bonus during signup).</p>
      </div>
    </div>
  </section>

  <section id="faq" class="section">
    <div class="container">
      <div class="card pad">
        <h2 class="section__title">Star Citizen performance FAQ</h2>
        <FAQ items={faqItems} />
      </div>
    </div>
  </section>
</BaseLayout>
