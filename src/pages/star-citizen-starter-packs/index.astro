---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReferralBanner from "../../components/ReferralBanner.astro";
import OnThisPage from "../../components/OnThisPage.astro";
import FaqSchema from "../../components/FaqSchema.astro";
import HowToSchema from "../../components/HowToSchema.astro";

const referralCode = "STAR-FSRJ-5N7Z";
const referralBonusUEC = "50,000";
const referralLink = `https://www.robertsspaceindustries.com/enlist?referral=${referralCode}`;

const officialPacksUrl = "https://robertsspaceindustries.com/en/store/pledge/browse/game-packages";

const heroImg = "/assets/img/star-citizen-starter-packs/star-citizen-starter-pack-guide-ship-selection-hero.webp";
const sectionImg = "/assets/img/star-citizen-starter-packs/star-citizen-starter-pack-comparison.webp";

const tocItems = [
  { label: "What a starter pack is", href: "#what-it-is" },
  { label: "How to choose", href: "#choose" },
  { label: "Best starter packs", href: "#best" },
  { label: "How to buy", href: "#how-to-buy" },
  { label: "Upgrade path", href: "#upgrade" },
  { label: "Common mistakes", href: "#mistakes" },
  { label: "FAQ", href: "#faq" },
];

const faqItems = [
  {
    q: "What is a Star Citizen starter pack?",
    a: "A starter pack (also called a game package) is the minimum purchase required to access the live game outside Free Fly. It includes game access and at least one ship so you can play immediately.",
  },
  {
    q: "Can I play without buying a starter pack?",
    a: "Only during official Free Fly events. Once Free Fly ends, you need a starter pack to keep playing.",
  },
  {
    q: "Do starter packs include Squadron 42?",
    a: "Starter packs are for the online universe. Single-player content is sold separately when available.",
  },
  {
    q: "Should I use a referral code before buying a starter pack?",
    a: "Yes. Use a referral code during RSI account creation (or within the limited post-signup window) to claim the new-player bonus, then buy your starter pack normally.",
  },
  {
    q: "Which starter pack is best for new players?",
    a: "The best starter pack is the one that matches your first mission loop. A balanced ship is usually the safest pick because it lets you test delivery, light combat, and basic travel without feeling locked into one playstyle.",
  },
  {
    q: "Can I upgrade my starter ship later?",
    a: "Yes. Most players start with a basic pack and upgrade later once they understand what they enjoy. You can change ships over time and keep your account.",
  },
  {
    q: "Where is the official starter pack store page?",
    a: "The official RSI store has a dedicated game package page where you can browse current starter packs and pricing.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: { "@type": "Answer", text: item.a },
  })),
};

const howToJsonLd = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: "How to buy a Star Citizen starter pack",
  description:
    "A beginner-safe checklist to buy the right starter pack: claim your referral bonus, pick the pack, complete checkout, and launch the game.",
  step: [
    {
      "@type": "HowToStep",
      name: "Create your RSI account (use a referral code)",
      text: "Create a new RSI account and enter a referral code during signup to claim the new-player bonus.",
    },
    {
      "@type": "HowToStep",
      name: "Open the official starter pack page",
      text: "Browse current game packages on the official RSI store page.",
      url: officialPacksUrl,
    },
    {
      "@type": "HowToStep",
      name: "Pick a beginner-safe starter pack",
      text: "Choose a pack that matches your first mission loop (balanced is usually safest).",
    },
    {
      "@type": "HowToStep",
      name: "Complete checkout",
      text: "Finish checkout in the RSI store, then install the launcher and log in.",
    },
  ],
};
---

<BaseLayout
  title="Best Star Citizen Starter Packs for New Players"
  description="A practical Star Citizen starter pack guide: what a starter pack includes, which pack to buy first, common mistakes, and the safest upgrade-friendly path for beginners."
  canonicalPath="/star-citizen-starter-packs/"
  ogImage={heroImg}
  ogImageAlt="Star Citizen starter pack guide hero image"
  activeNav="guides"
>
  <link slot="head" rel="preload" as="image" href={heroImg} fetchpriority="high" />
  <FaqSchema slot="head" json={faqJsonLd} />
  <HowToSchema slot="head" json={howToJsonLd} />

  <main>
    <!-- HERO -->
    <section class="hero">
      <img
        class="hero__img"
        src={heroImg}
        alt="Star Citizen ships in a cinematic hangar scene"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1536"
        height="1024"
      />
      <div class="hero__overlay"></div>

      <div class="hero__content">
        <div class="kicker"><span class="dot"></span> Starter Guides</div>
        <h1 class="h1">Best Star Citizen Starter Packs</h1>
        <p class="lead" style="max-width: 920px;">
          Pick a beginner-safe game package that fits your first sessions, avoids wasted spend, and stays upgrade-friendly later.
        </p>

        <div class="btnrow">
          <a class="btn primary" href="#best">See top picks</a>
          <a class="btn" href={officialPacksUrl} target="_blank" rel="noopener noreferrer">Browse official packs</a>
        </div>
      </div>

      <OnThisPage variant="hero" title="On this page" items={tocItems} />
    </section>

    <!-- Referral banner (consistent site-wide) -->
    <ReferralBanner
      code={referralCode}
      bonus={`${referralBonusUEC} UEC`}
      ctaHref={referralLink}
      howItWorksHref="/star-citizen-referral-code/#how-to-use"
      sublineHtml="Enter during signup — or within <b>24 hours</b> after account creation."
      ariaLabel="Referral bonus callout"
    />

    <!-- WHAT IT IS -->
    <section id="what-it-is" class="section">
      <div class="card pad">
        <h2 class="section__title">What a starter pack actually is</h2>
        <p>
          A starter pack (RSI calls it a <em>game package</em>) is the minimum purchase required to access the live game when Free Fly is not active.
          It’s not just a ship — it’s <strong>game access + a starter ship</strong>, so you can log in and play immediately.
        </p>

        <div class="grid2" style="margin-top:12px;">
          <div class="card pad">
            <h3 style="margin:0 0 8px;">What you get</h3>
            <ul class="bullets">
              <li><strong>Game access</strong> to the online universe.</li>
              <li><strong>A starter ship</strong> you can claim and fly right away.</li>
              <li><strong>A clean baseline</strong> you can upgrade later once you know what you enjoy.</li>
            </ul>
          </div>
          <div class="card pad">
            <h3 style="margin:0 0 8px;">What you don’t need</h3>
            <ul class="bullets">
              <li>Expensive ships on day one.</li>
              <li>Multi-crew “dream ships” before you’ve learned the basics.</li>
              <li>Complex loadouts or min-maxing to start having fun.</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- CHOOSE -->
    <section id="choose" class="section">
      <div class="card pad">
        <h2 class="section__title">How to choose the right starter pack</h2>
        <p>
          New players get stuck when the first ship feels too limited for the missions they naturally try. The safest choice is a pack that lets you test
          multiple beginner loops: basic delivery, light combat, and comfortable travel.
        </p>

        <div class="grid2" style="margin-top:12px;">
          <div class="card pad">
            <h3 style="margin:0 0 8px;">Pick based on your first loop</h3>
            <ul class="bullets">
              <li><strong>Balanced</strong>: best if you want a smooth start and flexibility.</li>
              <li><strong>Combat</strong>: best if you mainly want dogfights early.</li>
              <li><strong>Utility</strong>: best if you like cargo, small hauls, and convenience.</li>
            </ul>
          </div>
          <div class="card pad">
            <h3 style="margin:0 0 8px;">Rule of thumb</h3>
            <p style="margin:0;">
              Don’t optimize for the endgame on day one. Optimize for <strong>your first 10–20 hours</strong>: learning controls, completing missions, and staying mobile.
              You can always upgrade later.
            </p>
          </div>
        </div>

        <div class="card pad" style="margin-top:12px; display:flex; gap:12px; flex-wrap:wrap; align-items:center; justify-content:space-between;">
          <div>
            <strong>New to the signup flow?</strong>
            <div style="color: rgba(255,255,255,.74);">Use the referral bonus first so you don’t miss the extra starting credits.</div>
          </div>
          <a class="btn primary" href="/star-citizen-referral-code/">Use a referral code</a>
        </div>
      </div>
    </section>

    <!-- SECTION IMAGE -->
    <section class="section" aria-label="Starter pack comparison image">
      <div class="card pad" style="padding:0; overflow:hidden;">
        <img
          src={sectionImg}
          alt="Star Citizen starter pack comparison visual"
          loading="lazy"
          decoding="async"
          width="1536"
          height="1024"
          style="width:100%; height:auto; display:block;"
        />
      </div>
    </section>

    <!-- BEST -->
    <section id="best" class="section">
      <div class="card pad">
        <h2 class="section__title">Best starter packs for beginners</h2>
        <p>
          These are the most beginner-friendly picks by playstyle. Use this as a short-list, then confirm the exact current offers on the official store.
        </p>

        <div class="tableWrap" style="margin-top:12px;">
          <table class="table">
            <thead>
              <tr>
                <th>Pack type</th>
                <th>Best for</th>
                <th>Why it works for beginners</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th scope="row">Balanced starter pack</th>
                <td>First-time players</td>
                <td>Flexible mission choices, easy learning curve, fewer “dead-end” moments.</td>
              </tr>
              <tr>
                <th scope="row">Combat-focused starter pack</th>
                <td>Dogfights early</td>
                <td>More confidence in early combat contracts, fast handling, clear purpose.</td>
              </tr>
              <tr>
                <th scope="row">Utility / comfort starter pack</th>
                <td>Delivery + travel</td>
                <td>Better quality-of-life for moving around and carrying small mission items.</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="btnrow" style="margin-top:12px;">
          <a class="btn" href={officialPacksUrl} target="_blank" rel="noopener noreferrer">Compare current packs on RSI</a>
        </div>
      </div>
    </section>

    <!-- HOW TO BUY -->
    <section id="how-to-buy" class="section">
      <div class="card pad">
        <h2 class="section__title">How to buy a starter pack</h2>
        <p>
          This is the safest beginner sequence. It prevents you from missing the referral bonus and keeps the purchase process simple.
        </p>

        <div class="tableWrap" style="margin-top:12px;">
          <table class="table table--steps">
            <thead>
              <tr>
                <th>Step</th>
                <th>What to do</th>
                <th>Why it matters</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th scope="row">1</th>
                <td>Create your RSI account and enter a referral code</td>
                <td>Locks in the new-player bonus so you don’t rely on exceptions later.</td>
              </tr>
              <tr>
                <th scope="row">2</th>
                <td>Open the official starter pack page</td>
                <td>Ensures you’re comparing current packs and pricing from the source.</td>
              </tr>
              <tr>
                <th scope="row">3</th>
                <td>Pick a pack that matches your first mission loop</td>
                <td>A beginner-safe match reduces frustration and “buyer’s regret”.</td>
              </tr>
              <tr>
                <th scope="row">4</th>
                <td>Checkout, install the launcher, and log in</td>
                <td>Once you own a pack, you can play anytime (not just Free Fly).</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="card pad" style="margin-top:12px; display:flex; gap:12px; flex-wrap:wrap; align-items:center; justify-content:space-between;">
          <div>
            <strong>Want the bonus first?</strong>
            <div style="color: rgba(255,255,255,.74);">Create your RSI account with the referral code prefilled.</div>
          </div>
          <a class="btn primary" href={referralLink} target="_blank" rel="noopener noreferrer">Use referral code now</a>
        </div>
      </div>
    </section>

    <!-- UPGRADE -->
    <section id="upgrade" class="section">
      <div class="card pad">
        <h2 class="section__title">Upgrade path</h2>
        <p>
          The smartest beginner strategy is to start with a comfortable baseline, then upgrade after you’ve learned what you actually like.
          You don’t need to “solve” your forever ship on day one.
        </p>
        <div class="grid2" style="margin-top:12px;">
          <div class="card pad">
            <h3 style="margin:0 0 8px;">Start small</h3>
            <p style="margin:0;">A basic starter pack is enough to learn navigation, missions, and travel flow.</p>
          </div>
          <div class="card pad">
            <h3 style="margin:0 0 8px;">Upgrade after clarity</h3>
            <p style="margin:0;">Once you know your loop, upgrades become targeted instead of impulsive.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- MISTAKES -->
    <section id="mistakes" class="section">
      <div class="card pad">
        <h2 class="section__title">Common mistakes</h2>
        <div class="grid2" style="margin-top:12px;">
          <div class="card pad">
            <h3 style="margin:0 0 8px;">Buying too big too early</h3>
            <p style="margin:0;">Big ships are fun later, but they slow learning and add maintenance overhead when you’re still figuring out the basics.</p>
          </div>
          <div class="card pad">
            <h3 style="margin:0 0 8px;">Skipping the referral code</h3>
            <p style="margin:0;">If you create an account without a code, you may miss the new-player bonus. It’s easiest to do it during signup.</p>
          </div>
          <div class="card pad">
            <h3 style="margin:0 0 8px;">Choosing based on looks only</h3>
            <p style="margin:0;">Early comfort matters: how easy it is to complete missions, carry items, and move around without friction.</p>
          </div>
          <div class="card pad">
            <h3 style="margin:0 0 8px;">Over-optimizing the first purchase</h3>
            <p style="margin:0;">Your first pack should get you playing. You can optimize later once you understand what you enjoy.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq" class="section">
      <div class="card pad">
        <h2 class="section__title">FAQ</h2>

        <div class="faq" style="margin-top:12px;">
          {faqItems.map((item) => (
            <details class="faq__item">
              <summary class="faq__q">{item.q}</summary>
              <div class="faq__a">{item.a}</div>
            </details>
          ))}
        </div>

        <div class="card pad" style="margin-top:12px; display:flex; gap:12px; flex-wrap:wrap; align-items:center; justify-content:space-between;">
          <div>
            <strong>Next best step</strong>
            <div style="color: rgba(255,255,255,.74);">Use the referral bonus first, then pick your pack on the official store page.</div>
          </div>
          <div style="display:flex; gap:10px; flex-wrap:wrap;">
            <a class="btn primary" href="/star-citizen-referral-code/">Get referral bonus</a>
            <a class="btn" href={officialPacksUrl} target="_blank" rel="noopener noreferrer">Browse official packs</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
