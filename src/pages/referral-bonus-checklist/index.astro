---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReferralBanner from "../../components/ReferralBanner.astro";
import OnThisPage from "../../components/OnThisPage.astro";
import FaqSchema from "../../components/FaqSchema.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { REFERRAL_CODE, REFERRAL_LINK, REFERRAL_INFO_PATH, REFERRAL_BONUS_UEC, FLY_FREE_URL } from "../../config/site";

const referralCode = REFERRAL_CODE;
const referralLink = REFERRAL_LINK;

const heroImg = "/assets/img/referral/star-citizen-referral-code-hero.webp";

const tocItems = [
  { id: "quick-answer", label: "One rule" },
  { id: "do-this-now", label: "Signup checklist" },
  { id: "mistakes", label: "Avoid dead ends" },
  { id: "next-steps", label: "Next steps" },
  { id: "faq", label: "FAQ" }
];

const faqItems = [
  {
    "q": "When do I need the referral code?",
    "a": "During account creation. Treat it as a one-time signup field."
  },
  {
    "q": "Can I add it later?",
    "a": "Usually no. Enter it during signup so you don’t rely on exceptions."
  },
  {
    "q": "Does it change my price?",
    "a": "No. It’s optional and doesn’t change store pricing."
  },
  {
    "q": "Do I need to buy immediately?",
    "a": "No. Create the account with the code now and decide later (Free Fly helps)."
  },
  {
    "q": "What if the field is missing?",
    "a": "You’re likely not on the enlist/signup form. Use the official signup page."
  },
  {
    "q": "Is it safe?",
    "a": "Yes—use the official RSI signup page and don’t share passwords or payment info with anyone."
  },
  {
    "q": "What’s the simplest path?",
    "a": "Create account → verify login → follow a first session checklist → then decide on a starter pack."
  },
  {
    "q": "How do I verify it worked?",
    "a": "After signup the field is gone; you captured the window. Then check the referral guide for details."
  },
  {
    "q": "What’s the biggest mistake?",
    "a": "Creating the account first and then trying to fix it afterwards."
  },
  {
    "q": "Where do I go next?",
    "a": "Free Fly, Starter Packs, or Performance—depending on your goal."
  }
];
---

<BaseLayout
  title="Star Citizen referral bonus checklist (don’t miss the window) | Star Citizen Beginner"
  description="A simple signup checklist so you don’t miss the referral code window. Clear steps + the mistakes that cause dead ends."
  canonicalPath="/referral-bonus-checklist/"
  ogImage={heroImg}
  ogImageAlt="Star Citizen referral bonus checklist hero image"
  activeNav="guides"
>
  <main>
    <section class="hero">
      <div class="container">
        <Breadcrumbs items={[
          { label: "Home", href: "/" },
          { label: "Starter guides", href: "/" },
          { label: "Referral bonus checklist", href: "/referral-bonus-checklist/" }
        ]} />
        <div class="hero__inner">
          <div class="kicker"><span class="dot"></span>Checklist</div>
          <h1 class="h1">Referral bonus checklist</h1>
          <p class="hero__lead">One job: capture the signup window so you don’t have to troubleshoot later.</p>
          <div class="hero__cta">
            <a class="btn primary" href="#do-this-now">Use the checklist</a>
          </div>
        </div>

        <OnThisPage items={tocItems} />
      </div>
    </section>

    <ReferralBanner />

    <section id="quick-answer" class="section">
      <div class="container">
        <h2 class="h2">Quick answer</h2>

        <div class="card pad" style="margin-bottom:12px;">
          <div class="kicker"><span class="dot"></span>Answer</div>
          <p class="lead" style="margin-top:10px;">Enter a referral code <b>during account creation</b>—that’s the only moment that reliably matters.</p>
        </div>

        <ul class="bullets">
          <li>Optional: it doesn’t change pricing. It’s just a signup bonus.</li>
          <li>Do it once, then stop thinking about it.</li>
          <li>Full guide: <a class="link" href="/star-citizen-referral-code/">Referral code page</a>.</li>
        </ul>
      </div>
    </section>

    <section id="do-this-now" class="section">
      <div class="container">
        <h2 class="h2">Do this now</h2>

        <div class="card pad">
          <div class="grid-2">
            <div>
              <h3 class="h3">Signup checklist (5 steps)</h3>
              <ol class="steps">
                <li>Open the official enlist/signup page.</li>
                <li>Paste a referral code into the <b>Referral Code</b> field.</li>
                <li>Create the account and verify you can log in.</li>
                <li>Save your login details safely.</li>
                <li>Next: choose your path (Free Fly or Starter pack).</li>
              </ol>
              <p class="muted" style="margin-top:10px;">Verify: account exists; you captured the window.</p>
            </div>
            <div>
              <h3 class="h3">Use this code</h3>
              <div class="codebox">{referralCode}</div>
              <div style="display:flex; flex-wrap:wrap; gap:10px; margin-top: 12px;">
                <a class="btn primary" href={referralLink} rel="nofollow noopener" target="_blank">Create account + claim bonus</a>
                <a class="btn" href="/satellites/where-to-enter-referral-code/">Where to paste it</a>
              </div>
              <p class="muted" style="margin-top:10px;">Not buying yet? Create the account now, decide later.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="mistakes" class="section">
      <div class="container">
        <h2 class="h2">Avoid dead ends</h2>

        <div class="table-wrap">
          <table class="table">
            <thead>
              <tr><th>Mistake</th><th>What happens</th><th>Fix (exact)</th></tr>
            </thead>
            <tbody>
              <tr><td>Signing up without a code</td><td>You may lose the easy bonus window.</td><td>Enter it during account creation—don’t rely on later fixes.</td></tr>
              <tr><td>Using the wrong page</td><td>No referral field appears.</td><td>Use the official enlist/signup page.</td></tr>
              <tr><td>Expecting purchases to be affected</td><td>Unnecessary doubt.</td><td>Pricing doesn’t change; it’s a signup bonus only.</td></tr>
              <tr><td>Waiting “until I buy”</td><td>You forget and miss the window.</td><td>Create the account now; buy later if you decide it’s worth it.</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section id="next-steps" class="section">
      <div class="container">
        <h2 class="h2">Next steps</h2>
        <div class="grid-3">
          <a class="card pad linkcard" href="/free-fly/">
            <div class="kicker"><span class="dot"></span>Try first</div>
            <h3 class="h3">Free Fly</h3>
            <p class="muted">Try without buying and follow a safe first session route.</p>
          </a>
          <a class="card pad linkcard" href="/star-citizen-starter-packs/">
            <div class="kicker"><span class="dot"></span>Buy smart</div>
            <h3 class="h3">Starter packs</h3>
            <p class="muted">Spend the minimum and avoid beginner purchase traps.</p>
          </a>
          <a class="card pad linkcard" href="/should-you-buy-star-citizen/">
            <div class="kicker"><span class="dot"></span>Decide</div>
            <h3 class="h3">Should you buy?</h3>
            <p class="muted">A quick decision framework that matches your playstyle.</p>
          </a>
        </div>
      </div>
    </section>

    <section id="faq" class="section">
      <div class="container">
        <h2 class="h2">FAQ</h2>
        <div class="faq">
          {faqItems.map((item) => (
            <details class="faq__item">
              <summary class="faq__q"><span class="faq__icon">+</span>{item.q}</summary>
              <div class="faq__a"><p>{item.a}</p></div>
            </details>
          ))}
        </div>

        <div style="display:flex; flex-wrap:wrap; gap:10px; margin-top: 14px;">
          <a class="btn primary" href={referralLink} rel="nofollow noopener" target="_blank">Create account + claim bonus</a>
          <a class="btn" href="/star-citizen-referral-code/">Referral guide</a>
        </div>
      </div>
    </section>

    <FaqSchema items={faqItems} />
  </main>
</BaseLayout>
