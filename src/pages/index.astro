---
import BaseLayout from "../layouts/BaseLayout.astro";

const referralCode = "STAR-FSRJ-5N7Z";
const referralLink = `https://www.robertsspaceindustries.com/enlist?referral=${referralCode}`;
const referralPage = "/star-citizen-referral-code/";

const tiles = [
  {
    href: referralPage,
    img: "/assets/img/home/tiles/scb-tile-referral-bonus.webp",
    title: "Referral Bonus",
    desc: "Use a referral code during account creation and start with extra in-game credits.",
    pill: "Bonus",
  },
  {
    href: "/beginner-tips/",
    img: "/assets/img/home/tiles/scb-tile-beginner-tips.webp",
    title: "Beginner Tips",
    desc: "The non-obvious stuff that saves you hours: first goals, common traps, smart priorities.",
    pill: "Start here",
  },
  {
    href: "/first-2-hours/",
    img: "/assets/img/home/tiles/scb-tile-first-2-hours.webp",
    title: "First 2 Hours",
    desc: "A simple script: spawn → gear → first contract → money loop → confidence.",
    pill: "Checklist",
  },
  {
    href: "/starter-pack/",
    img: "/assets/img/home/tiles/scb-tile-starter-pack.webp",
    title: "Starter Pack",
    desc: "Which starter makes sense, when to upgrade, and whether Squadron 42 is worth it.",
    pill: "Buy smart",
  },
  {
    href: "/make-money-fast/",
    img: "/assets/img/home/tiles/scb-tile-make-money-fast.webp",
    title: "Make Money Fast",
    desc: "Early aUEC routes: contracts, loot, mining gems, trading basics—fast and safe.",
    pill: "aUEC",
  },
  {
    href: "/performance-settings/",
    img: "/assets/img/home/tiles/scb-tile-performance-settings.webp",
    title: "Performance & Settings",
    desc: "Best-practice settings and quick wins to make SC feel smoother (without placebo).",
    pill: "FPS wins",
  },
];
---

<BaseLayout
  lang="en"
  title="Star Citizen Beginner (SCB) | Smart Entry Guide for New Pilots"
  description="Start Star Citizen the smart way: claim your referral bonus, then follow clear guides for your first hours, starter packs, performance, and early aUEC."
  canonicalPath="/"
>
  <header class="topbar">
    <div class="container topbar__inner">
      <a class="brand" href="/" aria-label="SCB Home">
        <img src="/assets/img/global/scb-logo.svg" alt="SCB logo" />
        <span>Star Citizen Beginner</span>
      </a>

      <div class="lang" aria-label="Language switch (placeholder)">
        <span style="opacity:.7;">Lang:</span>
        <a class="active" href="/">EN</a>
        <a href="/de/">DE</a>
        <a href="/es/">ES</a>
        <a href="/fr/">FR</a>
        <a href="/ru/">RU</a>
        <a href="/zh/">中文</a>
      </div>
    </div>
  </header>

  <main class="container">
    <!-- HERO -->
    <section class="hero">
      <img class="hero__img" src="/assets/img/home/scb-home-hero.webp" alt="Epic Star Citizen scene" loading="eager" />
      <div class="hero__overlay"></div>

      <div class="hero__content">
        <div class="container" style="width:100%;">
          <div style="max-width:720px; padding: 26px 0;">
            <div class="kicker">
              <span class="dot"></span>
              Smart Entry Guide for New Pilots
            </div>

            <h1 class="h1">Star Citizen Beginner Guide: Start the smart way.</h1>

            <p class="lead">
              Skip early frustration. Follow a clean starter path, claim your bonus credits,
              and avoid the beginner mistakes that waste time.
            </p>

            <div class="btnrow">
              <a class="btn primary" href={referralLink} target="_blank" rel="noopener noreferrer">
                Get 5,000 UEC Bonus
              </a>
              <a class="btn secondary" href="#hub">Explore Guides</a>
            </div>

            <div style="margin-top:10px; color: rgba(255,255,255,.62); font-size: 13px;">
              Referral Code: <b>{referralCode}</b> <span style="opacity:.75;">(use during account creation)</span>
              <div style="margin-top:6px; color: rgba(255,255,255,.62); font-size: 13px;">
                Looking for a <b>Star Citizen referral code</b>? <a href={referralPage} style="text-decoration: underline;">Start here</a>.
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- HUB / TILES -->
    <section id="hub" class="section" style="margin-top: 18px;">
      <div class="card pad" style="margin-bottom:14px;">
        <div class="kicker"><span class="dot"></span> Star Citizen Beginner Guides</div>
        <h2 style="margin:12px 0 6px; font-size:24px; letter-spacing:-.3px;">Start here. Then go deeper.</h2>
        <p style="margin:0; color: var(--muted); line-height:1.6;">
          Six focused guides. No fluff. Built for real in-game decisions.
        </p>
      </div>

      <div class="tiles">
        {tiles.map((t) => (
          <a class="tile" href={t.href} aria-label={t.title}>
            <img src={t.img} alt={t.title} loading="lazy" />
            <div class="tile__content">
              <div class="tile__pill"><b>SCB</b> • {t.pill}</div>
              <h3 class="tile__title">{t.title}</h3>
              <p class="tile__desc">{t.desc}</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- WHAT IS -->
    <section class="section">
      <div class="section__grid">
        <div class="card pad">
          <div class="kicker"><span class="dot"></span> What is Star Citizen?</div>
          <h2 style="margin:12px 0 10px; font-size:24px; letter-spacing:-.3px;">A living sci-fi universe you actually inhabit.</h2>

          <p style="margin:0; color: var(--muted); line-height:1.6;">
            Star Citizen is a Persistent Universe (PU) that blends space flight, FPS gameplay, and an economy sandbox.
            You can fly ships, do contracts, move cargo, explore planets and stations, and team up for emergent co-op moments.
          </p>

          <p style="margin:12px 0 0; color: var(--muted); line-height:1.6;">
            It’s not a theme-park MMO where everything is on rails—most of the “wow” comes from unscripted situations:
            a messy landing, a rescue beacon turning into a firefight, a profitable cargo run that goes sideways.
          </p>

          <p style="margin:12px 0 0; color: var(--muted); line-height:1.6;">
            It’s also actively developed. That means features evolve, balance changes, and occasional rough patches.
            SCB is built to help you start with the least friction: what to do first, what to ignore, and how to build momentum.
          </p>
        </div>

        <div class="section__img">
          <img src="/assets/img/home/scb-home-what-is-star-citizen.webp" alt="What is Star Citizen visual" loading="lazy" />
        </div>
      </div>
    </section>

    <!-- IS IT FOR YOU (SECONDARY SECTION) -->
    <section class="section section--secondary">
      <div class="section__grid">
        <div class="section__img">
          <img src="/assets/img/home/scb-home-pros-cons.webp" alt="Pros and cons visual" loading="lazy" />
        </div>

        <div class="card pad">
          <div class="kicker"><span class="dot"></span> Is it for you?</div>
          <h2 style="margin:12px 0 10px; font-size:24px; letter-spacing:-.3px;">High highs. Real depth.</h2>

          <p style="margin:0; color: var(--muted); line-height:1.6;">
            Star Citizen rewards curiosity, systems thinking, and immersion. It’s a universe where you learn by doing —
            flying, trading, exploring, and figuring out efficient routes.
          </p>

          <p style="margin:12px 0 0; color: var(--muted); line-height:1.6;">
            Development is ongoing, which means features evolve and the experience keeps expanding. If you enjoy games that
            grow over time and reward patience and mastery, you’ll likely feel at home.
          </p>

          <ul style="margin:12px 0 0; padding-left:18px; color: var(--muted); line-height:1.65;">
            <li>
              <b style="color:rgba(255,255,255,.9);">You’ll love it if:</b>
              you enjoy exploration, flight, co-op problem-solving, and building your own path.
            </li>
            <li>
              <b style="color:rgba(255,255,255,.9);">Good to know:</b>
              performance and complexity improve with experience — your first hours matter.
            </li>
          </ul>

          <p style="margin:12px 0 0; color: var(--muted); line-height:1.6;">
            The practical tip: treat your first sessions like a guided onboarding. Follow a clean starter path, and the
            universe opens up quickly.
          </p>
        </div>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="footer">
      <div class="container">
        <div style="display:flex; flex-wrap:wrap; gap:12px; align-items:center; justify-content:space-between;">
          <div>
            <b>SCB</b> — Unofficial community guide.
          </div>
          <div>
            Referral: <a href={referralLink} target="_blank" rel="noopener noreferrer">{referralCode}</a>
          </div>
        </div>

        <div style="margin-top:10px;">
          Unofficial community guide. Not endorsed by Cloud Imperium Games or Roberts Space Industries. Star Citizen® is a trademark of its respective owner.
        </div>
      </div>
    </footer>
  </main>
</BaseLayout>
