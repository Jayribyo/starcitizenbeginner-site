---
import BaseLayout from "../layouts/BaseLayout.astro";

const referralCode = "STAR-FSRJ-5N7Z";
const referralLink = `https://www.robertsspaceindustries.com/enlist?referral=${referralCode}`;

const tiles = [
  {
    href: "/beginner-tips/",
    img: "/assets/img/home/tiles/scb-tile-beginner-tips.webp",
    title: "Beginner Tips",
    desc: "The non-obvious stuff that saves you hours: first goals, common traps, smart priorities.",
    pill: "Start here",
  },
  {
    href: "/first-2-hours/",
    img: "/assets/img/home/tiles/scb-tile-first-2-hours.webp",
    title: "First 2 Hours",
    desc: "A simple script: spawn → gear → first contract → money loop → confidence.",
    pill: "Checklist",
  },
  {
    href: "/starter-pack/",
    img: "/assets/img/home/tiles/scb-tile-starter-pack.webp",
    title: "Starter Pack",
    desc: "Which starter makes sense, when to upgrade, and whether Squadron 42 is worth it.",
    pill: "Buy smart",
  },
  {
    href: "/performance-settings/",
    img: "/assets/img/home/tiles/scb-tile-performance-settings.webp",
    title: "Performance & Settings",
    desc: "Best-practice settings and quick wins to make SC feel smoother (without placebo).",
    pill: "FPS wins",
  },
  {
    href: "/make-money-fast/",
    img: "/assets/img/home/tiles/scb-tile-make-money-fast.webp",
    title: "Make Money Fast",
    desc: "Early aUEC routes: contracts, loot, mining gems, trading basics—fast and safe.",
    pill: "aUEC",
  },
  {
    href: "/controls/",
    img: "/assets/img/home/tiles/scb-tile-controls.webp",
    title: "Controls",
    desc: "A clean keybind baseline for FPS + ship. Practical, minimal, and easy to learn.",
    pill: "Keybinds",
  },
];
---
<BaseLayout
  lang="en"
  title="Star Citizen Beginner (SCB) | Smart Entry Guide for New Pilots"
  description="A premium beginner hub for Star Citizen: understand the game, decide if it’s for you, then follow clear guides for your first hours, packs, settings, money, and controls."
  canonicalPath="/"
>
  <header class="topbar">
    <div class="container topbar__inner">
      <a class="brand" href="/" aria-label="SCB Home">
        <img src="/assets/img/global/scb-logo.svg" alt="SCB logo" />
        <span>Star Citizen Beginner</span>
      </a>

      <div class="lang" aria-label="Language switch (placeholder)">
        <span style="opacity:.7;">Lang:</span>
        <a class="active" href="/">EN</a>
        <a href="/de/">DE</a>
        <a href="/es/">ES</a>
        <a href="/fr/">FR</a>
        <a href="/ru/">RU</a>
        <a href="/zh/">中文</a>
      </div>
    </div>
  </header>

  <main class="container">
    <!-- HERO -->
    <section class="hero">
      <img class="hero__img" src="/assets/img/home/scb-home-hero.webp" alt="Epic Star Citizen scene" loading="eager" />
      <div class="hero__overlay"></div>

      <div class="hero__content">
        <div class="container" style="width:100%;">
          <div style="max-width:720px; padding: 26px 0;">
            <div class="kicker">
              <span class="dot"></span>
              Smart Entry Guide for New Pilots
            </div>

            <h1 class="h1">Start Star Citizen the smart way.</h1>

            <p class="lead">
              Star Citizen can feel overwhelming—until you follow a clean path.
              SCB gives you the “what matters first” flow, then deep guides when you’re ready.
            </p>

            <div class="btnrow">
              <a class="btn primary" href={referralLink} target="_blank" rel="noopener noreferrer">
                Create Account & Get 5000 UEC Bonus
              </a>
              <a class="btn secondary" href="#tiles">Explore Guides</a>
            </div>

            <div style="margin-top:10px; color: rgba(255,255,255,.62); font-size: 13px;">
              Referral code: <b>{referralCode}</b>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- WHAT IS -->
    <section class="section">
      <div class="section__grid">
        <div class="card pad">
          <div class="kicker"><span class="dot"></span> What is Star Citizen?</div>
          <h2 style="margin:12px 0 10px; font-size:24px; letter-spacing:-.3px;">A living sci-fi universe (with real stakes).</h2>
          <p style="margin:0; color: var(--muted); line-height:1.6;">
            It’s part space sim, part FPS, part sandbox MMO—where you fly, fight, explore, trade, and improvise.
            The best moments feel cinematic because they’re unscripted.
          </p>
          <p style="margin:12px 0 0; color: var(--muted); line-height:1.6;">
            This hub helps you decide if the game fits you—and if yes, start strong with minimal frustration.
          </p>
        </div>

        <div class="section__img">
          <img src="/assets/img/home/scb-home-what-is-star-citizen.webp" alt="What is Star Citizen visual" loading="lazy" />
        </div>
      </div>
    </section>

    <!-- PROS / CONS -->
    <section class="section">
      <div class="section__grid">
        <div class="section__img">
          <img src="/assets/img/home/scb-home-pros-cons.webp" alt="Pros and cons visual" loading="lazy" />
        </div>

        <div class="card pad">
          <div class="kicker"><span class="dot"></span> Is it for you?</div>
          <h2 style="margin:12px 0 10px; font-size:24px; letter-spacing:-.3px;">High highs. Some rough edges.</h2>

          <ul style="margin:0; padding-left:18px; color: var(--muted); line-height:1.65;">
            <li><b style="color:rgba(255,255,255,.9);">Pros:</b> unmatched immersion, ship fantasy, emergent moments, co-op stories.</li>
            <li><b style="color:rgba(255,255,255,.9);">Cons:</b> learning curve, performance varies, occasional bugs—patience helps.</li>
          </ul>

          <p style="margin:12px 0 0; color: var(--muted); line-height:1.6;">
            If you like exploration, problem-solving, and “make your own story” gameplay,
            Star Citizen can be addictive—in the good way.
          </p>
        </div>
      </div>
    </section>

    <!-- TILES -->
    <section id="tiles" class="section">
      <div class="card pad" style="margin-bottom:14px;">
        <div class="kicker"><span class="dot"></span> Your SCB Hub</div>
        <h2 style="margin:12px 0 6px; font-size:24px; letter-spacing:-.3px;">Pick a guide and go.</h2>
        <p style="margin:0; color: var(--muted); line-height:1.6;">
          Six focused pages. No fluff. Each one is built to be actionable in-game.
        </p>
      </div>

      <div class="tiles">
        {tiles.map(t => (
          <a class="tile" href={t.href} aria-label={t.title}>
            <img src={t.img} alt={t.title} loading="lazy" />
            <div class="tile__content">
              <div class="tile__pill"><b>SCB</b> • {t.pill}</div>
              <h3 class="tile__title">{t.title}</h3>
              <p class="tile__desc">{t.desc}</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- VIDEO -->
    <section class="section">
      <div class="card pad" style="margin-bottom:14px;">
        <div class="kicker"><span class="dot"></span> Beginner video</div>
        <h2 style="margin:12px 0 6px; font-size:24px; letter-spacing:-.3px;">Watch first. Then play.</h2>
        <p style="margin:0; color: var(--muted); line-height:1.6;">
          Current recommended beginner overview:
        </p>
      </div>

      <div class="video">
        <iframe
          src="https://www.youtube.com/embed/6BVZks1DgA4"
          title="Star Citizen Beginner Video"
          loading="lazy"
          referrerpolicy="strict-origin-when-cross-origin"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
        ></iframe>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="footer">
      <div class="container">
        <div style="display:flex; flex-wrap:wrap; gap:12px; align-items:center; justify-content:space-between;">
          <div>
            <b>SCB</b> — Unofficial community guide.
          </div>
          <div>
            Referral: <a href={referralLink} target="_blank" rel="noopener noreferrer">{referralCode}</a>
          </div>
        </div>

        <div style="margin-top:10px;">
          This site is not endorsed by or affiliated with Cloud Imperium or Roberts Space Industries.
          Star Citizen® and related marks are trademarks of their respective owners.
        </div>
      </div>
    </footer>
  </main>
</BaseLayout>
