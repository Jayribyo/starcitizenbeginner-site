---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import ReferralBanner from "../../components/ReferralBanner.astro";
import OnThisPage from "../../components/OnThisPage.astro";

const referralCode = "STAR-FSRJ-5N7Z";
const referralBonusUEC = "50,000";
const referralLink = `https://www.robertsspaceindustries.com/enlist?referral=${referralCode}`;

const flyFreeUrl = "https://robertsspaceindustries.com/en/flyfree";

const heroImg = "/assets/img/free-fly/star-citizen-free-fly-hero.webp";
const crewImg = "/assets/img/free-fly/star-citizen-free-fly-crew.webp"

const onThisPageItems = [
  { label: "What Free Fly is", href: "#what-is" },
  { label: "How to join", href: "#how-to-join" },
  { label: "First hour plan", href: "#quick-start" },
  { label: "Ships & roles", href: "#ships" },
  { label: "What to test", href: "#what-to-test" },
  { label: "Common pitfalls", href: "#pitfalls" },
  { label: "FAQ", href: "#faq" },
];
---

<BaseLayout
  lang="en"
  title="Star Citizen Free Fly – How to Join, What to Do First, Ships & Bonus Guide"
  description={`A practical Star Citizen Free Fly guide: check if it’s active, join step-by-step, follow a first-hour plan, try the right ship roles, and start with the ${referralBonusUEC} UEC referral bonus.`}
  canonicalPath="/free-fly/"
  ogImage={heroImg}
>
  <SiteHeader active="free-fly" />

  <main class="container">
    <!-- HERO -->
    <section class="hero freeFlyHero">
      <img
        class="hero__img freeFlyHero__img"
        src={heroImg}
        alt="Star Citizen Free Fly hangar with a variety of ships"
        loading="eager"
        fetchpriority="high"
      />
      <div class="hero__overlay freeFlyHero__overlay"></div>

      <div class="hero__content">
        <div class="freeFlyHero__content">
          <div class="kicker"><span class="dot"></span> Star Citizen Free Fly</div>
          <h1 class="h1">Free Fly: The best way to try Star Citizen (without buying).</h1>
          <p class="lead">
            This page tells you what Free Fly is, how to join, what to do in your first hour, which ships to test, and how to activate the referral bonus before you finish signup.
          </p>

          <div class="btnrow">
            <a class="btn primary" href={flyFreeUrl} target="_blank" rel="noopener noreferrer">Check if Free Fly is active</a>
            <a class="btn secondary" href="#how-to-join">How to join</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Referral banner (now global component) -->
    <div id="referral-bonus"></div>

    <ReferralBanner
      code={referralCode}
      bonus={`${referralBonusUEC} UEC`}
      ctaHref={referralLink}
      howItWorksHref="#how-to-join"
      sublineHtml="Best practice: enter during signup — or within <b>24 hours</b> after account creation if you forgot."
      ariaLabel="Referral bonus callout"
    />

    <!-- On this page (now global component) -->
    <OnThisPage items={onThisPageItems} />

    <!-- WHAT IS FREE FLY -->
    <section id="what-is" class="section">
      <div class="grid2">
        <div class="card pad">
          <div class="kicker"><span class="dot"></span> What it is</div>
          <h2 class="section__title">What is a Star Citizen Free Fly?</h2>

          <p>
            A Free Fly event is an official trial window where you can play Star Citizen without buying a starter pack. You create an RSI account, download the launcher, and log in during the event.
          </p>

          <p>
            Free Fly is the best time to test the game, the flight model, and different ship roles before spending money. It’s also when a lot of new players arrive — so onboarding matters.
          </p>

          <p class="miniLead">
            Official status page: <a href={flyFreeUrl} target="_blank" rel="noopener noreferrer" style="text-decoration: underline; opacity:.9;">RSI Fly Free</a>
          </p>
        </div>

        <div class="card pad">
          <img class="imgRounded" src={crewImg} alt="A sci-fi crew walking toward a ship during Free Fly" loading="lazy" />
        </div>
      </div>
    </section>

    <!-- HOW TO JOIN -->
    <section id="how-to-join" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Step-by-step</div>
        <h2 class="section__title">How to join Free Fly (clean process)</h2>

        <ol class="steps">
          <li>Open the official Free Fly page and check if the event is active.</li>
          <li>Create an RSI account (use a referral code during signup for the {referralBonusUEC} UEC bonus).</li>
          <li>Download the RSI launcher and install Star Citizen.</li>
          <li>Log in and claim the Free Fly access (if required on the event page).</li>
          <li>Enter the PU and spawn in your starting location.</li>
        </ol>

        <div class="miniNote">
          Tip: Use the referral code during account creation — it’s the only moment you can reliably apply it.
        </div>
      </div>
    </section>

    <!-- QUICK START -->
    <section id="quick-start" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> First hour plan</div>
        <h2 class="section__title">What to do in your first hour</h2>

        <p>
          Your goal is not “do everything”. Your goal is to build a stable baseline: controls, a short route, one simple contract, one ship test.
        </p>

        <ol class="steps">
          <li>Set your spawn: learn where the hangar terminals and elevators are.</li>
          <li>Fly one short route: take off, quantum, land once. Don’t overcomplicate.</li>
          <li>Do one beginner contract: delivery or basic bounty (depending on confidence).</li>
          <li>Test a second ship role: fighter vs. hauler vs. multi-role to feel the differences.</li>
        </ol>
      </div>
    </section>

    <!-- SHIPS -->
    <section id="ships" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Ships & roles</div>
        <h2 class="section__title">Which ships to test (so the trial is actually useful)</h2>

        <p>
          Free Fly often gives access to multiple ships. Don’t just pick what looks cool — test roles that map to real gameplay loops.
        </p>

        <div class="tableWrap">
          <table class="table">
            <thead>
              <tr>
                <th>Role</th>
                <th>What you learn</th>
                <th>Good trial focus</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th>Fighter</th>
                <td>Combat handling + target tracking</td>
                <td>Basic bounty / arena-style fights</td>
              </tr>
              <tr>
                <th>Hauler</th>
                <td>Navigation + landing workflow</td>
                <td>Delivery contracts</td>
              </tr>
              <tr>
                <th>Multi-role</th>
                <td>All-round feel + upgrade potential</td>
                <td>General “starter pack” comparison</td>
              </tr>
              <tr>
                <th>Mining / industry</th>
                <td>Economy loop thinking</td>
                <td>Intro mining / resource flow</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- WHAT TO TEST -->
    <section id="what-to-test" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Trial checklist</div>
        <h2 class="section__title">What to test before you buy anything</h2>

        <ul>
          <li>Can you reliably spawn, reach the hangar and take off?</li>
          <li>Is quantum travel stable for you (route + performance)?</li>
          <li>Can you land at a station and return without friction?</li>
          <li>Do you prefer combat, delivery, multi-crew, or sandbox roaming?</li>
          <li>Is FPS/performance acceptable with basic optimization?</li>
        </ul>
      </div>
    </section>

    <!-- PITFALLS -->
    <section id="pitfalls" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Common pitfalls</div>
        <h2 class="section__title">Free Fly mistakes that waste your trial</h2>

        <ul>
          <li>Trying to do “everything” instead of one clean route + one loop.</li>
          <li>Ignoring ship role testing (you learn less, buy worse later).</li>
          <li>Skipping the referral code during signup (you can’t reliably add it later).</li>
          <li>Not learning basic navigation (hangars, elevators, terminals).</li>
        </ul>
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> FAQ</div>
        <h2 class="section__title">Free Fly – frequently asked questions</h2>

        <div class="faq">
          <details class="faq__item">
            <summary class="faq__q">Where do I check if Free Fly is active?</summary>
            <div class="faq__a">
              The most reliable source is the official RSI Fly Free page: <a href={flyFreeUrl} target="_blank" rel="noopener noreferrer" style="text-decoration: underline;">robertsspaceindustries.com/en/flyfree</a>
            </div>
          </details>

          <details class="faq__item">
            <summary class="faq__q">Do I need a starter pack during Free Fly?</summary>
            <div class="faq__a">
              No. Free Fly is a trial window. You only need a starter pack if you want to keep playing after the event ends.
            </div>
          </details>

          <details class="faq__item">
            <summary class="faq__q">Should I still use a referral code if I only try Free Fly?</summary>
            <div class="faq__a">
              Yes. Create the account with the referral code during signup, then decide later if you activate the account with a starter pack.
            </div>
          </details>
        </div>
      </div>
    </section>

    <footer class="footer">
      <div class="footer__inner">
        <div class="footer__brand">SCB — Unofficial Star Citizen guide.</div>
        <div class="footer__legal">
          Not affiliated with Cloud Imperium Games or Roberts Space Industries. Star Citizen® and related marks are trademarks of their respective owners.
        </div>
      </div>
    </footer>
  </main>

  <style>
    .freeFlyHero__overlay{
      background:
        radial-gradient(900px 420px at 25% 45%, rgba(0,0,0,.08), rgba(0,0,0,.58) 66%),
        linear-gradient(90deg, rgba(7,10,18,.70), rgba(7,10,18,.10));
    }
    .freeFlyHero__content{ padding: 22px; }
    .miniLead{ margin-top: 10px; opacity:.84; font-size: 13px; max-width: 820px; }
  </style>
</BaseLayout>
