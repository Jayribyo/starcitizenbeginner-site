---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReferralBanner from "../../components/ReferralBanner.astro";
import OnThisPage from "../../components/OnThisPage.astro";
import FaqSchema from "../../components/FaqSchema.astro";
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const referralCode = "STAR-FSRJ-5N7Z";
const referralBonusUEC = "50,000";
const referralLink = `https://www.robertsspaceindustries.com/enlist?referral=${referralCode}`;

const flyFreeUrl = "https://robertsspaceindustries.com/en/flyfree";

const heroImg = "/assets/img/free-fly/star-citizen-free-fly-hero.webp";
const crewImg = "/assets/img/free-fly/star-citizen-free-fly-crew.webp";

// FAQ content also used for JSON-LD
const faqItems = [
  {
    q: "What is Star Citizen Free Fly?",
    a: "Free Fly is an official limited-time event where anyone can play Star Citizen without buying a starter pack. You create an RSI account, install the launcher, and get temporary access for the event window.",
  },
  {
    q: "How do I check if Free Fly is live right now?",
    a: "Open the official RSI Free Fly page. If an event is active, you’ll see the event banner plus the exact steps to get access.",
  },
  {
    q: "How long does a Free Fly usually last?",
    a: "Most Free Fly events run about 5–10 days. The exact start and end time is always listed on the official event page.",
  },
  {
    q: "Do I need a game package during Free Fly?",
    a: "No. During the event you can play without purchasing anything. To keep playing after the event ends, you’ll need a starter pack.",
  },
  {
    q: "Can I use a referral code during Free Fly?",
    a: `Yes. Use a referral code when creating a new RSI account to activate the enlistment bonus (commonly advertised as ${referralBonusUEC} UEC). The safest time is during signup.`,
  },
  {
    q: "Can I add a referral code after creating my account?",
    a: "Sometimes there’s a limited window (commonly up to 24 hours). If you want the bonus, enter the code during account creation so you don’t rely on exceptions.",
  },
  {
    q: "Do I keep my progress after Free Fly?",
    a: "Your RSI account stays. Your access to the game ends with the event unless you purchase a starter pack. Progress persistence can change over time because Star Citizen is in active development.",
  },
  {
    q: "Why does Free Fly feel laggy or unstable?",
    a: "Free Fly weeks bring huge player spikes. Servers and starting zones get crowded, which can make performance and stability worse than normal weeks.",
  },
  {
    q: "Which ships can I fly during Free Fly?",
    a: "It changes per event. RSI usually offers a curated selection, often with rotations, so you can test different roles like combat, cargo, and multi-crew.",
  },
  {
    q: "How big is the download and how long does it take?",
    a: "Expect a large download (often 80–100+ GB). Install on an SSD if possible and start the download before peak hours during event week.",
  },
  {
    q: "Is Free Fly available worldwide?",
    a: "Generally yes, but availability and login flow can vary by region and account status. If you can access the RSI website and launcher, you can usually participate.",
  },
  {
    q: "Should I buy during Free Fly?",
    a: "Only if you enjoyed the core loop you tested and your sessions were mostly stable. If the event week felt rough, wait a few days after Free Fly for a more typical experience.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: { "@type": "Answer", text: item.a },
  })),
};
---

<BaseLayout
  title="Star Citizen Free Fly Guide – How It Works, Best Ships & What to Expect"
  description="A complete Star Citizen Free Fly guide for new players: what it is, how to join, what to test, best ships to try, and the smartest next steps."
  canonicalPath="/free-fly/"
  stickyCtaLabel="Check Free Fly status"
  stickyCtaHref={flyFreeUrl}
  stickyCtaExternal={true}
 activeNav="free-fly">
  <link slot="head" rel="preload" as="image" href={heroImg} fetchpriority="high" />
  <main>

    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Starter guides', href: '/#pick-your-path' }, { label: 'Free Fly', href: '/free-fly/' }]} />
    <!-- HERO -->
    <section class="hero freeFlyHero">
      <img
        class="hero__img"
        src={heroImg}
        alt="Star Citizen Free Fly expo hall with many ships and players"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1536"
        height="1024"
      />
      <div class="hero__overlay freeFlyHero__overlay"></div>

      <div class="hero__content">
        <div class="freeFlyHero__content">
          <div class="kicker"><span class="dot"></span> Free Fly Guide</div>
          <h1 class="h1">Star Citizen Free Fly</h1>

          <p class="lead" style="max-width: 920px;">
            Play without buying a starter pack during official Free Fly events — then decide what to purchase with confidence.
          </p>

          <div class="btnrow">
            <a class="btn primary" href={flyFreeUrl} target="_blank" rel="noopener noreferrer">
              Check Free Fly status
            </a>
          </div>
        </div>
      </div>

      <OnThisPage
        variant="hero"
        title="On this page"
        items={[
          { label: "What Free Fly is", href: "#what-is" },
          { label: "Is it worth it?", href: "#worth-it" },
          { label: "How to join", href: "#how-to-join" },
          { label: "Free Fly vs full game", href: "#compare" },
          { label: "Best ships to try", href: "#ships" },
          { label: "Prepare like a pro", href: "#prepare" },
          { label: "Common myths", href: "#myths" },
          { label: "Buy or wait?", href: "#buy" },
                    { label: "Next steps", href: "#next-steps" },
          { label: "Related answers", href: "#related-answers" },
{ label: "FAQ", href: "#faq" },
        ]}
      />
    </section>

    <!-- Referral banner (consistent site-wide) -->
    <ReferralBanner
      code={referralCode}
      bonus={`${referralBonusUEC} UEC`}
      ctaHref={referralLink}
      howItWorksHref="#how-to-join"
      sublineHtml="Enter during signup — or within <b>24 hours</b> after account creation."
      ariaLabel="Referral bonus callout"
    />

    <!-- WHAT IS -->
    <section id="what-is" class="section">
      <div class="card pad">
        <h2 class="section__title">What Free Fly actually is</h2>

        <p class="muted" style="margin-top:10px;">New to the terms? <a class="link" href="/satellites/glossary/">Beginner glossary</a>.</p>


        <p>
          Free Fly is a limited-time “open access” event run by the developers (RSI). During the event window you can download the
          game, log in, and play without owning a starter pack. It’s the best way to feel the flight model, the scale, and the moment-to-moment
          experience before you spend anything.
        </p>

        <div class="grid2" style="margin-top:12px;">
          <div class="card pad">
            <h3 style="margin:0 0 8px;">What you get</h3>
            <ul class="bullets">
              <li><b>Time-limited access</b> to the live servers during the event.</li>
              <li><b>A curated ship selection</b> (often rotated) so you can test different roles.</li>
              <li><b>Real progression systems</b> (missions, money, reputation), like normal play.</li>
            </ul>
          </div>

          <div class="card pad">
            <h3 style="margin:0 0 8px;">What Free Fly is not</h3>
            <ul class="bullets">
              <li><b>Not a tiny demo.</b> It’s the actual live build, with all the good and all the rough edges.</li>
              <li><b>Not permanent access.</b> When the event ends, you’ll need a starter pack to keep playing.</li>
              <li><b>Not a “perfect performance week”.</b> The servers are often busiest during Free Fly.</li>
            </ul>
          </div>
        </div>

        <div style="margin-top:14px;">
          <img
            src={crewImg}
            alt="A small Star Citizen crew preparing ships together before launch"
            loading="lazy"
            decoding="async"
            width="1536"
            height="1024"
            style="border-radius:16px; border:1px solid rgba(255,255,255,.10);"
          />
        </div>
      </div>
    </section>

    <!-- WORTH IT -->
    <section id="worth-it" class="section">
      <div class="card pad">
        <h2 class="section__title">Is Free Fly worth it?</h2>

        <p>
          Usually yes — if you treat it like a <b>hands-on test flight</b>, not a speedrun. The event week can be crowded and sometimes a little chaotic,
          so your best outcome is simple: <b>learn the feel</b>, test a few roles, and decide whether you want to commit.
        </p>

        <div class="tableWrap" style="margin-top:12px;">
          <table class="table">
            <thead>
              <tr>
                <th>Free Fly is perfect for you if…</th>
                <th>You might want to wait if…</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>You want to experience the scale and flight model before buying.</td>
                <td>You only want a “polished release” experience right now.</td>
              </tr>
              <tr>
                <td>You’re okay learning a few systems (navigation, landing, inventory).</td>
                <td>You get frustrated easily by bugs or server instability.</td>
              </tr>
              <tr>
                <td>You can play outside peak hours for smoother sessions.</td>
                <td>You can only play at prime time and need ultra-stable servers.</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="callout" style="margin-top:12px;">
          <b>Expectation that keeps people happy:</b> If your first session is messy, don’t quit on the whole game.
          Try again at a different time of day — Free Fly weeks can be the noisiest weeks.
        </div>
      </div>
    </section>

    <!-- HOW TO JOIN -->
    <section id="how-to-join" class="section">
      <div class="card pad">
        <h2 class="section__title">How to join Free Fly</h2>

        <p>
          The cleanest setup is: create your RSI account (with a referral code), install the launcher, and then use the official Free Fly page to confirm access.
          If a Free Fly is live, RSI will show the exact steps for that specific event.
        </p>

        <div class="tableWrap" style="margin-top:12px;">
          <table class="table">
            <thead>
              <tr>
                <th class="nowrap">Step</th>
                <th>Do this</th>
                <th>Why it matters</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td class="nowrap">1</td>
                <td>Create an RSI account and enter the referral code during signup.</td>
                <td>You lock in the enlistment bonus and avoid the “I forgot the code” headache.</td>
              </tr>
              <tr>
                <td class="nowrap">2</td>
                <td>Install the RSI Launcher and start the download early.</td>
                <td>Free Fly traffic is huge — downloading before peak hours is smoother.</td>
              </tr>
              <tr>
                <td class="nowrap">3</td>
                <td>Open the official Free Fly page and follow the event access prompts.</td>
                <td>Events differ — the official page is the source of truth for access.</td>
              </tr>
              <tr>
                <td class="nowrap">4</td>
                <td>Pick one ship/role to test first and stick with it for 1–2 sessions.</td>
                <td>You learn faster when you repeat a loop instead of sampling everything once.</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="btnrow" style="margin-top:14px;">
          <a class="btn primary" href={flyFreeUrl} target="_blank" rel="noopener noreferrer">Check Free Fly status</a>
          <a class="btn" href="/beginner-tips/">Use the beginner first-hour plan</a>
        </div>
      </div>
    </section>

    <!-- COMPARE -->
    <section id="compare" class="section">
      <div class="card pad">
        <h2 class="section__title">Free Fly vs the full game</h2>

        <p>
          Free Fly gives you a real slice of the live game, but it’s still time-limited access. This table is the fastest way to set expectations.
        </p>

        <div class="tableWrap" style="margin-top:12px;">
          <table class="table">
            <thead>
              <tr>
                <th>Feature</th>
                <th>Free Fly</th>
                <th>Full account</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Access duration</td>
                <td>Limited to the event window</td>
                <td>Permanent (with a starter pack)</td>
              </tr>
              <tr>
                <td>Ships available</td>
                <td>Curated event selection (often rotates)</td>
                <td>Your starter ship + anything you earn/rent/buy in-game</td>
              </tr>
              <tr>
                <td>Best use</td>
                <td>Test the feel, roles, performance, and your tolerance for friction</td>
                <td>Settle into a loop, earn credits, and progress over time</td>
              </tr>
              <tr>
                <td>Buying decision</td>
                <td>Try first, then purchase if you enjoyed your loop</td>
                <td>Commit when you’re ready to keep playing past the event</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="callout" style="margin-top:12px;">
          <b>Pro tip:</b> If you love Free Fly but the week feels unstable, wait a few days after the event ends.
          The same build often feels smoother once the surge drops.
        </div>
      </div>
    </section>

    <!-- SHIPS -->
    <section id="ships" class="section">
      <div class="card pad">
        <h2 class="section__title">Best ships to try during Free Fly</h2>

        <p>
          Don’t try to fly everything. Pick <b>3–4 ships</b> that represent different roles and you’ll leave Free Fly with a clear sense of what you actually enjoy.
        </p>

        <div class="grid2" style="margin-top:12px;">
          <div class="card pad">
            <h3 style="margin:0 0 8px;">Combat</h3>
            <ul class="bullets">
              <li>Practice takeoff/landing under pressure.</li>
              <li>Try simple bounty contracts and learn travel + rearm flow.</li>
              <li>Focus on <b>time to re-try</b> rather than perfect dogfights.</li>
            </ul>
          </div>

          <div class="card pad">
            <h3 style="margin:0 0 8px;">Cargo & delivery</h3>
            <ul class="bullets">
              <li>Best role to learn stations, elevators, and navigation.</li>
              <li>Low stress, high repetition — perfect for beginners.</li>
              <li>Teaches “inventory realism” without constant combat risk.</li>
            </ul>
          </div>

          <div class="card pad">
            <h3 style="margin:0 0 8px;">Mining / industry</h3>
            <ul class="bullets">
              <li>Great for players who enjoy routines and optimization.</li>
              <li>Try it once to see if “process gameplay” clicks for you.</li>
              <li>Don’t judge it by your first run — learning curve is real.</li>
            </ul>
          </div>

          <div class="card pad">
            <h3 style="margin:0 0 8px;">Multi-crew</h3>
            <ul class="bullets">
              <li>Play with friends, or join an org to experience teamwork.</li>
              <li>Shows what makes Star Citizen feel unique vs other space sims.</li>
              <li>Even one good multi-crew session can sell the game.</li>
            </ul>
          </div>
        </div>

        <div class="callout" style="margin-top:12px;">
          <b>Small but huge win:</b> Rent ships in-game during Free Fly and compare “fun per minute” — not raw damage or max cargo.
        </div>
      </div>
    </section>

    <!-- PREPARE -->
    <section id="prepare" class="section">
      <div class="card pad">
        <h2 class="section__title">Prepare like a pro</h2>

        <p>
          Free Fly week rewards people who do the boring setup early. These are the steps that prevent the classic “I spent my whole night downloading and troubleshooting” session.
        </p>

        <div class="tableWrap" style="margin-top:12px;">
          <table class="table">
            <thead>
              <tr>
                <th>Do this before you play</th>
                <th>Why it helps</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Install on an SSD and leave extra free space.</td>
                <td>Reduces stutter and lowers the risk of patch/download issues.</td>
              </tr>
              <tr>
                <td>Create your account + referral bonus first.</td>
                <td>You’re not scrambling later, and you get the enlistment bonus.</td>
              </tr>
              <tr>
                <td>Play your first session outside peak hours if possible.</td>
                <td>Less queueing, fewer overloaded hubs, smoother mission flow.</td>
              </tr>
              <tr>
                <td>Start in a popular location only if you want the chaos.</td>
                <td>Busy hubs look cool — but they can also be the most unstable.</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="btnrow" style="margin-top:14px;">
          <a class="btn" href="/beginner-tips/">Beginner survival guide</a>
          <a class="btn" href="/star-citizen-referral-code/">Referral bonus explained</a>
        </div>
      </div>
    </section>

    <!-- MYTHS -->
    <section id="myths" class="section">
      <div class="card pad">
        <h2 class="section__title">Common Free Fly myths</h2>

        <div class="tableWrap" style="margin-top:12px;">
          <table class="table">
            <thead>
              <tr>
                <th>Myth</th>
                <th>Reality</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>“Free Fly is just a tiny demo.”</td>
                <td>It’s the live game. You’re seeing the real experience — including the rough edges.</td>
              </tr>
              <tr>
                <td>“If it runs badly during Free Fly, it always runs badly.”</td>
                <td>Free Fly weeks can be unusually busy. Performance can look worse than typical weeks.</td>
              </tr>
              <tr>
                <td>“I have to buy something to participate.”</td>
                <td>Free Fly is designed to be playable without purchase during the event.</td>
              </tr>
              <tr>
                <td>“Progress always resets immediately.”</td>
                <td>Progress policies can change over time. Treat Free Fly as a test, not as long-term grinding.</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="callout" style="margin-top:12px;">
          <b>Authority signal:</b> People who enjoy Star Citizen usually enjoy it because the sandbox “clicks”.
          Give yourself a few sessions to see if that click happens.
        </div>
      </div>
    </section>

    <!-- BUY -->
    <section id="buy" class="section">
      <div class="card pad">
        <h2 class="section__title">Should you buy during Free Fly?</h2>

        <p>
          Buy if you found a loop you genuinely enjoyed and you want to keep playing after the event. Wait if your sessions were dominated by queues, crashes, or you never got into a rhythm.
          A good rule is to base your decision on your <b>best session</b>, not your worst.
        </p>

        <div class="grid2" style="margin-top:12px;">
          <div class="card pad">
            <h3 style="margin:0 0 8px;">Buy now if…</h3>
            <ul class="bullets">
              <li>You completed the same mission type twice and it felt fun.</li>
              <li>You like the flight + landing loop.</li>
              <li>You’re okay with a game in active development.</li>
            </ul>
          </div>

          <div class="card pad">
            <h3 style="margin:0 0 8px;">Wait if…</h3>
            <ul class="bullets">
              <li>You only played at peak hours and it felt unplayable.</li>
              <li>You didn’t enjoy the core loop even when things worked.</li>
              <li>You want a finished, friction-free release experience.</li>
            </ul>
          </div>
        </div>

        <div class="btnrow" style="margin-top:14px;">
          <a class="btn primary" href={referralLink} target="_blank" rel="noopener noreferrer">Create your account</a>
          <a class="btn" href="/star-citizen-referral-code/">Referral bonus explained</a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    

    <section id="next-steps" class="section alt">
      <div class="container">
        <h2 class="h2">Next steps</h2>
        <ul class="bullets">
            <li><a href="/star-citizen-performance-guide/">Fix stutter + FPS</a></li>
            <li><a href="/make-money-fast/">Earn credits fast</a></li>
            <li><a href="/should-you-buy-star-citizen/">Take the 2-minute buy test</a></li>
            <li><a href="/star-citizen-starter-packs/">Pick a starter pack</a></li>
            <li><a href="/star-citizen-referral-code/">Referral code: where to paste it</a></li>
        </ul>
      </div>
    </section>

    <section id="related-answers" class="section alt">
      <div class="container">
        <h2 class="h2">Related answers</h2>
        <ul class="bullets">
            <li><a href="/satellites/free-fly-first-session/">Free Fly: first session route (beginner-proof)</a></li>
            <li><a href="/satellites/free-fly-download-install-checklist/">Download & install checklist (avoid setup traps)</a></li>
            <li><a href="/satellites/free-fly-what-do-i-keep/">Free Fly: what you keep (clear expectations)</a></li>
            <li><a href="/satellites/free-fly-queues-and-server-lag-fix/">Queues & lag: what you can control</a></li>
            <li><a href="/satellites/fix-stuttering/">Fix stuttering (10-minute checklist)</a></li>
            <li><a href="/satellites/best-time-to-play-free-fly/">Best time to play (get a fair impression)</a></li>
</ul>
      </div>
    </section>

<section id="faq" class="section">
      <div class="card pad">
        <h2 class="section__title">Free Fly FAQ</h2>
        <p class="miniLead">Fast answers to the questions new players search for during Free Fly week.</p>

        <div class="faq" style="margin-top:12px;">
          {faqItems.map((item) => (
            <details class="faq__item">
              <summary class="faq__q">{item.q}</summary>
              <div class="faq__a">{item.a}</div>
            </details>
          ))}
        </div>
      </div>
    </section>
  </main>

  <!-- SEO: FAQPage JSON-LD -->
  <FaqSchema json={faqJsonLd} />

  <style>
    .freeFlyHero__overlay{
      background:
        radial-gradient(900px 420px at 25% 45%, rgba(0,0,0,.10), rgba(0,0,0,.64) 66%),
        linear-gradient(90deg, rgba(7,10,18,.72), rgba(7,10,18,.10));
    }
    .freeFlyHero__content{ padding: 22px; }

    .nowrap{ white-space: nowrap; }
  </style>
</BaseLayout>
