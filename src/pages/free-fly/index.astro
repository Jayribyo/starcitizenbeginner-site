---
import BaseLayout from "../../layouts/BaseLayout.astro";

const pageTitle = "Star Citizen Free Fly: How to Play for Free During Events";
const pageDescription = "Learn how Star Citizen Free Fly events work, how to join, what ships you can fly, and why using a referral code during account creation gives you a bonus.";
const canonicalPath = "/free-fly/";
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonicalPath}>

<section class="container">

  <!-- HERO -->
  <header class="hero">
    <h1>Star Citizen Free Fly: How to Play for Free During Events</h1>
    <p class="lead">
      Free Fly events allow anyone to try Star Citizen at no cost for a limited time.
      Here’s how they work — and how to start properly.
    </p>

    <div class="cta-group">
      <a href="https://robertsspaceindustries.com/" class="btn-primary">
        Check if a Free Fly is active
      </a>
      <a href="/star-citizen-referral-code/" class="btn-secondary">
        Get 5,000 UEC bonus
      </a>
    </div>
  </header>

  <!-- HERO IMAGE PLACEHOLDER -->
  <figure class="image-block">
    <img 
      src="/images/free-fly/free-fly-hero-placeholder.webp" 
      alt="Star Citizen hangar with multiple ships during Free Fly event"
      width="1200"
      height="800"
      loading="lazy"
    />
  </figure>

  <!-- QUICK ANSWER -->
  <section>
    <h2>What is a Star Citizen Free Fly event?</h2>
    <p>
      A Free Fly event is a limited-time period during which Star Citizen can be played
      without purchasing a game package. New players can create an RSI account,
      download the launcher, and access selected ships and features at no cost.
    </p>
    <p>
      These events typically occur several times per year and are often tied to
      major in-game expos or celebrations. They provide an opportunity to test
      performance, explore the universe, and evaluate whether the game fits your expectations.
    </p>
  </section>

  <!-- HOW IT WORKS -->
  <section>
    <h2>How to join a Free Fly event</h2>
    <ol>
      <li>Create a new RSI account during the Free Fly period.</li>
      <li>Ensure the Free Fly access is activated on your account.</li>
      <li>Download and install the RSI Launcher.</li>
      <li>Launch the game and enter the universe.</li>
      <li>
        Optional but recommended: add a referral code during account creation
        to receive the available new-player bonus.
      </li>
    </ol>
  </section>

  <!-- WHAT YOU CAN DO -->
  <section>
    <h2>What can you do during Free Fly?</h2>

    <h3>Fly multiple ships</h3>
    <p>
      Free Fly events usually provide temporary access to a selection of ships,
      allowing you to test different roles such as cargo hauling, combat, or exploration.
    </p>

    <h3>Explore major cities and planets</h3>
    <p>
      You can visit planetary landing zones, space stations, and moons to experience
      the scale and visual design of the universe.
    </p>

    <h3>Try missions and contracts</h3>
    <p>
      Accept delivery contracts, bounty missions, or service beacons to understand
      the gameplay loops available in the current build.
    </p>

    <h3>Evaluate performance</h3>
    <p>
      Free Fly is a practical way to test how Star Citizen performs on your hardware
      before committing to a purchase.
    </p>
  </section>

  <!-- IMAGE PLACEHOLDER -->
  <figure class="image-block">
    <img 
      src="/images/free-fly/free-fly-expo-placeholder.webp" 
      alt="Star Citizen expo hall with ships on display"
      width="1200"
      height="800"
      loading="lazy"
    />
  </figure>

  <!-- REFERRAL INTEGRATION -->
  <section>
    <h2>Should you use a referral code during Free Fly?</h2>
    <p>
      If you are creating a new account during a Free Fly event,
      this is the only moment when a referral code can be applied.
      It cannot be added retroactively after registration.
    </p>
    <p>
      Using a referral code does not increase the price of the game,
      and it does not create any obligation. It simply activates
      the available new-player bonus at account creation.
    </p>

    <div class="cta-inline">
      <p><strong>Start with the bonus active:</strong></p>
      <a href="/star-citizen-referral-code/" class="btn-primary">
        Apply referral before creating account
      </a>
    </div>
  </section>

  <!-- TIMING -->
  <section>
    <h2>When is the next Free Fly event?</h2>
    <p>
      Free Fly events usually occur multiple times per year, often alongside
      large in-game expos such as fleet showcases or anniversary events.
      There is no fixed schedule, but they are recurring.
    </p>
    <p>
      To stay informed, monitor the official RSI website or newsletter.
      During active periods, account creation grants temporary access without purchase.
    </p>
  </section>

  <!-- WORTH IT -->
  <section>
    <h2>Is Free Fly worth trying?</h2>

    <h3>Advantages</h3>
    <ul>
      <li>No financial commitment</li>
      <li>Access to multiple ships</li>
      <li>Test performance on your system</li>
      <li>Experience core gameplay loops</li>
    </ul>

    <h3>Considerations</h3>
    <ul>
      <li>Server load may be higher during events</li>
      <li>Performance can fluctuate depending on hardware</li>
      <li>Access is limited to the event duration</li>
    </ul>

    <p>
      Free Fly is ideal for players who want to evaluate the project realistically
      before investing in a starter package.
    </p>
  </section>

  <!-- FAQ -->
  <section>
    <h2>Common questions</h2>

    <details>
      <summary>Do I need to buy a game package during Free Fly?</summary>
      <p>No. During Free Fly, access is granted without purchasing a package.</p>
    </details>

    <details>
      <summary>Can I keep my progress after Free Fly?</summary>
      <p>Account progress remains, but continued access requires purchasing a starter package.</p>
    </details>

    <details>
      <summary>Can I add a referral code later?</summary>
      <p>No. Referral codes must be entered during account creation.</p>
    </details>

    <details>
      <summary>How long do Free Fly events last?</summary>
      <p>Typically several days to around one week, depending on the event.</p>
    </details>

    <details>
      <summary>Are all ships available?</summary>
      <p>No. A curated selection is usually provided for testing purposes.</p>
    </details>

  </section>

</section>

<!-- FAQ SCHEMA -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Do I need to buy a game package during Free Fly?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. During Free Fly events, access is granted without purchasing a game package."
      }
    },
    {
      "@type": "Question",
      "name": "Can I add a referral code later?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. Referral codes must be entered during account creation and cannot be added retroactively."
      }
    },
    {
      "@type": "Question",
      "name": "How long do Free Fly events last?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Free Fly events usually last several days up to about a week."
      }
    }
  ]
}
</script>

</BaseLayout>