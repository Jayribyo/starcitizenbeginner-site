---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import ReferralBanner from "../../components/ReferralBanner.astro";
import OnThisPage from "../../components/OnThisPage.astro";
import FaqSchema from "../../components/FaqSchema.astro";

const referralCode = "STAR-FSRJ-5N7Z";
const referralBonusUEC = "50,000";
const referralLink = `https://www.robertsspaceindustries.com/enlist?referral=${referralCode}`;

const flyFreeUrl = "https://robertsspaceindustries.com/en/flyfree";

const heroImg = "/assets/img/free-fly/star-citizen-free-fly-hero.webp";
const crewImg = "/assets/img/free-fly/star-citizen-free-fly-crew.webp";

// FAQ content also used for JSON-LD
const faqItems = [
  {
    q: "What is Star Citizen Free Fly?",
    a: "Free Fly is an official limited-time event where you can play Star Citizen without buying a starter pack. You create an RSI account, install the launcher, and get temporary access for the event window.",
  },
  {
    q: "How do I check if Free Fly is active right now?",
    a: "Use the official RSI Free Fly page. If a Free Fly is live, the event and access steps will be shown there.",
  },
  {
    q: "Do I need to buy a starter pack during Free Fly?",
    a: "No. Free Fly lets you play without purchase during the event. If you want to continue after it ends, you’ll need a starter pack.",
  },
  {
    q: "Can I keep my account and progress after Free Fly?",
    a: "Your RSI account stays. Access after the event requires a starter pack. As with any live development game, long-term progression can change over time.",
  },
  {
    q: "Should I use a referral code during Free Fly?",
    a: `Yes. If you’re creating a new account, apply a referral code during signup to activate the enlistment bonus (commonly advertised as ${referralBonusUEC} UEC). It doesn’t change pricing and it’s easiest to do at registration.`,
  },
  {
    q: "Can I add a referral code after creating my account?",
    a: "Often there’s a limited window (commonly referenced as ~24 hours). The safest approach is to apply it during account creation so you don’t miss it.",
  },
  {
    q: "How long do Free Fly events last?",
    a: "Most Free Fly events run roughly 5–10 days depending on the promotion. The exact duration is listed on the official Free Fly page when active.",
  },
  {
    q: "What ships are available during Free Fly?",
    a: "It changes per event. You typically get a curated rotating selection so you can try different roles (combat, cargo, multi-crew).",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: { "@type": "Answer", text: item.a },
  })),
};
---

<BaseLayout
  title="Star Citizen Free Fly Guide – How It Works & What to Test"
  description="Everything about Star Citizen Free Fly events: how to join, what ships to test, when it happens, and how to prepare as a new player."
  canonicalPath="/free-fly/"
  stickyCtaLabel="Check Free Fly status"
  stickyCtaHref={flyFreeUrl}
  stickyCtaExternal={true}
>

<link slot="head" rel="preload" as="image" href={heroImg} fetchpriority="high" />

  <SiteHeader active="free-fly" />

  <main class="container">

    <!-- HERO -->
    <section class="hero freeFlyHero">
      <img
  class="hero__img"
  src={heroImg}
  alt="Star Citizen Free Fly expo hall with many ships and players"
  loading="eager"
  fetchpriority="high"
  decoding="async"
  width="1536"
  height="1024"
/>
      <div class="hero__overlay freeFlyHero__overlay"></div>

      <div class="hero__content">
        <div class="freeFlyHero__content">
          <div class="kicker"><span class="dot"></span> Free Fly Guide</div>
          <h1 class="h1">Star Citizen Free Fly</h1>
<p></p>
          <p class="lead" style="max-width: 920px;">
          </p>

  <p class="miniLead">
            Check if Free Fly is available and activate the referral bonus before you finish signup.
          </p>

          <div class="btnrow">
            <a class="btn primary" href={flyFreeUrl} target="_blank" rel="noopener noreferrer">
              Check Free Fly status (official)
            </a>
          </div>
      
        </div>
      </div>
    </section>

    <!-- Referral banner (consistent with referral page) -->
    <ReferralBanner
      code={referralCode}
      bonus={`${referralBonusUEC} UEC`}
      ctaHref={referralLink}
      howItWorksHref="#how-to-join"
      sublineHtml="Enter during signup — or within <b>24 hours</b> after account creation."
      ariaLabel="Referral bonus callout"
    />

    <!-- ON THIS PAGE -->
    <OnThisPage
      title="On this page"
      items={[
        { label: "What Free Fly is", href: "#what-is" },
        { label: "How to join", href: "#how-to-join" },
        { label: "First hour plan", href: "#quick-start" },
        { label: "Ships & roles", href: "#ships" },
        { label: "What to test", href: "#what-to-test" },
        { label: "When it happens", href: "#timing" },
        { label: "Next steps", href: "#next" },
        { label: "FAQ", href: "#faq" },
      ]}
    />

    <!-- WHAT IT IS -->
    <section id="what-is" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> What it is</div>
        <h2 class="section__title">What is Star Citizen Free Fly?</h2>

        <p class="lead" style="margin-top:0;">
          Free Fly is an official trial window where you can play Star Citizen without purchasing a starter pack.
          You create an RSI account, install the launcher, and get access for the event duration.
        </p>

        <div class="tableWrap">
          <table class="table" aria-label="Free Fly overview">
            <thead>
              <tr>
                <th>Item</th>
                <th>Free Fly</th>
                <th>After Free Fly</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th>Cost to try</th>
                <td>Free</td>
                <td>Starter pack required</td>
              </tr>
              <tr>
                <th>Account</th>
                <td>RSI account (create once)</td>
                <td>Same account continues</td>
              </tr>
              <tr>
                <th>Ships</th>
                <td>Curated rotating selection</td>
                <td>Depends on your package / rentals / purchases</td>
              </tr>
              <tr>
                <th>Best use-case</th>
                <td>Find your playstyle + test performance</td>
                <td>Pick a starter path and build routine</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="miniNote">
          <b>Beginner tip:</b> Don’t try to “see everything” on day one.
          Aim for one clean loop: spawn → reach your ship → do a simple contract → return safely.
        </div>
      </div>
    </section>

    <!-- HOW TO JOIN -->
    <section id="how-to-join" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> How to join</div>
        <h2 class="section__title">How to join Free Fly (step-by-step)</h2>

        <ol class="steps">
          <li>
            <b>Check status:</b> Open the official Free Fly page and confirm the event is active.
            <div class="miniLead">
              <a href={flyFreeUrl} target="_blank" rel="noopener noreferrer" style="text-decoration: underline; opacity:.9;">
                robertsspaceindustries.com/en/flyfree
              </a>
            </div>
          </li>
          <li>
            <b>Create an RSI account:</b> If you’re new, register once and keep that account forever.
          </li>
          <li>
            <b>Use the referral code at signup:</b> Apply <b>{referralCode}</b> during registration to activate the enlistment bonus ({referralBonusUEC} UEC).
          </li>
          <li>
            <b>Install the RSI launcher:</b> Download, install, then install Star Citizen.
          </li>
          <li>
            <b>Log in and enter the PU:</b> Once Free Fly access is active, select the Persistent Universe and spawn in.
          </li>
        </ol>

        <div class="grid2" style="margin-top: 14px;">
          <div class="card pad" style="background: rgba(0,0,0,.16); border-color: rgba(255,255,255,.10);">
            <div style="font-weight: 900; letter-spacing:.08em; text-transform:uppercase; font-size:12px; opacity:.76;">
              Referral code
            </div>
            <div style="font-size: 22px; font-weight: 1000; letter-spacing:.14em; margin-top: 6px;">
              {referralCode}
            </div>
            <div style="margin-top: 10px;">
              <a class="btn primary" href={referralLink} target="_blank" rel="noopener noreferrer">Create your RSI account</a>
            </div>
          </div>

          <div class="card pad" style="background: rgba(0,0,0,.16); border-color: rgba(255,255,255,.10);">
            <div style="font-weight: 900; letter-spacing:.08em; text-transform:uppercase; font-size:12px; opacity:.76;">
              Why this matters
            </div>
            <p style="margin-top: 8px; color: rgba(255,255,255,.78); line-height: 1.65;">
              Free Fly brings the largest wave of new players. If you create a fresh account anyway, applying a referral code at signup is the cleanest path.
              If you skip it, you may not be able to add it later.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- QUICK START -->
    <section id="quick-start" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> First-hour plan</div>
        <h2 class="section__title">Your first hour: a clean, repeatable plan</h2>

        <p class="lead" style="margin-top:0;">
          The goal is not to “see everything”. The goal is to build a stable baseline:
          controls → a short flight route → one contract → one ship comparison.
        </p>

        <div class="grid2" style="margin-top: 14px;">
          <div class="card pad" style="background: rgba(0,0,0,.16); border-color: rgba(255,255,255,.10);">
            <h3 style="margin: 0 0 10px; font-size: 16px;">Phase 1: Get functional</h3>
            <ol class="steps">
              <li>Find the hangar terminals and elevators.</li>
              <li>Call your ship, reach the hangar, and take off once.</li>
              <li>Set a short quantum route and land at a station.</li>
            </ol>
          </div>

          <div class="card pad" style="background: rgba(0,0,0,.16); border-color: rgba(255,255,255,.10);">
            <h3 style="margin: 0 0 10px; font-size: 16px;">Phase 2: Run one loop</h3>
            <ol class="steps">
              <li>Pick one beginner contract type (delivery or simple bounty).</li>
              <li>Complete it once end-to-end.</li>
              <li>Return safely and repeat once if possible.</li>
            </ol>
          </div>
        </div>

        <div class="miniNote">
          <b>Why this works:</b> If you can do one loop reliably, you can scale from there.
          If you scatter your attention, Free Fly becomes confusing and you learn less.
        </div>
      </div>
    </section>

    <!-- SHIPS -->
    <section id="ships" class="section">
      <div class="grid2">
        <div class="card pad">
          <div class="kicker"><span class="dot"></span> Ships & roles</div>
          <h2 class="section__title">Which ships to try (so the trial is actually useful)</h2>

          <p>
            Free Fly often gives you access to multiple ships. Don’t pick randomly.
            Try at least <b>two roles</b> so you understand the real difference in gameplay loops.
          </p>

          <div class="tableWrap">
            <table class="table" aria-label="Ship roles during Free Fly">
              <thead>
                <tr>
                  <th>Role</th>
                  <th>What you learn</th>
                  <th>Best test</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <th>Fighter</th>
                  <td>Combat handling + targeting</td>
                  <td>Basic bounty contract</td>
                </tr>
                <tr>
                  <th>Hauler</th>
                  <td>Navigation + landing workflow</td>
                  <td>Delivery contract</td>
                </tr>
                <tr>
                  <th>Multi-role</th>
                  <td>General “starter pack” feel</td>
                  <td>Compare comfort + upgrades</td>
                </tr>
                <tr>
                  <th>Multi-crew</th>
                  <td>Team roles + ship systems</td>
                  <td>Tour / multi-seat operation</td>
                </tr>
              </tbody>
            </table>
          </div>

          <div class="miniNote">
            <b>Beginner tip:</b> Your best Free Fly outcome is a clear answer to:
            “Do I want combat, cargo, exploration, or multi-crew as my default?”
          </div>
        </div>

        <div class="card pad">
          <img
  class="imgRounded"
  src={crewImg}
  alt="A sci-fi crew walking toward a ship"
  loading="lazy"
  decoding="async"
  width="1536"
  height="1024"
/>
        </div>
      </div>
    </section>

    <!-- WHAT TO TEST -->
    <section id="what-to-test" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Checklist</div>
        <h2 class="section__title">What to test before you buy a starter pack</h2>

        <div class="grid2" style="margin-top: 12px;">
          <div class="card pad" style="background: rgba(0,0,0,.16); border-color: rgba(255,255,255,.10);">
            <h3 style="margin: 0 0 10px; font-size: 16px;">Gameplay</h3>
            <ul>
              <li>Spawn → hangar → ship call → takeoff</li>
              <li>Short quantum route + landing</li>
              <li>One contract end-to-end</li>
              <li>At least two ship roles</li>
            </ul>
          </div>

          <div class="card pad" style="background: rgba(0,0,0,.16); border-color: rgba(255,255,255,.10);">
            <h3 style="margin: 0 0 10px; font-size: 16px;">Performance</h3>
            <ul>
              <li>Are you comfortable in major cities?</li>
              <li>Are ship fights playable for you?</li>
              <li>Is stutter acceptable after basic settings?</li>
              <li>Can you land without big input delay?</li>
            </ul>
          </div>
        </div>

        <div class="miniNote">
          <b>Reality check:</b> Free Fly is high traffic. Don’t judge everything on one session.
          Your goal is: “Is this universe worth investing in?” not “Is it perfect?”
        </div>
      </div>
    </section>

    <!-- TIMING -->
    <section id="timing" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> When it happens</div>
        <h2 class="section__title">When Free Fly events happen (and what to watch)</h2>

        <p class="lead" style="margin-top:0;">
          Free Fly typically runs around major promotions and events.
          The exact dates and included ships are always listed on the official Free Fly page when active.
        </p>

        <div class="miniNote">
          <b>Best practice:</b> Always verify status on the official page:
          <a href={flyFreeUrl} target="_blank" rel="noopener noreferrer" style="text-decoration: underline; opacity:.9;">
            robertsspaceindustries.com/en/flyfree
          </a>
        </div>
      </div>
    </section>

    <!-- NEXT -->
    <section id="next" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Next steps</div>
        <h2 class="section__title">After Free Fly: what to do next</h2>

        <div class="grid2" style="margin-top: 12px;">
          <div class="card pad" style="background: rgba(0,0,0,.16); border-color: rgba(255,255,255,.10);">
            <h3 style="margin: 0 0 10px; font-size: 16px;">If you want to buy</h3>
            <ul>
              <li>Pick a starter pack that matches your role preference.</li>
              <li>Use your referral bonus as early buffer (gear + refuel).</li>
              <li>Follow a simple aUEC loop to stabilize income.</li>
            </ul>
            <div style="margin-top: 10px;">
              <a class="btn secondary" href="/starter-pack/">Starter pack guide</a>
              <a class="btn secondary" href="/make-money-fast/">Make money fast</a>
            </div>
          </div>

          <div class="card pad" style="background: rgba(0,0,0,.16); border-color: rgba(255,255,255,.10);">
            <h3 style="margin: 0 0 10px; font-size: 16px;">If you want to keep testing</h3>
            <ul>
              <li>Try a different ship role next session.</li>
              <li>Do one loop twice to reduce “randomness”.</li>
              <li>Optimize FPS settings if needed.</li>
            </ul>
            <div style="margin-top: 10px;">
              <a class="btn secondary" href="/performance-settings/">Performance guide</a>
              <a class="btn secondary" href="/beginner-tips/">Beginner tips</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> FAQ</div>
        <h2 class="section__title">Free Fly – frequently asked questions</h2>

        <div class="faq">
          {faqItems.map((item) => (
            <details class="faq__item">
              <summary class="faq__q">{item.q}</summary>
              <div class="faq__a">{item.a}</div>
            </details>
          ))}
        </div>
      </div>
    </section>

  </main>

 <!-- SEO: FAQPage JSON-LD -->
<FaqSchema json={faqJsonLd} />

  <style>
    .freeFlyHero__overlay{
      background:
        radial-gradient(900px 420px at 25% 45%, rgba(0,0,0,.10), rgba(0,0,0,.64) 66%),
        linear-gradient(90deg, rgba(7,10,18,.72), rgba(7,10,18,.10));
    }
    .freeFlyHero__content{ padding: 22px; }

    /* Minimal page-scoped adjustments kept from repo baseline */
    .miniLead{ margin-top: 10px; opacity:.84; font-size: 13px; max-width: 820px; }
  </style>
</BaseLayout>











