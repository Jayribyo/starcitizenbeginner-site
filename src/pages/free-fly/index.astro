---
import BaseLayout from "../../layouts/BaseLayout.astro";

const referralBonusUEC = "50,000";
const flyFreeUrl = "https://robertsspaceindustries.com/en/flyfree";

const heroImg = "/assets/img/free-fly/star-citizen-free-fly-hero.webp";
const crewImg = "/assets/img/free-fly/star-citizen-free-fly-crew.webp";

const faqItems = [
  {
    q: "What is Star Citizen Free Fly?",
    a: "Free Fly is an official limited-time event where you can play Star Citizen without buying a starter pack. You create an RSI account, install the launcher, and get temporary access for the event window.",
  },
  {
    q: "How do I check if Free Fly is active right now?",
    a: "Use the official RSI Free Fly page. If a Free Fly is live, you’ll see the active event and access instructions there.",
  },
  {
    q: "Do I need to buy a starter pack during Free Fly?",
    a: "No. Free Fly lets you play without purchase during the event. If you want to continue playing after it ends, you’ll need a starter pack.",
  },
  {
    q: "Can I keep my account and progress after Free Fly?",
    a: "Your RSI account stays. Access after the event requires a starter pack. Like any live development game, long-term progression can change over time.",
  },
  {
    q: "Can I use a referral code during Free Fly?",
    a: `Yes. Enter the referral code during signup to activate the enlistment bonus (commonly advertised as ${referralBonusUEC} UEC).`,
  },
  {
    q: "Can I add a referral code after creating my account?",
    a: "Sometimes there’s a limited window, but the safest approach is to apply it during account creation so you don’t miss it.",
  },
  {
    q: "How long do Free Fly events last?",
    a: "Most Free Fly events run roughly 5–10 days depending on the promotion. The exact duration is shown on the official Free Fly page when active.",
  },
  {
    q: "What ships are available during Free Fly?",
    a: "It changes per event. You typically get a curated rotating selection to try different roles (combat, cargo, multi-crew).",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: { "@type": "Answer", text: item.a },
  })),
};
---

<BaseLayout
  lang="en"
  title="Star Citizen Free Fly – How to Join, What to Do First, Ships & Bonus Guide"
  description={`The most practical Star Citizen Free Fly guide: how to check if it’s active, how to join step-by-step, what to do in your first hour, what ships to try, and how to start with the ${referralBonusUEC} UEC referral bonus.`}
  canonicalPath="/free-fly/"
  ogImage={heroImg}
>
  <header class="topbar">
    <div class="container topbar__inner">
      <a class="brand" href="/" aria-label="SCB Home">
        <img src="/assets/img/global/scb-logo.svg" alt="SCB logo" />
        <span>Star Citizen Beginner</span>
      </a>

      <div class="lang" aria-label="Language switch (placeholder)">
        <span style="opacity:.7;">Lang:</span>
        <a class="active" href="/free-fly/">EN</a>
        <a href="/de/">DE</a>
        <a href="/es/">ES</a>
        <a href="/fr/">FR</a>
        <a href="/ru/">RU</a>
        <a href="/zh/">中文</a>
      </div>
    </div>
  </header>

  <main class="container">

    <!-- HERO -->
    <section class="hero freeFlyHero">
      <img
        class="hero__img"
        src={heroImg}
        alt="Star Citizen Free Fly expo hall with many ships and players"
        loading="eager"
        fetchpriority="high"
      />
      <div class="hero__overlay freeFlyHero__overlay"></div>

      <div class="hero__content">
        <div class="freeFlyHero__content">
          <div class="kicker"><span class="dot"></span> Free Fly Guide</div>
          <h1 class="h1">Star Citizen Free Fly: Start the smart way</h1>
          <p class="lead" style="max-width: 900px;">
            Free Fly is the easiest way to try Star Citizen without buying anything.
            Use this page to get in fast, test the right things, and avoid common beginner dead-ends.
          </p>

          <!-- CTA order: Free Fly status + Referral bonus (prominent but not spammy) -->
          <div class="btnrow">
            <a class="btn primary" href={flyFreeUrl} target="_blank" rel="noopener noreferrer">
              Check Free Fly status (official)
            </a>
            <a class="btn primary" href="/star-citizen-referral-code/">
              Start with {referralBonusUEC} UEC bonus
            </a>
            <a class="btn secondary" href="#quick-start">Quick start checklist</a>
          </div>

          <p class="miniLead">
            Creating a new account? Apply the referral during signup so the bonus is active from the start.
          </p>
        </div>
      </div>
    </section>

    <!-- Premium benefit strip (like homepage logic; subtle but visible) -->
    <section class="section">
      <div class="refOffer">
        <div class="refOffer__badge" aria-hidden="true">BONUS</div>

        <div class="refOffer__main">
          <div class="refOffer__title">
            New account during Free Fly: activate the enlistment bonus (<b>{referralBonusUEC} UEC</b>).
          </div>
          <div class="refOffer__sub">
            It takes under a minute and doesn’t change pricing — it simply applies the official referral bonus at signup.
          </div>
        </div>

        <div class="refOffer__actions">
          <a class="btn primary" href="/star-citizen-referral-code/">Get the code + steps</a>
          <a class="refOffer__link" href="#how-to-join">How it works ↓</a>
        </div>
      </div>
    </section>

    <!-- TOC -->
    <section class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> On this page</div>
        <div class="toc">
          <a href="#what-is">What Free Fly is</a>
          <a href="#how-to-join">How to join</a>
          <a href="#quick-start">First hour checklist</a>
          <a href="#ships">Ships & roles</a>
          <a href="#what-to-test">What to test</a>
          <a href="#timing">When it happens</a>
          <a href="#faq">FAQ</a>
        </div>
      </div>
    </section>

    <!-- WHAT IT IS -->
    <section id="what-is" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> What it is</div>
        <h2 class="section__title">What is Star Citizen Free Fly?</h2>

        <p class="lead" style="margin-top:0;">
          Free Fly is an official trial window where you can play Star Citizen without purchasing a starter pack.
          You create an RSI account, install the launcher, and get access for the event duration.
        </p>

        <table class="scTable" role="table" aria-label="Free Fly overview table">
          <thead>
            <tr>
              <th>Item</th>
              <th>Free Fly</th>
              <th>After Free Fly</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Cost to try</td>
              <td>Free</td>
              <td>Starter pack required</td>
            </tr>
            <tr>
              <td>Account</td>
              <td>RSI account (create once)</td>
              <td>Same account continues</td>
            </tr>
            <tr>
              <td>Ships</td>
              <td>Curated rotating selection</td>
              <td>Depends on your package / rentals / purchases</td>
            </tr>
            <tr>
              <td>Best use-case</td>
              <td>Find your playstyle + test performance</td>
              <td>Pick a starter path and build routine</td>
            </tr>
          </tbody>
        </table>

        <!-- Replace the “server” line with beginner-first, actionable guidance -->
        <div class="miniNote">
          <b>Beginner tip:</b> Don’t try to “see everything” on day one.
          Aim for a clean first loop: spawn → reach your ship → take one simple contract → return safely.
        </div>
      </div>
    </section>

    <!-- HOW TO JOIN -->
    <section id="how-to-join" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> How to join</div>
        <h2 class="section__title">How to join Free Fly (step-by-step)</h2>

        <ol class="steps">
          <li><b>Open the official page:</b> <a href={flyFreeUrl} target="_blank" rel="noopener noreferrer">robertsspaceindustries.com/en/flyfree</a></li>
          <li><b>Create your RSI account</b> (or sign in if you already have one).</li>
          <li><b>Apply a referral code during signup</b> to activate the enlistment bonus (<b>{referralBonusUEC} UEC</b>).</li>
          <li><b>Install the RSI Launcher</b> and download the current build.</li>
          <li><b>Launch</b>, pick a starting location, and run your first simple contract.</li>
        </ol>

        <div class="btnrow">
          <a class="btn primary" href={flyFreeUrl} target="_blank" rel="noopener noreferrer">Official Free Fly page</a>
          <a class="btn secondary" href="/star-citizen-referral-code/">Referral code (bonus active)</a>
        </div>
      </div>
    </section>

    <!-- FIRST HOUR CHECKLIST (stronger beginner utility than generic “best practice”) -->
    <section id="quick-start" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> First hour</div>
        <h2 class="section__title">Your first 60 minutes (a simple, reliable plan)</h2>

        <div class="grid2">
          <div>
            <h3 class="h3">Step 1: Get to space once</h3>
            <ul class="bullets">
              <li>Spawn → find the transit → reach the spaceport</li>
              <li>Claim your ship → take off → exit atmosphere</li>
            </ul>
            <div class="miniNote">Goal: prove you can consistently get airborne.</div>
          </div>

          <div>
            <h3 class="h3">Step 2: Do one low-risk contract</h3>
            <ul class="bullets">
              <li>Pick a delivery / courier style contract</li>
              <li>Avoid “high threat” tasks for your first hour</li>
            </ul>
            <div class="miniNote">Goal: learn how contracts + navigation + landing connect.</div>
          </div>

          <div>
            <h3 class="h3">Step 3: Test 2 ships (not 10)</h3>
            <ul class="bullets">
              <li>One smaller ship for handling</li>
              <li>One larger ship for interiors + scale</li>
            </ul>
            <div class="miniNote">Goal: quickly feel what you enjoy.</div>
          </div>

          <div>
            <h3 class="h3">Step 4: Decide your next step</h3>
            <ul class="bullets">
              <li>If you liked it → read the Starter Pack Guide</li>
              <li>If performance is rough → apply basic FPS settings</li>
            </ul>
            <div class="miniNote">
              Next links: <a href="/starter-pack/">Starter Pack Guide</a> · <a href="/performance-settings/">Performance & FPS</a>
            </div>
          </div>
        </div>

        <div class="btnrow">
          <a class="btn secondary" href="/starter-pack/">Starter Pack Guide</a>
          <a class="btn secondary" href="/performance-settings/">Performance & FPS</a>
          <a class="btn secondary" href="/beginner-tips/">Beginner Tips</a>
        </div>
      </div>
    </section>

    <!-- SHIPS -->
    <section id="ships" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Ships</div>
        <h2 class="section__title">What ships can you fly during Free Fly?</h2>
        <p class="lead" style="margin-top:0;">
          The lineup changes per event. Use Free Fly to compare roles — combat vs cargo vs multi-crew — and find what feels fun.
        </p>

        <table class="scTable" role="table" aria-label="Ship roles during Free Fly">
          <thead>
            <tr>
              <th>Role</th>
              <th>What to try</th>
              <th>Beginner signal</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Combat</td>
              <td>One basic bounty mission</td>
              <td>Do you enjoy pressure and piloting skill?</td>
            </tr>
            <tr>
              <td>Cargo / hauling</td>
              <td>Deliveries + simple hauling</td>
              <td>Do you enjoy calm, routine gameplay?</td>
            </tr>
            <tr>
              <td>Multi-crew</td>
              <td>Turret / ship interior roles</td>
              <td>Do you enjoy teamwork and roles?</td>
            </tr>
            <tr>
              <td>Daily driver</td>
              <td>One versatile ship</td>
              <td>Could this be your first purchase?</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Smaller secondary image: capped height to avoid scroll monster -->
    <section class="section">
      <figure class="freeFlyFigure freeFlyFigure--compact">
        <img
          class="freeFlyFigure__img"
          src={crewImg}
          alt="A small crew boarding a ship for a mission during Free Fly"
          loading="lazy"
          width="1600"
          height="900"
        />
      </figure>
    </section>

    <!-- WHAT TO TEST -->
    <section id="what-to-test" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> What to test</div>
        <h2 class="section__title">What to test during Free Fly (the efficient way)</h2>

        <table class="scTable" role="table" aria-label="What to test during Free Fly">
          <thead>
            <tr>
              <th>Priority</th>
              <th>Test</th>
              <th>Why it matters</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>1</td>
              <td>Baseline performance in your starting city</td>
              <td>Decides whether the game is playable for you right now</td>
            </tr>
            <tr>
              <td>2</td>
              <td>One reliable contract loop</td>
              <td>Shows how navigation + missions + landing work together</td>
            </tr>
            <tr>
              <td>3</td>
              <td>Two ship styles (small + larger)</td>
              <td>Quickly reveals your preferred playstyle</td>
            </tr>
            <tr>
              <td>4</td>
              <td>Multi-crew moment (optional)</td>
              <td>Determines if social/team roles are your thing</td>
            </tr>
          </tbody>
        </table>

        <div class="miniNote">
          If performance is borderline, use our <a href="/performance-settings/">Performance & FPS guide</a> before you decide.
        </div>
      </div>
    </section>

    <!-- TIMING -->
    <section id="timing" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Timing</div>
        <h2 class="section__title">When does Free Fly happen?</h2>
        <p class="lead" style="margin-top:0;">
          There’s no fixed calendar, but Free Fly commonly aligns with major showcases and promotions.
        </p>

        <table class="scTable" role="table" aria-label="Typical Free Fly windows">
          <thead>
            <tr>
              <th>Window</th>
              <th>Typical month</th>
              <th>What it’s like</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Invictus-style showcase</td>
              <td>May (often)</td>
              <td>Strong ship trial rotation, military focus</td>
            </tr>
            <tr>
              <td>IAE-style expo</td>
              <td>November (often)</td>
              <td>Largest variety; best “try before buy” period</td>
            </tr>
            <tr>
              <td>Patch / promo Free Fly</td>
              <td>Variable</td>
              <td>Shorter event; still perfect for new accounts</td>
            </tr>
          </tbody>
        </table>

        <div class="btnrow">
          <a class="btn primary" href={flyFreeUrl} target="_blank" rel="noopener noreferrer">Check official status</a>
          <a class="btn secondary" href="/star-citizen-referral-code/">Start with {referralBonusUEC} UEC</a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> FAQ</div>
        <h2 class="section__title">Common questions</h2>

        <div class="faq">
          {faqItems.map((item) => (
            <details>
              <summary>{item.q}</summary>
              <p>{item.a}</p>
            </details>
          ))}
        </div>

        <div class="btnrow">
          <a class="btn primary" href="/star-citizen-referral-code/">Referral code + steps</a>
          <a class="btn secondary" href="/starter-pack/">Starter Pack Guide</a>
          <a class="btn secondary" href="/beginner-tips/">Beginner Tips</a>
        </div>
      </div>
    </section>

  </main>

  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)}></script>

  <style>
    /* Improve readability on the busy hero background */
    .freeFlyHero__overlay{
      background:
        radial-gradient(900px 420px at 25% 45%, rgba(0,0,0,0.10), rgba(0,0,0,0.62) 66%),
        linear-gradient(90deg, rgba(7,10,18,0.74), rgba(7,10,18,0.12));
    }
    .freeFlyHero__content{ padding: 22px; }
    .miniLead{ margin-top: 10px; opacity:.86; font-size: 13px; max-width: 820px; }

    .toc{
      display:flex; flex-wrap:wrap; gap:10px 14px; margin-top:10px;
      font-weight:800; font-size:13px; opacity:.9;
    }
    .toc a{
      border:1px solid rgba(255,255,255,.10);
      background: rgba(255,255,255,.04);
      padding:8px 10px; border-radius:12px;
    }
    .toc a:hover{ background: rgba(255,255,255,.07); }

    .scTable{
      width:100%;
      border-collapse: separate;
      border-spacing: 0;
      margin-top: 14px;
      overflow:hidden;
      border-radius: 14px;
      border: 1px solid rgba(255,255,255,0.10);
      background: rgba(255,255,255,0.03);
    }
    .scTable th, .scTable td{
      padding: 12px 12px;
      border-bottom: 1px solid rgba(255,255,255,0.08);
      vertical-align: top;
      font-size: 13px;
      line-height: 1.35;
    }
    .scTable th{
      text-align:left;
      font-weight: 900;
      background: rgba(255,255,255,0.04);
    }
    .scTable tr:last-child td{ border-bottom: 0; }

    .steps{ margin: 10px 0 0; padding-left: 18px; }
    .steps li{ margin: 8px 0; }

    .grid2{
      display:grid;
      grid-template-columns: 1fr;
      gap: 14px;
      margin-top: 12px;
    }
    @media (min-width: 860px){
      .grid2{ grid-template-columns: 1fr 1fr; }
    }
    .h3{ font-size: 15px; margin: 8px 0 6px; }
    .bullets{ margin: 0; padding-left: 18px; opacity: .92; }
    .bullets li{ margin: 6px 0; }

    /* Secondary image should not dominate scroll */
    .freeFlyFigure{
      margin:0;
      border-radius: var(--radius);
      overflow:hidden;
      border: 1px solid rgba(255,255,255,0.10);
      box-shadow: var(--shadow);
      background: rgba(255,255,255,0.02);
    }
    .freeFlyFigure__img{
      width:100%;
      height:auto;
      display:block;
      object-fit: cover;
      object-position: 50% 55%;
      filter: saturate(1.05) brightness(1.02);
    }
    .freeFlyFigure--compact{
      max-height: 440px;
    }
    .freeFlyFigure--compact .freeFlyFigure__img{
      height: 440px;
    }
    @media (max-width: 680px){
      .freeFlyFigure--compact{ max-height: 320px; }
      .freeFlyFigure--compact .freeFlyFigure__img{ height: 320px; }
    }
  </style>

</BaseLayout>
