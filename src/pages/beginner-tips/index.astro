---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import ReferralBanner from "../../components/ReferralBanner.astro";
import OnThisPage from "../../components/OnThisPage.astro";
import FaqSchema from "../../components/FaqSchema.astro";

const referralCode = "STAR-FSRJ-5N7Z";
const referralLink = `https://www.robertsspaceindustries.com/enlist?referral=${referralCode}`;
const referralPage = "/star-citizen-referral-code/";

/* IMPORTANT: Cloudflare Pages build requires /public in URL */
const heroImg = "/public/assets/img/beginner-tips/scb-beginner-tips-structured-route-hero.webp";
const planningImg = "/public/assets/img/beginner-tips/scb-beginner-tips-priority-planning.webp";

const faqItems = [
{
q: "What should I focus on during my first hours?",
a: "Focus on stability. Set regeneration point, create a cheap baseline kit, and complete one repeatable contract type before expanding."
},
{
q: "Why do beginners feel overwhelmed?",
a: "Because they stack too many systems at once. Reduce variables and repeat one loop until it becomes predictable."
},
{
q: "When should I upgrade my ship?",
a: "Only after income is stable. Hardware should scale after consistency, not before."
}
];

const faqJsonLd = {
"@context": "https://schema.org",
"@type": "FAQPage",
mainEntity: faqItems.map((item) => ({
"@type": "Question",
name: item.q,
acceptedAnswer: {
"@type": "Answer",
text: item.a
}
}))
};
---

<BaseLayout
title="Star Citizen Beginner Guide - Structured Progression Strategy"
description="In-depth Star Citizen beginner guide with structured progression, mission loops, risk control and long-term economic scaling."
canonicalPath="/beginner-tips/"
>

<link slot="head" rel="preload" as="image" href={heroImg} fetchpriority="high" />

<SiteHeader active="guides" />

<main class="container">

<!-- HERO (same structural logic as referral page) -->
<section class="hero">
<img
class="hero__img"
src={heroImg}
alt="Structured beginner route on a star map"
loading="eager"
fetchpriority="high"
decoding="async"
width="1536"
height="1024"
/>
<div class="hero__overlay"></div>

<div class="hero__content">
<div class="homeHero__content">
<div style="max-width:760px;padding:26px 0;">
<div class="kicker"><span class="dot"></span> Beginner Strategy</div>
<h1 class="h1">Star Citizen Beginner Guide</h1>
<p class="lead">
This is a structured progression framework designed to eliminate chaos and accelerate mastery.
</p>
</div>
</div>
</div>
</section>

<ReferralBanner
code={referralCode}
bonus="50,000 UEC"
ctaHref={referralLink}
howItWorksHref={`${referralPage}#how-to-use`}
sublineHtml="Enter during signup or within <b>24 hours</b> after account creation."
ariaLabel="Referral bonus"
/>

<OnThisPage
title="Guide structure"
items={[
{ label: "Progression model", href: "#progression" },
{ label: "Session framework", href: "#sessions" },
{ label: "Mission loops", href: "#loops" },
{ label: "Risk system", href: "#risk" },
{ label: "Scaling income", href: "#scaling" },
{ label: "FAQ", href: "#faq" }
]}
/>

<!-- PROGRESSION MODEL -->
<section id="progression" class="section">
<div class="card pad">
<h2 class="section__title">Structured Progression Model</h2>

<p>
Most beginners fail because they chase variety instead of stability.
Progression in Star Citizen is about system mastery.
</p>

<div class="tableWrap">
<table class="scTable">
<thead>
<tr>
<th scope="col">Phase</th>
<th scope="col">Primary goal</th>
<th scope="col">Result</th>
</tr>
</thead>
<tbody>
<tr>
<th scope="row">Stabilize</th>
<td>Learn navigation and return cycles</td>
<td>No more confusion or random resets</td>
</tr>
<tr>
<th scope="row">Repeat</th>
<td>Run one contract type multiple times</td>
<td>Predictable income flow</td>
</tr>
<tr>
<th scope="row">Optimize</th>
<td>Reduce downtime and recovery time</td>
<td>Higher profit per hour</td>
</tr>
<tr>
<th scope="row">Expand</th>
<td>Add second loop or upgrade ship</td>
<td>Compounding progression</td>
</tr>
</tbody>
</table>
</div>
</div>
</section>

<!-- SESSION FRAMEWORK -->
<section id="sessions" class="section">
<div class="card pad">
<h2 class="section__title">3-Session Framework</h2>

<div class="tableWrap">
<table class="scTable">
<thead>
<tr>
<th scope="col">Session</th>
<th scope="col">Focus</th>
<th scope="col">Measured outcome</th>
</tr>
</thead>
<tbody>
<tr>
<th scope="row">1</th>
<td>Spawn setup and one safe contract</td>
<td>Travel cycle mastered</td>
</tr>
<tr>
<th scope="row">2</th>
<td>Repeat identical contract</td>
<td>Reduced mistakes</td>
</tr>
<tr>
<th scope="row">3</th>
<td>Add minor complexity</td>
<td>Controlled expansion</td>
</tr>
</tbody>
</table>
</div>
</div>
</section>

<!-- PLANNING SECTION -->
<section class="section">
<div class="grid2">
<div class="card pad">
<h2 class="section__title">Planning Before Profit</h2>
<p>
Early success is determined by structure, not gear.
Define a baseline kit.
Define your route.
Define your fallback point.
</p>
<p>
When you remove unpredictability, confidence grows.
Confidence increases efficiency.
Efficiency creates income.
</p>
</div>

<div class="card pad">
<img
class="imgRounded"
src={planningImg}
alt="Priority planning for beginner pilot"
loading="lazy"
decoding="async"
width="1536"
height="1024"
/>
</div>
</div>
</section>

<!-- MISSION LOOPS -->
<section id="loops" class="section">
<div class="card pad">
<h2 class="section__title">Beginner Mission Loop Selection</h2>

<div class="tableWrap">
<table class="scTable">
<thead>
<tr>
<th scope="col">Loop</th>
<th scope="col">What it builds</th>
<th scope="col">Risk</th>
</tr>
</thead>
<tbody>
<tr>
<th scope="row">Delivery</th>
<td>Navigation discipline</td>
<td>Low</td>
</tr>
<tr>
<th scope="row">Local bunker</th>
<td>Combat fundamentals</td>
<td>Medium</td>
</tr>
<tr>
<th scope="row">Salvage practice</th>
<td>Ship positioning and scanning</td>
<td>Low to medium</td>
</tr>
</tbody>
</table>
</div>

</div>
</section>

<!-- RISK SYSTEM -->
<section id="risk" class="section">
<div class="card pad">
<h2 class="section__title">Risk Budget System</h2>

<p>
Never carry more value than the mission justifies.
Risk multiplies losses if skill is not stable.
</p>

<div class="tableWrap">
<table class="scTable">
<thead>
<tr>
<th scope="col">Loadout type</th>
<th scope="col">When to use</th>
<th scope="col">Purpose</th>
</tr>
</thead>
<tbody>
<tr>
<th scope="row">Baseline kit</th>
<td>Default contracts</td>
<td>Fast recovery cycle</td>
</tr>
<tr>
<th scope="row">Enhanced kit</th>
<td>Controlled missions</td>
<td>Higher success rate</td>
</tr>
<tr>
<th scope="row">High value kit</th>
<td>Advanced contracts</td>
<td>High risk high reward</td>
</tr>
</tbody>
</table>
</div>

</div>
</section>

<!-- SCALING -->
<section id="scaling" class="section">
<div class="card pad">
<h2 class="section__title">Income Scaling Strategy</h2>

<p>
Once loops are stable, reduce downtime between contracts.
Profit is determined by efficiency, not intensity.
</p>

<ul>
<li>Reduce claim and refuel downtime</li>
<li>Cache gear locally</li>
<li>Deposit frequently</li>
<li>Expand only after stability</li>
</ul>

</div>
</section>

<!-- FAQ -->
<section id="faq" class="section">
<div class="card pad">
<h2 class="section__title">FAQ</h2>
<div class="faq">
{faqItems.map((item) => (
<details class="faqItem">
<summary class="faqQ">{item.q}</summary>
<div class="faqA">{item.a}</div>
</details>
))}
</div>
</div>
</section>

<FaqSchema json={faqJsonLd} />

</main>
</BaseLayout>
