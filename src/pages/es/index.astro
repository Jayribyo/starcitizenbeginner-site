---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReferralCTA from "../../components/ReferralCTA.astro";

const paths = { en:"/", de:"/de/", es:"/es/", fr:"/fr/", ru:"/ru/", zh:"/zh/" };

const t = {
  title: "Guía para Principiantes de Star Citizen | Inicio rápido + Bonus de referral",
  desc: "Guía rápida para principiantes de Star Citizen con pasos clave, puntos de interés y cómo activar el bonus por código de referral.",
  heroKicker: "Para pilotos nuevos",
  heroH1: "Empieza bien en el Verse.",
  heroLead: "Una guía clara y sin spam para entrar al juego rápido — con una explicación sencilla del bonus de referral (paso a paso).",
  qsTitle: "Inicio rápido (5 minutos)",
  qs1: "Crea tu cuenta RSI (usa el código de referral durante el registro).",
  qs2: "Elige un starter pack que puedas volar y mejorar más tarde.",
  qs3: "Instala, inicia y haz tu primer contrato sencillo para aprender navegación y aterrizaje.",
  poiTitle: "Puntos de interés (recomendados para principiantes)",
  poiLead: "Algunos lugares fáciles de entender y útiles al principio:",
  poi: [
    "Area18 (ArcCorp) – buen hub para compras y transporte",
    "New Babbage (microTech) – diseño limpio, ideal para aprender",
    "Lorville (Hurston) – hub urbano clásico e industrial",
    "Orison (Crusader) – precioso, pero puede bajar FPS"
  ],
  faqTitle: "FAQ (código de referral)",
  faq1q: "¿Usar un código de referral me cuesta algo?",
  faq1a: "No. Es un registro normal. Simplemente recibes el bonus si creas la cuenta con un código/enlace.",
  faq2q: "¿Dónde se introduce el código?",
  faq2a: "Durante la creación de la cuenta en la web de RSI. Si usas el enlace de referral, se aplica automáticamente.",
  disclaimer: "Guía comunitaria no oficial. No está afiliada a Cloud Imperium Games ni a Roberts Space Industries."
};
---
<BaseLayout lang="es" title={t.title} description={t.desc} canonicalPath="/es/" brand="Star Citizen Beginner" paths={paths}>
  <main>
    <div class="grid">
      <section class="card">
        <div class="kicker">{t.heroKicker}</div>
        <h1 class="h1">{t.heroH1}</h1>
        <p class="lead">{t.heroLead}</p>

        <div class="badge">Código de Referral: <strong style="color:#fff;">STAR-FSRJ-5N7Z</strong></div>

        <hr class="sep" />

        <div id="quickstart">
          <h2 style="margin:0 0 10px;">{t.qsTitle}</h2>
          <ol style="margin:0; padding-left: 18px; color: rgba(255,255,255,.82);">
            <li>{t.qs1}</li>
            <li>{t.qs2}</li>
            <li>{t.qs3}</li>
          </ol>
        </div>

        <hr class="sep" />

        <h2 style="margin:0 0 10px;">{t.poiTitle}</h2>
        <p class="lead" style="margin-top:0;">{t.poiLead}</p>
        <ul style="margin:0; padding-left: 18px; color: rgba(255,255,255,.82);">
          {t.poi.map(x => <li>{x}</li>)}
        </ul>

        <footer>
          <p style="margin:16px 0 0;">{t.disclaimer}</p>
        </footer>
      </section>

      <aside>
        <ReferralCTA
          title="Activa el bonus de registro"
          blurb="Si vas a crear una cuenta nueva, usar un código/enlace de referral activa el bonus. Aquí lo explicamos claro y seguimos centrados en ayudar a principiantes."
          ctaPrimary="Crear cuenta (referral aplicado)"
          ctaSecondary="Leer inicio rápido"
        />

        <div style="height:14px;"></div>

        <div class="card">
          <div class="kicker">Siguiente paso</div>
          <h2 style="margin:10px 0 8px; font-size: 20px;">Starter packs & rendimiento</h2>
          <p style="margin:0; color: rgba(255,255,255,.78);">
            Añadiremos una comparación limpia de starter packs y una guía de rendimiento/configuración (muy buena para SEO).
          </p>
        </div>
      </aside>
    </div>

    <div style="height:18px;"></div>

    <section class="card">
      <h2 style="margin:0 0 10px;">{t.faqTitle}</h2>

      <details style="padding:10px 0; border-top:1px solid rgba(255,255,255,.12);">
        <summary style="cursor:pointer; font-weight:800;">{t.faq1q}</summary>
        <p style="margin:8px 0 0; color: rgba(255,255,255,.78);">{t.faq1a}</p>
      </details>

      <details style="padding:10px 0; border-top:1px solid rgba(255,255,255,.12);">
        <summary style="cursor:pointer; font-weight:800;">{t.faq2q}</summary>
        <p style="margin:8px 0 0; color: rgba(255,255,255,.78);">{t.faq2a}</p>
      </details>
    </section>
  </main>
</BaseLayout>