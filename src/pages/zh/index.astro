---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReferralCTA from "../../components/ReferralCTA.astro";

import { DEFAULT_LANGUAGE_PATHS, REFERRAL_CODE, REFERRAL_LINK, REFERRAL_INFO_PATH, REFERRAL_BONUS_UEC, FLY_FREE_URL } from "../../config/site";

const paths = DEFAULT_LANGUAGE_PATHS;

const t = {
  title: "Star Citizen 新手指南 | 快速上手 + 推荐码奖励",
  desc: "面向新手的 Star Citizen 快速上手指南：关键步骤、推荐地点，以及如何使用推荐码获得注册奖励。",
  heroKicker: "新手友好",
  heroH1: "更聪明地开始你的 Verse 之旅。",
  heroLead: "一份清晰、不打扰的入门指南：帮助你快速进游戏并理解基础操作，同时简单说明推荐码奖励怎么拿。",
  qsTitle: "快速上手（5 分钟）",
  qs1: "创建 RSI 账号（注册时使用推荐码）。",
  qs2: "选择一个真正适合新手飞行的入门包（之后可以升级）。",
  qs3: "安装并启动游戏，做第一个简单任务，学习导航与降落。",
  poiTitle: "推荐地点（新手精选）",
  poiLead: "这些地点更容易理解，也很适合前期活动：",
  poi: [
    "Area18（ArcCorp）— 购物与交通枢纽，方便上手",
    "New Babbage（microTech）— 布局清晰，适合学习",
    "Lorville（Hurston）— 经典工业城市枢纽",
    "Orison（Crusader）— 很漂亮，但可能更吃性能（FPS）"
  ],
  faqTitle: "常见问题（推荐码）",
  faq1q: "使用推荐码需要额外付费吗？",
  faq1a: "不需要。这是正常注册流程，只是用推荐码/链接注册会获得奖励。",
  faq2q: "在哪里输入推荐码？",
  faq2a: "在 RSI 官网创建账号时输入。如果使用推荐链接，会自动应用推荐码。",
  disclaimer: "非官方社区指南，与 Cloud Imperium Games / Roberts Space Industries 无关联。"
};
---
<BaseLayout lang="zh" title={t.title} description={t.desc} canonicalPath="/zh/" brand="Star Citizen Beginner" paths={paths}>
  <main>
    <div class="grid">
      <section class="card">
        <div class="kicker">{t.heroKicker}</div>
        <h1 class="h1">{t.heroH1}</h1>
        <p class="lead">{t.heroLead}</p>

        <div class="badge">推荐码：<strong style="color:#fff;">STAR-FSRJ-5N7Z</strong></div>

        <hr class="sep" />

        <div id="quickstart">
          <h2 style="margin:0 0 10px;">{t.qsTitle}</h2>
          <ol style="margin:0; padding-left: 18px; color: rgba(255,255,255,.82);">
            <li>{t.qs1}</li>
            <li>{t.qs2}</li>
            <li>{t.qs3}</li>
          </ol>
        </div>

        <hr class="sep" />

        <h2 style="margin:0 0 10px;">{t.poiTitle}</h2>
        <p class="lead" style="margin-top:0;">{t.poiLead}</p>
        <ul style="margin:0; padding-left: 18px; color: rgba(255,255,255,.82);">
          {t.poi.map(x => <li>{x}</li>)}
        </ul>

        <footer>
          <p style="margin:16px 0 0;">{t.disclaimer}</p>
        </footer>
      </section>

      <aside>
        <ReferralCTA
          title="领取注册奖励"
          blurb="如果你正在创建新账号，使用推荐码/链接可获得注册奖励。本页会清晰说明，并保持对新手真正有用。"
          ctaPrimary="创建账号（已应用推荐码）"
          ctaSecondary="阅读快速上手"
        />

        <div style="height:14px;"></div>

        <div class="card">
          <div class="kicker">下一步</div>
          <h2 style="margin:10px 0 8px; font-size: 20px;">入门包对比与性能设置</h2>
          <p style="margin:0; color: rgba(255,255,255,.78);">
            下一步我们会加入入门包对比，以及性能/设置指南（非常适合 SEO 流量）。
          </p>
        </div>
      </aside>
    </div>

    <div style="height:18px;"></div>

    <section class="card">
      <h2 style="margin:0 0 10px;">{t.faqTitle}</h2>

      <details style="padding:10px 0; border-top:1px solid rgba(255,255,255,.12);">
        <summary style="cursor:pointer; font-weight:800;">{t.faq1q}</summary>
        <p style="margin:8px 0 0; color: rgba(255,255,255,.78);">{t.faq1a}</p>
      </details>

      <details style="padding:10px 0; border-top:1px solid rgba(255,255,255,.12);">
        <summary style="cursor:pointer; font-weight:800;">{t.faq2q}</summary>
        <p style="margin:8px 0 0; color: rgba(255,255,255,.78);">{t.faq2a}</p>
      </details>
    </section>
  </main>
</BaseLayout>