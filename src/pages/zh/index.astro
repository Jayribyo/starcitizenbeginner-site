---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReferralCTA from "../../components/ReferralCTA.astro";
import FaqSchema from "../../components/FaqSchema.astro";

import { DEFAULT_LANGUAGE_PATHS, REFERRAL_CODE } from "../../config/site";

const paths = DEFAULT_LANGUAGE_PATHS;
const referralCode = REFERRAL_CODE;

const t = {
  title: "Star Citizen 新手指南 | 快速上手 + 推荐码奖励",
  desc: "面向新手的 Star Citizen 快速上手指南：关键步骤、推荐地点，以及如何使用推荐码获得注册奖励。",
  heroKicker: "新手友好",
  heroH1: "更聪明地开始你的 Verse 之旅。",
  heroLead: "一份清晰、不打扰的入门指南：帮助你快速进游戏并理解基础操作，同时简单说明推荐码奖励怎么拿。",
  qsTitle: "快速上手（5 分钟）",
  qs1: "创建 RSI 账号（注册时使用推荐码）。",
  qs2: "选择一个真正适合新手飞行的入门包（之后可以升级）。",
  qs3: "安装并启动游戏，做第一个简单任务，学习导航与降落。",
  poiTitle: "推荐地点（新手精选）",
  poiLead: "这些地点更容易理解，也很适合前期活动：",
  poi: [
    "Area18（ArcCorp）— 购物与交通枢纽，方便上手",
    "New Babbage（microTech）— 布局清晰，适合学习",
    "Lorville（Hurston）— 经典工业城市枢纽",
    "Orison（Crusader）— 很漂亮，但可能更吃性能（FPS）"
  ],
  faqTitle: "常见问题（推荐码）",
  faq1q: "使用推荐码需要额外付费吗？",
  faq1a: "不需要。这是正常注册流程，只是用推荐码/链接注册会获得奖励。",
  faq2q: "在哪里输入推荐码？",
  faq2a: "在 RSI 官网创建账号时输入。如果使用推荐链接，会自动应用推荐码。",
  disclaimer: "非官方社区指南，与 Cloud Imperium Games / Roberts Space Industries 无关联。"
};
const faqItems = [
  { q: t.faq1q, a: t.faq1a },
  { q: t.faq2q, a: t.faq2a },
];

---
<BaseLayout lang="zh" title={t.title} description={t.desc} canonicalPath="/zh/" brand="Star Citizen Beginner" paths={paths}>
  <FaqSchema items={faqItems} />
  <main class="langPage">
    <section class="section section--heroWidth">
      <div class="grid">
        <section class="card langPage__heroCard">
          <div class="kicker">{t.heroKicker}</div>
          <h1 class="h1">{t.heroH1}</h1>
          <p class="lead">{t.heroLead}</p>

          <div class="badge">推荐码： <strong style="color:#fff;">{referralCode}</strong></div>

          <hr class="sep" />

          <div id="quickstart" class="langPage__stack">
            <div>
              <h2 class="section__title">{t.qsTitle}</h2>
              <ol class="steps muted">
                <li>{t.qs1}</li>
                <li>{t.qs2}</li>
                <li>{t.qs3}</li>
              </ol>
            </div>

            <div>
              <h2 class="section__title">{t.poiTitle}</h2>
              <p class="lead">{t.poiLead}</p>
              <ul class="bullets muted">
                {t.poi.map(x => <li>{x}</li>)}
              </ul>
            </div>
          </div>

          <div class="miniNote">
            {t.disclaimer}
          </div>
        </section>

        <aside class="langPage__asideStack">
          <ReferralCTA
            title={"领取注册奖励"}
            blurb={"如果你正在创建新账号，使用推荐码/链接可获得注册奖励。本页会清晰说明，并保持对新手真正有用。"}
            ctaPrimary={"创建账号（已应用推荐码）"}
            ctaSecondary={"阅读快速上手"}
          />

          <div class="card pad">
            <div class="kicker">下一步</div>
            <h2 class="section__title">入门包对比与性能设置</h2>
            <p class="muted">下一步最值得补充的是入门包对比和性能设置指南，这两类内容对新手最有帮助。</p>
          </div>
        </aside>
      </div>
    </section>

    <section class="section">
      <div class="card pad">
        <h2 class="section__title">{t.faqTitle}</h2>
        <div class="faq">
          <details class="faq__item">
            <summary class="faq__q">{t.faq1q}</summary>
            <div class="faq__a"><p>{t.faq1a}</p></div>
          </details>
          <details class="faq__item">
            <summary class="faq__q">{t.faq2q}</summary>
            <div class="faq__a"><p>{t.faq2a}</p></div>
          </details>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>