---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReferralBanner from "../../components/ReferralBanner.astro";
import OnThisPage from "../../components/OnThisPage.astro";
import FaqSchema from "../../components/FaqSchema.astro";
import HowToSchema from "../../components/HowToSchema.astro";

const referralCode = "STAR-FSRJ-5N7Z";
const referralLink = `https://www.robertsspaceindustries.com/enlist?referral=${referralCode}`;

const heroImg = "/assets/img/referral/star-citizen-referral-code-50000-uec-bonus-hero.webp";
const signupFieldImg = "/assets/img/referral/star-citizen-referral-signup-field.webp";

// FAQ content is also used to generate FAQPage JSON-LD for SEO.
const faqItems = [
  {
    q: "What is a Star Citizen referral code?",
    a: "A referral code is part of Star Citizen’s official referral program. New accounts can enter a code during account creation to receive a starter bonus and link the account to a recruiter.",
  },
  {
    q: "What do I get for using a referral code?",
    a: "New accounts typically receive an enlistment bonus credited as starting UEC after the account becomes active. The bonus amount can change during promotions, but the common signup bonus is 50,000 UEC.",
  },
  {
    q: "When should I enter the referral code?",
    a: "The safest option is to enter it during signup. In many cases you can also add it within about 24 hours after creating your account.",
  },
  {
    q: "Can I add a referral code after creating my account?",
    a: "Often yes, but only within a limited window (commonly around 24 hours). After that it usually can’t be applied.",
  },
  {
    q: "Does using a referral code cost money?",
    a: "No. Entering a referral code is free.",
  },
  {
    q: "Does the referral code change starter pack pricing?",
    a: "No. A referral code doesn’t change what you can buy or the price. It only applies a bonus and sets referral attribution.",
  },
  {
    q: "Do I need a referral code to play?",
    a: "No, it’s optional. But if you’re creating a new account, using one is a free upside.",
  },
  {
    q: "Does it work during Free Fly?",
    a: "Yes. You can create your account with a referral code even if you plan to play during Free Fly first. You’ll receive the bonus when the account becomes active.",
  },
  {
    q: "Where do I enter the referral code?",
    a: "During account creation, look for the field labeled “Referral Code (optional)” and paste it before completing signup.",
  },
  {
    q: "How do I confirm the code was applied?",
    a: "During signup you should see a confirmation message. After creation, your account’s referral status typically shows that you were referred.",
  },
  {
    q: "Can I change the referral code later?",
    a: "Usually no. Referral attribution is typically locked once the account is created (or once the limited window closes).",
  },
  {
    q: "Do bonuses stack if I use multiple codes?",
    a: "No. Only one referral code can be applied per account.",
  },
  {
    q: "What are common mistakes?",
    a: "Forgetting to enter the code, missing the time window, or typing it incorrectly. Copy/paste avoids most issues.",
  },
  {
    q: "Will I get banned for using a referral code?",
    a: "No. Using a referral code is an intended part of the official program. Creating extra accounts to refer yourself is not recommended.",
  },
];

const howToJsonLd = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to use a Star Citizen referral code",
  "description": "Step-by-step instructions for entering a Star Citizen referral code during signup to receive the starter bonus.",
  "totalTime": "PT2M",
  "supply": [
    {
      "@type": "HowToSupply",
      "name": "Star Citizen referral code"
    }
  ],
  "tool": [
    {
      "@type": "HowToTool",
      "name": "RSI account creation page"
    }
  ],
  "step": [
    {
      "@type": "HowToStep",
      "name": "Open account creation",
      "text": "Open the official Star Citizen (RSI) account creation page."
    },
    {
      "@type": "HowToStep",
      "name": "Enter the referral code",
      "text": "Enter referral code STAR-FSRJ-5N7Z in the optional referral field."
    },
    {
      "@type": "HowToStep",
      "name": "Create your account",
      "text": "Complete account creation and verify your email."
    },
    {
      "@type": "HowToStep",
      "name": "Activate the account",
      "text": "When you are ready to play outside Free Fly, purchase a starter pack to activate your account."
    },
    {
      "@type": "HowToStep",
      "name": "Receive the bonus",
      "text": "Once the account becomes active, the starter bonus is credited to your account."
    }
  ]
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.a
    }
  }))
};
---

<BaseLayout
  title="Star Citizen Referral Code – Get 50,000 UEC Bonus (Official Guide)"
  description="Use the official Star Citizen referral code to get 50,000 UEC bonus. Step-by-step instructions, 24-hour rule explained, and common mistakes to avoid."
  canonicalPath="/star-citizen-referral-code/"
  stickyCtaLabel="Claim your start bonus"
  stickyCtaHref={referralLink}
  stickyCtaExternal={true}
 activeNav="referral">
  <link slot="head" rel="preload" as="image" href={heroImg} fetchpriority="high" />
  <main>
    <!-- HERO (reduced, no redundant 50,000 repetition) -->
    <section class="hero refHero">
<img
  class="hero__img refHero__img"
  src={heroImg}
  alt="Two Star Citizen pilots introducing the referral system with subtle recruit progression UI"
  loading="eager"
  fetchpriority="high"
  decoding="async"
  width="1536"
  height="1024"
/>
      <div class="hero__overlay refHero__overlay"></div>

      <div class="hero__content">
        <div class="refHero__content">
          <div class="kicker"><span class="dot"></span> Referral Code Guide</div>
          <h1 class="h1">Star Citizen Referral Code</h1>
          <p class="lead">
            This page shows where to enter a referral code, what you receive, and how the recruit reward ladder works.
          </p>

          <div class="btnrow" style="margin-top: 14px;">
            <a class="btn primary" href={referralLink} target="_blank" rel="noopener noreferrer">
              Claim your start bonus
            </a>
          </div>
        </div>
      </div>

      <OnThisPage
        variant="hero"
        title="On this page"
        items={[
          { label: "What it is", href: "#quick-answer" },
          { label: "How to use", href: "#how-to-use" },
          { label: "Is it legit?", href: "#is-it-legit" },
          { label: "What you get", href: "#what-you-get" },
          { label: "24-hour rule", href: "#24-hour-rule" },
          { label: "Free Fly", href: "#free-fly" },
          { label: "Starter packs", href: "#starter-pack" },
          { label: "How it works", href: "#how-it-works" },
          { label: "Common mistakes", href: "#common-mistakes" },
          { label: "FAQ", href: "#faq" },
        ]}
      />
    </section>

    <ReferralBanner
      code={referralCode}
      bonus="50,000 UEC"
      ctaHref={referralLink}
      howItWorksHref="#how-to-use"
      sublineHtml="Enter during signup — or within <b>24 hours</b> after account creation."
      ariaLabel="Referral bonus offer"
    />


    <!-- QUICK ANSWER -->
    <section id="quick-answer" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> What it is</div>
        <h2 class="section__title">Use a referral code to start with an extra 50,000 UEC</h2>
        <p>
          A Star Citizen referral code is a free signup code from the official referral program. Enter it during account creation (or within
          about <b>24 hours</b> after signup) to receive a starter bonus once your account becomes active.
        </p>

        <div style="display:flex; flex-wrap:wrap; gap:10px; align-items:center; margin-top: 12px;">
          <span style="color: rgba(255,255,255,.72); font-weight: 850;">Referral code:</span>
          <span style="display:inline-flex; align-items:center; gap:10px;">
            <button class="refOffer__code js-copyCode" type="button" aria-label="Copy referral code STAR-FSRJ-5N7Z to clipboard" title="Click to copy">STAR-FSRJ-5N7Z</button>
            <span class="refOffer__copied js-copyStatus" role="status" aria-live="polite"></span>
          </span>
        </div>

        <div class="btnrow" style="margin-top: 16px;">
          <a class="btn primary" href={referralLink} target="_blank" rel="noopener noreferrer">Create your account</a>
          <a class="btn secondary" href="#how-to-use">See the step-by-step</a>
        </div>
      </div>
    </section>

<section id="how-to-use" class="section">
      <div class="grid2">
        <div class="card pad">
          <div class="kicker"><span class="dot"></span> Step-by-step</div>
          <h2 class="section__title">How to use the Star Citizen referral code</h2>
          <p>
            The easiest way is to use the referral code <b>during account creation</b>. If you already created an account, you may still be able to
            add it within the limited window — but doing it during signup is always the safest option.
          </p>

          <div class="tableWrap" style="margin-top: 12px;">
            <table class="table table--steps">
              <thead>
                <tr><th>Step</th><th>Action</th></tr>
              </thead>
              <tbody>
                <tr><th>1</th><td>Open the official account creation page.</td></tr>
                <tr><th>2</th><td>Paste referral code <button class="refOffer__code js-copyCode" type="button" data-copy="STAR-FSRJ-5N7Z" aria-label="Copy referral code">STAR-FSRJ-5N7Z</button>.</td></tr>
                <tr><th>3</th><td>Create your account and verify your email.</td></tr>
                <tr><th>4</th><td>When you’re ready to keep playing, purchase a starter pack to activate the account.</td></tr>
                <tr><th>5</th><td>Start playing with the referral bonus credited once the account becomes active.</td></tr>
              </tbody>
            </table>
          </div>

          <div class="btnrow" style="margin-top: 16px;">
            <a class="btn primary" href={referralLink} target="_blank" rel="noopener noreferrer">Create your account</a>
            <a class="btn secondary" href="#24-hour-rule">Understand the 24-hour rule</a>
          </div>
        </div>

        <div class="card pad">
          <h3 style="margin:0 0 8px;">Where to enter the code</h3>
          <p style="margin:0 0 12px;">
            During signup, look for the field labeled <b>“Referral Code (optional)”</b>. Copy/paste the code to avoid typos.
          </p>
          <img src={signupFieldImg} alt="Star Citizen signup form showing the referral code field" loading="lazy" decoding="async" style="width:100%; height:auto; border-radius:14px; border:1px solid rgba(255,255,255,.12);" />
          <div style="display:flex; flex-wrap:wrap; gap:10px; align-items:center; margin-top: 12px;">
            <button class="refOffer__code js-copyCode" type="button" aria-label="Copy referral code STAR-FSRJ-5N7Z to clipboard" title="Click to copy">STAR-FSRJ-5N7Z</button>
            <span class="refOffer__copied js-copyStatus" role="status" aria-live="polite"></span>
          </div>
        </div>
      </div>
    </section>

    <!-- 24 HOUR RULE -->
    



    <!-- TRUST / LEGITIMACY -->
    <section id="is-it-legit" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Trust</div>
        <h2 class="section__title">Is this referral code legitimate?</h2>
        <p>
          Yes. Referral codes are part of Star Citizen’s <b>official</b> referral program. Every player receives a code that can be shared with
          new players during signup. Using a code is optional — it simply adds a starter bonus and links your account to a recruiter.
        </p>

        <div class="grid2" style="margin-top:12px;">
          <div class="card pad">
            <h3 style="margin:0 0 8px;">What a referral code does</h3>
            <ul class="bullets">
              <li><b>Adds a starter bonus</b> once your account becomes active.</li>
              <li><b>Locks referral attribution</b> to one recruiter (one-time setup).</li>
              <li><b>Costs nothing</b> — it doesn’t change pricing or purchases.</li>
            </ul>
          </div>
          <div class="card pad">
            <h3 style="margin:0 0 8px;">What it does not do</h3>
            <ul class="bullets">
              <li><b>No discounts.</b> It doesn’t reduce starter pack prices.</li>
              <li><b>No “special access”.</b> It doesn’t skip progression systems.</li>
              <li><b>No risk.</b> It’s an intended feature of the signup flow.</li>
            </ul>
          </div>
        </div>

        <div class="btnrow" style="margin-top: 16px;">
          <a class="btn secondary" href="/beginner-tips">Read the beginner guide</a>
          <a class="btn secondary" href="/free-fly">Check Free Fly status</a>
        </div>
      </div>
    </section>

    <!-- WHAT YOU GET -->
    <section id="what-you-get" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Value</div>
        <h2 class="section__title">What you get with a referral code</h2>
        <p>
          For new players, the referral bonus is basically a small “starter buffer”. It won’t replace learning the game — but it can make your
          first sessions smoother by giving you extra room for gear, rentals, and inevitable beginner mistakes.
        </p>

        <div class="tableWrap" style="margin-top: 12px;">
          <table class="table">
            <thead>
              <tr>
                <th>Item</th>
                <th>With a referral code</th>
                <th>Without a referral code</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th>Starting credits</th>
                <td><b>+50,000 UEC</b> once your account becomes active</td>
                <td>No bonus</td>
              </tr>
              <tr>
                <th>When to enter</th>
                <td>During signup (best) or within about <b>24 hours</b></td>
                <td>Not applicable</td>
              </tr>
              <tr>
                <th>Cost</th>
                <td>Free</td>
                <td>Free</td>
              </tr>
              <tr>
                <th>Starter pack</th>
                <td>Still required to play outside Free Fly</td>
                <td>Still required to play outside Free Fly</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="grid2" style="margin-top:12px;">
          <div class="card pad">
            <h3 style="margin:0 0 8px;">Good early uses</h3>
            <ul class="bullets">
              <li>Basic equipment (multitool, med supplies, ammo).</li>
              <li>Short-term ship rentals to test different roles.</li>
              <li>Transportation costs and “recovery” after bad runs.</li>
            </ul>
          </div>
          <div class="card pad">
            <h3 style="margin:0 0 8px;">Best practice</h3>
            <ul class="bullets">
              <li><b>Enter the code during signup</b> to avoid missing the window.</li>
              <li><b>Copy/paste</b> to avoid typos.</li>
              <li>Keep your first sessions simple — one mission loop at a time.</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- HOW TO USE -->
    <section id="24-hour-rule" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Timing</div>
        <h2 class="section__title">The 24-hour rule (can you add a code later?)</h2>
        <p>
          Many players sign up first and only realize later that they forgot the referral code. In many cases you can still add it — but only
          within a limited window (commonly around <b>24 hours</b> after account creation). After that, it usually cannot be applied.
        </p>

        <div class="grid2" style="margin-top:12px;">
          <div class="card pad">
            <h3 style="margin:0 0 8px;">Best practice</h3>
            <ul class="bullets">
              <li>Enter the code <b>during signup</b>.</li>
              <li>Use copy/paste to avoid mistakes.</li>
              <li>Don’t wait until after you’re deep into setup.</li>
            </ul>
          </div>
          <div class="card pad">
            <h3 style="margin:0 0 8px;">If you already created an account</h3>
            <ul class="bullets">
              <li>Log in to your RSI account.</li>
              <li>Find the referral settings / referral field (if available).</li>
              <li>Paste the code and save.</li>
            </ul>
            <p style="margin:10px 0 0; color: rgba(255,255,255,.72);">
              If the field is no longer available, the window has likely closed — which is why using it during signup is recommended.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- WHY IT MATTERS -->
    <section id="why-it-matters" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Why it matters</div>
        <h2 class="section__title">Why using a referral code helps new players</h2>
        <p>
          Star Citizen is at its best when you’re learning one thing at a time. The bonus UEC won’t “carry” you — but it gives you breathing room
          for your first loadouts, rentals, and the mistakes everyone makes while figuring out missions, travel, and recovery loops.
        </p>

        <div class="grid2" style="margin-top:12px;">
          <div class="card pad">
            <h3 style="margin:0 0 8px;">Practical benefits</h3>
            <ul class="bullets">
              <li>Buy basic gear without going broke.</li>
              <li>Rent a ship to test a mission loop before committing.</li>
              <li>Recover faster after deaths, crashes, or lost gear.</li>
            </ul>
          </div>
          <div class="card pad">
            <h3 style="margin:0 0 8px;">Make it effortless</h3>
            <p style="margin:0 0 12px; color: rgba(255,255,255,.78);">
              Copy the code, paste it during signup, and you’re done. That’s it.
            </p>
            <div style="display:flex; flex-wrap:wrap; gap:10px; align-items:center;">
              <button class="refOffer__code js-copyCode" type="button" aria-label="Copy referral code STAR-FSRJ-5N7Z to clipboard" title="Click to copy">STAR-FSRJ-5N7Z</button>
              <span class="refOffer__copied js-copyStatus" role="status" aria-live="polite"></span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FREE FLY -->
    <section id="free-fly" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Try before you buy</div>
        <h2 class="section__title">Try Star Citizen during Free Fly (and still use the referral code)</h2>
        <p>
          Not ready to buy a starter pack yet? During official <b>Free Fly</b> events you can try the game without purchasing anything.
          You can still create your account with a referral code first, then decide later whether you want to activate the account with a starter pack.
        </p>

        <div class="btnrow" style="margin-top: 16px;">
          <a class="btn primary" href="/free-fly">Check Free Fly status</a>
          <a class="btn secondary" href={referralLink} target="_blank" rel="noopener noreferrer">Create your account</a>
        </div>
      </div>
    </section>

    <!-- STARTER PACK BRIDGE -->
    <section id="starter-pack" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Next step</div>
        <h2 class="section__title">After signup: you only need a starter pack to keep playing</h2>
        <p>
          Once your account exists (with the referral code applied), the next step is simple: get a starter pack when you’re ready to play outside Free Fly.
          Starter packs include game access plus a starter ship — and the right choice can make your first hours far more enjoyable.
        </p>

        <div class="btnrow" style="margin-top: 16px;">
          <a class="btn primary" href="/starter-pack-guide">Pick a beginner-friendly starter pack</a>
          <a class="btn secondary" href="/beginner-tips">Read beginner tips first</a>
        </div>
      </div>
    </section>

    <!-- HOW IT WORKS -->
    <section id="how-it-works" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Program explained</div>
        <h2 class="section__title">How the Star Citizen referral program works</h2>
        <p>
          Referral codes are part of a larger recruitment program. After your account becomes active, you receive your own referral code.
          When new players sign up with your code and become active, you progress on the recruit reward ladder.
        </p>

        <div class="grid2" style="margin-top:12px;">
          <div class="card pad">
            <h3 style="margin:0 0 8px;">For new players</h3>
            <ul class="bullets">
              <li>Enter a code during signup (or within the allowed window).</li>
              <li>Receive a starter bonus once the account becomes active.</li>
            </ul>
          </div>
          <div class="card pad">
            <h3 style="margin:0 0 8px;">For recruiters</h3>
            <ul class="bullets">
              <li>Earn referral credit when recruits become active.</li>
              <li>Unlock rewards over time as more recruits join.</li>
            </ul>
            <p style="margin:10px 0 0; color: rgba(255,255,255,.72);">
              Reward details can change during promotions, but the core structure stays the same.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- COMMON MISTAKES -->
    <section id="common-mistakes" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Avoid this</div>
        <h2 class="section__title">Common referral code mistakes</h2>

        <div class="tableWrap" style="margin-top: 12px;">
          <table class="table">
            <thead>
              <tr><th>Mistake</th><th>What happens</th><th>Do this instead</th></tr>
            </thead>
            <tbody>
              <tr>
                <th>Signing up first</th>
                <td>You may miss the window to add the code later.</td>
                <td>Enter the code during account creation.</td>
              </tr>
              <tr>
                <th>Typing the code manually</th>
                <td>Typos are common, and the code won’t apply.</td>
                <td>Copy/paste the code.</td>
              </tr>
              <tr>
                <th>Assuming it stacks</th>
                <td>Only one code can be applied per account.</td>
                <td>Pick one code and apply it once.</td>
              </tr>
              <tr>
                <th>Expecting a discount</th>
                <td>A referral code doesn’t change pricing.</td>
                <td>Use it for the free bonus, then choose a starter pack normally.</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div style="display:flex; flex-wrap:wrap; gap:10px; align-items:center; margin-top: 14px;">
          <button class="refOffer__code js-copyCode" type="button" aria-label="Copy referral code STAR-FSRJ-5N7Z to clipboard" title="Click to copy">STAR-FSRJ-5N7Z</button>
          <span class="refOffer__copied js-copyStatus" role="status" aria-live="polite"></span>
          <span style="color: rgba(255,255,255,.72);">Copy it once — paste it during signup.</span>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> FAQ</div>
        <h2 class="section__title">Star Citizen referral code FAQ</h2>

        <div class="faq">
          {faqItems.map((item) => (
            <details class="faq__item">
              <summary class="faq__q">{item.q}</summary>
              <div class="faq__a">{item.a}</div>
            </details>
          ))}
        </div>

        <div class="btnrow" style="margin-top: 16px;">
          <a class="btn primary" href={referralLink} target="_blank" rel="noopener noreferrer">Create your account</a>
          <a class="btn secondary" href="#how-to-use">Back to steps</a>
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section id="start" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Start here</div>
        <h2 class="section__title">Ready to start?</h2>
        <p>
          Copy the referral code, paste it during signup, and you’re set. It’s free, and there’s no downside for new accounts.
        </p>

        <div style="display:flex; flex-wrap:wrap; gap:10px; align-items:center; margin-top: 12px;">
          <button class="refOffer__code js-copyCode" type="button" aria-label="Copy referral code STAR-FSRJ-5N7Z to clipboard" title="Click to copy">STAR-FSRJ-5N7Z</button>
          <span class="refOffer__copied js-copyStatus" role="status" aria-live="polite"></span>
        </div>

        <div class="btnrow" style="margin-top: 16px;">
          <a class="btn primary" href={referralLink} target="_blank" rel="noopener noreferrer">Create your account</a>
          <a class="btn secondary" href="/beginner-tips">Read beginner tips</a>
        </div>
      </div>
    </section>

<!-- SEO: HowTo + FAQPage JSON-LD -->
<HowToSchema json={howToJsonLd} />
<FaqSchema json={faqJsonLd} />
  </main>

