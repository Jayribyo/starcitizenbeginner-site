---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReferralBanner from "../../components/ReferralBanner.astro";
import OnThisPage from "../../components/OnThisPage.astro";
import FaqSchema from "../../components/FaqSchema.astro";
import HowToSchema from "../../components/HowToSchema.astro";
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { REFERRAL_CODE, REFERRAL_LINK, REFERRAL_BONUS_LABEL } from "../../config/site";

const referralCode = REFERRAL_CODE;
const referralLink = REFERRAL_LINK;
const referralBonusLabel = REFERRAL_BONUS_LABEL;

const heroImg = "/assets/img/referral/star-citizen-referral-code-50000-uec-bonus-hero.webp";
const signupFieldImg = "/assets/img/referral/star-citizen-referral-signup-field.webp";

const faqItems = [
  {
    q: "What is a Star Citizen referral code?",
    a: "It is an optional code you add while creating a new RSI account. Use it during signup and the new account gets the standard 50,000 UEC enlistment bonus.",
  },
  {
    q: "What do I get for using a referral code?",
    a: "A brand-new account gets the standard 50,000 UEC signup bonus once the account becomes active.",
  },
  {
    q: "When should I enter the referral code?",
    a: "During signup. That is the version you should plan around.",
  },
  {
    q: "Can I add a referral code after creating my account?",
    a: "Only as a short backup. RSI’s current referral FAQ says brand-new accounts may have a 24-hour grace window after creation, so check immediately instead of planning around it.",
  },
  {
    q: "Does using a referral code cost money?",
    a: "No. It is free to use and does not add anything to your order total.",
  },
  {
    q: "Does the referral code change starter pack pricing?",
    a: "No. It does not change the pack price, taxes, or discounts. It only adds the signup bonus.",
  },
  {
    q: "Does it work during Free Fly?",
    a: "Yes. You can create the account with the referral code first, try Free Fly, and only buy a starter pack later if you want to keep playing.",
  },
  {
    q: "Where do I enter the referral code?",
    a: "On the account creation form, in the field labeled “Referral Code (optional)”, before you finish signup.",
  },
  {
    q: "How do I confirm the code was applied?",
    a: "The easiest check is the referral link, because it opens the signup form with the code already filled in. If you are using the backup window instead, RSI says the entry box appears in your account summary for a short time.",
  },
  {
    q: "Do I need to buy a game package right away?",
    a: "No. You can create the account now, use it for Free Fly when that is available, and only buy a game package later if you decide the game is worth keeping.",
  },
  {
    q: "Is using a Star Citizen referral code legit?",
    a: "Yes. RSI provides a referral field during account creation and documents the standard signup bonus in its official referral FAQ.",
  },
];

const howToJsonLd = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to use a Star Citizen referral code",
  "description": "How to enter a Star Citizen referral code during signup to receive the starter bonus, in a few simple steps.",
  "totalTime": "PT2M",
  "supply": [
    {
      "@type": "HowToSupply",
      "name": "Star Citizen referral code"
    }
  ],
  "tool": [
    {
      "@type": "HowToTool",
      "name": "RSI account creation page"
    }
  ],
  "step": [
    {
      "@type": "HowToStep",
      "name": "Open account creation",
      "text": "Open the official Star Citizen (RSI) account creation page."
    },
    {
      "@type": "HowToStep",
      "name": "Enter the referral code",
      "text": `Enter referral code ${referralCode} in the optional referral field.`
    },
    {
      "@type": "HowToStep",
      "name": "Create your account",
      "text": "Complete account creation and verify your email."
    },
    {
      "@type": "HowToStep",
      "name": "Activate the account",
      "text": "When you are ready to play outside Free Fly, purchase a starter pack to activate your account."
    },
    {
      "@type": "HowToStep",
      "name": "Receive the bonus",
      "text": "Once the account becomes active, the starter bonus is credited to your account."
    }
  ]
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.a
    }
  }))
};
---

<BaseLayout
  title="Star Citizen Referral Code – Where to Enter It and Get the 50,000 UEC Bonus"
  description={`Use referral code ${referralCode} while creating your account to start with 50,000 UEC, see where to enter it, and avoid the common signup mistakes new players make.`}
  canonicalPath="/star-citizen-referral-code/"
  stickyCtaLabel="Claim your start bonus"
  stickyCtaHref={referralLink}
  stickyCtaExternal={true}
  activeNav="referral">
  <link slot="head" rel="preload" as="image" href={heroImg} fetchpriority="high" />
  <main>

    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Starter guides', href: '/#pick-your-path' }, { label: 'Referral code', href: '/star-citizen-referral-code/' }]} />
    <section class="hero refHero">
      <img
        class="hero__img refHero__img"
        src={heroImg}
        alt="Two Star Citizen pilots introducing the referral system with subtle referral program UI"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1536"
        height="1024"
      />
      <div class="hero__overlay refHero__overlay"></div>

      <div class="hero__content">
        <div class="refHero__content">
          <div class="kicker"><span class="dot"></span> Referral Code Guide</div>
          <h1 class="h1">Star Citizen Referral Code</h1>
          <p class="lead">
            Use referral code {referralCode} while you create your account to start with 50,000 UEC, see exactly where it goes, and avoid the easy mistakes that make people miss the bonus.
          </p>

          <div class="btnrow" style="margin-top: 14px;">
            <a class="btn primary" href={referralLink} target="_blank" rel="noopener noreferrer" data-scb-role="referral-signup">
              Claim your start bonus
            </a>
          </div>
        </div>
      </div>

      <OnThisPage
        variant="hero"
        title="On this page"
        items={[
          { label: "Quick answer", href: "#quick-answer" },
          { label: "Official rules", href: "#official-rules" },
          { label: "Where to enter it", href: "#how-to-use" },
          { label: "Already created the account?", href: "#24-hour-rule" },
                    { label: "Common mistakes", href: "#common-mistakes" },
          { label: "Free Fly", href: "#free-fly" },
                    { label: "FAQ", href: "#faq" },
        ]}
      />
    </section>

    <div id="referral-code">
      <ReferralBanner
        code={referralCode}
        bonus={referralBonusLabel}
        ctaHref={referralLink}
        ctaLabel="Claim your start bonus"
        howItWorksHref="#how-to-use"
        sublineHtml="Use it while you create the account. It does not change the price — it simply adds the signup bonus for brand-new accounts."
        ariaLabel="Referral bonus offer"
      />
    </div>

    <section id="quick-answer" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Quick answer</div>
        <h2 class="section__title">Quick answer: add the code during signup, then move on</h2>
        <p>
          Use the referral link or paste the code while you create the account. Finish signup, verify your email, and then move on. The new account gets 50,000 UEC once it becomes active, and the code does not change the price of anything you may buy later.
        </p>

        <div class="decisionGrid" style="margin-top:14px;">
          <div class="decisionCard">
            <div class="decisionCard__kicker">1 · Start</div>
            <div class="decisionCard__title">Click the button and open signup with the code already there</div>
            <p class="decisionCard__body">That gives you the easiest start and removes the need to type the code yourself.</p>
            <div class="btnrow" style="margin-top: 12px;">
              <a class="btn secondary" href={referralLink} target="_blank" rel="noopener noreferrer" data-scb-role="referral-signup">Open signup with code ready</a>
            </div>
          </div>
          <div class="decisionCard">
            <div class="decisionCard__kicker">2 · Create your account</div>
            <div class="decisionCard__title">Enter the required details and finish signup</div>
            <p class="decisionCard__body">Create the account first. If you are still unsure what you may want to buy later, use the <a class="link" href="/how-to-buy-star-citizen/">how-to-buy guide</a>.</p>
          </div>
          <div class="decisionCard">
            <div class="decisionCard__kicker">3 · Buy now or later</div>
            <div class="decisionCard__title">Use the same account for Free Fly or for your starter pack later</div>
            <p class="decisionCard__body">You can buy a game package right away, or use <a class="link" href="/free-fly/">Free Fly</a> first and only choose a <a class="link" href="/star-citizen-starter-packs/">starter pack</a> if you decide the game is worth keeping.</p>
          </div>
        </div>

        <div class="tableWrap" style="margin-top: 14px;">
          <table class="table">
            <thead>
              <tr><th>Your situation</th><th>Best move</th><th>Why it works</th></tr>
            </thead>
            <tbody>
              <tr>
                <th>Brand-new account</th>
                <td>Use the code during signup.</td>
                <td>That is the easiest way to lock in the bonus and stop thinking about it.</td>
              </tr>
              <tr>
                <th>Trying Free Fly first</th>
                <td>Create the account with the code now, then buy later only if the game clicks for you.</td>
                <td>You can set up the account correctly without spending money up front.</td>
              </tr>
              <tr>
                <th>Account created a moment ago</th>
                <td>Check the short backup section below immediately.</td>
                <td>There may be a short recovery window, but it is still better to fix it immediately than to count on it.</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="miniNote" style="margin-top: 12px; display:flex; flex-wrap:wrap; gap:10px; align-items:center;">
          <span class="muted">Copy the code here if you want to paste it manually.</span>
          <button class="refOffer__code js-copyCode" type="button" data-copy-referral={referralCode} aria-label={`Copy referral code ${referralCode} to clipboard`} title="Click to copy">{referralCode}</button>
          <span class="muted">The referral link above is still the easiest option.</span>
        </div>

        <div class="btnrow" style="margin-top: 16px;">
          <a class="btn primary" href={referralLink} target="_blank" rel="noopener noreferrer" data-scb-role="referral-signup">Claim your start bonus</a>
        </div>
      </div>
    </section>

    <section id="official-rules" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Official rules</div>
        <h2 class="section__title">Official rules at a glance</h2>
        <p>
          This is the short official version you actually need: what you get, when to use it, when the short backup window matters, and what the code does not do.
        </p>

        <div class="tableWrap" style="margin-top: 12px;">
          <table class="table">
            <thead>
              <tr><th>Question</th><th>Answer</th><th>Why it matters</th></tr>
            </thead>
            <tbody>
              <tr>
                <th>What do you get?</th>
                <td>50,000 UEC for a brand-new account.</td>
                <td>It is a starter bonus, not a discount and not a replacement for a game package.</td>
              </tr>
              <tr>
                <th>When should you use it?</th>
                <td>During signup.</td>
                <td>That avoids the most common mistake right from the start.</td>
              </tr>
              <tr>
                <th>Can it work later?</th>
                <td>RSI’s current referral FAQ says new accounts have a 24-hour grace window after creation.</td>
                <td>Treat that as backup only. The easy version is still adding the code during signup.</td>
              </tr>
              <tr>
                <th>Does it cost extra?</th>
                <td>No.</td>
                <td>The code is free to use and does not change your total.</td>
              </tr>
              <tr>
                <th>Does it change pack pricing?</th>
                <td>No.</td>
                <td>You still choose your starter pack normally. The code only adds the signup bonus.</td>
              </tr>
              <tr>
                <th>Best way to add it?</th>
                <td>The referral link is the preferred method.</td>
                <td>It opens the signup page with the code already filled in, so there is less to miss.</td>
              </tr>
              <tr>
                <th>Do you need to buy immediately?</th>
                <td>No.</td>
                <td>You can create the account now, use that same account for <a class="link" href="/free-fly/">Free Fly</a> when it is live, and only buy later if you decide the game is worth keeping.</td>
              </tr>
            </tbody>
          </table>
        </div>

        <p class="muted" style="margin-top:12px;">For most people, that is the whole referral step: add the code during signup, create the account, and then choose your next move — try <a class="link" href="/free-fly/">Free Fly</a>, compare packs, or use the full <a class="link" href="/how-to-buy-star-citizen/">how-to-buy guide</a>.</p>
      </div>
    </section>

    <section id="how-to-use" class="section">
      <div class="grid2">
        <div class="card pad">
          <div class="kicker"><span class="dot"></span> Step-by-step</div>
          <h2 class="section__title">Where to paste the referral code</h2>
          <p>
            Open the signup page, find “Referral Code (optional)”, paste the code before you finish creating the account, and then verify your email. After that, the referral part is done.
          </p>

          <div class="tableWrap" style="margin-top: 12px;">
            <table class="table table--steps">
              <thead>
                <tr><th>Step</th><th>Do this</th></tr>
              </thead>
              <tbody>
                <tr><th>1</th><td>Open the official signup page. The referral link is the easiest option because RSI says it prefills the code for you.</td></tr>
                <tr><th>2</th><td>If you are entering it manually, paste {referralCode} into the “Referral Code (optional)” field.</td></tr>
                <tr><th>3</th><td>Finish creating the RSI account and verify your email.</td></tr>
                <tr><th>4</th><td>After that, keep the same account for <a class="link" href="/free-fly/">Free Fly</a> or for the <a class="link" href="/star-citizen-starter-packs/">starter pack</a> you choose later.</td></tr>
              </tbody>
            </table>
          </div>

          <div class="miniNote" style="margin-top: 12px; display:flex; flex-wrap:wrap; gap:10px; align-items:center;">
            <button class="refOffer__code js-copyCode" type="button" data-copy-referral={referralCode} aria-label={`Copy referral code ${referralCode} to clipboard`} title="Click to copy">{referralCode}</button>
            <span class="muted">Copy here if you want to paste it manually during signup.</span>
          </div>
        </div>

        <div class="card pad">
          <h3 class="h3">What the field looks like</h3>
          <p style="margin:0 0 12px;">
            The field is easy to miss if you rush. This screenshot shows the exact place to paste the referral code before you finish creating the account. After that, the full <a class="link" href="/how-to-buy-star-citizen/">how-to-buy guide</a> covers the rest from account to launcher.
          </p>
          <img src={signupFieldImg} alt="Star Citizen signup form showing the referral code field" loading="lazy" decoding="async" style="width:100%; height:auto; border-radius:14px; border:1px solid rgba(255,255,255,.12);" />
          <p style="margin-top: 12px; color: rgba(255,255,255,.78);">
            Once the code is in the field, you can finish signup normally.
          </p>
        </div>
      </div>
    </section>

    <section id="24-hour-rule" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Backup window</div>
        <h2 class="section__title">Already created the account? Check the short backup window right away</h2>
        <p>
          The best version is still simple: add the code while you create the account. If you already finished signup a few minutes ago, check right away whether your new account still shows the short referral entry option RSI mentions in its current FAQ. Treat that as a last chance, not as the normal plan.
        </p>

        <div class="tableWrap" style="margin-top:12px;">
          <table class="table">
            <thead>
              <tr>
                <th>Your situation</th>
                <th>Do this now</th>
                <th>Reality check</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th>You have not created the account yet</th>
                <td>Use the code during signup.</td>
                <td>This avoids the usual “can I still add it later?” problem completely.</td>
              </tr>
              <tr>
                <th>You created the account very recently</th>
                <td>Log in, click your user icon, and check the bottom of the account summary panel for the referral entry box.</td>
                <td>RSI’s current FAQ mentions a 24-hour grace window, but it should feel like a backup, not your main plan.</td>
              </tr>
              <tr>
                <th>The account is older and the field is gone</th>
                <td>Move on and use the account as-is.</td>
                <td>RSI also says support cannot add a code after the account is created, so it is better to stop chasing a fix and simply decide whether to keep testing with <a class="link" href="/free-fly/">Free Fly</a> or continue with the normal <a class="link" href="/how-to-buy-star-citizen/">buying guide</a>.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section id="what-you-get" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Value</div>
        <h2 class="section__title">What the bonus actually helps with</h2>
        <p>
          The extra 50,000 UEC is not a giant shortcut. It mainly helps with the small costs that show up early: basic gear, med supplies, ammo, fuel, repairs, or one early mistake while you are still figuring things out. If you are still deciding whether the game is worth your money, the <a class="link" href="/should-you-buy-star-citizen/">should-you-buy guide</a> is the best next stop.
        </p>

        <div class="tableWrap" style="margin-top: 12px;">
          <table class="table">
            <thead>
              <tr>
                <th>Question</th>
                <th>With the referral code</th>
                <th>Without the referral code</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th>Starting credits</th>
                <td>+50,000 UEC once the account becomes active</td>
                <td>No signup bonus</td>
              </tr>
              <tr>
                <th>What changes</th>
                <td>More room for early gear, medpens, ammo, fuel, repairs, and one or two beginner mistakes</td>
                <td>You have less room for the small early expenses that show up right away</td>
              </tr>

            </tbody>
          </table>
        </div>

        <div class="grid2" style="margin-top:12px;">
          <div class="miniNote">
            <h3 class="h3">Good early uses</h3>
            <ul class="bullets">
              <li>Basic gear, med supplies, ammo, fuel, repairs, and other small early buys.</li>
              <li>A little recovery room after early mistakes or lost equipment.</li>
            </ul>
          </div>
          <div class="miniNote">
            <h3 class="h3">What it does not do</h3>
            <ul class="bullets">
              <li>It does not discount starter packs.</li>
              <li>It does not remove the need for a game package outside Free Fly.</li>
              <li>It does not turn an expensive starter pack into a better deal.</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section id="common-mistakes" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Avoid this</div>
        <h2 class="section__title">Common referral code mistakes</h2>

        <div class="tableWrap" style="margin-top: 12px;">
          <table class="table">
            <thead>
              <tr><th>Mistake</th><th>What happens</th><th>Do this instead</th></tr>
            </thead>
            <tbody>
              <tr>
                <th>Creating the account first and planning to fix it later</th>
                <td>You may lose the easy signup window for the bonus.</td>
                <td>Use the code while you create the account and remove the problem entirely.</td>
              </tr>
              <tr>
                <th>Typing the code manually in a hurry</th>
                <td>A small typo can stop it from applying.</td>
                <td>Use the referral link or copy/paste the code.</td>
              </tr>
              <tr>
                <th>Assuming the code lowers the pack price</th>
                <td>You end up expecting a discount that does not exist.</td>
                <td>Treat it as a free signup bonus, not as a coupon.</td>
              </tr>
              <tr>
                <th>Skipping the code because you want to try Free Fly first</th>
                <td>You miss the easy moment to attach it to the account.</td>
                <td>Create the account with the code first, then use the same account for Free Fly.</td>
              </tr>
              <tr>
                <th>Overthinking the purchase before the account even exists</th>
                <td>The whole signup step feels more complicated than it really is.</td>
                <td>Separate the steps: account first, buying decision after that.</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="miniNote" style="margin-top: 12px; display:flex; flex-wrap:wrap; gap:10px; align-items:center;">
          <button class="refOffer__code js-copyCode" type="button" data-copy-referral={referralCode} aria-label={`Copy referral code ${referralCode} to clipboard`} title="Click to copy">{referralCode}</button>
          <span class="muted">Use the code during signup and you avoid most of these problems automatically.</span>
        </div>
      </div>
    </section>

    <section id="free-fly" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Try before you buy</div>
        <h2 class="section__title">Free Fly is one of the best reasons to create the account now</h2>
        <p>
          You do not need to buy immediately. Many new players are better off creating the account with the code first, testing the game during <a class="link" href="/free-fly/">Free Fly</a> when it is live, and only choosing a starter pack after they know how the game feels on their system. If you want that route, go straight to the <a class="link" href="/free-fly/">Free Fly guide</a>. If that first session feels rough, check the <a class="link" href="/star-citizen-performance-guide/">performance guide</a> before you write the game off.
        </p>

        <div class="grid2" style="margin-top:12px;">
          <div class="miniNote">
            <h3 class="h3">Why this path works well</h3>
            <ul class="bullets">
              <li>You get the referral step done while the account is still brand-new.</li>
              <li>You can test performance and feel before spending money.</li>
              <li>You keep the same account if you decide to buy a package later.</li>
            </ul>
          </div>
          <div class="miniNote">
            <h3 class="h3">Good mindset for Free Fly</h3>
            <ul class="bullets">
              <li>Create the account now.</li>
              <li>Use that same account during <a class="link" href="/free-fly/">Free Fly</a> if it is available.</li>
              <li>Only buy a <a class="link" href="/star-citizen-starter-packs/">starter pack</a> later if the game actually feels worth keeping.</li>
            </ul>
          </div>
        </div>

        <div class="btnrow" style="margin-top: 16px;">
          <a class="btn primary" href="/free-fly/" data-scb-role="internal-free-fly-guide">Check Free Fly status</a>
        </div>
      </div>
    </section>

    <section id="how-it-works" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> What to do next</div>
        <h2 class="section__title">After signup, keep the rest simple</h2>
        <p>
          Once the account exists, keep the rest simple. Verify your email, keep using that same RSI account, and then choose only one next step: try <a class="link" href="/free-fly/">Free Fly</a>, compare a <a class="link" href="/star-citizen-starter-packs/">starter pack</a>, or use the <a class="link" href="/should-you-buy-star-citizen/">should-you-buy guide</a> if you are not ready to spend money yet.
        </p>

        <div class="grid2" style="margin-top:12px;">
          <div class="miniNote">
            <h3 class="h3">If you are not buying yet</h3>
            <ul class="bullets">
              <li>Verify the account email and keep the account ready.</li>
              <li>Use the same account for Free Fly whenever an event is live.</li>
              <li>Come back to <a class="link" href="/star-citizen-starter-packs/">starter packs</a> only if you decide you want to keep playing.</li>
            </ul>
            <div class="btnrow" style="margin-top: 14px;">
              <a class="btn secondary" href="/free-fly/" data-scb-role="internal-free-fly-guide">Check Free Fly status</a>
            </div>
          </div>
          <div class="miniNote">
            <h3 class="h3">If you want to keep playing</h3>
            <ul class="bullets">
              <li>Buy one beginner-friendly game package when you are ready.</li>
              <li>Check My Hangar once so you know the package is attached to the same account.</li>
              <li>Install the launcher, download the game, and start with one simple first session. If performance feels rough right away, use the <a class="link" href="/star-citizen-performance-guide/">performance guide</a> before judging the game too hard.</li>
            </ul>
            <div class="btnrow" style="margin-top: 14px;">
              <a class="btn primary" href="/star-citizen-starter-packs/" data-scb-role="internal-starter-packs-guide">Pick a starter pack</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="next-steps" class="section alt">
      <div class="container">
        <h2 class="h2">Next steps</h2>
        <p class="miniLead">Use these once the referral part is done and you want the clearest next move.</p>
        <ul class="bullets">
          <li><a class="link" href="/free-fly/">Try the game during Free Fly first if you are not ready to buy yet</a></li>
          <li><a class="link" href="/star-citizen-starter-packs/">Compare beginner-friendly starter packs</a></li>
          <li><a class="link" href="/should-you-buy-star-citizen/">Read the should-you-buy guide if you are still unsure</a></li>
          <li><a class="link" href="/star-citizen-performance-guide/">Fix FPS and stutter before your first real impression</a></li>
        </ul>
      </div>
    </section>

    <section id="related-answers" class="section alt">
      <div class="container">
        <h2 class="h2">Related answers</h2>
        <p class="miniLead">These cover the smaller follow-up questions people usually have around the code itself.</p>
        <ul class="bullets">
          <li><a class="link" href="/referral-bonus-checklist/">Referral bonus checklist</a></li>
          <li><a class="link" href="/satellites/where-to-enter-referral-code/">Where to enter the code</a></li>
          <li><a class="link" href="/satellites/can-you-add-referral-code-after-signup/">Can you add it after signup?</a></li>
          <li><a class="link" href="/satellites/referral-code-not-working/">Referral code not working</a></li>
          <li><a class="link" href="/satellites/does-referral-code-change-price/">Does a code change the price?</a></li>
          <li><a class="link" href="/satellites/get-a-star-citizen-referral-code/">Where to get a referral code</a></li>
        </ul>
      </div>
    </section>

    <section id="faq" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> FAQ</div>
        <h2 class="section__title">Star Citizen referral code FAQ</h2>
        <p class="miniLead">These are the short answers most new players still need right before signup, right after they notice the referral field, or while deciding whether to buy later.</p>

        <div class="faq">
          {faqItems.map((item) => (
            <details class="faq__item">
              <summary class="faq__q">{item.q}</summary>
              <div class="faq__a">{item.a}</div>
            </details>
          ))}
        </div>

        <div class="btnrow" style="margin-top: 16px;">
          <a class="btn primary" href={referralLink} target="_blank" rel="noopener noreferrer" data-scb-role="referral-signup">Claim your start bonus</a>
        </div>
      </div>
    </section>

    <section id="start" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Start here</div>
        <h2 class="section__title">Ready to start?</h2>
        <p class="miniLead">You only need one clean signup pass here.</p>
        <p>
          Use the referral link or copy the code, finish signup, and then move on to Free Fly or your buying decision.
        </p>

        <div style="display:flex; flex-wrap:wrap; gap:10px; align-items:center; margin-top: 12px;">
          <button class="refOffer__code js-copyCode" type="button" data-copy-referral={referralCode} aria-label={`Copy referral code ${referralCode} to clipboard`} title="Click to copy">{referralCode}</button>
          <span class="refOffer__copied js-copyStatus" role="status" aria-live="polite"></span>
        </div>

        <div class="btnrow" style="margin-top: 16px;">
          <a class="btn primary" href={referralLink} target="_blank" rel="noopener noreferrer" data-scb-role="referral-signup">Claim your start bonus</a>
        </div>
      </div>
    </section>

    <HowToSchema json={howToJsonLd} />
    <FaqSchema json={faqJsonLd} />
  </main>

