---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import ReferralBanner from "../../components/ReferralBanner.astro";
import OnThisPage from "../../components/OnThisPage.astro";
import FaqSchema from "../../components/FaqSchema.astro";

const referralCode = "STAR-FSRJ-5N7Z";
const referralLink = `https://www.robertsspaceindustries.com/enlist?referral=${referralCode}`;

const heroImg = "/assets/img/referral/star-citizen-referral-code-50000-uec-bonus-hero.webp";
const signupFieldImg = "/assets/img/referral/star-citizen-referral-signup-field.webp";

// FAQ content is also used to generate FAQPage JSON-LD for SEO.
const faqItems = [
  {
    q: "What is a Star Citizen referral code?",
    a: "A referral code is part of Star Citizen’s official recruit / referral program. New accounts can enter a code during account creation to receive an enlistment bonus and link the account to a recruiter.",
  },
  {
    q: "What bonus do you get from a referral code?",
    a: "Most of the time, new accounts get an enlistment bonus credited in UEC after the account becomes active. The advertised amount can change during promotions — this page is built around the commonly advertised 50,000 UEC bonus.",
  },
  {
    q: "When do you receive the bonus UEC?",
    a: "The bonus is usually credited after your account becomes ‘active’ (i.e., after a game package purchase / activation step is completed). It’s not always instant; allow some time after activation.",
  },
  {
    q: "Can I add a referral code after creating my account?",
    a: "Often yes — but only within a limited window. A common rule is: enter it during signup, or within about 24 hours after account creation. After that, it typically can’t be applied.",
  },
  {
    q: "Is the referral code required to play?",
    a: "No. It’s optional. Using one is simply a ‘free upside’ for new accounts because it can add extra starting credits and helps you begin with less friction.",
  },
  {
    q: "Does a referral code cost anything?",
    a: "No. Entering a code is free. The only ‘cost’ is that you must enter it on a brand-new account within the allowed time window.",
  },
  {
    q: "Where do I enter the referral code?",
    a: "During RSI account creation, look for the field labeled ‘Referral Code (optional)’. Paste the code there before you complete signup.",
  },
  {
    q: "Is it better to use a prefilled signup link or type the code manually?",
    a: "A prefilled link reduces typos and ensures the code is applied at the right moment in the signup flow. If you type it manually, double-check the formatting before submitting.",
  },
  {
    q: "What are the most common mistakes?",
    a: "The big ones: signing up first and forgetting the code, missing the time window, typing the code wrong, or assuming you can switch codes later. Treat it as a one-time setup step.",
  },
  {
    q: "Can I change the referral code later?",
    a: "Usually no. Referral attribution is typically locked once the account is created (or once the limited window closes). Pick a code and commit during signup.",
  },
  {
    q: "Do bonuses stack if I use multiple codes?",
    a: "No — you can generally only apply one referral code per account.",
  },
  {
    q: "Does the referral code affect my starter pack price or content?",
    a: "No. A referral code doesn’t change the starter pack you buy. It simply adds an enlistment bonus and sets referral attribution.",
  },
  {
    q: "Does it work during Free Fly?",
    a: "Free Fly periods can be confusing because you can test without buying a starter package. The safe approach: enter the referral code at account creation anyway, then activate the account when you’re ready.",
  },
  {
    q: "How do I confirm the referral code was applied?",
    a: "During signup you should see a confirmation (often ‘Referral code successfully applied’). After the account is created, your account/referral status may show who referred you.",
  },
  {
    q: "What if I don’t see the referral code field?",
    a: "Make sure you’re on the RSI account creation flow (not just logging in). If you’re already signed in, log out and start the create-account process again. Some browsers/extensions can hide form elements — try a clean browser session.",
  },
  {
    q: "What can I do with 50,000 UEC early on?",
    a: "Think of it as an early-game buffer: you can buy basic gear, stock medical supplies/ammo, cover transport costs, rent small ships for testing, and absorb ‘learning mistakes’ without going broke.",
  },
  {
    q: "How does the recruit reward ladder work?",
    a: "After your account is active, you get your own referral code. When new players sign up using your code and become active, you progress on the recruit ladder. Rewards vary and can change over time, but the structure is generally: more active recruits → more rewards.",
  },
  {
    q: "Can I use my own referral code on a new account?",
    a: "Referral programs are intended for recruiting new players. Creating extra accounts just to refer yourself can violate program expectations and is not a recommended path.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.a
    }
  }))
};
---

<BaseLayout
  title="Star Citizen Referral Code – Get 50,000 UEC Bonus (Official Guide)"
  description="Use the official Star Citizen referral code to get 50,000 UEC bonus. Step-by-step instructions, 24-hour rule explained, and common mistakes to avoid."
  canonicalPath="/star-citizen-referral-code/"
>
  <link slot="head" rel="preload" as="image" href={heroImg} fetchpriority="high" />

  <SiteHeader active="referral" />

  <main class="container">
    <!-- HERO (reduced, no redundant 50,000 repetition) -->
    <section class="hero refHero">
<img
  class="hero__img refHero__img"
  src={heroImg}
  alt="Two Star Citizen pilots introducing the referral system with subtle recruit progression UI"
  loading="eager"
  fetchpriority="high"
  decoding="async"
  width="1536"
  height="1024"
/>
      <div class="hero__overlay refHero__overlay"></div>

      <div class="hero__content">
        <div class="refHero__content">
          <div class="kicker"><span class="dot"></span> Referral Code Guide</div>
          <h1 class="h1">Star Citizen Referral Code</h1>
          <p class="lead">
            This page shows where to enter a referral code, what you receive, and how the recruit reward ladder works.
          </p>

          <div class="btnrow">
            <a class="btn primary" href="#how-to-use">How to use it</a>
            <a class="btn secondary" href="#faq">FAQ</a>
          </div>
        </div>
      </div>
    </section>

    <ReferralBanner
      code={referralCode}
      bonus="50,000 UEC"
      ctaHref={referralLink}
      howItWorksHref="#how-to-use"
      sublineHtml="Enter during signup — or within <b>24 hours</b> after account creation."
      ariaLabel="Referral bonus offer"
    />

    <OnThisPage
      title="On this page"
      items={[
        { label: "How to use", href: "#how-to-use" },
        { label: "Quick facts", href: "#quick-facts" },
        { label: "What 50,000 UEC does", href: "#what-50000-uec-does" },
        { label: "24-hour rule", href: "#24-hour-rule" },
        { label: "Recruit ladder", href: "#recruit-ladder" },
        { label: "Common mistakes", href: "#common-mistakes" },
        { label: "FAQ", href: "#faq" },
      ]}
    />

<!-- HOW TO USE -->
    <section id="how-to-use" class="section">
      <div class="grid2">
        <div class="card pad">
          <div class="kicker"><span class="dot"></span> How to use it</div>
          <h2 class="section__title">How to use a Star Citizen referral code (step-by-step)</h2>

          <div class="card pad" style="background: rgba(0,0,0,.18); border-color: rgba(255,255,255,.10); margin-top: 12px;">
            <div style="opacity:.72; font-size:12px; font-weight:900; letter-spacing:.12em; text-transform:uppercase;">
              Referral code
            </div>
            <div style="font-size:22px; font-weight:1000; letter-spacing:.14em; margin-top:6px;">
              {referralCode}
            </div>
            <div style="margin-top:10px;">
              <a class="btn primary" href={referralLink} target="_blank" rel="noopener noreferrer">Use prefilled link</a>
            </div>
            <div style="margin-top:10px; font-size:12px; opacity:.78;">
              Recommended: avoids typos and ensures the code is applied at the right moment.
            </div>
          </div>

          <ol style="margin-top: 14px; padding-left: 18px; color: rgba(255,255,255,.78); line-height: 1.75;">
            <li>Create your RSI account. Start the registration process.</li>
            <li>Enter the referral code in the “Referral Code (optional)” field.</li>
            <li>Finish signup and confirm your account details.</li>
            <li>Activate your account with a starter package purchase.</li>
          </ol>

          <div class="card pad" style="margin-top:14px; background: rgba(0,0,0,.16); border-color: rgba(255,255,255,.10);">
            <b>24-hour window:</b> If you forgot the code at signup, you can often still add it within ~24 hours after creating your account. After that, it can’t be applied.
          </div>
        </div>

        <div class="card pad">
          <div class="kicker"><span class="dot"></span> What it is</div>
          <h2 class="section__title">What is a Star Citizen referral code?</h2>

          <p>
            A referral code is part of Star Citizen’s official recruit program. New accounts can enter a code during account creation to receive an enlistment bonus.
            It’s not a discount coupon and it doesn’t change package pricing.
          </p>

          <p>
            The goal is simple: smoother onboarding for new players, and long-term recruit rewards for the inviter. Once your account is active, you get your own referral code.
          </p>

          <div class="card pad" style="background: rgba(0,0,0,.18); border-color: rgba(255,255,255,.10); margin-top: 12px;">
            <img
  src={signupFieldImg}
  alt="Referral code field during RSI account creation showing a successfully applied code"
  loading="lazy"
  decoding="async"
  width="653"
  height="385"
/>
          </div>
        </div>
      </div>
    </section>

    <!-- SUMMARY -->
    <section id="quick-facts" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Quick facts</div>
        <h2 class="section__title">Referral bonus summary</h2>

        <div style="overflow:auto; border-radius: 14px; border: 1px solid rgba(255,255,255,.12); background: rgba(0,0,0,.18); margin-top: 12px;">
          <table style="width:100%; border-collapse: collapse; min-width: 680px;">
            <thead>
              <tr>
                <th style="padding: 12px; text-align:left; background: rgba(255,255,255,.06);">Item</th>
                <th style="padding: 12px; text-align:left; background: rgba(255,255,255,.06);">Value</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th style="padding: 12px; text-align:left; border-bottom: 1px solid rgba(255,255,255,.10); background: rgba(255,255,255,.03);">Bonus amount</th>
                <td style="padding: 12px; border-bottom: 1px solid rgba(255,255,255,.10);">50,000 UEC</td>
              </tr>
              <tr>
                <th style="padding: 12px; text-align:left; border-bottom: 1px solid rgba(255,255,255,.10); background: rgba(255,255,255,.03);">When to enter</th>
                <td style="padding: 12px; border-bottom: 1px solid rgba(255,255,255,.10);">During signup or within ~24 hours after account creation</td>
              </tr>
              <tr>
                <th style="padding: 12px; text-align:left; border-bottom: 1px solid rgba(255,255,255,.10); background: rgba(255,255,255,.03);">Cost</th>
                <td style="padding: 12px; border-bottom: 1px solid rgba(255,255,255,.10);">Free</td>
              </tr>
              <tr>
                <th style="padding: 12px; text-align:left; background: rgba(255,255,255,.03);">Official program</th>
                <td style="padding: 12px;">Yes (RSI recruit / referral system)</td>
              </tr>
            </tbody>
          </table>
        </div>

        <p style="margin-top:12px; opacity:.78;">
          The biggest mistake is entering too late. If you’re creating a new account anyway, enter the code during signup.
        </p>
      </div>
    </section>

    <!-- WHAT YOU CAN DO -->
    <section id="what-50000-uec-does" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> What you get</div>
        <h2 class="section__title">What can you do with 50,000 UEC?</h2>

        <p>
          50,000 UEC won’t buy a new ship — but it removes early friction. It helps you gear up, stay mission ready, and recover from beginner mistakes without turning your first sessions into a grind.
        </p>

        <div style="overflow:auto; border-radius: 14px; border: 1px solid rgba(255,255,255,.12); background: rgba(0,0,0,.18); margin-top: 12px;">
          <table style="width:100%; border-collapse: collapse; min-width: 820px;">
            <thead>
              <tr>
                <th style="padding: 12px; text-align:left; background: rgba(255,255,255,.06);">Category</th>
                <th style="padding: 12px; text-align:left; background: rgba(255,255,255,.06);">Examples</th>
                <th style="padding: 12px; text-align:left; background: rgba(255,255,255,.06);">Why it matters</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th style="padding: 12px; text-align:left; border-bottom: 1px solid rgba(255,255,255,.10); background: rgba(255,255,255,.03);">Mission readiness</th>
                <td style="padding: 12px; border-bottom: 1px solid rgba(255,255,255,.10);">Armor, med pens, ammo, basic tools</td>
                <td style="padding: 12px; border-bottom: 1px solid rgba(255,255,255,.10);">Lets you attempt early content faster</td>
              </tr>
              <tr>
                <th style="padding: 12px; text-align:left; border-bottom: 1px solid rgba(255,255,255,.10); background: rgba(255,255,255,.03);">Ship operations</th>
                <td style="padding: 12px; border-bottom: 1px solid rgba(255,255,255,.10);">Refuel, rearm, small repairs</td>
                <td style="padding: 12px; border-bottom: 1px solid rgba(255,255,255,.10);">Keeps you from getting stranded early</td>
              </tr>
              <tr>
                <th style="padding: 12px; text-align:left; border-bottom: 1px solid rgba(255,255,255,.10); background: rgba(255,255,255,.03);">Utility tools</th>
                <td style="padding: 12px; border-bottom: 1px solid rgba(255,255,255,.10);">Multi-tool, attachments, basic navigation essentials</td>
                <td style="padding: 12px; border-bottom: 1px solid rgba(255,255,255,.10);">Unlocks smoother gameplay loops</td>
              </tr>
              <tr>
                <th style="padding: 12px; text-align:left; border-bottom: 1px solid rgba(255,255,255,.10); background: rgba(255,255,255,.03);">Mistake buffer</th>
                <td style="padding: 12px; border-bottom: 1px solid rgba(255,255,255,.10);">Respawns, replacing gear, buying essentials “twice”</td>
                <td style="padding: 12px; border-bottom: 1px solid rgba(255,255,255,.10);">Reduces frustration; helps you build momentum</td>
              </tr>
              <tr>
                <th style="padding: 12px; text-align:left; background: rgba(255,255,255,.03);">Testing / rentals</th>
                <td style="padding: 12px;">Short rentals to compare roles</td>
                <td style="padding: 12px;">Helps you choose smarter later</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="card pad" style="margin-top:14px; background: rgba(0,0,0,.16); border-color: rgba(255,255,255,.10);">
          <b>Reality check:</b> Prices, availability, and balance can change over time. The point of the bonus is not “to buy a ship” — it’s to make your first hours smoother: fewer hard stops, fewer “I’m broke again” resets, and faster learning.
        </div>
      </div>
    </section>

    <!-- 24-hour rule -->
    <section id="24-hour-rule" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Timing</div>
        <h2 class="section__title">The 24-hour rule (can you add it later?)</h2>

        <p>
          If you didn’t enter a code during signup, you can often still add one within ~24 hours after creating your RSI account. After that, the code can’t be applied.
        </p>

        <ol style="margin-top: 12px; padding-left: 18px; color: rgba(255,255,255,.78); line-height: 1.75;">
          <li>Log in to your RSI account.</li>
          <li>Open your account settings / summary.</li>
          <li>Locate the referral field (if still within the window).</li>
          <li>Enter <b>{referralCode}</b> and save.</li>
        </ol>

        <div class="miniNote" style="margin-top:14px;">
          <b>Recommendation:</b> Use the code at signup. It’s the cleanest path and avoids edge cases.
        </div>
      </div>
    </section>

    <!-- Recruit ladder -->
    <section id="recruit-ladder" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Recruit rewards</div>
        <h2 class="section__title">How the recruit reward ladder works</h2>

        <p>
          After your account is active, you get your own referral code. When friends sign up using it and become active, your recruit progress advances and unlocks rewards over time.
          The ladder changes occasionally, but the structure is stable: more active recruits → more rewards.
        </p>

        <div style="overflow:auto; border-radius: 14px; border: 1px solid rgba(255,255,255,.12); background: rgba(0,0,0,.18); margin-top: 12px;">
          <table style="width:100%; border-collapse: collapse; min-width: 820px;">
            <thead>
              <tr>
                <th style="padding: 12px; text-align:left; background: rgba(255,255,255,.06);">Tier</th>
                <th style="padding: 12px; text-align:left; background: rgba(255,255,255,.06);">Reward theme</th>
                <th style="padding: 12px; text-align:left; background: rgba(255,255,255,.06);">What to expect</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th style="padding: 12px; text-align:left; border-bottom: 1px solid rgba(255,255,255,.10); background: rgba(255,255,255,.03);">Entry</th>
                <td style="padding: 12px; border-bottom: 1px solid rgba(255,255,255,.10);">Cosmetics / small items</td>
                <td style="padding: 12px; border-bottom: 1px solid rgba(255,255,255,.10);">Starter collectibles and momentum-based goodies</td>
              </tr>
              <tr>
                <th style="padding: 12px; text-align:left; border-bottom: 1px solid rgba(255,255,255,.10); background: rgba(255,255,255,.03);">Mid</th>
                <td style="padding: 12px; border-bottom: 1px solid rgba(255,255,255,.10);">Exclusive collectibles</td>
                <td style="padding: 12px; border-bottom: 1px solid rgba(255,255,255,.10);">More rare items; improves the signal for long-term support</td>
              </tr>
              <tr>
                <th style="padding: 12px; text-align:left; background: rgba(255,255,255,.03);">High</th>
                <td style="padding: 12px;">Major rewards</td>
                <td style="padding: 12px;">Long-term progression; not a fast path, but meaningful over time</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="btnrow" style="margin-top: 14px;">
          <a class="btn primary" href={referralLink} target="_blank" rel="noopener noreferrer">Use {referralCode}</a>
          <a class="btn secondary" href="/">Back to SCB Hub</a>
        </div>
      </div>
    </section>

    <!-- Common mistakes -->
    <section id="common-mistakes" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Avoid mistakes</div>
        <h2 class="section__title">Common referral code mistakes</h2>

        <ul style="color: rgba(255,255,255,.78); line-height: 1.75;">
          <li><b>Waiting too long:</b> you only have signup (or a limited window after account creation).</li>
          <li><b>Typos:</b> use the prefilled link to avoid entering the code incorrectly.</li>
          <li><b>Assuming you can change it later:</b> treat it as a one-time setup step.</li>
          <li><b>Expecting “stacking”:</b> accounts typically link to one recruiter only.</li>
        </ul>
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> FAQ</div>
        <h2 class="section__title">Star Citizen referral code – frequently asked questions</h2>

        <div class="faq">
          {faqItems.map((item) => (
            <details class="faq__item">
              <summary class="faq__q">{item.q}</summary>
              <div class="faq__a">{item.a}</div>
            </details>
          ))}
        </div>

        <div class="btnrow" style="margin-top: 16px;">
          <a class="btn primary" href={referralLink} target="_blank" rel="noopener noreferrer">Create Account (Code prefilled)</a>
          <a class="btn secondary" href="#how-to-use">Back to steps</a>
        </div>
      </div>
    </section>

<!-- SEO: FAQPage JSON-LD -->
<FaqSchema json={faqJsonLd} />

    <footer class="footer">
      <div class="footer__inner">
        <div class="footer__brand">SCB — Unofficial Star Citizen guide.</div>
        <div class="footer__legal">
          Not affiliated with Cloud Imperium Games or Roberts Space Industries. Star Citizen® and related marks are trademarks of their respective owners.
        </div>
      </div>
    </footer>
  </main>

  <style>
    /* Referral hero */
    .refHero__overlay{
      background:
        radial-gradient(900px 420px at 25% 45%, rgba(0,0,0,.08), rgba(0,0,0,.58) 66%),
        linear-gradient(90deg, rgba(7,10,18,.74), rgba(7,10,18,.08));
    }
    .refHero__content{ padding: 22px; }

</style>
</BaseLayout>
