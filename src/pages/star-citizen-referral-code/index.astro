---
import BaseLayout from "../../layouts/BaseLayout.astro";

const referralCode = "STAR-FSRJ-5N7Z";
const referralLink = `https://www.robertsspaceindustries.com/enlist?referral=${referralCode}`;

const heroImg = "/assets/img/referral/star-citizen-referral-code-50000-uec-bonus-hero.webp";
const signupFieldImg = "/assets/img/referral/star-citizen-referral-signup-field.webp";

// FAQ content is also used to generate FAQPage JSON-LD for SEO.
const faqItems = [
  {
    q: "What is a Star Citizen referral code?",
    a: "A referral code is part of Star Citizen’s official recruit / referral program. New accounts can enter a code during account creation to receive an enlistment bonus and link the account to a recruiter.",
  },
  {
    q: "What bonus do you get from a referral code?",
    a: "Most of the time, new accounts get an enlistment bonus credited in UEC after the account becomes active. The advertised amount can change during promotions — this page is built around the commonly advertised 50,000 UEC bonus.",
  },
  {
    q: "When do you receive the bonus UEC?",
    a: "The bonus is usually credited after your account becomes ‘active’ (i.e., after a game package purchase / activation step is completed). It’s not always instant; allow some time after activation.",
  },
  {
    q: "Can I add a referral code after creating my account?",
    a: "Often yes — but only within a limited window. A common rule is: enter it during signup, or within about 24 hours after account creation. After that, it typically can’t be applied.",
  },
  {
    q: "Is the referral code required to play?",
    a: "No. It’s optional. Using one is simply a ‘free upside’ for new accounts because it can add extra starting credits and helps you begin with less friction.",
  },
  {
    q: "Does a referral code cost anything?",
    a: "No. Entering a code is free. The only ‘cost’ is that you must enter it on a brand‑new account within the allowed time window.",
  },
  {
    q: "Where do I enter the referral code?",
    a: "During RSI account creation, look for the field labeled ‘Referral Code (optional)’. Paste the code there before you complete signup.",
  },
  {
    q: "Is it better to use a prefilled signup link or type the code manually?",
    a: "A prefilled link reduces typos and ensures the code is applied at the right moment in the signup flow. If you type it manually, double‑check the formatting before submitting.",
  },
  {
    q: "What are the most common mistakes?",
    a: "The big ones: signing up first and forgetting the code, missing the time window, typing the code wrong, or assuming you can switch codes later. Treat it as a one‑time setup step.",
  },
  {
    q: "Can I change the referral code later?",
    a: "Usually no. Referral attribution is typically locked once the account is created (or once the limited window closes). Pick a code and commit during signup.",
  },
  {
    q: "Do bonuses stack if I use multiple codes?",
    a: "No — you can generally only apply one referral code per account.",
  },
  {
    q: "Does the referral code affect my starter pack price or content?",
    a: "No. A referral code doesn’t change the starter pack you buy. It simply adds an enlistment bonus and sets referral attribution.",
  },
  {
    q: "Does it work during Free Fly?",
    a: "Free Fly periods can be confusing because you can test without buying a starter package. The safe approach: enter the referral code at account creation anyway, then activate the account when you’re ready.",
  },
  {
    q: "How do I confirm the referral code was applied?",
    a: "During signup you should see a confirmation (often ‘Referral code successfully applied’). After the account is created, your account/referral status may show who referred you.",
  },
  {
    q: "What if I don’t see the referral code field?",
    a: "Make sure you’re on the RSI account creation flow (not just logging in). If you’re already signed in, log out and start the create‑account process again. Some browsers/extensions can hide form elements — try a clean browser session.",
  },
  {
    q: "What can I do with 50,000 UEC early on?",
    a: "Think of it as an early‑game buffer: you can buy basic gear, stock medical supplies/ammo, cover transport costs, rent small ships for testing, and absorb ‘learning mistakes’ without going broke.",
  },
  {
    q: "How does the recruit reward ladder work?",
    a: "After your account is active, you get your own referral code. When new players sign up using your code and become active, you progress on the recruit ladder. Rewards vary and can change over time, but the structure is generally: more active recruits → more rewards.",
  },
  {
    q: "Can I use my own referral code on a new account?",
    a: "Referral programs are intended for recruiting new players. Creating extra accounts just to refer yourself can violate program expectations and is not a recommended path.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.a
    }
  }))
};
---

<BaseLayout
  lang="en"
  title="Star Citizen Referral Code – How to Get the 50,000 UEC Bonus"
  description="Use a Star Citizen referral code during account creation and receive the official 50,000 UEC enlistment bonus. Step-by-step guide, 24-hour rule, reward ladder and FAQ explained."
  canonicalPath="/star-citizen-referral-code/"
  ogImage={heroImg}
>
  <!-- Topbar (matches site style; no global CSS change needed) -->
  <header class="topbar">
    <div class="container topbar__inner">
      <a class="brand" href="/" aria-label="SCB Home">
        <img src="/assets/img/global/scb-logo.svg" alt="SCB logo" />
        <span>Star Citizen Beginner</span>
      </a>

      <div class="lang" aria-label="Language switch (placeholder)">
        <span style="opacity:.7;">Lang:</span>
        <a class="active" href="/star-citizen-referral-code/">EN</a>
        <a href="/de/">DE</a>
        <a href="/es/">ES</a>
        <a href="/fr/">FR</a>
        <a href="/ru/">RU</a>
        <a href="/zh/">中文</a>
      </div>
    </div>
  </header>

  <main class="container">
    <!-- HERO (reduced, no redundant 50,000 repetition) -->
    <section class="hero refHero">
      <img
        class="hero__img refHero__img"
        src={heroImg}
        alt="Two Star Citizen pilots introducing the referral system with subtle recruit progression UI"
        loading="eager"
        fetchpriority="high"
      />
      <div class="hero__overlay refHero__overlay"></div>

      <div class="hero__content">
        <div class="refHero__content">
          <h1 class="h1">Star Citizen Referral Code – Get the Official Bonus</h1>
          <p class="lead" style="max-width: 860px;">
            This page shows exactly where to enter a referral code, what you receive, and how the recruit reward ladder works.
            Follow the steps once and you’re set.
          </p>

          <div class="btnrow">
            <a class="btn secondary" href="#how-to-use">How to use it</a>
            <a class="btn secondary" href="#faq">FAQ</a>
          </div>
        </div>

      </div>
    </section>

    <!-- PRIMARY CTA STRIP (gold/bronze; high visibility) -->
    <section class="section" aria-label="Referral bonus callout">
      <div class="refOffer">
        <div class="refOffer__badge" aria-hidden="true">BONUS</div>

        <div class="refOffer__main">
          <div class="refOffer__title">
            Use referral code <span class="refOffer__code">{referralCode}</span> to start with <b>50,000 UEC</b>.
          </div>
          <div class="refOffer__sub">
            Enter during signup — or within <b>24 hours</b> after account creation if you forgot.
          </div>
        </div>

        <div class="refOffer__actions">
          <a class="btn primary" href={referralLink} target="_blank" rel="noopener noreferrer">
            Create Account (Code prefilled)
          </a>
          <a class="refOffer__link" href="#how-to-use">How it works ↓</a>
        </div>
      </div>
    </section>

    <!-- HOW TO USE + WHAT IS (side-by-side) -->
    <section id="how-to-use" class="section">
      <div class="section__grid">
        <div class="card pad">
          <div class="kicker"><span class="dot"></span> How to use it</div>
          <h2 class="section__title">How to use a Star Citizen referral code (step-by-step)</h2>

          <div class="callout">
            <div class="callout__left">
              <div class="callout__label">Referral code</div>
              <div class="callout__code" aria-label={`Referral code ${referralCode}`}>{referralCode}</div>
            </div>
            <div class="callout__right">
              <a class="btn primary" href={referralLink} target="_blank" rel="noopener noreferrer">
                Use prefilled link
              </a>
              <div class="callout__hint">Recommended: prevents typos.</div>
            </div>
          </div>

          <ol class="steps">
            <li><b>Create your RSI account.</b> Start the registration process.</li>
            <li><b>Enter the referral code</b> in the “Referral Code (optional)” field: <span class="inlineCode">{referralCode}</span>.</li>
            <li><b>Finish signup</b> and confirm your account details.</li>
            <li><b>Activate your account</b> with a starter package purchase.</li>
          </ol>

          <div class="miniNote">
            <b>24-hour window:</b> If you forgot the code at signup, you can still add one within <b>24 hours</b> after creating your account.
            After that, it can’t be applied.
          </div>
        </div>

        <div class="card pad">
          <div class="kicker"><span class="dot"></span> What it is</div>
          <h2 class="section__title">What is a Star Citizen referral code?</h2>

          <p class="lead" style="margin-top:0;">
            A referral code is part of Star Citizen’s official recruit program. New accounts can link to an existing account
            during registration to receive an enlistment bonus. It’s not a discount coupon and it doesn’t change package pricing.
          </p>

          <p class="lead" style="margin-top:12px;">
            The goal is simple: smoother onboarding for new players, and long-term recruit rewards for the inviter.
            Once your account is active, you’ll have your own code too.
          </p>

          <div class="imgFrame">
            <img
              src={signupFieldImg}
              alt="Star Citizen signup form showing the referral code field"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- QUICK FACTS -->
    <section class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Quick facts</div>
        <h2 class="section__title">Referral bonus summary</h2>

        <div class="tableWrap" role="region" aria-label="Referral bonus summary table">
          <table class="table">
            <tbody>
              <tr><th>Bonus amount</th><td><b>50,000 UEC</b></td></tr>
              <tr><th>When to enter</th><td>During signup or within <b>24 hours</b> after account creation</td></tr>
              <tr><th>Cost</th><td>Free</td></tr>
              <tr><th>Official program</th><td>Yes (RSI recruit / referral system)</td></tr>
            </tbody>
          </table>
        </div>

        <p class="lead" style="margin-top:12px; max-width: 980px;">
          The biggest mistake is waiting too long. If you’re creating an account now, enter the code during signup.
        </p>
      </div>
    </section>

    <!-- WHAT DO YOU GET (expanded, concrete but update-safe) -->
    <section class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> What you get</div>
        <h2 class="section__title">What can you do with 50,000 UEC?</h2>

        <p class="lead" style="max-width: 980px;">
          50,000 UEC won’t buy a new ship — but it removes early friction. It helps you gear up, stay mission-ready,
          and recover from beginner mistakes without turning your first sessions into a grind.
        </p>

        <div class="tableWrap" role="region" aria-label="What 50,000 UEC can cover early on table" style="margin-top:12px;">
          <table class="table">
            <thead>
              <tr>
                <th>Category</th>
                <th>Examples</th>
                <th>Why it matters</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Mission readiness</td>
                <td>Armor + basic FPS loadout, medpens, ammo, spare utilities</td>
                <td>Less downtime after early deaths; faster learning</td>
              </tr>
              <tr>
                <td>Ship operations</td>
                <td>Refuel, rearm, small repairs, restocks</td>
                <td>Keeps you flying instead of constantly returning broke</td>
              </tr>
              <tr>
                <td>Utility tools</td>
                <td>Multitool + attachments (e.g., tractor beam), essentials for contracts</td>
                <td>Unlocks smoother gameplay loops early</td>
              </tr>
              <tr>
                <td>Starter upgrades</td>
                <td>Small component tweaks (depending on ship and goals)</td>
                <td>Lets you experiment sooner and learn what matters</td>
              </tr>
              <tr>
                <td>Mistake buffer</td>
                <td>Replacing lost gear, re-buying essentials, “oops” moments</td>
                <td>Reduces frustration; helps you build momentum</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="grid-2" style="margin-top:14px;">
          <div class="card soft pad" style="background: rgba(0,0,0,.18);">
            <h3 class="h3" style="margin:0 0 10px;">Concrete early buys (ideas)</h3>
            <ul class="bullets" style="margin:0;">
              <li><b>Basic armor + medpens + ammo</b> so you can run a few FPS missions without constantly re-buying.</li>
              <li><b>Multitool + tractor beam + small utility items</b> that make early looting / hauling smoother.</li>
              <li><b>Ship service costs</b> (repairs, refuel, re-arm) so one messy landing doesn’t end the session.</li>
              <li><b>Starter upgrades</b> like basic components / consumables (where applicable) to reduce friction.</li>
              <li><b>A small buffer</b> for experimentation: try a contract, fail, and still keep going.</li>
            </ul>
          </div>

          <div class="card soft pad" style="background: rgba(0,0,0,.18);">
            <h3 class="h3" style="margin:0 0 10px;">Reality check</h3>
            <p class="muted" style="margin:0;">
              Prices, availability, and balance can change over time. The point of the enlistment bonus isn’t to “buy a big ship” —
              it’s to make your <b>first hours</b> smoother: fewer hard stops, fewer “I’m broke again” resets, and faster learning.
            </p>
          </div>
        </div>

        <p class="lead" style="margin-top:12px; max-width: 980px;">
          The practical value is flexibility: you can try a few loops (delivery, basic contracts, FPS missions) without feeling punished for experimentation.
        </p>
      </div>
    </section>

    <!-- 24 HOUR RULE -->
    <section class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Timing</div>
        <h2 class="section__title">The 24-hour rule (can you add it later?)</h2>

        <p class="lead" style="max-width: 980px;">
          If you didn’t enter a code during signup, you can still add one within <b>24 hours</b> after creating your RSI account.
          After that, the code can’t be applied.
        </p>

        <ol class="steps">
          <li>Log in to your RSI account.</li>
          <li>Open your account settings / summary.</li>
          <li>Locate the referral field (if still within the window).</li>
          <li>Enter <span class="inlineCode">{referralCode}</span> and save.</li>
        </ol>

        <div class="miniNote">
          <b>Recommendation:</b> Use the code at signup. It’s the cleanest path and avoids edge cases.
        </div>
      </div>
    </section>

    <!-- REWARD LADDER -->
    <section class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Recruit rewards</div>
        <h2 class="section__title">How the recruit reward ladder works</h2>

        <p class="lead" style="max-width: 980px;">
          After your account is active, you get your own referral code. When friends sign up using it and become active,
          you earn recruit progress and unlock reward tiers over time. The ladder changes occasionally, but the structure is stable:
          more active recruits → more rewards.
        </p>

        <div class="tableWrap" role="region" aria-label="Recruit reward ladder overview table" style="margin-top:12px;">
          <table class="table">
            <thead>
              <tr>
                <th>Tier</th>
                <th>Reward theme</th>
                <th>What to expect</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Early</td>
                <td>Cosmetics / small items</td>
                <td>Starter collectibles and account-bound goodies</td>
              </tr>
              <tr>
                <td>Mid</td>
                <td>Exclusive collectibles</td>
                <td>More noticeable items that signal long-term community support</td>
              </tr>
              <tr>
                <td>High</td>
                <td>Major rewards</td>
                <td>Long-term progression track for heavy referrers</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="btnrow" style="margin-top: 14px;">
          <a class="btn primary" href={referralLink} target="_blank" rel="noopener noreferrer">Use {referralCode}</a>
          <a class="btn secondary" href="/">Back to SCB Hub</a>
        </div>
      </div>
    </section>

    <!-- COMMON MISTAKES -->
    <section class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Avoid mistakes</div>
        <h2 class="section__title">Common referral code mistakes</h2>

        <ul class="bullets">
          <li><b>Waiting too long:</b> you only have signup or 24 hours after account creation.</li>
          <li><b>Typos:</b> use the prefilled link to avoid entering the code incorrectly.</li>
          <li><b>Assuming you can change it later:</b> treat it as a one-time setup step.</li>
          <li><b>Expecting “stacking”:</b> accounts are typically linked once.</li>
        </ul>
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> FAQ</div>
        <h2 class="section__title">Star Citizen referral code – frequently asked questions</h2>

        <div class="faq">
          {faqItems.map((item) => (
            <details class="faq__item">
              <summary class="faq__q">{item.q}</summary>
              <div class="faq__a">{item.a}</div>
            </details>
          ))}
        </div>

        <div class="btnrow" style="margin-top: 16px;">
          <a class="btn primary" href={referralLink} target="_blank" rel="noopener noreferrer">Create Account (Code prefilled)</a>
          <a class="btn secondary" href="#how-to-use">Back to steps</a>
        </div>
      </div>
    </section>

    <footer class="footer">
      <div class="container">
        <div><b>SCB</b> — Unofficial community guide.</div>
        <div style="margin-top:10px;">
          This site is not endorsed by or affiliated with Cloud Imperium Games or Roberts Space Industries.
          Star Citizen® and related marks are trademarks of their respective owners.
        </div>
      </div>
    </footer>

    <!-- Page-local styles (scoped to this page; won't break Home) -->
    <style>
      .refHero__img { height: 360px; }
      @media (max-width: 720px) { .refHero__img { height: 420px; } }

      .refHero__overlay{
        background:
          radial-gradient(900px 420px at 25% 45%, rgba(0,0,0,.08), rgba(0,0,0,.56) 66%),
          linear-gradient(90deg, rgba(7,10,18,.68), rgba(7,10,18,.10));
      }
      .refHero__content{
        width: min(980px, calc(100% - 32px));
        margin: 0 auto;
        padding: 26px 0;
      }

      .refOffer{
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap:14px;
        padding: 14px;
        border-radius: 16px;
        border: 1px solid rgba(216,168,74,.34);
        background: linear-gradient(180deg, rgba(216,168,74,.16), rgba(216,168,74,.06));
        box-shadow: 0 16px 44px rgba(0,0,0,.45), 0 0 0 1px rgba(216,168,74,.10) inset;
      }
      .refOffer__badge{
        font-size: 11px;
        letter-spacing: .14em;
        font-weight: 900;
        padding: 9px 11px;
        border-radius: 999px;
        text-transform: uppercase;
        color: rgba(255, 236, 195, .96);
        background: rgba(216,168,74,.18);
        border: 1px solid rgba(216,168,74,.35);
        box-shadow: 0 0 22px rgba(216,168,74,.16);
        flex: 0 0 auto;
      }
      .refOffer__main{ min-width:0; }
      .refOffer__title{ font-weight: 750; line-height: 1.25; color: rgba(255,255,255,.95); }
      .refOffer__title b { color: rgba(255, 224, 160, .96); }
      .refOffer__sub{ margin-top: 4px; font-size: 13px; color: rgba(255,255,255,.70); line-height: 1.5; }
      .refOffer__code{
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        font-size: 12px;
        letter-spacing: .08em;
        padding: 6px 10px;
        border-radius: 999px;
        background: rgba(0,0,0,.22);
        border: 1px solid rgba(216,168,74,.28);
        color: rgba(255, 236, 195, .96);
        white-space: nowrap;
      }
      .refOffer__actions{
        display:flex;
        flex-direction:column;
        align-items:flex-end;
        gap: 8px;
        flex: 0 0 auto;
      }
      .refOffer__link{
        color: rgba(255, 224, 160, .92);
        font-weight: 700;
        font-size: 13px;
        border-bottom: 1px solid rgba(255, 224, 160, .35);
        padding-bottom: 2px;
        white-space: nowrap;
      }
      .refOffer__link:hover{
        color: rgba(255, 238, 195, 1);
        border-bottom-color: rgba(255, 238, 195, .75);
      }
      @media (max-width: 720px){
        .refOffer{ flex-direction: column; align-items:flex-start; }
        .refOffer__actions{ width:100%; align-items:flex-start; }
      }

      .section__grid{
        display:grid;
        grid-template-columns: 1.1fr .9fr;
        gap: 14px;
        align-items: start;
      }
      @media (max-width: 920px){
        .section__grid{ grid-template-columns: 1fr; }
      }

      .imgFrame{
        margin-top: 12px;
        border-radius: 14px;
        overflow:hidden;
        border: 1px solid rgba(255,255,255,.12);
        background: rgba(0,0,0,.18);
      }

      .callout{
        margin-top: 12px;
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap: 12px;
        border-radius: 14px;
        padding: 12px;
        background: rgba(255,255,255,.06);
        border: 1px solid rgba(255,255,255,.12);
      }
      @media (max-width: 720px){
        .callout{ flex-direction: column; align-items:flex-start; }
        .callout__right{ width:100%; }
      }
      .callout__label{ font-size: 12px; opacity: .75; letter-spacing: .08em; text-transform: uppercase; }
      .callout__code{
        margin-top: 6px;
        font-size: 18px;
        font-weight: 900;
        letter-spacing: .14em;
        color: rgba(255,255,255,.95);
      }
      .callout__hint{ margin-top: 8px; font-size: 12px; color: rgba(255,255,255,.66); }

      .steps{
        margin: 12px 0 0;
        padding-left: 18px;
        color: var(--muted);
        line-height: 1.75;
      }
      .inlineCode{
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        font-size: 12px;
        padding: 2px 8px;
        border-radius: 999px;
        background: rgba(0,0,0,.22);
        border: 1px solid rgba(255,255,255,.14);
        white-space: nowrap;
      }
      .miniNote{
        margin-top: 14px;
        padding: 12px;
        border-radius: 14px;
        background: rgba(216,168,74,.12);
        border: 1px solid rgba(216,168,74,.22);
        color: rgba(255,255,255,.84);
        line-height: 1.55;
      }

      .tableWrap{
        overflow:auto;
        border-radius: 14px;
        border: 1px solid rgba(255,255,255,.12);
        background: rgba(0,0,0,.18);
      }
      .table{
        width: 100%;
        border-collapse: collapse;
        min-width: 680px;
      }
      .table th, .table td{
        padding: 12px 12px;
        border-bottom: 1px solid rgba(255,255,255,.10);
        text-align: left;
        vertical-align: top;
        color: rgba(255,255,255,.84);
        font-size: 14px;
        line-height: 1.55;
      }
      .table thead th{
        background: rgba(255,255,255,.06);
        color: rgba(255,255,255,.92);
        font-weight: 900;
      }
      .table tbody th{
        width: 220px;
        color: rgba(255,255,255,.92);
        font-weight: 800;
        background: rgba(255,255,255,.03);
      }

      .bullets{
        margin: 12px 0 0;
        padding-left: 18px;
        color: var(--muted);
        line-height: 1.75;
      }

      .faq{ margin-top: 10px; }
      .faq__item{
        border-top: 1px solid rgba(255,255,255,.12);
        padding: 10px 0;
      }
      .faq__q{
        cursor: pointer;
        font-weight: 900;
        list-style: none;
        position: relative;
        padding-right: 26px;
      }
      .faq__q::-webkit-details-marker{ display:none; }
      .faq__q::after{
        content: "+";
        position:absolute;
        right: 0;
        top: 0;
        color: rgba(255,255,255,.78);
        font-weight: 900;
      }
      details[open] > .faq__q::after{ content: "–"; }
      .faq__a{
        margin-top: 8px;
        color: rgba(255,255,255,.78);
        line-height: 1.65;
      }
    </style>
  </main>
</BaseLayout>
