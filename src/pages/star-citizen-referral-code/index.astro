---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReferralBanner from "../../components/ReferralBanner.astro";
import OnThisPage from "../../components/OnThisPage.astro";
import FaqSchema from "../../components/FaqSchema.astro";
import HowToSchema from "../../components/HowToSchema.astro";
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import {
  REFERRAL_CODE,
  REFERRAL_LINK,
  REFERRAL_BONUS_LABEL,
  REFERRAL_BONUS_UEC,
  FLY_FREE_URL,
} from "../../config/site";

const referralCode = REFERRAL_CODE;
const referralLink = REFERRAL_LINK;
const referralBonusLabel = REFERRAL_BONUS_LABEL;
const referralBonusUEC = REFERRAL_BONUS_UEC;

const heroImg = "/assets/img/referral/star-citizen-referral-code-50000-uec-bonus-hero.webp";
const signupFieldImg = "/assets/img/referral/star-citizen-referral-signup-field.webp";

const tocItems = [
  { label: "Quick answer", href: "#quick-answer" },
  { label: "Official rules", href: "#official-rules" },
  { label: "Where to paste it", href: "#how-to-use" },
  { label: "Already created the account?", href: "#already-created" },
  { label: "Common mistakes", href: "#common-mistakes" },
  { label: "Free Fly", href: "#free-fly" },
  { label: "What to do next", href: "#starter-pack" },
  { label: "FAQ", href: "#faq" },
];

const faqItems = [
  {
    q: "What is a Star Citizen referral code?",
    a: "A Star Citizen referral code is a free code from the official referral program. You enter it while creating a brand-new RSI account so that account starts with the new-player bonus.",
  },
  {
    q: `What do I get for using a referral code?`,
    a: `A new account starts with the standard enlistment bonus of ${referralBonusLabel} once the account becomes active. It does not change store pricing or give you a discount.`,
  },
  {
    q: "When should I enter the referral code?",
    a: "Enter it during signup. That is the safe path and the one every new player should plan around.",
  },
  {
    q: "Can I add a referral code after creating my account?",
    a: "Sometimes there is a short backup window after account creation, but you should not rely on that. The right move is still to enter the code during signup.",
  },
  {
    q: "Does a Star Citizen referral code cost money or change the price?",
    a: "No. Using a referral code is free, and it does not lower or increase starter pack pricing. It only adds the signup bonus to a new account.",
  },
  {
    q: "Does it work during Free Fly?",
    a: "Yes. You can create the RSI account with the referral code first, try Free Fly without buying anything, and decide on a starter pack later.",
  },
  {
    q: "Where do I enter the referral code?",
    a: "During RSI account creation, look for the field labeled “Referral Code (optional)” and paste the code before you finish signup.",
  },
  {
    q: "How do I confirm the code was applied?",
    a: "During signup you should see a confirmation that the code was applied. The easiest way to avoid mistakes is to use the referral signup link or copy and paste the code instead of typing it manually.",
  },
];

const howToJsonLd = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: "How to use a Star Citizen referral code",
  description: "How to enter a Star Citizen referral code during signup so a new account starts with the bonus.",
  totalTime: "PT2M",
  supply: [
    {
      "@type": "HowToSupply",
      name: "Star Citizen referral code",
    },
  ],
  tool: [
    {
      "@type": "HowToTool",
      name: "RSI account creation page",
    },
  ],
  step: [
    {
      "@type": "HowToStep",
      name: "Open account creation",
      text: "Open the official RSI account creation page.",
    },
    {
      "@type": "HowToStep",
      name: "Enter the referral code",
      text: `Paste referral code ${referralCode} into the optional referral field.`,
    },
    {
      "@type": "HowToStep",
      name: "Finish signup",
      text: "Complete account creation and verify your email.",
    },
    {
      "@type": "HowToStep",
      name: "Play Free Fly or buy later",
      text: "You can try Free Fly first or buy a starter pack later when you want full access outside Free Fly.",
    },
  ],
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.a,
    },
  })),
};
---

<BaseLayout
  title="Star Citizen Referral Code – Where to Enter It and Get the 50,000 UEC Bonus"
  description={`Use referral code ${referralCode} during account creation to start with ${referralBonusLabel}, see exactly where to enter it, and avoid the signup mistakes that make new players miss the bonus.`}
  canonicalPath="/star-citizen-referral-code/"
  stickyCtaLabel="Claim your start bonus"
  stickyCtaHref={referralLink}
  stickyCtaExternal={true}
  activeNav="referral"
>
  <link slot="head" rel="preload" as="image" href={heroImg} fetchpriority="high" />

  <main>
    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Starter guides', href: '/#pick-your-path' }, { label: 'Referral code', href: '/star-citizen-referral-code/' }]} />

    <section class="hero refHero">
      <img
        class="hero__img refHero__img"
        src={heroImg}
        alt="Two Star Citizen pilots introducing the referral system with subtle referral program UI"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1536"
        height="1024"
      />
      <div class="hero__overlay refHero__overlay"></div>

      <div class="hero__content">
        <div class="refHero__content">
          <div class="kicker"><span class="dot"></span> Referral Code Guide</div>
          <h1 class="h1">Star Citizen Referral Code</h1>
          <p class="lead">
            Use referral code {referralCode} while you create your RSI account so the account starts with {referralBonusLabel}. The safest path is simple: use the prefilled signup link or paste the code before you finish signup.
          </p>

          <div class="btnrow" style="margin-top: 16px;">
            <a class="btn primary" href={referralLink} target="_blank" rel="noopener noreferrer" data-scb-role="referral-signup">
              Claim 50,000 UEC
            </a>
          </div>
        </div>
      </div>

      <OnThisPage variant="hero" title="On this page" items={tocItems} />
    </section>

    <div id="referral-code">
      <ReferralBanner
        code={referralCode}
        bonus={referralBonusLabel}
        ctaLabel="Claim 50,000 UEC"
        ctaHref={referralLink}
        howItWorksHref="#how-to-use"
        sublineHtml="Use the referral signup link if you want the easy option. If you would rather do it manually, copy the code and paste it into the signup field before you finish creating the account."
        ariaLabel="Referral bonus offer"
      />
    </div>

    <section id="quick-answer" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Quick answer</div>
        <h2 class="section__title">Use the code before you finish creating the account</h2>
        <p>
          This page only needs to solve one thing: help you use the referral code correctly the first time. The easiest option is to open the RSI signup page with the code already filled in. If you would rather do it manually, copy the code below and paste it into the <b>“Referral Code (optional)”</b> field while you create the account.
        </p>

        <div class="decisionGrid" style="margin-top:14px;">
          <div class="decisionCard">
            <div class="decisionCard__kicker">Best option</div>
            <div class="decisionCard__title">Use the referral link</div>
            <p class="decisionCard__body">Open the signup page with the code already filled in. That way you can move on without worrying about typos.</p>
          </div>
          <div class="decisionCard">
            <div class="decisionCard__kicker">Manual option</div>
            <div class="decisionCard__title">Copy and paste the code</div>
            <div class="decisionCard__body">
              <p style="margin:0 0 10px;">Copy it here, then paste it into the referral field.</p>
              <button class="refOffer__code js-copyCode" type="button" data-copy-referral={referralCode} aria-label={`Copy referral code ${referralCode} to clipboard`} title="Click to copy">{referralCode}</button>
            </div>
          </div>
          <div class="decisionCard">
            <div class="decisionCard__kicker">Do not do this</div>
            <div class="decisionCard__title">Do not plan on adding it later</div>
            <p class="decisionCard__body">There may be a short backup window after signup, but it is much better to handle the code during account creation.</p>
          </div>
        </div>

        <div class="tableWrap" style="margin-top: 14px;">
          <table class="table">
            <thead>
              <tr><th>Your situation</th><th>Best move</th><th>Why</th></tr>
            </thead>
            <tbody>
              <tr>
                <th>You have not created the account yet</th>
                <td>Use the referral code during signup</td>
                <td>That is the simplest way to get it right the first time.</td>
              </tr>
              <tr>
                <th>You want to try Free Fly first</th>
                <td>Create the account now with the code, buy later if you like the game</td>
                <td>You lock in the bonus path without spending anything.</td>
              </tr>
              <tr>
                <th>You already created the account</th>
                <td>Check immediately whether the account still offers a referral field</td>
                <td>There may be a short backup window, but you should not rely on it.</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="btnrow" style="margin-top: 16px;">
          <a class="btn primary" href={referralLink} target="_blank" rel="noopener noreferrer" data-scb-role="referral-signup">Claim 50,000 UEC</a>
        </div>
      </div>
    </section>

    <section id="official-rules" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Official rules</div>
        <h2 class="section__title">The rules new players actually need to know</h2>
        <p>
          Most of the confusion comes from people mixing up account creation, Free Fly, starter packs, and what happens later. If you are new, the rules below are the ones that actually matter right now.
        </p>

        <div class="tableWrap" style="margin-top:12px;">
          <table class="table">
            <thead>
              <tr>
                <th>Question</th>
                <th>Simple answer</th>
                <th>Why it matters</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th>What do you get?</th>
                <td><b>{referralBonusLabel}</b> for a brand-new account</td>
                <td>The code is worth using if you are creating the account anyway.</td>
              </tr>
              <tr>
                <th>When should you enter it?</th>
                <td><b>During signup</b></td>
                <td>This is the easiest way to avoid missing the bonus.</td>
              </tr>
              <tr>
                <th>Can you add it later?</th>
                <td>Sometimes there is a short <b>24-hour backup window</b></td>
                <td>Good to know about, but not something you should plan around.</td>
              </tr>
              <tr>
                <th>Does it change the price?</th>
                <td>No</td>
                <td>A referral code is not a discount code.</td>
              </tr>
              <tr>
                <th>Do you need to buy a package immediately?</th>
                <td>No</td>
                <td>You can create the account now, use Free Fly if available, and decide on a package later.</td>
              </tr>
              <tr>
                <th>What is still required to play outside Free Fly?</th>
                <td>One <b>game package</b></td>
                <td>The referral code does not replace game access.</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="grid2" style="margin-top:12px;">
          <div class="card pad">
            <h3 style="margin:0 0 8px;">What the code does</h3>
            <ul class="bullets">
              <li>Adds the new-player bonus to a brand-new account.</li>
              <li>Works fine before Free Fly, during Free Fly, or before buying later.</li>
              <li>Keeps the signup decision simple if you use it immediately.</li>
            </ul>
          </div>
          <div class="card pad">
            <h3 style="margin:0 0 8px;">What the code does not do</h3>
            <ul class="bullets">
              <li>It does <b>not</b> reduce starter pack prices.</li>
              <li>It does <b>not</b> replace a game package outside Free Fly.</li>
              <li>It does <b>not</b> need to complicate anything if you use it before finishing signup.</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section id="how-to-use" class="section">
      <div class="grid2">
        <div class="card pad">
          <div class="kicker"><span class="dot"></span> Step-by-step</div>
          <h2 class="section__title">Where to paste the Star Citizen referral code</h2>
          <p>
            If you are doing it manually instead of using the referral signup link, the process is short: open the signup page, paste the code into the referral field, finish account creation, verify your email, and then decide whether you want to try Free Fly or buy a starter pack later.
          </p>

          <div class="tableWrap" style="margin-top: 12px;">
            <table class="table table--steps">
              <thead>
                <tr><th>Step</th><th>Action</th></tr>
              </thead>
              <tbody>
                <tr><th>1</th><td>Open the official RSI account creation page.</td></tr>
                <tr><th>2</th><td>Find the field labeled <b>“Referral Code (optional)”</b>.</td></tr>
                <tr><th>3</th><td>Paste the code instead of typing it manually.</td></tr>
                <tr><th>4</th><td>Finish creating the account and verify your email.</td></tr>
                <tr><th>5</th><td>Use that same account for Free Fly or buy one game package later when you are ready.</td></tr>
              </tbody>
            </table>
          </div>

          <div class="miniNote" style="margin-top:12px; display:flex; flex-wrap:wrap; gap:10px; align-items:center;">
            <button class="refOffer__code js-copyCode" type="button" data-copy-referral={referralCode} aria-label={`Copy referral code ${referralCode} to clipboard`} title="Click to copy">{referralCode}</button>
            <span class="muted">Copy here, then paste it into the referral field during signup.</span>
          </div>

          <div class="btnrow" style="margin-top: 16px;">
            <a class="btn primary" href={referralLink} target="_blank" rel="noopener noreferrer" data-scb-role="referral-signup">Use signup link</a>
          </div>
        </div>

        <div class="card pad">
          <h3 style="margin:0 0 8px;">What the field looks like</h3>
          <p style="margin:0 0 12px;">
            During signup, look for the field labeled <b>“Referral Code (optional)”</b>. This screenshot only exists to show you exactly where that field sits.
          </p>
          <img src={signupFieldImg} alt="Star Citizen signup form showing the referral code field" loading="lazy" decoding="async" style="width:100%; height:auto; border-radius:14px; border:1px solid rgba(255,255,255,.12);" />
          <p style="margin-top: 12px; color: rgba(255,255,255,.78);">
            If you used the referral signup link, the field should already be filled. If you did it manually, paste the code before you submit the form.
          </p>
        </div>
      </div>
    </section>

    <section id="already-created" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Already signed up?</div>
        <h2 class="section__title">If you already created the account, act immediately</h2>
        <p>
          The official support guidance that matters here is simple: the best option is always to enter the code during signup. If you already created the account, check right away whether your account still gives you a short window to add the code. Some support guidance mentions about 24 hours, but that should only be seen as a fallback.
        </p>

        <div class="tableWrap" style="margin-top:12px;">
          <table class="table">
            <thead>
              <tr>
                <th>Your situation</th>
                <th>Do this now</th>
                <th>What not to expect</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th>Account created a few minutes ago</th>
                <td>Check the account area immediately for a referral option.</td>
                <td>Do not assume the window will stay open long.</td>
              </tr>
              <tr>
                <th>No field visible anymore</th>
                <td>Stop chasing workarounds and move on.</td>
                <td>Do not expect support to rescue a missed signup step later.</td>
              </tr>
              <tr>
                <th>You have not created the account yet</th>
                <td>Ignore all of this and just use the code during signup.</td>
                <td>That is the easiest way to avoid this problem completely.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section id="common-mistakes" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Avoid this</div>
        <h2 class="section__title">The mistakes that make people miss the bonus</h2>

        <div class="tableWrap" style="margin-top: 12px;">
          <table class="table">
            <thead>
              <tr><th>Mistake</th><th>What happens</th><th>Do this instead</th></tr>
            </thead>
            <tbody>
              <tr>
                <th>Creating the account first</th>
                <td>You may lose the easy path to add the code.</td>
                <td>Use it during signup.</td>
              </tr>
              <tr>
                <th>Typing the code manually</th>
                <td>A small typo can break the whole step.</td>
                <td>Use the referral link or copy and paste the code.</td>
              </tr>
              <tr>
                <th>Thinking it is a discount code</th>
                <td>You misunderstand what the code actually does.</td>
                <td>Treat it as a free signup bonus, not as store price reduction.</td>
              </tr>
              <tr>
                <th>Buying random ships first</th>
                <td>You overcomplicate a beginner decision.</td>
                <td>Create the account, use the code, then choose one game package only when you are ready.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section id="free-fly" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Try before you buy</div>
        <h2 class="section__title">Yes — the referral code still makes sense if you want Free Fly first</h2>
        <p>
          Free Fly is one of the best entry points if you want to look around before spending money. The simple order is: create the account with the referral code first, try the game during Free Fly, and only buy a starter pack later if you decide the game is for you. That lets you set up the account properly without forcing the buying decision too early.
        </p>

        <div class="grid2" style="margin-top:12px;">
          <div class="card pad">
            <h3 style="margin:0 0 8px;">Best Free Fly sequence</h3>
            <ul class="bullets">
              <li>Create the account now with the referral code.</li>
              <li>Use Free Fly when it is active.</li>
              <li>If you enjoy it, buy one starter pack later on the same account.</li>
            </ul>
          </div>
          <div class="card pad">
            <h3 style="margin:0 0 8px;">Why this path works well</h3>
            <ul class="bullets">
              <li>No rushed spending decision.</li>
              <li>No confusion about whether the code belongs on the account yet.</li>
              <li>No need to make Free Fly and buying happen on the same day.</li>
            </ul>
          </div>
        </div>

        <div class="btnrow" style="margin-top: 16px;">
          <a class="btn primary" href="/free-fly/" data-scb-role="internal-free-fly-guide">See Free Fly guide</a>
          <a class="btn secondary" href={FLY_FREE_URL} target="_blank" rel="noopener noreferrer">Official Free Fly page</a>
        </div>
      </div>
    </section>

    <section id="starter-pack" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> What to do next</div>
        <h2 class="section__title">After signup, one game package is enough</h2>
        <p>
          Once your RSI account exists and your email is verified, the next step is much simpler than the store makes it look: if you want to keep playing outside Free Fly, you need <b>one game package</b>. That already includes game access and a ship. You do not need a large ship, extra ships, or a subscription to begin.
        </p>

        <div class="grid2" style="margin-top:12px;">
          <div class="card pad">
            <h3 style="margin:0 0 8px;">Do this after signup</h3>
            <ul class="bullets">
              <li>Verify the email tied to the new account.</li>
              <li>If Free Fly is active, try the game first if you want.</li>
              <li>If you want permanent access outside Free Fly, buy one game package on that same account.</li>
            </ul>
          </div>
          <div class="card pad">
            <h3 style="margin:0 0 8px;">Do not overcomplicate it</h3>
            <ul class="bullets">
              <li>You do not need a big ship to start well.</li>
              <li>You do not need a subscription to play.</li>
              <li>You do not need to decide everything about the game on day one.</li>
            </ul>
          </div>
        </div>

        <div class="btnrow" style="margin-top: 16px;">
          <a class="btn primary" href="/star-citizen-starter-packs/" data-scb-role="internal-starter-packs-guide">See starter packs</a>
          <a class="btn secondary" href="/should-you-buy-star-citizen/" data-scb-role="internal-buy-guide">Use the buy decision guide</a>
        </div>
      </div>
    </section>

    <section id="next-steps" class="section alt">
      <div class="container">
        <h2 class="h2">Next steps</h2>
        <ul class="bullets">
          <li><a href="/star-citizen-starter-packs/">Pick a starter pack without overbuying</a></li>
          <li><a href="/should-you-buy-star-citizen/">Use the buy decision guide</a></li>
          <li><a href="/free-fly/">Try Star Citizen without buying first</a></li>
          <li><a href="/referral-bonus-checklist/">Use the referral bonus checklist</a></li>
          <li><a href="/satellites/">Browse quick answers</a></li>
        </ul>
      </div>
    </section>

    <section id="related-answers" class="section alt">
      <div class="container">
        <h2 class="h2">Related answers</h2>
        <ul class="bullets">
          <li><a href="/referral-bonus-checklist/">Referral bonus checklist</a></li>
          <li><a href="/satellites/where-to-enter-referral-code/">Where to paste the code</a></li>
          <li><a href="/satellites/can-you-add-referral-code-after-signup/">Can you add it after signup?</a></li>
          <li><a href="/satellites/referral-code-not-working/">Referral code not working</a></li>
          <li><a href="/satellites/does-referral-code-change-price/">Does a code change the price?</a></li>
          <li><a href="/satellites/get-a-star-citizen-referral-code/">How to get a referral code</a></li>
        </ul>
      </div>
    </section>

    <section id="faq" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> FAQ</div>
        <h2 class="section__title">Star Citizen referral code FAQ</h2>

        <div class="faq">
          {faqItems.map((item) => (
            <details class="faq__item">
              <summary class="faq__q">{item.q}</summary>
              <div class="faq__a">{item.a}</div>
            </details>
          ))}
        </div>

        <div class="btnrow" style="margin-top: 16px;">
          <a class="btn primary" href={referralLink} target="_blank" rel="noopener noreferrer" data-scb-role="referral-signup">Create account</a>
        </div>
      </div>
    </section>

    <section id="start" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Start here</div>
        <h2 class="section__title">Ready to create the account correctly?</h2>
        <p>
          Keep the signup simple. Open the referral signup link, or copy the code and paste it during account creation. That is all most new players need to do.
        </p>

        <div style="display:flex; flex-wrap:wrap; gap:10px; align-items:center; margin-top: 12px;">
          <button class="refOffer__code js-copyCode" type="button" data-copy-referral={referralCode} aria-label={`Copy referral code ${referralCode} to clipboard`} title="Click to copy">{referralCode}</button>
          <span class="refOffer__copied js-copyStatus" role="status" aria-live="polite"></span>
          <span class="muted">Paste it into the referral field before you finish signup.</span>
        </div>

        <div class="btnrow" style="margin-top: 16px;">
          <a class="btn primary" href={referralLink} target="_blank" rel="noopener noreferrer" data-scb-role="referral-signup">Start signup</a>
        </div>
      </div>
    </section>

    <HowToSchema json={howToJsonLd} />
    <FaqSchema json={faqJsonLd} />
  </main>

  <style>
    .refHero__overlay{
      background:
        radial-gradient(900px 420px at 25% 45%, rgba(0,0,0,.08), rgba(0,0,0,.58) 66%),
        linear-gradient(90deg, rgba(7,10,18,.74), rgba(7,10,18,.08));
    }

    .refHero__content{
