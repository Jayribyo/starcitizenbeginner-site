---
import BaseLayout from "../../layouts/BaseLayout.astro";

const referralCode = "STAR-FSRJ-5N7Z";
const referralLink = `https://www.robertsspaceindustries.com/enlist?referral=${referralCode}`;

// NOTE: In your uploaded repo, the hero file is named "...5000...". If you renamed it to 50000,
// just update this path.
const heroImg = "/assets/img/referral/star-citizen-referral-code-50000-uec-bonus-hero.webp";
const signupFieldImg = "/assets/img/referral/star-citizen-referral-signup-field.webp";
---

<BaseLayout
  lang="en"
  title="Star Citizen Referral Code – 50,000 UEC Bonus Guide"
  description="Learn how the Star Citizen referral code works, how to claim the 50,000 UEC bonus, when to enter it (signup or within 24 hours), and how the recruit reward system works."
  canonicalPath="/star-citizen-referral-code/"
  ogImage={heroImg}
>
  <!-- Topbar (keine Änderung an global.css nötig) -->
  <header class="topbar">
    <div class="container topbar__inner">
      <a class="brand" href="/" aria-label="SCB Home">
        <img src="/assets/img/global/scb-logo.svg" alt="SCB logo" />
        <span>Star Citizen Beginner</span>
      </a>

      <div class="lang" aria-label="Language switch (placeholder)">
        <span style="opacity:.7;">Lang:</span>
        <a class="active" href="/star-citizen-referral-code/">EN</a>
        <a href="/de/">DE</a>
        <a href="/es/">ES</a>
        <a href="/fr/">FR</a>
        <a href="/ru/">RU</a>
        <a href="/zh/">中文</a>
      </div>
    </div>
  </header>

  <main class="container">
    <!-- HERO -->
    <section class="hero refHero">
      <img
        class="hero__img refHero__img"
        src={heroImg}
        alt="Two Star Citizen pilots in a hangar introducing the referral system with subtle recruit progression UI"
        loading="eager"
        fetchpriority="high"
      />
      <div class="hero__overlay refHero__overlay"></div>

      <div class="hero__content">
        <div class="refHero__content">
          <h1 class="h1">Star Citizen Referral Code – Complete Guide to the 50,000 UEC Bonus</h1>
          <p class="lead" style="max-width: 820px;">
            If you’re about to create an RSI account, a referral code is the cleanest “free win”:
            you start with <b style="color:rgba(255,255,255,.95);">50,000 bonus UEC</b> and you lose nothing.
            This page explains how it works, exactly when to enter it, and what the recruit reward ladder is.
          </p>

          <!-- CTA row: keep it minimal in hero, primary CTA lives in the bar below -->
          <div class="btnrow">
            <a class="btn secondary" href="#how-to-use">How to use it</a>
            <a class="btn secondary" href="#faq">FAQ</a>
          </div>
        </div>
      </div>
    </section>

    <!-- PRIMARY CTA STRIP (premium, high visibility, not spammy) -->
    <section class="section" aria-label="Referral bonus callout">
      <div class="refOffer">
        <div class="refOffer__badge" aria-hidden="true">BONUS</div>

        <div class="refOffer__main">
          <div class="refOffer__title">
            Use referral code <span class="refOffer__code">{referralCode}</span> and start with <b>50,000 UEC</b>.
          </div>
          <div class="refOffer__sub">
            Best practice: enter it during signup. If you forgot, you can still add a code within <b>24 hours</b>.
          </div>
        </div>

        <div class="refOffer__actions">
          <a class="btn primary" href={referralLink} target="_blank" rel="noopener noreferrer">
            Create Account (Code prefilled)
          </a>
          <a class="refOffer__link" href="#how-to-use">How it works ↓</a>
        </div>
      </div>
    </section>

    <!-- HOW TO USE (first, because that's the dominant intent) -->
    <section id="how-to-use" class="section">
      <div class="section__grid">
        <div class="card pad">
          <div class="kicker"><span class="dot"></span> How to use it</div>
          <h2 class="section__title">How to use a Star Citizen referral code (step-by-step)</h2>

          <div class="callout">
            <div class="callout__left">
              <div class="callout__label">Referral code</div>
              <div class="callout__code" aria-label={`Referral code ${referralCode}`}>{referralCode}</div>
            </div>
            <div class="callout__right">
              <a class="btn primary" href={referralLink} target="_blank" rel="noopener noreferrer">
                Use prefilled link
              </a>
              <div class="callout__hint">Recommended: it prevents typos.</div>
            </div>
          </div>

          <ol class="steps">
            <li>
              <b>Create your RSI account.</b> Start on the official enlist page (the button above opens it with the code already filled in).
            </li>
            <li>
              <b>Enter the referral code</b> in the “Referral Code (optional)” field:
              <span class="inlineCode">{referralCode}</span>.
            </li>
            <li>
              <b>Finish registration</b> and confirm your account details.
            </li>
            <li>
              <b>Activate your account with a starter package.</b> Your bonus is tied to the account once it’s active.
            </li>
          </ol>

          <div class="miniNote">
            <b>Forgot the code?</b> You can still add one within <b>24 hours</b> after creating your account.
            After that, it can’t be applied.
          </div>

          <div class="btnrow" style="margin-top: 14px;">
            <a class="btn secondary" href="/starter-pack/">Starter Pack Guide</a>
            <a class="btn secondary" href="/first-2-hours/">First 2 Hours Guide</a>
          </div>
        </div>

        <div class="card pad">
          <div class="kicker"><span class="dot"></span> Where to enter it</div>
          <h2 class="section__title">Find the referral code field during signup</h2>
          <p class="lead" style="margin-top:0;">
            During account creation, look for the “Referral Code (optional)” input. Paste the code exactly as shown.
          </p>

          <div class="imgFrame">
            <img
              src={signupFieldImg}
              alt="Star Citizen signup page showing the referral code field during account creation"
              loading="lazy"
            />
          </div>

          <p class="lead" style="margin-top:12px;">
            Tip: using the prefilled link reduces errors and makes the process one click.
          </p>
        </div>
      </div>
    </section>

    <!-- QUICK FACTS (snippet-friendly) -->
    <section class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Quick facts</div>
        <h2 class="section__title">Referral bonus summary</h2>

        <div class="tableWrap" role="region" aria-label="Referral bonus summary table">
          <table class="table">
            <tbody>
              <tr>
                <th>Bonus amount</th>
                <td><b>50,000 UEC</b></td>
              </tr>
              <tr>
                <th>When to enter</th>
                <td>During signup or within <b>24 hours</b> after account creation</td>
              </tr>
              <tr>
                <th>Cost</th>
                <td>Free (no surcharge, no subscription requirement)</td>
              </tr>
              <tr>
                <th>Official program</th>
                <td>Yes (RSI Recruit / Referral Program)</td>
              </tr>
              <tr>
                <th>Best practice</th>
                <td>Use the prefilled enlist link to avoid typos</td>
              </tr>
            </tbody>
          </table>
        </div>

        <p class="lead" style="margin-top:12px;">
          The goal is simple: reduce early friction for new pilots while rewarding community referrals over time.
        </p>
      </div>
    </section>

    <!-- WHAT IS A REFERRAL CODE -->
    <section class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Basics</div>
        <h2 class="section__title">What is a Star Citizen referral code?</h2>

        <p class="lead" style="max-width: 980px;">
          A Star Citizen referral code is part of RSI’s official recruit system. A new player can enter a code during
          account creation to receive a starting bonus of in-game credits. The person who shared the code earns progress
          in the recruit reward ladder when their recruit becomes an active player.
        </p>

        <p class="lead" style="max-width: 980px; margin-top: 12px;">
          Importantly, a referral code is not a discount coupon and it does not change the price of the game.
          It’s an onboarding bonus designed to help new players start smoother.
        </p>
      </div>
    </section>

    <!-- WHAT YOU GET + WHAT 50k MEANS -->
    <section class="section">
      <div class="section__grid">
        <div class="card pad">
          <div class="kicker"><span class="dot"></span> What you get</div>
          <h2 class="section__title">What do you get for using a referral code?</h2>

          <p class="lead">
            The direct benefit is simple: <b>50,000 UEC</b> credited as a starting bonus.
            UEC is the in-game currency used for equipment, ship supplies, and early upgrades.
          </p>

          <h3 class="subhead">What 50,000 UEC can realistically cover early on</h3>

          <div class="tableWrap" role="region" aria-label="What 50,000 UEC can cover table">
            <table class="table">
              <thead>
                <tr>
                  <th>Use case</th>
                  <th>Why it helps</th>
                  <th>Typical cost range</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>FPS starter kit</td>
                  <td>Armor + a few essentials so early missions feel less punishing</td>
                  <td>10k–25k UEC</td>
                </tr>
                <tr>
                  <td>Ship basics</td>
                  <td>Fuel, repairs, consumables, small component improvements</td>
                  <td>5k–20k UEC</td>
                </tr>
                <tr>
                  <td>Early upgrades</td>
                  <td>Helps you test different play loops faster</td>
                  <td>15k–40k UEC</td>
                </tr>
              </tbody>
            </table>
          </div>

          <p class="lead" style="margin-top: 12px;">
            The bonus doesn’t “skip” progression — it removes some early friction and lets you make fewer costly mistakes.
          </p>
        </div>

        <div class="card pad">
          <div class="kicker"><span class="dot"></span> Worth it?</div>
          <h2 class="section__title">Is it worth using a referral code?</h2>

          <p class="lead">
            For most new players: yes. There’s no downside, no additional cost, and no commitment.
            It’s simply better to start with extra UEC than to start at zero.
          </p>

          <div class="decision">
            <div class="decision__row">
              <div class="decision__tag">Best fit</div>
              <div class="decision__text">
                You’re new and want a smoother first session (gear, supplies, upgrades without grinding immediately).
              </div>
            </div>
            <div class="decision__row">
              <div class="decision__tag">Good to know</div>
              <div class="decision__text">
                The biggest “mistake” is waiting too long — enter the code during signup or within 24 hours.
              </div>
            </div>
            <div class="decision__row">
              <div class="decision__tag">No downside</div>
              <div class="decision__text">
                A referral code doesn’t change your package price and doesn’t lock you into anything.
              </div>
            </div>
          </div>

          <div class="btnrow" style="margin-top: 14px;">
            <a class="btn primary" href={referralLink} target="_blank" rel="noopener noreferrer">
              Create Account (Code prefilled)
            </a>
            <a class="btn secondary" href="/">Back to SCB Hub</a>
          </div>
        </div>
      </div>
    </section>

    <!-- 24-HOUR RULE -->
    <section class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Timing</div>
        <h2 class="section__title">The 24-hour rule (can you add it later?)</h2>

        <p class="lead" style="max-width: 980px;">
          If you didn’t enter a referral code during registration, you still have a grace window:
          <b>you can add a referral code within 24 hours after creating your RSI account.</b>
          After that, the code can’t be applied to the account.
        </p>

        <h3 class="subhead">How to add a referral code after signup (within 24 hours)</h3>
        <ol class="steps">
          <li>Log in to your RSI account.</li>
          <li>Open your account settings / account summary panel (via your user icon).</li>
          <li>Locate the referral code entry field in the account summary.</li>
          <li>Enter <span class="inlineCode">{referralCode}</span> and save.</li>
        </ol>

        <div class="miniNote">
          <b>Recommendation:</b> Use the code during signup whenever possible. It’s cleaner and avoids any delays or confusion.
        </div>
      </div>
    </section>

    <!-- REWARD LADDER -->
    <section class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Recruit rewards</div>
        <h2 class="section__title">How the recruit reward ladder works</h2>

        <p class="lead" style="max-width: 980px;">
          The referral program isn’t only about the new-player bonus. It also includes a reward ladder for players who
          invite others. When your recruits become active players, you earn recruitment points that unlock ladder rewards.
          These rewards can change over time, but the structure stays consistent: more active recruits → more rewards.
        </p>

        <div class="tableWrap" role="region" aria-label="Recruit reward ladder overview table">
          <table class="table">
            <thead>
              <tr>
                <th>Recruits / Points</th>
                <th>Reward theme</th>
                <th>What it means</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Early tiers</td>
                <td>Cosmetics + gear</td>
                <td>Small quality-of-life rewards and collectible items</td>
              </tr>
              <tr>
                <td>Mid tiers</td>
                <td>Exclusive collectibles</td>
                <td>Unique items that signal long-term community support</td>
              </tr>
              <tr>
                <td>High tiers</td>
                <td>Major rewards</td>
                <td>Long-term progression track for heavy referrers</td>
              </tr>
            </tbody>
          </table>
        </div>

        <p class="lead" style="margin-top: 12px; max-width: 980px;">
          If you’re new, you can ignore the ladder at first. The immediate value is the <b>50,000 UEC</b> signup bonus.
          Later, if you enjoy the game, you’ll naturally understand the ladder and can share your own code with friends.
        </p>
      </div>
    </section>

    <!-- COMMON MISTAKES -->
    <section class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Avoid mistakes</div>
        <h2 class="section__title">Common referral code mistakes (and how to avoid them)</h2>

        <ul class="bullets">
          <li><b>Waiting too long:</b> you only have signup or 24 hours after account creation.</li>
          <li><b>Typos:</b> use the prefilled link to avoid entering the code incorrectly.</li>
          <li><b>Assuming you can change it later:</b> once associated, it typically can’t be changed.</li>
          <li><b>Thinking codes stack:</b> one account can only be linked once.</li>
        </ul>

        <div class="btnrow" style="margin-top: 14px;">
          <a class="btn primary" href={referralLink} target="_blank" rel="noopener noreferrer">
            Use {referralCode}
          </a>
          <a class="btn secondary" href="/beginner-tips/">Beginner Tips</a>
        </div>
      </div>
    </section>

    <!-- FAQ (Accordion) -->
    <section id="faq" class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> FAQ</div>
        <h2 class="section__title">Star Citizen referral code – frequently asked questions</h2>
        <p class="lead" style="max-width: 980px;">
          These are the questions that most often decide whether people use a code correctly — especially the timing rules.
        </p>

        <div class="faq">
          <details class="faq__item">
            <summary class="faq__q">Do all referral codes give the same 50,000 UEC bonus?</summary>
            <div class="faq__a">
              Yes. Any valid referral code provides the same enlistment bonus for new accounts. The difference is only
              which account receives the recruit credit on the ladder.
            </div>
          </details>

          <details class="faq__item">
            <summary class="faq__q">When do I receive the 50,000 UEC?</summary>
            <div class="faq__a">
              The bonus is linked to your account once the referral code is applied correctly (signup or within 24 hours).
              Timing of visibility can vary, but the key is applying the code within the allowed window.
            </div>
          </details>

          <details class="faq__item">
            <summary class="faq__q">Can I add a referral code after creating my account?</summary>
            <div class="faq__a">
              Yes, but only within <b>24 hours</b> after account creation. After that, it can’t be added.
              If you’re still at signup, it’s best to enter it immediately.
            </div>
          </details>

          <details class="faq__item">
            <summary class="faq__q">Can I change the referral code later?</summary>
            <div class="faq__a">
              Generally no. Once your account is associated through a referral code, it’s not meant to be changed.
              Treat it as a one-time setup step.
            </div>
          </details>

          <details class="faq__item">
            <summary class="faq__q">Does using a referral code cost anything?</summary>
            <div class="faq__a">
              No. It doesn’t increase package price, and it doesn’t require a subscription. It’s a free onboarding bonus.
            </div>
          </details>

          <details class="faq__item">
            <summary class="faq__q">Does the referral code act like a discount coupon?</summary>
            <div class="faq__a">
              No. It doesn’t discount the game package. It gives you additional in-game credits (UEC) as a starting bonus.
            </div>
          </details>

          <details class="faq__item">
            <summary class="faq__q">Do I need to buy a starter pack to get the bonus?</summary>
            <div class="faq__a">
              To fully activate your account for the Persistent Universe, you’ll need a starter package.
              Applying the referral code at signup is still the correct first step.
            </div>
          </details>

          <details class="faq__item">
            <summary class="faq__q">Does the bonus expire?</summary>
            <div class="faq__a">
              The bonus is tied to your account once applied. The critical limitation is the <b>time window</b> to apply
              the code (signup or within 24 hours).
            </div>
          </details>

          <details class="faq__item">
            <summary class="faq__q">Is this pay-to-win?</summary>
            <div class="faq__a">
              No. 50,000 UEC is a helpful head start, not a permanent advantage. You still progress by learning systems,
              flying contracts, and building experience.
            </div>
          </details>

          <details class="faq__item">
            <summary class="faq__q">Can I use my own referral code?</summary>
            <div class="faq__a">
              The program is designed to link a new account to an existing account. Most players simply use a code from a
              friend (or a guide like this) during signup.
            </div>
          </details>

          <details class="faq__item">
            <summary class="faq__q">What if I typed the code wrong?</summary>
            <div class="faq__a">
              If you’re still within the allowed window, correct it as soon as possible. The safest path is using the
              prefilled enlist link to avoid typos entirely.
            </div>
          </details>

          <details class="faq__item">
            <summary class="faq__q">Does it work during Free Fly events?</summary>
            <div class="faq__a">
              You can create an account at any time and apply a referral code in the normal way. To play long-term and fully
              activate your account, you’ll eventually need a game package.
            </div>
          </details>

          <details class="faq__item">
            <summary class="faq__q">Do referral bonuses stack?</summary>
            <div class="faq__a">
              No. An account can only be associated once. You can’t apply multiple referral codes to the same account.
            </div>
          </details>

          <details class="faq__item">
            <summary class="faq__q">Is the referral program official?</summary>
            <div class="faq__a">
              Yes. It’s part of RSI’s official recruit/referral system. This page is an unofficial guide explaining the process.
            </div>
          </details>

          <details class="faq__item">
            <summary class="faq__q">What should I do right after signup?</summary>
            <div class="faq__a">
              If you’re new, follow a clean onboarding path: choose a starter pack, learn a simple first mission loop, and
              optimize your settings. SCB’s guides are designed for exactly that.
            </div>
          </details>
        </div>

        <div class="btnrow" style="margin-top: 16px;">
          <a class="btn primary" href={referralLink} target="_blank" rel="noopener noreferrer">
            Create Account (Code prefilled)
          </a>
          <a class="btn secondary" href="/">Go to SCB Hub</a>
        </div>
      </div>
    </section>

    <!-- INTERNAL LINKS -->
    <section class="section">
      <div class="card pad">
        <div class="kicker"><span class="dot"></span> Next steps</div>
        <h2 class="section__title">Start smart after signup</h2>
        <p class="lead" style="max-width: 980px;">
          Referral done? Now make your first sessions smooth with a structured path:
        </p>

        <div class="linkGrid">
          <a class="linkCard" href="/first-2-hours/">
            <div class="linkCard__title">First 2 Hours</div>
            <div class="linkCard__desc">A clean starter loop for your first missions and credits.</div>
          </a>
          <a class="linkCard" href="/starter-pack/">
            <div class="linkCard__title">Starter Pack Guide</div>
            <div class="linkCard__desc">Pick the right pack and avoid buyer’s regret.</div>
          </a>
          <a class="linkCard" href="/performance-settings/">
            <div class="linkCard__title">Performance & FPS</div>
            <div class="linkCard__desc">Settings that reduce friction and improve feel.</div>
          </a>
          <a class="linkCard" href="/make-money-fast/">
            <div class="linkCard__title">Make Money Fast</div>
            <div class="linkCard__desc">Early aUEC routes and safe income loops.</div>
          </a>
        </div>
      </div>
    </section>

    <!-- FOOTER (no referral repetition here; keep it clean) -->
    <footer class="footer">
      <div class="container">
        <div style="display:flex; flex-wrap:wrap; justify-content:space-between; gap:12px;">
          <div><b>SCB</b> — Unofficial community guide.</div>
        </div>
        <div style="margin-top:10px;">
          This site is not endorsed by or affiliated with Cloud Imperium Games or Roberts Space Industries.
          Star Citizen® and related marks are trademarks of their respective owners.
        </div>
      </div>
    </footer>

    <!-- PAGE-LOCAL STYLES (scoped; does not affect Home) -->
    <style>
      .refHero__img { height: 380px; }
      @media (max-width: 720px) { .refHero__img { height: 420px; } }
      .refHero__overlay {
        background:
          radial-gradient(900px 420px at 25% 45%, rgba(0,0,0,.08), rgba(0,0,0,.58) 66%),
          linear-gradient(90deg, rgba(7,10,18,.72), rgba(7,10,18,.10));
      }
      .refHero__content {
        width: min(980px, calc(100% - 32px));
        margin: 0 auto;
        padding: 28px 0;
      }

      .refOffer{
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap:14px;
        padding: 14px 14px;
        border-radius: 16px;
        border: 1px solid rgba(216,168,74,.34);
        background: linear-gradient(180deg, rgba(216,168,74,.16), rgba(216,168,74,.06));
        box-shadow: 0 16px 44px rgba(0,0,0,.45), 0 0 0 1px rgba(216,168,74,.10) inset;
      }
      .refOffer__badge{
        font-size: 11px;
        letter-spacing: .14em;
        font-weight: 900;
        padding: 9px 11px;
        border-radius: 999px;
        text-transform: uppercase;
        color: rgba(255, 236, 195, .96);
        background: rgba(216,168,74,.18);
        border: 1px solid rgba(216,168,74,.35);
        box-shadow: 0 0 22px rgba(216,168,74,.16);
        flex: 0 0 auto;
      }
      .refOffer__main{ min-width:0; }
      .refOffer__title{
        font-weight: 750;
        line-height: 1.25;
        color: rgba(255,255,255,.95);
      }
      .refOffer__title b { color: rgba(255, 224, 160, .96); }
      .refOffer__sub{
        margin-top: 4px;
        font-size: 13px;
        color: rgba(255,255,255,.70);
        line-height: 1.5;
      }
      .refOffer__code{
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        font-size: 12px;
        letter-spacing: .08em;
        padding: 6px 10px;
        border-radius: 999px;
        background: rgba(0,0,0,.22);
        border: 1px solid rgba(216,168,74,.28);
        color: rgba(255, 236, 195, .96);
        box-shadow: 0 0 18px rgba(216,168,74,.10);
        white-space: nowrap;
      }
      .refOffer__actions{
        display:flex;
        flex-direction:column;
        align-items:flex-end;
        gap: 8px;
        flex: 0 0 auto;
      }
      .refOffer__link{
        color: rgba(255, 224, 160, .92);
