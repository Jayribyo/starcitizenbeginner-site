---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReferralCTA from "../../components/ReferralCTA.astro";
import FaqSchema from "../../components/FaqSchema.astro";

import { DEFAULT_LANGUAGE_PATHS, REFERRAL_CODE } from "../../config/site";

const paths = DEFAULT_LANGUAGE_PATHS;
const referralCode = REFERRAL_CODE;

const t = {
  title: "Guide Débutant Star Citizen | Démarrage rapide + Bonus de parrainage",
  desc: "Guide rapide pour débutants sur Star Citizen : étapes clés, points d’intérêt et comment activer le bonus via un code de parrainage.",
  heroKicker: "Pour nouveaux pilotes",
  heroH1: "Démarre intelligemment dans le Verse.",
  heroLead: "Un guide clair et sans spam pour entrer en jeu rapidement — avec une explication simple du bonus de parrainage (étape par étape).",
  qsTitle: "Démarrage rapide (5 minutes)",
  qs1: "Crée ton compte RSI (utilise le code de parrainage à l’inscription).",
  qs2: "Choisis un starter pack que tu peux vraiment piloter et améliorer plus tard.",
  qs3: "Installe, lance et fais ton premier contrat simple pour apprendre navigation et atterrissage.",
  poiTitle: "Points d’intérêt (recommandés débutant)",
  poiLead: "Quelques lieux faciles à comprendre et utiles au début :",
  poi: [
    "Area18 (ArcCorp) – bon hub pour shopping & transports",
    "New Babbage (microTech) – très lisible, idéal pour apprendre",
    "Lorville (Hurston) – hub urbain industriel classique",
    "Orison (Crusader) – magnifique, mais peut être lourd en FPS"
  ],
  faqTitle: "FAQ (code de parrainage)",
  faq1q: "Utiliser un code de parrainage coûte quelque chose ?",
  faq1a: "Non. L’inscription est normale. Tu reçois simplement le bonus si tu crées ton compte avec un code/lien.",
  faq2q: "Où saisir le code ?",
  faq2a: "Pendant la création du compte sur le site RSI. Si tu utilises le lien de parrainage, il est appliqué automatiquement.",
  disclaimer: "Guide communautaire non officiel. Non affilié à Cloud Imperium Games ni à Roberts Space Industries."
};
const faqItems = [
  { q: t.faq1q, a: t.faq1a },
  { q: t.faq2q, a: t.faq2a },
];

---
<BaseLayout lang="fr" title={t.title} description={t.desc} canonicalPath="/fr/" brand="Star Citizen Beginner" paths={paths}>
  <FaqSchema items={faqItems} />
  <main class="langPage">
    <section class="section section--heroWidth">
      <div class="grid">
        <section class="card langPage__heroCard">
          <div class="kicker">{t.heroKicker}</div>
          <h1 class="h1">{t.heroH1}</h1>
          <p class="lead">{t.heroLead}</p>

          <div class="badge">Code de parrainage : <strong style="color:#fff;">{referralCode}</strong></div>

          <hr class="sep" />

          <div id="quickstart" class="langPage__stack">
            <div>
              <h2 class="section__title">{t.qsTitle}</h2>
              <ol class="steps muted">
                <li>{t.qs1}</li>
                <li>{t.qs2}</li>
                <li>{t.qs3}</li>
              </ol>
            </div>

            <div>
              <h2 class="section__title">{t.poiTitle}</h2>
              <p class="lead">{t.poiLead}</p>
              <ul class="bullets muted">
                {t.poi.map(x => <li>{x}</li>)}
              </ul>
            </div>
          </div>

          <div class="miniNote">
            {t.disclaimer}
          </div>
        </section>

        <aside class="langPage__asideStack">
          <ReferralCTA
            title={"Activer le bonus d’inscription"}
            blurb={"Si tu crées un nouveau compte, utiliser un code/lien de parrainage active le bonus. Ici on explique clairement — tout en restant utile aux débutants."}
            ctaPrimary={"Créer un compte (parrainage appliqué)"}
            ctaSecondary={"Lire le démarrage rapide"}
          />

          <div class="card pad">
            <div class="kicker">Prochaine étape</div>
            <h2 class="section__title">Starter packs & performances</h2>
            <p class="muted">Ensuite, une comparaison claire des starter packs et un guide performance sont les meilleurs contenus à consulter.</p>
          </div>
        </aside>
      </div>
    </section>

    <section class="section">
      <div class="card pad">
        <h2 class="section__title">{t.faqTitle}</h2>
        <div class="faq">
          <details class="faq__item">
            <summary class="faq__q">{t.faq1q}</summary>
            <div class="faq__a"><p>{t.faq1a}</p></div>
          </details>
          <details class="faq__item">
            <summary class="faq__q">{t.faq2q}</summary>
            <div class="faq__a"><p>{t.faq2a}</p></div>
          </details>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>