---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import ReferralBanner from "../../components/ReferralBanner.astro";
import HowToSchema from "../../components/HowToSchema.astro";
import FaqSchema from "../../components/FaqSchema.astro";

import { REFERRAL_CODE, REFERRAL_LINK, REFERRAL_BONUS_LABEL } from "../../config/site";

const REF_CODE = REFERRAL_CODE;
const REF_LINK = REFERRAL_LINK;
const REF_BONUS = REFERRAL_BONUS_LABEL;

// Evergreen title (no years/patches)
const title = "How to Buy Star Citizen – Simple Step-by-Step Signup and Starter Pack Guide";
const description =
  `A simple step-by-step Star Citizen buying guide: create your RSI account, verify your email, buy one game package, check your hangar, install the launcher, and get into the game without making day one harder than it needs to be.`;

const crumbs = [
  { label: "Home", href: "/" },
  { label: "How to Buy Star Citizen", href: "/how-to-buy-star-citizen/" },
];

const faqs = [
  {
    q: "Where do I enter the Star Citizen referral code?",
    a: `During RSI account creation (signup) — that’s the only time the signup bonus applies. Use ${REF_CODE} to start with +${REF_BONUS}.`,
  },
  {
    q: "What’s the difference between login email and handle/moniker?",
    a: "Your login is your email. Your public handle (often called account name/moniker) is what others see in Spectrum and in-game.",
  },
  {
    q: "Do I need to buy a ship separately?",
    a: "No. A starter pack already includes game access + a ship. You can earn or rent ships in-game later.",
  },
  {
    q: "Can I change my handle later?",
    a: "Sometimes, yes — but don’t treat it as disposable. Pick something you’re happy to be tagged with publicly (Spectrum + in-game).",
  },
  {
    q: "I bought a pack — what’s next?",
    a: "Open My Hangar to make sure the pack is on your account, then install the RSI Launcher, download the game to an SSD if possible, and run one simple first session.",
  },
  {
    q: "Do I need a subscription to play?",
    a: "No. A subscription is optional. Once you own one game package, you can keep playing outside Free Fly.",
  },
  {
    q: "What should my first login look like?",
    a: "Choose your home location, create your character, retrieve your ship at an ASOP terminal, and finish one simple contract before you try anything more ambitious.",
  },
];

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: f.a,
    },
  })),
};

// HowTo schema mirrors the on-page steps (keep it short + generic).
const howToLd = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: "How to buy Star Citizen",
  description,
  step: [
    {
      "@type": "HowToStep",
      name: "Create RSI account (enter referral code during signup)",
      text: `Create your RSI account and enter referral code ${REF_CODE} during signup to get +${REF_BONUS}.`,
    },
    {
      "@type": "HowToStep",
      name: "Pick a public handle",
      text: "Choose your public handle/moniker (what others see in Spectrum and in-game).",
    },
    {
      "@type": "HowToStep",
      name: "Buy one starter pack",
      text: "Pick one starter pack (game access + ship) that matches your first loop.",
    },
    {
      "@type": "HowToStep",
      name: "Install launcher and run a clean first session",
      text: "Install the RSI Launcher, download the game, and follow a simple first-session checklist.",
    },
  ],
};
---

<BaseLayout
  activeNav="buy"
  title={title}
  description={description}
  canonicalPath="/how-to-buy-star-citizen/"
  ogImage="/assets/img/how-to-buy-star-citizen/star-citizen-pilot-logs-in-hero.webp"
  ogImageAlt="Star Citizen pilot signing in on the RSI website"
  robots="index,follow"
  stickyCtaLabel={`Create account + claim bonus (+50k UEC)`}
  stickyCtaHref={REF_LINK}
  stickyCtaExternal={true}
>
  <HowToSchema json={howToLd} />
  <FaqSchema json={faqLd} />

  <Breadcrumbs crumbs={crumbs} />

  <!-- ===================== HERO ===================== -->
  <section class="hero">
    <img
      class="hero__img"
      src="/assets/img/how-to-buy-star-citizen/star-citizen-pilot-logs-in-hero.webp"
      alt="Star Citizen pilot signing in on the RSI website"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      width="1536"
      height="1024"
    />
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <div class="homeHero__content">
        <div style="max-width:720px; padding: 26px 0;">
          <h1 class="h1">How to buy Star Citizen</h1>
          <p class="lead">We walk you through the RSI signup and purchase steps in plain English: create the account, verify your email, buy one game package, check your hangar, and get into the game without overthinking day one.</p>
          <div class="btnrow">
            <a class="btn primary" href="#do-this-now" data-scb-role="how-to-buy-start-steps">Start the buying steps</a>
          </div>
        </div>
      </div>
    </div>

    <!-- ON THIS PAGE (integrated into hero on desktop) -->
    <div class="hero__toc" aria-label="On this page">
      <div class="container">
        <div class="card pad hero__tocCard">
          <div class="kicker"><span class="dot"></span>On this page</div>
          <div class="toc">
            <a href="#quick-answer">Quick answer</a>
            <a href="#do-this-now">Buying steps</a>
            <a href="#account">Account setup</a>
            <a href="#starter-pack">Starter pack</a>
            <a href="#install">Install & launch</a>
            <a href="#faq">FAQ</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <ReferralBanner
    title={`Use referral code ${REF_CODE} to start with ${REF_BONUS}.`}
    sub="Optional. No cost. Doesn’t change your price — it just adds the signup bonus during account creation."
    ctaLabel="Create account + claim your start bonus"
    ctaHref={REF_LINK}
  />

  <!-- ===================== QUICK ANSWER ===================== -->
  <section id="quick-answer" class="section">
    <div class="card pad">
      <h2 class="section__title">Quick answer: this is easier than it looks</h2>
      <ul class="list">
        <li>
          <b>Signup:</b> Create your RSI account and enter referral code <b>{REF_CODE}</b> while you sign up so you start with <b>+{REF_BONUS}</b>.
        </li>
        <li>
          <b>Name choice:</b> Your <b>handle</b> (aka moniker/account name) is public. Your login is your email.
        </li>
        <li>
          <b>Purchase:</b> Buy <b>one game package</b> (game access + a ship). Extra ships can wait until you know you actually want them.
        </li>
        <li>
          <b>After checkout:</b> Open <b>My Hangar</b> once. If your package is there, your game access is in place.
        </li>
        <li>
          <b>Install:</b> Download the RSI Launcher, install to an <b>SSD</b> if you can, and run one simple first session.
        </li>
        <li>
          <b>You do not need:</b> A subscription, extra ships, or a complicated upgrade plan to get started.
        </li>
      </ul>
      <p class="muted" style="margin-top:10px;">
        Still deciding if it is worth it for you? Use the <a href="/should-you-buy-star-citizen/">quick buy guide →</a>
      </p>
      <div class="decisionGrid" style="margin-top:14px;">
        <div class="decisionCard">
          <div class="decisionCard__kicker">Step 1</div>
          <div class="decisionCard__title">Set up the account once, the easy way</div>
          <p class="decisionCard__body">Use the referral code during signup, pick a handle you are happy to keep publicly, and finish account creation once.</p>
        </div>
        <div class="decisionCard">
          <div class="decisionCard__kicker">Step 2</div>
          <div class="decisionCard__title">Buy one starter pack</div>
          <p class="decisionCard__body">Do not turn day one into a fleet-planning project. Buy the starter pack that fits the way you want to start and leave everything else for later.</p>
        </div>
        <div class="decisionCard">
          <div class="decisionCard__kicker">Step 3</div>
          <div class="decisionCard__title">Confirm the purchase, then play one good first session</div>
          <p class="decisionCard__body">Check My Hangar once, install on SSD, and play one simple first session before you worry about anything else.</p>
        </div>
      </div>
      <div class="callout" style="margin-top:12px;">
        <div class="kicker"><span class="dot"></span> Keep it simple</div>
        <p class="muted" style="margin:6px 0 0;">
          Break it into three parts: <b>create the account</b>, <b>buy one starter pack</b>, then <b>see how the game feels after one good first session</b>.
          Most beginner regret comes from trying to solve all three at once and spending too much too early.
        </p>
      </div>

    </div>
  </section>

  <!-- ===================== BUYING STEPS ===================== -->
  <section id="do-this-now" class="section">
    <div class="card pad">
      <h2 class="section__title">Buying steps (do this in order)</h2>
      <p style="max-width: 980px;">
        Keep it simple: account → verify email → one game package → check My Hangar → launcher → first session. Do it in that order and it stays easy.
      </p>

      <div class="tableWrap" style="margin-top:12px;">
        <table class="table">
          <thead>
            <tr>
              <th>Step</th>
              <th>Do this</th>
              <th>Why it matters</th>
              <th>Common mistake</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <th>1</th>
              <td>
                <b>Create your RSI account</b> and enter referral code <b>{REF_CODE}</b> during signup.
                <div style="margin-top:8px;">
                  <a class="btn primary" href={REF_LINK} target="_blank" rel="noopener noreferrer" data-scb-role="referral-signup">
                    Create account + claim bonus
                  </a>
                </div>
              </td>
              <td>This is when the field is right in front of you. It does not change the price — it just adds starting credits.</td>
              <td>Creating the account first, then trying to add the code later.</td>
            </tr>
            <tr>
              <th>2</th>
              <td>
                Choose your <b>public handle</b> (account name / moniker). Keep it readable — people will tag you as <code>@Handle</code>.
              </td>
              <td>This becomes your public identity in Spectrum and in-game. Treat it like a gamer tag you’ll keep.</td>
              <td>Picking something hard to spell, full of numbers, or “temporary”.</td>
            </tr>
            <tr>
              <th>3</th>
              <td>
                Buy <b>one game package</b> that fits your first loop (delivery / light combat / general).
                <div style="margin-top:8px;">
                  <a class="btn ghost" href="/star-citizen-starter-packs/">Pick a starter pack (no fluff) →</a>
                </div>
              </td>
              <td>Game packages include game access + a ship. One package is enough to validate whether the game actually works for you.</td>
              <td>Buying based on looks or “big ship” hype.</td>
            </tr>
            <tr>
              <th>4</th>
              <td>
                Open <b>My Hangar</b> once after checkout and make sure the package is there.
              </td>
              <td>This is the fastest “yes, I really own the game now” check.</td>
              <td>Closing the store tab and wondering later whether the purchase actually landed on the account.</td>
            </tr>
            <tr>
              <th>5</th>
              <td>
                Download the RSI Launcher, install the game, and run one simple first session before you judge it.
                <div style="margin-top:8px; display:flex; gap:10px; flex-wrap:wrap;">
                  <a class="btn ghost" href="/first-session/">First session checklist →</a>
                  <a class="btn ghost" href="/star-citizen-performance-guide/#do-this-now">If it stutters: 10‑minute fix →</a>
                </div>
              </td>
              <td>A bad first hour is often a setup problem, not a final verdict on the game.</td>
              <td>Quitting after one bad spawn or laggy server before you have tried one calmer session.</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="card" style="margin-top:14px;">
        <div class="pad">
          <div class="kicker"><span class="dot"></span>After you buy</div>
          <div class="grid2" style="margin-top:10px;">
            <div>
              <h3 style="margin:0 0 8px;">1) Check My Hangar</h3>
              <p class="muted" style="margin:0;">Go to <b>My Hangar</b> and make sure your game package is listed there. If it is, your purchase went through correctly.</p>
            </div>
            <div>
              <h3 style="margin:0 0 8px;">2) Download the launcher</h3>
              <p class="muted" style="margin:0;">Install the RSI Launcher, log in with the same account, and install the game on an SSD if you can.</p>
            </div>
            <div>
              <h3 style="margin:18px 0 8px;">3) Give the install room</h3>
              <p class="muted" style="margin:0;">Leave plenty of free space and let the install finish cleanly. A cramped drive is an easy way to turn setup into a bad first impression.</p>
            </div>
            <div>
              <h3 style="margin:18px 0 8px;">4) Keep the first login small</h3>
              <p class="muted" style="margin:0;">Choose a home location, retrieve your ship, and finish one simple contract. That is enough for day one.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="card" style="margin-top:14px;">
        <div class="pad">
          <div class="kicker"><span class="dot"></span>Decision rule</div>
          <p style="margin:0;">
            If you can complete <b>one full contract loop</b> (spawn → ship → contract → payout → safe log out) without rage‑quitting,
            you’re past the “first session trap”. That’s when upgrades make sense.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== ACCOUNT SETUP ===================== -->
  <section id="account" class="section">
    <div class="card pad">
      <h2 class="section__title">RSI account setup (what to do on the signup form)</h2>
      <p style="max-width: 980px;">
        This part decides two things: <b>your login</b> (email) and <b>your public name</b> (handle/moniker). And it’s where you must enter the referral code.
      </p>

      <div class="grid2" style="margin-top:12px;">
        <div class="card pad">
          <div class="kicker"><span class="dot"></span>Signup checklist</div>
          <div class="tableWrap" style="margin-top:12px;">
            <table class="table table--steps">
              <thead>
                <tr>
                  <th>Step</th>
                  <th>Do this</th>
                  <th>Why</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <th>1</th>
                  <td><b>Email = login</b>. Use an email you’ll keep long-term (you’ll need it for receipts + password resets).</td>
                  <td>A forgotten email is the fastest way to lose access to an account.</td>
                </tr>
                <tr>
                  <th>2</th>
                  <td><b>Password:</b> use a password manager if you can (long random beats “clever”).</td>
                  <td>RSI is like any other account — treat it like something you’ll keep for years.</td>
                </tr>
                <tr>
                  <th>3</th>
                  <td><b>Handle / Moniker:</b> pick a readable public name (letters > numbers). Avoid “temp” handles.</td>
                  <td>This is what people see in Spectrum and in-game. You’ll get tagged with <code>@Handle</code>.</td>
                </tr>
                <tr>
                  <th>4</th>
                  <td><b>Referral code:</b> enter <b>{REF_CODE}</b> during signup.</td>
                  <td>Only works during account creation. That’s your +50,000 UEC start bonus.</td>
                </tr>
                <tr>
                  <th>5</th>
                  <td><b>Verify email</b> if prompted, then continue to buying the starter pack.</td>
                  <td>Some accounts get stuck until email is verified.</td>
                </tr>
              </tbody>
            </table>
          </div>

          <div class="card" style="margin-top:14px;">
            <div class="pad">
              <div class="kicker"><span class="dot"></span>Handle rules of thumb</div>
              <ul class="list" style="margin-top:10px;">
                <li>Pick something you’d be happy hearing in voice chat.</li>
                <li>Make it easy to type. Your friends will literally type it.</li>
                <li>Avoid character soup like <code>xXx_420_Sn1p3r_xXx</code>.</li>
              </ul>
            </div>
          </div>
        </div>

        <div>
          <img
            class="imgRounded"
            src="/assets/img/how-to-buy-star-citizen/star-citizen-account-registration.webp"
            alt="RSI account registration screen"
            loading="lazy"
            decoding="async"
            width="1400"
            height="900"
          />
          <p class="lead" style="margin-top:10px;">
            Tip: if you don’t see the referral field, you’re usually on the wrong step — use the official enlist/signup flow.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== STARTER PACK ===================== -->
  <section id="starter-pack" class="section">
    <div class="card pad">
      <h2 class="section__title">Starter pack buying (what you’re actually purchasing)</h2>
      <p style="max-width: 980px;">
        A starter pack is <b>game access + one ship</b>. That’s all you need to start. Everything else is optional.
      </p>

      <div class="tableWrap" style="margin-top:12px;">
        <table class="table">
          <thead>
            <tr>
              <th>Your goal</th>
              <th>Pick this kind of pack</th>
              <th>Why</th>
              <th>Don’t do this</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <th>Learn the basics comfortably</th>
              <td>General starter (balanced)</td>
              <td>Forgiving “first loop” ship.</td>
              <td>“I’ll buy a huge ship so it’s easier.”</td>
            </tr>
            <tr>
              <th>Fast first credits</th>
              <td>Delivery-friendly starter</td>
              <td>Courier loops teach navigation + UI with low risk.</td>
              <td>All-in trading on day one.</td>
            </tr>
            <tr>
              <th>Combat first</th>
              <td>Light combat starter</td>
              <td>Lets you learn bounties without hard progression walls.</td>
              <td>Buying extra weapons/ships before your first stable session.</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="btnrow" style="margin-top:14px; flex-wrap: wrap;">
        <a class="btn primary" href={REF_LINK} target="_blank" rel="nofollow noopener noreferrer" data-scb-role="referral-signup">
          Create account + claim signup bonus
        </a>
        <a class="btn ghost" href="/star-citizen-starter-packs/">Which starter pack should you buy? →</a>
      </div>
    </div>
  </section>

  <!-- ===================== INSTALL ===================== -->
  <section id="install" class="section">
    <div class="card pad">
      <h2 class="section__title">Install & launch (so your first impression isn’t ruined)</h2>
      <p style="max-width: 980px;">
        Install is straightforward, but performance isn’t. The single biggest “new buyer” regret is judging the game while it’s stuttering.
      </p>

      <div class="tableWrap" style="margin-top:12px;">
        <table class="table table--steps">
          <thead>
            <tr>
              <th>Step</th>
              <th>Do</th>
              <th>Why</th>
              <th>If it goes wrong</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <th>1</th>
              <td>Download and install the RSI Launcher.</td>
              <td>It manages updates and the game install.</td>
              <td>If login fails: double-check email/handle confusion (email is login).</td>
            </tr>
            <tr>
              <th>2</th>
              <td>Install the game to an <b>SSD</b> if possible.</td>
              <td>Star Citizen is extremely storage-sensitive.</td>
              <td>Stutters on HDD are “normal” — it’s not the right baseline.</td>
            </tr>
            <tr>
              <th>3</th>
              <td>Launch once, then follow a simple first-session checklist.</td>
              <td>Prevents overwhelm and “random wandering”.</td>
              <td><a href="/first-session/">First session checklist →</a></td>
            </tr>
            <tr>
              <th>4</th>
              <td>If FPS/stutters are bad, do the quick performance fixes before you judge anything.</td>
              <td>Fixes are high impact and fast.</td>
              <td><a href="/star-citizen-performance-guide/#do-this-now">10‑minute performance fix →</a></td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="card" style="margin-top:14px;">
        <div class="pad">
          <div class="kicker"><span class="dot"></span>What your first login usually looks like</div>
          <ul class="list" style="margin-top:10px;">
            <li><b>Choose your home location</b> carefully. That becomes your first base and where many starting items live.</li>
            <li><b>Create your character</b> and keep moving. You can refine details later.</li>
            <li><b>Retrieve your ship at an ASOP terminal</b> instead of wandering the spaceport guessing.</li>
            <li><b>Run one simple contract</b> before you judge the whole game. That first clean loop matters more than any menu tour.</li>
          </ul>
        </div>
      </div>

      <div class="card" style="margin-top:14px;">
        <div class="pad">
          <div class="kicker"><span class="dot"></span>What “success” looks like</div>
          <p style="margin:0;">
            Your first win condition is boring on purpose: <b>one clean contract loop</b> completed without getting lost or crashing.
            Once you can repeat that, the game opens up fast.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== FAQ ===================== -->
  <section id="faq" class="section">
    <div class="card pad">
      <h2 class="section__title">FAQ</h2>

      <div class="faq" style="margin-top:12px;">
        {faqs.map((f) => (
          <details class="faq__item">
            <summary class="faq__q">{f.q}</summary>
            <div class="faq__a">{f.a}</div>
          </details>
        ))}
      </div>

      <div class="btnrow" style="margin-top:14px; flex-wrap: wrap;">
        <a class="btn primary" href={REF_LINK} target="_blank" rel="nofollow noopener noreferrer" data-scb-role="referral-signup">
          Create account + claim signup bonus
        </a>
        <a class="btn ghost" href="/star-citizen-referral-code/">Referral code guide →</a>
      </div>
    </div>
  </section>
</BaseLayout>
