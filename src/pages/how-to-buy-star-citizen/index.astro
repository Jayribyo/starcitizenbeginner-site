---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import ReferralBanner from "../../components/ReferralBanner.astro";
import OnThisPage from "../../components/OnThisPage.astro";
import HowToSchema from "../../components/HowToSchema.astro";
import FaqSchema from "../../components/FaqSchema.astro";

import { REFERRAL_CODE, REFERRAL_LINK, REFERRAL_BONUS_LABEL } from "../../config/site";

const REF_CODE = REFERRAL_CODE;
const REF_LINK = REFERRAL_LINK;
const REF_BONUS = REFERRAL_BONUS_LABEL;

// Evergreen title (no years/patches)
const title = "How to Buy Star Citizen – Simple Step-by-Step Signup and Starter Pack Guide";
const description =
  `A simple step-by-step Star Citizen buying guide: create your RSI account, verify your email, buy one game package, check your hangar, install the launcher, and get into the game without making day one harder than it needs to be.`;

const crumbs = [
  { label: "Home", href: "/" },
  { label: "How to Buy Star Citizen", href: "/how-to-buy-star-citizen/" },
];

const tocItems = [
  { label: "What you need", href: "#quick-answer" },
  { label: "Buying steps", href: "#do-this-now" },
  { label: "Account setup", href: "#account" },
  { label: "Starter pack", href: "#starter-pack" },
  { label: "Install & launch", href: "#install" },
  { label: "FAQ", href: "#faq" },
];

const faqs = [
  {
    q: "What do I actually need to buy to play Star Citizen?",
    a: "One RSI account and one game package. That is the only purchase requirement for normal entry into Star Citizen.",
  },
  {
    q: "What’s the difference between a game package and a standalone ship?",
    a: "A game package includes Star Citizen access and a starter ship. A standalone ship is just an extra ship purchase and does not replace a game package by itself.",
  },
  {
    q: "Where do I enter the Star Citizen referral code?",
    a: `During RSI account creation (signup). That is the only moment the signup bonus applies. Use ${REF_CODE} to start with +${REF_BONUS}.`,
  },
  {
    q: "What’s the difference between login email and handle?",
    a: "Your email is your login. Your handle is the public name other players see in Spectrum and in-game.",
  },
  {
    q: "Do I need a subscription or Squadron 42 to start?",
    a: "No. A subscription is optional, and Squadron 42 is the separate single-player campaign. Neither is required to start playing Star Citizen online.",
  },
  {
    q: "What should I do right after I buy a package?",
    a: "Open My Hangar to confirm the package is on your account, install the RSI Launcher, put the game on an SSD if possible, and keep your first session simple.",
  },
];

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: f.a,
    },
  })),
};

// HowTo schema mirrors the on-page steps (keep it short + generic).
const howToLd = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: "How to buy Star Citizen",
  description,
  step: [
    {
      "@type": "HowToStep",
      name: "Create RSI account (enter referral code during signup)",
      text: `Create your RSI account and enter referral code ${REF_CODE} during signup to get +${REF_BONUS}.`,
    },
    {
      "@type": "HowToStep",
      name: "Pick a public handle",
      text: "Choose your public handle/moniker (what others see in Spectrum and in-game).",
    },
    {
      "@type": "HowToStep",
      name: "Buy one starter pack",
      text: "Pick one starter pack (game access + ship) that matches your first loop.",
    },
    {
      "@type": "HowToStep",
      name: "Install launcher and run a clean first session",
      text: "Install the RSI Launcher, download the game, and follow a simple first-session checklist.",
    },
  ],
};
---

<BaseLayout
  activeNav="buy"
  title={title}
  description={description}
  canonicalPath="/how-to-buy-star-citizen/"
  ogImage="/assets/img/how-to-buy-star-citizen/star-citizen-pilot-logs-in-hero.webp"
  ogImageAlt="Star Citizen pilot signing in on the RSI website"
  robots="index,follow"
  stickyCtaLabel={`Create account + claim bonus (+50k UEC)`}
  stickyCtaHref={REF_LINK}
  stickyCtaExternal={true}
>
  <HowToSchema json={howToLd} />
  <FaqSchema json={faqLd} />

  <Breadcrumbs crumbs={crumbs} />

  <!-- ===================== HERO ===================== -->
  <section class="hero">
    <img
      class="hero__img"
      src="/assets/img/how-to-buy-star-citizen/star-citizen-pilot-logs-in-hero.webp"
      alt="Star Citizen pilot signing in on the RSI website"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      width="1536"
      height="1024"
    />
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <div class="homeHero__content">
        <div style="max-width:720px; padding: 26px 0;">
          <h1 class="h1">How to buy Star Citizen</h1>
          <p class="lead">The practical version is simple: create your account, buy one game package, check My Hangar once, then install the launcher and log in.</p>
          <div class="btnrow" style="flex-wrap:wrap;">
            <a class="btn primary" href="#quick-answer" data-scb-role="how-to-buy-quick-answer">See what you actually need</a>
          </div>
        </div>
      </div>
    </div>

    <OnThisPage
      variant="hero"
      title="On this page"
      items={tocItems}
    />
  </section>

  <ReferralBanner
    title={`Use referral code ${REF_CODE} to start with ${REF_BONUS}.`}
    sub="Optional. No cost. Doesn’t change your price — it just adds the signup bonus during account creation."
    ctaLabel="Create account + claim your start bonus"
    ctaHref={REF_LINK}
  />

  <!-- ===================== QUICK ANSWER ===================== -->
  <section id="quick-answer" class="section">
    <div class="card pad">
      <h2 class="section__title">What you actually need</h2>
      <p style="max-width: 980px;">
        To start playing Star Citizen, you only need an RSI account and one game package.
        Everything else is optional, later, or easy to ignore on day one.
      </p>

      <div class="tableWrap" style="margin-top:12px;">
        <table class="table table--steps">
          <thead>
            <tr>
              <th>Thing</th>
              <th>Do you need it?</th>
              <th>What matters</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <th>RSI account</th>
              <td>Yes</td>
              <td>Create the account first. Your login is your email, and your public handle is the name other players see.</td>
            </tr>
            <tr>
              <th>Game package</th>
              <td>Yes</td>
              <td>This is what gives you game access. It already includes a starter ship.</td>
            </tr>
            <tr>
              <th>Standalone ship</th>
              <td>No</td>
              <td>Nice to own later, but by itself it does not replace a game package.</td>
            </tr>
            <tr>
              <th>Subscription</th>
              <td>No</td>
              <td>Optional. It is not required to start playing.</td>
            </tr>
            <tr>
              <th>Big ship or upgrade plan</th>
              <td>No</td>
              <td>Start smaller. Most beginner regret comes from overbuying before the game has even clicked.</td>
            </tr>
            <tr>
              <th>Squadron 42</th>
              <td>No, not for Star Citizen itself</td>
              <td>That is the separate single-player campaign, not your ticket into the persistent universe.</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="grid2" style="margin-top:14px; gap:14px; align-items:start;">
        <div class="card pad">
          <ul class="list">
            <li>Create your RSI account and enter referral code {REF_CODE} during signup if you want the +{REF_BONUS} start bonus.</li>
            <li>Buy one game package. That already covers game access and your first ship.</li>
            <li>Open My Hangar once after checkout to confirm the package is on your account.</li>
            <li>Install the RSI Launcher on an SSD if you can, then judge the game after one clean first session.</li>
          </ul>
        </div>

        <div class="card pad">
          <p class="muted" style="margin:0;">
            You do not need to force the decision today. If your real question is still whether Star Citizen is worth buying,
            step sideways into the <a href="/should-you-buy-star-citizen/">should you buy guide</a> or use <a href="/free-fly/">Free Fly</a> first.
          </p>
        </div>
      </div>

      <div class="btnrow" style="margin-top:14px; flex-wrap:wrap;">
        <a class="btn primary" href="#do-this-now" data-scb-role="how-to-buy-start-steps">Start the buying steps</a>
        <a class="btn ghost" href="/star-citizen-starter-packs/">Pick a starter pack</a>
      </div>
    </div>
  </section>

  <!-- ===================== BUYING STEPS ===================== -->
  <section id="do-this-now" class="section">
    <div class="card pad">
      <h2 class="section__title">Buying steps (do this in order)</h2>
      <p style="max-width: 980px;">
        Keep it in this order: create the account, verify it, buy one game package, check My Hangar, then install the launcher.
      </p>

      <div class="tableWrap" style="margin-top:12px;">
        <table class="table">
          <thead>
            <tr>
              <th>Step</th>
              <th>Do this</th>
              <th>Why it matters</th>
              <th>Common mistake</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <th>1</th>
              <td>
                Create your RSI account and enter referral code {REF_CODE} during signup.
                <div style="margin-top:8px;">
                  <a class="btn primary" href={REF_LINK} target="_blank" rel="noopener noreferrer" data-scb-role="referral-signup">
                    Create account + claim bonus
                  </a>
                </div>
              </td>
              <td>This is the only moment the referral field is available. If you want the signup bonus, do it now and move on.</td>
              <td>Making the account first, then trying to add the code later.</td>
            </tr>
            <tr>
              <th>2</th>
              <td>
                Verify your email if prompted and pick a readable public handle you will not hate in a week.
              </td>
              <td>Your email is your login. Your handle is the public name other players see in Spectrum and in-game.</td>
              <td>Treating the handle like a throwaway placeholder.</td>
            </tr>
            <tr>
              <th>3</th>
              <td>
                Buy one game package, not a standalone ship.
                <div class="muted" style="margin-top:8px;">
                  A real game package is what gives you Star Citizen access. It already includes your first ship.
                </div>
                <div style="margin-top:8px;">
                  <a class="btn ghost" href="/star-citizen-starter-packs/">Pick a starter pack (no fluff) →</a>
                </div>
              </td>
              <td>This is the one buying decision that actually matters on day one.</td>
              <td>Buying a ship that looks cool, then realizing it was not a game package.</td>
            </tr>
            <tr>
              <th>4</th>
              <td>
                Open My Hangar once after checkout and confirm the package is there.
              </td>
              <td>This is the fastest “yes, the purchase landed on the correct account” check.</td>
              <td>Skipping the check, then troubleshooting the launcher before confirming ownership.</td>
            </tr>
            <tr>
              <th>5</th>
              <td>
                Download the RSI Launcher, install the game, and keep your first login small.
                <div style="margin-top:8px; display:flex; gap:10px; flex-wrap:wrap;">
                  <a class="btn ghost" href="/satellites/first-session/">First session checklist →</a>
                  <a class="btn ghost" href="/star-citizen-performance-guide/#do-this-now">If it stutters: 10‑minute fix →</a>
                </div>
              </td>
              <td>Once the package is on your account, the rest is mostly setup discipline.</td>
              <td>Judging the game before you have done one clean install and one calm first session.</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ===================== ACCOUNT SETUP ===================== -->
  <section id="account" class="section">
    <div class="card pad">
      <h2 class="section__title">RSI account setup (what matters on the signup form)</h2>
      <p style="max-width: 980px;">
        The signup screen feels more important than it really is. Keep it simple: your email is your login, your handle is your public name,
        and the referral field only works during account creation.
      </p>

      <div class="grid2" style="margin-top:12px; gap:14px; align-items:start;">
        <div class="card pad">
          <div class="tableWrap">
            <table class="table table--steps">
              <thead>
                <tr>
                  <th>Field</th>
                  <th>What it is</th>
                  <th>What to do</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <th>Email</th>
                  <td>Your login and account recovery address.</td>
                  <td>Use an email you will keep. Receipts, verification, and password resets all point back here.</td>
                </tr>
                <tr>
                  <th>Password</th>
                  <td>Your account security.</td>
                  <td>Use a long password and turn on 2FA later. Do not treat this like a throwaway game signup.</td>
                </tr>
                <tr>
                  <th>Handle / moniker</th>
                  <td>Your public identity in Spectrum and in-game.</td>
                  <td>Pick something readable, easy to type, and worth keeping.</td>
                </tr>
                <tr>
                  <th>Referral code</th>
                  <td>Your one-time signup bonus field.</td>
                  <td>Enter <b>{REF_CODE}</b> during signup if you want the <b>+{REF_BONUS}</b> start bonus.</td>
                </tr>
              </tbody>
            </table>
          </div>

          <p class="muted" style="margin:14px 0 0;">
            Keep this part boring: use an email you still want next year, pick a handle your friends can spell, and do not overthink the community side of the account on day one.
          </p>
        </div>

        <div>
          <img
            class="imgRounded"
            src="/assets/img/how-to-buy-star-citizen/star-citizen-account-registration.webp"
            alt="RSI account registration screen"
            loading="lazy"
            decoding="async"
            width="1400"
            height="900"
          />
          <p class="muted" style="margin:12px 0 0;">
            If you want the referral signup bonus, enter the code while you are creating the account. If the account already exists, that moment is gone.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== STARTER PACK ===================== -->
  <section id="starter-pack" class="section">
    <div class="card pad">
      <h2 class="section__title">Game package vs standalone ship (this is the buying part that trips people up)</h2>
      <p style="max-width: 980px;">
        The RSI store looks bigger than the real decision. For a new player, the key distinction is simple: a game package lets you play.
        A standalone ship does not replace that.
      </p>

      <div class="tableWrap" style="margin-top:12px;">
        <table class="table">
          <thead>
            <tr>
              <th>Store item</th>
              <th>Can you play Star Citizen with it?</th>
              <th>What it is actually for</th>
              <th>Beginner move</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <th>Game package</th>
              <td>Yes</td>
              <td>Includes Star Citizen access and a starter ship.</td>
              <td>Buy one and stop there until you know the game fits you.</td>
            </tr>
            <tr>
              <th>Standalone ship</th>
              <td>No, not by itself</td>
              <td>An extra ship purchase for accounts that already have access.</td>
              <td>Ignore it on day one unless you already know exactly why you want it.</td>
            </tr>
            <tr>
              <th>Squadron 42</th>
              <td>No, not for the persistent universe</td>
              <td>The separate single-player campaign.</td>
              <td>Do not confuse it with your Star Citizen game access.</td>
            </tr>
            <tr>
              <th>Subscription</th>
              <td>No</td>
              <td>Optional membership, not a requirement to play.</td>
              <td>Treat it as irrelevant until you are settled in.</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="grid2" style="margin-top:14px; gap:14px; align-items:start;">
        <div class="card pad">
          <p style="margin:0 0 12px;">
            Keep the decision narrow. You are not choosing your forever ship here — you are choosing the cleanest way into the game.
          </p>
          <div class="tableWrap" style="margin-top:12px;">
            <table class="table table--steps">
              <thead>
                <tr>
                  <th>If this sounds like you</th>
                  <th>Best move</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <th>I just want the cheapest sensible way in</th>
                  <td>Start with a basic package and keep the buy-in low.</td>
                </tr>
                <tr>
                  <th>I want the easiest all-round beginner experience</th>
                  <td>Choose a more practical starter package with better day-one flexibility.</td>
                </tr>
                <tr>
                  <th>I am already comparing specific ships</th>
                  <td>Use the dedicated starter-packs guide. That comparison belongs there, not here.</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <div class="card pad">
          <p style="margin:0;">
            Buy one sensible game package, confirm it in My Hangar, and let the game prove itself before you spend another euro.
          </p>
        </div>
      </div>

      <div class="btnrow" style="margin-top:14px; flex-wrap: wrap;">
        <a class="btn primary" href="/star-citizen-starter-packs/">Compare starter packs properly</a>
        <a class="btn ghost" href={REF_LINK} target="_blank" rel="nofollow noopener noreferrer" data-scb-role="referral-signup">
          Create account + claim signup bonus
        </a>
      </div>
    </div>
  </section>

  <!-- ===================== MISTAKES ===================== -->
  <section class="section">
    <div class="card pad">
      <h2 class="section__title">Common buying mistakes (this is where new players waste money or time)</h2>
      <p style="max-width: 980px;">
        Most buying regret does not come from picking the “wrong dream ship.” It comes from getting one boring thing wrong early.
        Avoid these and your first purchase usually stays simple.
      </p>

      <div class="tableWrap" style="margin-top:12px;">
        <table class="table">
          <thead>
            <tr>
              <th>Mistake</th>
              <th>What goes wrong</th>
              <th>Better move</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <th>Buying a standalone ship instead of a game package</th>
              <td>You spend money and still do not actually have Star Citizen access.</td>
              <td>Make sure the store item clearly says game package before checkout.</td>
            </tr>
            <tr>
              <th>Spending too much too early</th>
              <td>You lock in a bigger purchase before you even know whether the game loop, performance, and pace suit you.</td>
              <td>Start smaller. You can always reassess later once the game has clicked.</td>
            </tr>
            <tr>
              <th>Trying to learn upgrades, melts, and store credit on day one</th>
              <td>You turn a simple first purchase into store gymnastics you do not need yet.</td>
              <td>Ignore advanced store systems until after you have played enough to care.</td>
            </tr>
            <tr>
              <th>Assuming a subscription is required</th>
              <td>You overcomplicate the entry cost and buy something unrelated to actual access.</td>
              <td>One game package is enough to start playing outside Free Fly.</td>
            </tr>
            <tr>
              <th>Judging the purchase before a clean install and first session</th>
              <td>Bad performance or a chaotic first login can make a correct package feel like the wrong decision.</td>
              <td>Install on an SSD, keep the first session small, and then judge the game.</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="grid2" style="margin-top:14px; gap:14px; align-items:start;">
        <div class="card pad">
          <p style="margin:0;">
            Still comparing packages? Use the <a href="/star-citizen-starter-packs/">starter packs guide</a> for the real package comparison.
          </p>
        </div>
        <div class="card pad">
          <p style="margin:0;">
            Not sure whether to spend at all? Step sideways into the <a href="/should-you-buy-star-citizen/">should you buy guide</a> or try <a href="/free-fly/">Free Fly</a> first.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== INSTALL ===================== -->
  <section id="install" class="section">
    <div class="card pad">
      <h2 class="section__title">After you buy: install cleanly and keep the first session simple</h2>
      <p style="max-width: 980px;">
        Once your package is in My Hangar, the buying job is done. From here, your goal is not to “master Star Citizen” on day one — it is to get through one clean install and one calm first session without creating extra friction.
      </p>

      <div class="tableWrap" style="margin-top:12px;">
        <table class="table table--steps">
          <thead>
            <tr>
              <th>Step</th>
              <th>Do</th>
              <th>Why</th>
              <th>If it goes wrong</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <th>1</th>
              <td>Download and install the RSI Launcher.</td>
              <td>It manages updates and the game install.</td>
              <td>If login fails: double-check email/handle confusion (email is login).</td>
            </tr>
            <tr>
              <th>2</th>
              <td>Install the game to an SSD if possible.</td>
              <td>Star Citizen is extremely storage-sensitive.</td>
              <td>Stutters on HDD are “normal” — it’s not the right baseline.</td>
            </tr>
            <tr>
              <th>3</th>
              <td>Launch once, then follow a simple first-session checklist.</td>
              <td>Prevents overwhelm and “random wandering”.</td>
              <td><a href="/satellites/first-session/">First session checklist →</a></td>
            </tr>
            <tr>
              <th>4</th>
              <td>If FPS/stutters are bad, do the quick performance fixes before you judge anything.</td>
              <td>Fixes are high impact and fast.</td>
              <td><a href="/star-citizen-performance-guide/#do-this-now">10‑minute performance fix →</a></td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="grid2" style="margin-top:14px; gap:14px; align-items:start;">
        <div class="card pad">
          <ul class="list">
            <li>Choose your home location carefully. That becomes your first base and where many starting items live.</li>
            <li>Create your character and keep moving. You can refine details later.</li>
            <li>Retrieve your ship at an ASOP terminal instead of wandering the spaceport guessing.</li>
            <li>Run one simple contract before you judge the whole game.</li>
          </ul>
        </div>

        <div class="card pad">
          <p style="margin:0;">
            Keep the day-one win condition boring on purpose: get into the game, retrieve your ship, and complete one clean beginner-friendly loop without getting lost or stuck in settings menus for an hour.
          </p>
        </div>
      </div>
    </div>
  </section>


  <!-- ===================== NEXT STEPS ===================== -->
  <section class="section">
    <div class="card pad">
      <h2 class="section__title">What to do next depends on where you are</h2>
      <p style="max-width: 980px;">
        Pick the branch that matches your real next question.
      </p>

      <div class="grid2" style="margin-top:14px; gap:14px; align-items:start;">
        <div class="card pad">
          <p style="margin:0 0 12px;">Still comparing packs? Use the starter-packs guide for the real ship and package comparison.</p>
          <a class="btn ghost" href="/star-citizen-starter-packs/">Compare starter packs</a>
        </div>

        <div class="card pad">
          <p style="margin:0 0 12px;">Not sure the game is worth the money yet? Step sideways before you buy.</p>
          <div class="btnrow" style="flex-wrap:wrap;">
            <a class="btn ghost" href="/should-you-buy-star-citizen/">Should you buy Star Citizen?</a>
            <a class="btn ghost" href="/free-fly/">Try Free Fly first</a>
          </div>
        </div>
      </div>

      <div class="grid2" style="margin-top:14px; gap:14px; align-items:start;">
        <div class="card pad">
          <p style="margin:0 0 12px;">Want the signup bonus done correctly? Use the referral guide for timing, field placement, and the “can I add it later?” question.</p>
          <div class="btnrow" style="flex-wrap:wrap;">
            <a class="btn primary" href={REF_LINK} target="_blank" rel="nofollow noopener noreferrer" data-scb-role="referral-signup">
              Create account + claim signup bonus
            </a>
            <a class="btn ghost" href="/star-citizen-referral-code/">Referral code guide</a>
          </div>
        </div>

        <div class="card pad">
          <p style="margin:0 0 12px;">Already bought the package? Stop shopping and switch to setup and first-session help.</p>
          <div class="btnrow" style="flex-wrap:wrap;">
            <a class="btn ghost" href="/satellites/first-session/">First session checklist</a>
            <a class="btn ghost" href="/star-citizen-performance-guide/">Performance guide</a>
          </div>
        </div>
      </div>
