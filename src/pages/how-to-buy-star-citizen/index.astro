      <h2 class="section__title">FAQ</h2>
      <p style="max-width: 980px; margin-top: 8px;">
        These are the last buying questions that still trip people up right before checkout or right after it.
      </p>

      <div class="faq" style="margin-top:12px;">
        {faqs.map((f) => (
          <details class="faq__item">
