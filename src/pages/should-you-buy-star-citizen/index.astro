---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReferralBanner from "../../components/ReferralBanner.astro";
import OnThisPage from "../../components/OnThisPage.astro";
import FaqSchema from "../../components/FaqSchema.astro";
import HowToSchema from "../../components/HowToSchema.astro";

const referralCode = "STAR-FSRJ-5N7Z";
const referralBonusUEC = "50,000";
const referralLink = `https://www.robertsspaceindustries.com/enlist?referral=${referralCode}`;

const heroImg = "/assets/img/should-you-buy-star-citizen/star-citizen-multiplayer-fleet-hero.webp";
const buyImg = "/assets/img/should-you-buy-star-citizen/star-citizen-buy-or-not.webp";

const tocItems = [
  { label: "TL;DR", href: "#tldr" },
  { label: "2-minute decision test", href: "#decision-test" },
  { label: "Decision table: who should buy?", href: "#decision-table" },
  { label: "What you actually get", href: "#what-you-get" },
  { label: "Safest way to start (spend the minimum)", href: "#safe-start" },
  { label: "Your first 60 minutes (do this now)", href: "#first-hour" },
  { label: "Performance reality (don’t let FPS ruin it)", href: "#performance" },
  { label: "Common mistakes (and fixes)", href: "#mistakes" },
  { label: "FAQ", href: "#faq" },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Do I need a game package to play Star Citizen?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. A starter package is required to play outside Free Fly events. Free Fly lets you try the game temporarily without buying."
      }
    },
    {
      "@type": "Question",
      "name": "Is Star Citizen worth it for casual players?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "It can be — if you enjoy sandbox games and don’t mind learning a few core systems. If you want a polished, guided campaign experience every session, you may enjoy it less."
      }
    },
    {
      "@type": "Question",
      "name": "What’s the safest way to start without wasting money?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Try Free Fly first if available. If you buy, start with the minimum starter package, play a few sessions, and only upgrade after you know what you enjoy."
      }
    },
    {
      "@type": "Question",
      "name": "Should I buy extra ships right away?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Usually no. Learn your preferred playstyle first. Many players spend more than they need early and then realize they prefer different roles later."
      }
    },
    {
      "@type": "Question",
      "name": "Do referral codes cost money?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. A referral code is free. It’s simply a signup bonus you can apply when you create your account."
      }
    },
    {
      "@type": "Question",
      "name": "What if performance is bad on my PC?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Start by confirming the game is installed on an SSD and apply a few high-impact settings changes. Our performance guide gives a concrete checklist and the fastest fixes first."
      }
    }
  ]
};

const howToJsonLd = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "Your first 60 minutes in Star Citizen (beginner-safe route)",
  "description": "A beginner-safe first session route: get your ship, fly a simple contract, earn your first credits, and log out without losing your momentum.",
  "totalTime": "PT60M",
  "step": [
    { "@type": "HowToStep", "name": "Set expectations and keep it simple", "text": "Pick one small goal for your first session: one contract completed. Avoid shopping and distractions until you get your first payout." },
    { "@type": "HowToStep", "name": "Spawn, gear up lightly, and claim your ship", "text": "Equip a basic undersuit and helmet if you plan to leave the station. Claim your ship at the terminal and head to the hangar." },
    { "@type": "HowToStep", "name": "Take one beginner-friendly contract", "text": "Choose a simple courier/delivery contract or an easy legal mission. Avoid multi-step chains on your very first run." },
    { "@type": "HowToStep", "name": "Complete the loop and get paid", "text": "Fly to the objective, finish the task, and confirm you received the payout before you take the next mission." },
    { "@type": "HowToStep", "name": "Lock in momentum", "text": "Repeat the same loop once more, then stop. Consistency beats complexity early." }
  ]
};
---

<BaseLayout
  title="Should You Buy Star Citizen? Honest Worth-It Guide (Costs, Fun Factor, Performance, Free Fly)"
  description="A no-fluff decision guide: who will love Star Citizen, who should skip it, what you actually get, the safest way to start, and a 2-minute test to decide."
  canonicalPath="/should-you-buy-star-citizen/"
  ogImage={heroImg}
  ogImageAlt="Star Citizen fleet scene representing the buying decision"
  stickyCtaLabel="Claim +50k UEC start bonus"
  stickyCtaHref={referralLink}
  stickyCtaExternal={true}
  activeNav="guides"
>
  <link slot="head" rel="preload" as="image" href={heroImg} imagesrcset={`${heroImg} 1536w`} />

  <FaqSchema json={faqJsonLd} />
  <HowToSchema json={howToJsonLd} />

  <main>
    <!-- HERO (must match global landing page hero layout) -->
    <section class="hero guideHero">
      <img
        class="hero__img"
        src={heroImg}
        alt="A Star Citizen fleet in space — a cinematic moment that sells the dream"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1536"
        height="1024"
      />
      <div class="hero__overlay"></div>

      <div class="hero__content">
        <div class="guideHero__content">
          <div class="kicker"><span class="dot"></span> Buying Guide</div>
          <h1 class="h1">Should You Buy Star Citizen?</h1>
          <p class="lead" style="max-width: 920px;">
            This is the <b>honest</b> decision page: who will love it, who will hate it, what you actually do in-game,
            and the <b>safest way to start</b> without wasting money.
            Take the 2-minute test — then start with a beginner-proof first session route.
          </p>

          <div class="btnrow" style="margin-top: 14px;">
            <a class="btn primary" href="#decision-test">Take the 2-minute test</a>
            <a class="btn secondary" href="#safe-start">Safest way to start</a>
          </div>

          <div class="callout" style="margin-top: 12px;">
            <b>New account?</b> You can claim a free signup bonus.
            <a href="/star-citizen-referral-code/" style="margin-left: 8px;">How it works →</a>
          </div>
        </div>
      </div>

      <OnThisPage variant="hero" title="On this page" items={tocItems} />
    </section>

    <!-- Referral banner (consistent site-wide; subtle funnel) -->
    <ReferralBanner
      code={referralCode}
      bonus={`${referralBonusUEC} UEC`}
      ctaHref={referralLink}
      howItWorksHref="/star-citizen-referral-code/#how-to-use"
      sublineHtml="If you decide to buy, use it during signup — it’s free, and you only get this <b>first signup moment</b> once."
      ariaLabel="Referral bonus callout"
    />

    <!-- TL;DR -->
    <section id="tldr" class="section">
      <div class="card pad">
        <h2 class="section__title">TL;DR: the shortest honest answer</h2>

        <div class="grid2" style="margin-top: 10px;">
          <div>
            <ul class="list">
              <li><b>Buy</b> if you like sandboxes, self-made goals, and long-term progression.</li>
              <li><b>Skip</b> if you want a polished, guided campaign experience every session.</li>
              <li><b>Safest start:</b> try <a href="/free-fly/"><b>Free Fly</b></a> first (when available). If you buy, start with the <b>minimum starter package</b>.</li>
              <li><b>Don’t overspend early:</b> upgrade only after a few sessions when you know your playstyle.</li>
              <li><b>Performance matters:</b> install on an SSD and do the 10-minute fixes before judging the game.
                <a href="/star-citizen-performance-guide/" style="margin-left: 6px;">Performance guide →</a>
              </li>
            </ul>
          </div>

          <div>
            <div class="callout">
              <b>Quick truth:</b> Star Citizen is a “make your own adventure” game. When it clicks, it’s unforgettable.
              When it doesn’t, it can feel overwhelming. This page helps you decide <b>before</b> you spend.
            </div>

            <div class="btnrow" style="margin-top: 12px;">
              <a class="btn secondary" href="#decision-table">See the decision table</a>
              <a class="btn secondary" href="/make-money-fast/">Make money fast (beginner)</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- DECISION TEST -->
    <section id="decision-test" class="section">
      <div class="card pad">
        <h2 class="section__title">2-minute decision test (be honest)</h2>
        <p style="max-width: 980px;">
          Check the boxes that describe you. Then use the score to pick the safest next step.
          This is designed for <b>beginners</b> and <b>Free Fly</b> players who don’t want to waste time or money.
        </p>

        <div class="grid2" style="margin-top: 12px; align-items: start;">
          <div>
            <div class="callout">
              <b>Score yourself:</b>
              <ul class="list" style="margin-top: 8px;">
                <li>✅ I enjoy sandbox games (I can set my own goals)</li>
                <li>✅ I like learning systems (ships, navigation, missions)</li>
                <li>✅ I can tolerate occasional rough edges without rage-quitting</li>
                <li>✅ I will play at least 3–5 sessions before judging it</li>
                <li>✅ I like slow-burn progression more than instant rewards</li>
                <li>✅ I’m happy if my best moments come from emergent situations</li>
                <li>✅ I’m okay asking questions / using guides</li>
                <li>✅ My PC can handle a modern game (SSD is available)</li>
              </ul>
            </div>
          </div>

          <div>
            <div class="tableWrap">
              <table class="table">
                <thead>
                  <tr>
                    <th>Your score</th>
                    <th>Recommendation</th>
                    <th>Next step</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <th>0–3</th>
                    <td>Don’t buy yet. Watch gameplay and learn what the game actually is.</td>
                    <td><a href="#what-you-get">What you actually get →</a></td>
                  </tr>
                  <tr>
                    <th>4–6</th>
                    <td>Try Free Fly first. It’s the safest way to find out if the loop clicks for you.</td>
                    <td><a href="/free-fly/">Free Fly guide →</a></td>
                  </tr>
                  <tr>
                    <th>7–8</th>
                    <td>Buying the minimum starter package makes sense — start small, then upgrade later.</td>
                    <td><a href="#safe-start">Safest way to start →</a></td>
                  </tr>
                </tbody>
              </table>
            </div>

            <div class="callout" style="margin-top: 12px;">
              <b>Micro rule:</b> If you’re mostly excited but worried about performance, fix FPS first — it changes the entire first impression.
              <a href="/star-citizen-performance-guide/" style="margin-left: 8px;">Fix stutter →</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- DECISION TABLE -->
    <section id="decision-table" class="section">
      <div class="card pad">
        <h2 class="section__title">Decision table: who should buy Star Citizen?</h2>
        <p style="max-width: 980px;">
          This table is the heart of the page. Find your player type, read the honest trade-offs,
          then follow the recommended start.
        </p>

        <div class="tableWrap" style="margin-top: 12px;">
          <table class="table">
            <thead>
              <tr>
                <th>You are…</th>
                <th>You’ll love…</th>
                <th>You’ll hate…</th>
                <th>Worth it?</th>
                <th>Simplest start</th>
                <th>Next SCB page</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th>Explorer / immersion player</th>
                <td>Scale, atmosphere, travel, “living world” vibes</td>
                <td>Strict objectives and scripted pacing</td>
                <td><b>Yes</b> (if you accept learning friction)</td>
                <td>Free Fly → then minimum starter package</td>
                <td><a href="/beginner-tips/">Beginner priorities →</a></td>
              </tr>
              <tr>
                <th>Progression grinder</th>
                <td>Loop mastery, upgrades, earning and optimizing</td>
                <td>Instant rewards and “win in 10 minutes” design</td>
                <td><b>Usually yes</b></td>
                <td>Starter package → money loop → upgrades</td>
                <td><a href="/make-money-fast/">Make money fast →</a></td>
              </tr>
              <tr>
                <th>Combat-focused (PvE)</th>
                <td>Ship combat, bounty progression, skill improvement</td>
                <td>Long travel and prep if you want “quick matches”</td>
                <td><b>Depends</b> (time-to-fun matters)</td>
                <td>Start low tier, scale gradually</td>
                <td><a href="/star-citizen-performance-guide/">FPS & settings →</a></td>
              </tr>
              <tr>
                <th>Social / org player</th>
                <td>Emergent moments with friends, roles, events</td>
                <td>Solo “what do I do now?” moments</td>
                <td><b>Yes</b> (with people)</td>
                <td>Join a beginner-friendly group</td>
                <td><a href="/beginner-tips/#social">Social starters →</a></td>
              </tr>
              <tr>
                <th>Polish-first / campaign gamer</th>
                <td>Guided missions with consistent flow</td>
                <td>Sandbox friction and rough edges</td>
                <td><b>Often no</b></td>
                <td>Try Free Fly only, then decide</td>
                <td><a href="#what-you-get">What you get →</a></td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="callout" style="margin-top: 12px;">
          <b>Beginner rule:</b> If you don’t have fun in your first 3–5 sessions, it’s usually because your first loop was too complex.
          Use the first-hour route below and keep it simple.
        </div>
      </div>
    </section>

    <!-- WHAT YOU GET -->
    <section id="what-you-get" class="section">
      <div class="card pad">
        <h2 class="section__title">What you actually get (no hype, just reality)</h2>

        <div class="grid2" style="margin-top: 12px; align-items: start;">
          <div>
            <img
              src={buyImg}
              alt="Star Citizen buying decision visual"
              loading="lazy"
              decoding="async"
              width="1536"
              height="1024"
              style="border-radius: 18px; width:100%; height:auto;"
            />
          </div>

          <div>
            <div class="tableWrap">
              <table class="table">
                <thead>
                  <tr>
                    <th>What you do</th>
                    <th>Feels like</th>
                    <th>Best for</th>
                    <th>Where people get disappointed</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <th>Ship life (spawn → fly → land)</th>
                    <td>Slow-burn immersion + huge scale</td>
                    <td>Explorers, sim vibes</td>
                    <td>Expecting instant action every minute</td>
                  </tr>
                  <tr>
                    <th>Contracts & money loops</th>
                    <td>Repeatable loops → upgrades → bigger loops</td>
                    <td>Grinders, optimizers</td>
                    <td>Jumping between 10 activities with no plan</td>
                  </tr>
                  <tr>
                    <th>Combat (ship + FPS)</th>
                    <td>Skill matters; preparation matters</td>
                    <td>Combat-focused players</td>
                    <td>Wanting instant match-based pacing</td>
                  </tr>
                  <tr>
                    <th>Social/emergent moments</th>
                    <td>Unscripted stories and chaos</td>
                    <td>Group play, orgs</td>
                    <td>Playing solo with zero direction</td>
                  </tr>
                </tbody>
              </table>
            </div>

            <div class="callout" style="margin-top: 12px;">
              <b>Reality check:</b> Your experience is heavily shaped by two things: (1) your first loop and (2) your performance.
              Fix those early, and the game reads very differently.
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SAFE START -->
    <section id="safe-start" class="section">
      <div class="card pad">
        <h2 class="section__title">Safest way to start (spend the minimum)</h2>
        <p style="max-width: 980px;">
          This is a beginner funnel, but it’s also just good consumer advice: validate that you enjoy the loop
          before you upgrade anything.
        </p>

        <div class="tableWrap" style="margin-top: 12px;">
          <table class="table">
            <thead>
              <tr>
                <th>Option</th>
                <th>Who it’s for</th>
                <th>Why it’s smart</th>
                <th>Common mistake</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th>Try Free Fly first</th>
                <td>Anyone unsure</td>
                <td>Zero spend, real hands-on feel</td>
                <td>Judging after one chaotic session</td>
              </tr>
              <tr>
                <th>Buy the minimum starter package</th>
                <td>You’re excited and ready to learn</td>
                <td>Lowest commitment path to real progression</td>
                <td>Buying extra ships immediately</td>
              </tr>
              <tr>
                <th>Upgrade later (only if you keep playing)</th>
                <td>You’ve logged multiple sessions</td>
                <td>You now know your playstyle (combat, trade, mining)</td>
                <td>Upgrading to “fix boredom” instead of fixing your loop</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="grid2" style="margin-top: 12px;">
          <div class="callout">
            <b>If you decide to buy:</b> do it correctly.
            <ul class="list" style="margin-top: 8px;">
              <li>Start with the <b>minimum</b> package.</li>
              <li>Claim your free signup bonus first (optional).</li>
              <li>Then follow the 60-minute route below to get your first win.</li>
            </ul>
            <div class="btnrow" style="margin-top: 10px;">
              <a class="btn primary" href={referralLink} target="_blank" rel="noopener noreferrer">Claim +{referralBonusUEC} UEC bonus</a>
              <a class="btn secondary" href="/star-citizen-referral-code/">How referral works</a>
            </div>
          </div>

          <div class="callout">
            <b>Want to buy smarter?</b>
            <ul class="list" style="margin-top: 8px;">
              <li>Pick a starter that matches your first loop.</li>
              <li>Avoid paying for roles you won’t play.</li>
              <li>Upgrade only after you’ve earned your first aUEC reliably.</li>
            </ul>
            <div class="btnrow" style="margin-top: 10px;">
              <a class="btn secondary" href="/star-citizen-starter-packs/">Best starter packs →</a>
              <a class="btn secondary" href="/make-money-fast/">Make money fast →</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FIRST HOUR -->
    <section id="first-hour" class="section">
      <div class="card pad">
        <h2 class="section__title">Your first 60 minutes (do this now)</h2>
        <p style="max-width: 980px;">
          Most “Star Citizen is boring” experiences happen because the first session is chaotic.
          Follow this route once. It’s designed to give you a clean first win.
        </p>

        <div class="grid2" style="margin-top: 12px; align-items: start;">
          <div>
            <div class="callout">
              <b>Time:</b> 60 minutes
              <ol class="list" style="margin-top: 8px;">
                <li><b>Pick one goal:</b> complete one simple contract (nothing else).</li>
                <li><b>Claim your ship</b> and fly carefully (don’t rush takeoff/landing).</li>
                <li><b>Take one beginner contract</b> (courier/delivery is ideal).</li>
                <li><b>Finish the loop</b> and confirm the payout.</li>
                <li><b>Repeat once</b> to lock in the muscle memory.</li>
                <li><b>Stop while it’s good:</b> end the session with a win, not frustration.</li>
              </ol>
            </div>
          </div>

          <div>
            <div class="tableWrap">
              <table class="table">
                <thead>
                  <tr>
                    <th>Verification</th>
                    <th>What “good” looks like</th>
                    <th>If not…</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <th>You completed 1 contract</th>
                    <td>You now understand terminals, travel, and mission flow</td>
                    <td>Repeat the same simple mission once more</td>
                  </tr>
                  <tr>
                    <th>You can land without panic</th>
                    <td>Travel stops feeling like friction</td>
                    <td>Slow down; treat landing like a skill, not a chore</td>
                  </tr>
                  <tr>
                    <th>The game feels playable</th>
                    <td>You can judge the loop fairly</td>
                    <td><a href="/star-citizen-performance-guide/">Do the 10-minute performance fixes</a></td>
                  </tr>
                </tbody>
              </table>
            </div>

            <div class="btnrow" style="margin-top: 12px;">
              <a class="btn secondary" href="/beginner-tips/">Beginner tips (next) →</a>
              <a class="btn secondary" href="/make-money-fast/">First money loop →</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- PERFORMANCE -->
    <section id="performance" class="section">
      <div class="card pad">
        <h2 class="section__title">Performance reality (don’t let FPS ruin the decision)</h2>
        <p style="max-width: 980px;">
          Your first impression is fragile. If your game stutters badly, you’ll judge the loop unfairly.
          Fix the high-impact basics first.
        </p>

        <div class="grid2" style="margin-top: 12px;">
          <div class="callout">
            <b>High-impact basics:</b>
            <ul class="list" style="margin-top: 8px;">
              <li>Install the game on an <b>SSD</b> (not HDD).</li>
              <li>Close overlays and background apps that hook the GPU.</li>
              <li>Use the recommended in-game settings changes from our guide.</li>
            </ul>
            <div class="btnrow" style="margin-top: 10px;">
              <a class="btn primary" href="/star-citizen-performance-guide/#do-now">Do the 10-minute fixes</a>
              <a class="btn secondary" href="/star-citizen-performance-guide/">Full performance guide</a>
            </div>
          </div>

          <div class="callout">
            <b>If you’re on Free Fly:</b> treat it like a test drive.
            <ul class="list" style="margin-top: 8px;">
              <li>Pick one location and compare before/after fixes.</li>
              <li>Don’t chase “perfect FPS” — chase “playable and smooth enough”.</li>
              <li>Once it feels stable, judge the game on gameplay — not stutter.</li>
            </ul>
            <div class="btnrow" style="margin-top: 10px;">
              <a class="btn secondary" href="/free-fly/">Free Fly guide →</a>
              <a class="btn secondary" href="/make-money-fast/">Money loops →</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- MISTAKES -->
    <section id="mistakes" class="section">
      <div class="card pad">
        <h2 class="section__title">Common mistakes (and exact fixes)</h2>

        <div class="tableWrap" style="margin-top: 12px;">
          <table class="table">
            <thead>
              <tr>
                <th>Mistake</th>
                <th>What happens</th>
                <th>Fix (exact)</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th>Expecting a guided “campaign” loop</th>
                <td>You feel lost and bored</td>
                <td>Pick one loop (courier or bounties) and repeat it twice before exploring</td>
              </tr>
              <tr>
                <th>Overspending early</th>
                <td>Regret, buyer’s remorse, wrong role</td>
                <td>Start with minimum package; upgrade only after you’ve played multiple sessions</td>
              </tr>
              <tr>
                <th>Judging after one bad session</th>
                <td>You quit before the “click”</td>
                <td>Do the first-hour route + performance basics, then decide</td>
              </tr>
              <tr>
                <th>Trying 10 systems at once</th>
                <td>Overwhelm and no progress</td>
                <td>One goal per session: one contract, one upgrade, one new mechanic</td>
              </tr>
              <tr>
                <th>Letting stutter define your verdict</th>
                <td>Gameplay feels worse than it is</td>
                <td>SSD + 10-minute settings fixes, then retest in the same area</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="callout" style="margin-top: 12px;">
          <b>If you only do one thing:</b> keep your first loop simple and repeat it once. That single choice changes the entire first week.
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq" class="section">
