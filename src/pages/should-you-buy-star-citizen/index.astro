---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReferralBanner from "../../components/ReferralBanner.astro";
import OnThisPage from "../../components/OnThisPage.astro";
import FaqSchema from "../../components/FaqSchema.astro";
import HowToSchema from "../../components/HowToSchema.astro";
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { REFERRAL_CODE, REFERRAL_LINK, REFERRAL_INFO_PATH, REFERRAL_BONUS_UEC, FLY_FREE_URL } from "../../config/site";

const referralCode = REFERRAL_CODE;
const referralBonusUEC = REFERRAL_BONUS_UEC;
const referralLink = REFERRAL_LINK;

const heroImg = "/assets/img/should-you-buy-star-citizen/star-citizen-multiplayer-fleet-hero.webp";
const buyImg = "/assets/img/should-you-buy-star-citizen/star-citizen-buy-or-not.webp";

const tocItems = [
  { label: "Quick answer", href: "#tldr" },
  { label: "Quick buy check", href: "#decision-test" },
  { label: "Who usually enjoys it", href: "#decision-table" },
  { label: "What you actually get", href: "#what-you-get" },
  { label: "Buying guide: how to buy", href: "#buying-guide" },
  { label: "The easiest way to start", href: "#safe-start" },
  { label: "Your first 60 minutes: do this now", href: "#first-hour" },
  { label: "Performance reality: don’t let FPS ruin it", href: "#performance" },
  { label: "Common mistakes and fixes", href: "#mistakes" },
  { label: "FAQ", href: "#faq" },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Do I need a game package to play Star Citizen?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. A starter package is required to play outside Free Fly events. Free Fly lets you try the game temporarily without buying."
      }
    },
    {
      "@type": "Question",
      "name": "Is Star Citizen worth it for casual players?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "It can be — if you enjoy sandbox games and don’t mind learning a few core systems. If you want a polished, guided campaign experience every session, you may enjoy it less."
      }
    },
    {
      "@type": "Question",
      "name": "What’s the easiest way to start without overspending?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Try Free Fly first if available. If you buy, start with the minimum starter package, play a few sessions, and only upgrade after you know what you enjoy."
      }
    },
    {
      "@type": "Question",
      "name": "Should I buy extra ships right away?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Usually no. Learn your preferred playstyle first. Many players spend more than they need early and then realize they prefer different roles later."
      }
    },
    {
      "@type": "Question",
      "name": "Do referral codes cost money?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. A referral code is free. It’s simply a signup bonus you can apply when you create your account."
      }
    },
    {
      "@type": "Question",
      "name": "What if performance is bad on my PC?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Start by confirming the game is installed on an SSD and apply a few high-impact settings changes. Our performance guide gives a concrete checklist and the fastest fixes first."
      }
    },
    {
      "@type": "Question",
      "name": "What’s the easiest way to try Star Citizen first?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Try Free Fly first if one is available. If not, buy the minimum starter package only, then follow a simple first-session checklist before spending anything else."
      }
    },
    {
      "@type": "Question",
      "name": "Is Star Citizen pay-to-win?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "You can buy ships, but the smartest approach is still to start minimal and upgrade later if you keep playing. Early progress comes from learning the loop, not owning a big ship."
      }
    },
    {
      "@type": "Question",
      "name": "How long until Star Citizen clicks for most beginners?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Rule-of-thumb: give it 3–5 sessions. Session 1 is often setup-heavy; sessions 2–5 are where you learn the loop and decide if the sandbox style is for you."
      }
    },
    {
      "@type": "Question",
      "name": "Do I need friends or an org to enjoy it?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No, but it helps. Solo play is totally viable, yet the game shines with other players. If you’re on the fence, try one or two social sessions before deciding."
      }
    }
  ]
};

const howToJsonLd = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "Your first 60 minutes in Star Citizen",
  "description": "A simple first session: get your ship, fly an easy contract, earn your first credits, and log out feeling like the game makes more sense.",
  "totalTime": "PT60M",
  "step": [
    { "@type": "HowToStep", "name": "Set expectations and keep it simple", "text": "Pick one small goal for your first session: one contract completed. Avoid shopping and distractions until you get your first payout." },
    { "@type": "HowToStep", "name": "Spawn, gear up lightly, and claim your ship", "text": "Equip a basic undersuit and helmet if you plan to leave the station. Claim your ship at the terminal and head to the hangar." },
    { "@type": "HowToStep", "name": "Take one beginner-friendly contract", "text": "Choose a simple courier/delivery contract or an easy legal mission. Avoid multi-step chains on your very first run." },
    { "@type": "HowToStep", "name": "Complete the loop and get paid", "text": "Fly to the objective, finish the task, and confirm you received the payout before you take the next mission." },
    { "@type": "HowToStep", "name": "Lock in momentum", "text": "Repeat the same loop once more, then stop. Consistency beats complexity early." }
  ]
};
---

<BaseLayout
  title="Should You Buy Star Citizen? Honest Beginner Guide"
  description="Not sure if Star Citizen is for you? Use this quick buy guide, see who should wait, and learn the easiest way to start without overspending."
  canonicalPath="/should-you-buy-star-citizen/"
  ogImage={heroImg}
  ogImageAlt="Star Citizen fleet scene representing the buying decision"
  stickyCtaLabel="Claim +50k UEC start bonus"
  stickyCtaHref={referralLink}
  stickyCtaExternal={true}
  activeNav="guides"
>
  <link slot="head" rel="preload" as="image" href={heroImg} imagesrcset={`${heroImg} 1536w`} />

  <FaqSchema json={faqJsonLd} />
  <HowToSchema json={howToJsonLd} />

  <main>

    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Starter guides', href: '/#pick-your-path' }, { label: 'Should you buy Star Citizen', href: '/should-you-buy-star-citizen/' }]} />
    <!-- HERO (must match global landing page hero layout) -->
    <section class="hero guideHero">
      <img
        class="hero__img"
        src={heroImg}
        alt="A Star Citizen fleet in space — a cinematic moment that sells the dream"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1536"
        height="1024"
      />
      <div class="hero__overlay"></div>

      <div class="hero__content">
        <div class="guideHero__content">
          <div class="kicker"><span class="dot"></span> Buying Guide</div>
          <h1 class="h1">Should You Buy Star Citizen?</h1>
          <p class="lead" style="max-width: 920px;">Not sure if you will actually enjoy Star Citizen? This page gives you a fast, honest answer and shows how to try it without making one rough session decide everything for you.</p>

          <div class="btnrow" style="margin-top: 14px;">
            <a class="btn primary" href="#decision-test" data-scb-role="decision-test-start">Use the quick buy check</a>
</div>
</div>
      </div>

      <OnThisPage variant="hero" title="On this page" items={tocItems} />
    </section>

    <!-- Referral banner (consistent site-wide; subtle funnel) -->
    <ReferralBanner
      code={referralCode}
      bonus={`${referralBonusUEC} UEC`}
            ctaLabel="Claim your free start bonus"
ctaHref={referralLink}
      howItWorksHref="/star-citizen-referral-code/#how-to-use"
      sublineHtml="If you decide to buy, use it during signup. It is free, simple, and easiest to do right away."
      ariaLabel="Referral bonus callout"
    />

    <!-- Quick answer -->
    <section id="tldr" class="section">
      <div class="card pad">
        <h2 class="section__title">Quick answer: the honest short version</h2>

        <div class="decisionGrid" style="margin-top:14px; margin-bottom:14px;">
          <div class="decisionCard">
            <div class="decisionCard__kicker">Buy now</div>
            <div class="decisionCard__title">You enjoy sandboxes and self-directed play</div>
            <p class="decisionCard__body">You are okay learning a few systems and making your own momentum instead of expecting the game to guide every step.</p>
          </div>
          <div class="decisionCard">
            <div class="decisionCard__kicker">Try first</div>
            <div class="decisionCard__title">You are curious but not sold yet</div>
            <p class="decisionCard__body">Use Free Fly or start with the minimum package. That gives you a fair feel for the game before you commit further.</p>
          </div>
          <div class="decisionCard">
            <div class="decisionCard__kicker">Skip for now</div>
            <div class="decisionCard__title">You want a smoother, more guided game every session</div>
            <p class="decisionCard__body">You will probably notice the friction faster than the magic, especially if you do not enjoy figuring things out as you go.</p>
          </div>
        </div>

        <div class="tableWrap" style="margin-top:12px;">
          <table class="table">
            <thead>
              <tr>
                <th>If this sounds like you</th>
                <th>Best call</th>
                <th>Why</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th>You like sandboxes, self-made goals, and learning through repetition</th>
                <td><b>Buy</b></td>
                <td>The game is strongest when you enjoy building your own momentum rather than following a tight script.</td>
              </tr>
              <tr>
                <th>You want a polished, guided campaign-like experience every session</th>
                <td><b>Skip for now</b></td>
                <td>You are more likely to notice friction than magic.</td>
              </tr>
              <tr>
                <th>You are curious, but not yet convinced</th>
                <td><b>Try Free Fly first</b></td>
                <td>It lets you test the feel of the game before you spend money.</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="grid2" style="margin-top:12px;">
          <div>
            <ul class="list">
              <li><b>Paid start:</b> buy the <b>minimum game package</b>, not the dream ship.</li>
              <li><b>You do not need a subscription:</b> one game package is enough to start playing outside Free Fly.</li>
              <li><b>Do not overspend early:</b> upgrade only after a few sessions when you know your actual playstyle.</li>
              <li><b>Performance matters:</b> install on an SSD and do the 10-minute fixes before you decide how the game really feels.
                <a href="/star-citizen-performance-guide/" style="margin-left: 6px;">Performance guide →</a>
              </li>
            </ul>
            <p class="muted" style="margin-top:10px;">Need a term explained? <a class="link" href="/satellites/glossary/">Open the beginner glossary</a>.</p>
          </div>

          <div class="callout">
            <div class="kicker"><span class="dot"></span> Best beginner sequence</div>
            <ol class="list" style="margin-top:8px; padding-left:18px;">
              <li>Run the Quick buy check.</li>
              <li>Try Free Fly if it is available.</li>
              <li>If you buy, buy one game package only.</li>
              <li>Judge the game after 3–5 sessions, not one messy spawn.</li>
            </ol>
            <div class="btnrow" style="margin-top: 12px;">
              <a class="btn secondary" href="/make-money-fast/">What to do after buying →</a>
            </div>
            <p class="muted" style="margin-top:10px;">A fair beginner test is simple: install on an SSD, run one easy session, then decide after a few tries instead of one messy spawn.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- DECISION TEST -->
    <section id="decision-test" class="section">
      <div class="card pad">
        <h2 class="section__title">Quick buy check</h2>
        <p style="max-width: 980px;">
          Check the boxes that sound like you. Then use the score to choose the next step that fits you best.
          This is designed for <b>beginners</b> and <b>Free Fly</b> players who want a clear answer without turning the first week into a huge commitment.
        </p>

        <div class="grid2" style="margin-top: 12px; align-items: start;">
          <div>
            <h3 class="h3">Check what’s true for you</h3>
            <p style="margin-top:6px; color: rgba(255,255,255,.76);">
              Count your <b>yes</b> answers. Don’t overthink it — this is about expectations, not skill.
            </p>
            <ul class="list" style="margin-top:10px;">
              <li>☐ I enjoy sandbox games where I set my own goals.</li>
              <li>☐ I can handle rough edges (bugs/friction) without rage-quitting.</li>
              <li>☐ I’m willing to play <b>at least 3 sessions</b> before judging it.</li>
              <li>☐ I like learning systems (ships, travel, missions, inventory) over time.</li>
              <li>☐ I’m okay if one session sometimes goes sideways — I’ll try again.</li>
              <li>☐ I’m excited by immersion and scale (even if it’s not “perfect”).</li>
              <li>☐ I’m fine starting small (minimum package) and upgrading later.</li>
              <li>☐ I have or can meet the basics: <b>SSD</b> + stable performance setup.
                <a href="/star-citizen-performance-guide/" style="margin-left:6px;">Fix FPS fast →</a>
              </li>
            </ul>

            <p style="margin-top:10px; color: rgba(255,255,255,.72);">
              <b>Micro rule:</b> if you’re mostly excited but worried about performance, do the 10‑minute performance fixes
              before you judge the game — it changes the entire first impression.
            </p>
</div>

          <div>
            <div class="tableWrap">
              <table class="table">
                <thead>
                  <tr>
                    <th>Your score</th>
                    <th>Recommendation</th>
                    <th>Next step</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <th>0–2</th>
                    <td>Don’t buy yet. Watch gameplay and learn what the game actually is.</td>
                    <td><a href="#what-you-get">What you actually get →</a></td>
                  </tr>
                  <tr>
                    <th>3–5</th>
                    <td>Try Free Fly first. It is the easiest way to find out if the game really clicks for you.</td>
                    <td><a href="/free-fly/">Free Fly guide →</a></td>
                  </tr>
                  <tr>
                    <th>6–8</th>
                    <td>Buying the minimum starter package makes sense — start small, then upgrade only after a few sessions.</td>
                    <td><a href="#safe-start">The easiest way to start →</a></td>
                  </tr>
                </tbody>
              </table>
            </div>
</div>
        </div>
      </div>
    </section>

    <!-- DECISION TABLE -->
    <section id="decision-table" class="section">
      <div class="card pad">
        <h2 class="section__title">Who usually enjoys it, and who usually doesn’t</h2>
        <p style="max-width: 980px;">
          This table is the heart of the page. Find your player type, read the honest trade-offs,
          then follow the recommended start.
        </p>

    <!-- Contextual referral CTA (banner stays only once, below hero) -->
    <p style="margin-top: 14px; max-width: 980px;">
      <b>New account?</b> If you decide to buy, grab the free signup bonus first — it only applies during account creation.
    </p>
    <div class="btnrow" style="margin-top: 10px; flex-wrap: wrap;">
      <a class="btn primary" href={referralLink} target="_blank" rel="nofollow noopener noreferrer" data-scb-role="referral-signup">Create account + get +{referralBonusUEC} UEC</a>
      <button class="codePill js-copyCode" type="button" data-copy-referral={referralCode} aria-label={`Copy referral code ${referralCode} to clipboard`} title="Click to copy">Copy code: {referralCode}</button>
    </div>

<div class="tableWrap" style="margin-top: 12px;">
          <table class="table">
            <thead>
              <tr>
                <th>You are…</th>
                <th>You’ll love…</th>
                <th>You’ll hate…</th>
                <th>Worth it?</th>
                <th>Simplest start</th>
                <th>Next SCB page</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th>Explorer / immersion player</th>
                <td>Scale, atmosphere, travel, “living world” vibes</td>
                <td>Strict objectives and scripted pacing</td>
                <td><b>Yes</b> (if you accept learning friction)</td>
                <td>Free Fly → then minimum starter package</td>
                <td><a href="/beginner-tips/">Beginner priorities →</a></td>
              </tr>
              <tr>
                <th>Progression grinder</th>
                <td>Loop mastery, upgrades, earning and optimizing</td>
                <td>Instant rewards and “win in 10 minutes” design</td>
                <td><b>Usually yes</b></td>
                <td>Starter package → money loop → upgrades</td>
                <td><a href="/make-money-fast/">Make money fast →</a></td>
              </tr>
              <tr>
                <th>Combat-focused (PvE)</th>
                <td>Ship combat, bounty progression, skill improvement</td>
                <td>Long travel and prep if you want “quick matches”</td>
                <td><b>Depends</b> (time-to-fun matters)</td>
                <td>Start small and build from there</td>
                <td><a href="/star-citizen-performance-guide/">FPS & settings →</a></td>
              </tr>
              <tr>
                <th>Social / org player</th>
                <td>Emergent moments with friends, roles, events</td>
                <td>Solo “what do I do now?” moments</td>
                <td><b>Yes</b> (with people)</td>
                <td>Join a beginner-friendly group</td>
                <td><a href="/beginner-tips/#social">Social starters →</a></td>
              </tr>
              <tr>
                <th>Polish-first / campaign gamer</th>
                <td>Guided missions with consistent flow</td>
                <td>Sandbox friction and rough edges</td>
                <td><b>Often no</b></td>
                <td>Try Free Fly only, then decide</td>
                <td><a href="#what-you-get">What you get →</a></td>
              </tr>
            </tbody>
          </table>
        </div>
</div>
    </section>

    <!-- WHAT YOU GET -->
    <section id="what-you-get" class="section">
      <div class="card pad">
        <h2 class="section__title">What you actually get (no hype, just reality)</h2>

        <div class="grid2" style="margin-top: 12px; align-items: start;">
          <div>
            <img
              src={buyImg}
              alt="Star Citizen buying decision visual"
              loading="lazy"
              decoding="async"
              width="1536"
              height="1024"
              style="border-radius: 18px; width:100%; height:auto;"
            />
          </div>

          <div>
            <div class="tableWrap">
              <table class="table">
                <thead>
                  <tr>
                    <th>What you do</th>
                    <th>Feels like</th>
                    <th>Best for</th>
                    <th>Where people get disappointed</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <th>Ship life (spawn → fly → land)</th>
                    <td>Slow-burn immersion + huge scale</td>
                    <td>Explorers, sim vibes</td>
                    <td>Expecting instant action every minute</td>
                  </tr>
                  <tr>
                    <th>Contracts & money loops</th>
                    <td>Repeatable loops → upgrades → bigger loops</td>
                    <td>Grinders, optimizers</td>
                    <td>Jumping between 10 activities with no plan</td>
                  </tr>
                  <tr>
                    <th>Combat (ship + FPS)</th>
                    <td>Skill matters; preparation matters</td>
                    <td>Combat-focused players</td>
                    <td>Wanting instant match-based pacing</td>
                  </tr>
                  <tr>
                    <th>Social/emergent moments</th>
                    <td>Unscripted stories and chaos</td>
                    <td>Group play, orgs</td>
                    <td>Playing solo with zero direction</td>
                  </tr>
                </tbody>
              </table>
            </div>
</div>
        </div>
      </div>
    </section>

    <!-- BUYING GUIDE (how to buy) -->
    <section id="buying-guide" class="section">
  <div class="card pad">
    <h2 class="section__title">Buying guide: how to buy without overdoing it</h2>
    <p style="max-width: 980px;">
      If you decided “yes”, keep it simple: buy one game package that lets you play, apply the signup bonus
      during account creation, and only upgrade after you’ve completed a few clean sessions.
    </p>

    <div class="tableWrap" style="margin-top:12px;">
      <table class="table table--steps">
        <thead>
          <tr>
            <th>Step</th>
            <th>Do this</th>
            <th>Why it matters</th>
            <th>Common mistake</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <th>1</th>
            <td>
              Create your RSI account and enter referral code <b>{referralCode}</b> during signup.
              <div class="btnrow" style="margin-top:10px; flex-wrap:wrap;">
                <a class="btn secondary" href={referralLink}>Claim +{referralBonusUEC} UEC start bonus</a>
                <button class="codePill js-copyCode" type="button" data-copy-referral={referralCode} aria-label={`Copy referral code ${referralCode} to clipboard`} title="Click to copy">Copy code: {referralCode}</button>
              </div>
            </td>
            <td>
              The bonus only applies during account creation. It doesn’t change your price — it just adds starting credits.
            </td>
            <td>Creating the account first, then trying to add the code later.</td>
          </tr>
          <tr>
            <th>2</th>
            <td>
              Choose a starter pack that matches your first loop (delivery / light combat / general).
              <div class="btnrow" style="margin-top:10px; flex-wrap:wrap;">
                <a class="btn secondary" href="/star-citizen-starter-packs/">Pick a starter pack (no fluff) →</a>
              </div>
            </td>
            <td>
              Starter packs include game access + a ship. Buying extra ships early is the #1 regret pattern.
            </td>
            <td>Buying based on looks or “big ship” hype, then bouncing after a rough first session.</td>
          </tr>
          <tr>
            <th>3</th>
            <td>
              Install and run one simple first session (60 minutes max) before you judge the game.
              <div class="btnrow" style="margin-top:10px; flex-wrap:wrap;">
                <a class="btn secondary" href="/satellites/first-session/">First good session guide →</a>
                <a class="btn secondary" href="/star-citizen-performance-guide/">If it stutters: 10‑minute fix →</a>
              </div>
            </td>
            <td>
              Most “this game is awful” experiences are actually performance / setup / expectation issues.
            </td>
            <td>Quitting after one bad spawn or laggy server before you have tried one calmer session.</td>
          </tr>
          <tr>
            <th>4</th>
            <td>
              Keep your spend minimal for your first week. Upgrade only after repeatable wins.
            </td>
            <td>
              Your real goal is one simple loop you enjoy. Once that is true, upgrades are much easier to judge.
            </td>
            <td>“All‑in” spending before you even know your playstyle.</td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="card" style="margin-top:14px;">
      <div class="pad">
        <div class="kicker"><span class="dot"></span>Decision rule</div>
        <p style="margin:0;">
          If you can complete <b>one full contract loop</b> (spawn → ship → contract → payout → safe log out)
          without rage‑quitting, you’re past the “first session trap”. That’s the point where buying upgrades makes sense.
        </p>
      </div>
    </div>
  </div>
</section>



    <!-- SAFE START -->
    <section id="safe-start" class="section">
      <div class="card pad">
        <h2 class="section__title">The easiest way to start: spend the minimum</h2>
        <p style="max-width: 980px;">
          This is a beginner funnel, but it’s also just good consumer advice: validate that you enjoy the loop
          before you upgrade anything.
        </p>

    <!-- Contextual referral CTA (banner stays only once, below hero) -->
    <p style="margin-top: 14px; max-width: 980px;">
      <b>New account?</b> A referral code gives you a free starting credit boost — only during signup.
    </p>
    <div class="btnrow" style="margin-top: 10px; flex-wrap: wrap;">
      <a class="btn secondary" href={referralLink}>Claim your start bonus +{referralBonusUEC} UEC</a>
      <button class="codePill js-copyCode" type="button" data-copy-referral={referralCode} aria-label={`Copy referral code ${referralCode} to clipboard`} title="Click to copy">Copy code: {referralCode}</button>
    </div>

<div class="tableWrap" style="margin-top: 12px;">
          <table class="table">
            <thead>
              <tr>
                <th>Option</th>
