---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ReferralBanner from "../../../components/ReferralBanner.astro";
import OnThisPage from "../../../components/OnThisPage.astro";
import FaqSchema from "../../../components/FaqSchema.astro";

const referralCode = "STAR-FSRJ-5N7Z";
const referralLink = `https://www.robertsspaceindustries.com/enlist?referral=${referralCode}`;

const heroImg = "/assets/img/performance/star-citizen-performance-guide-hero.webp";

const tocItems = [
  { id: "quick-answer", label: "What you’ll learn" },
  { id: "do-this-now", label: "2-minute test" },
  { id: "common-mistakes", label: "Misreads to avoid" },
  { id: "next-steps", label: "Next steps" },
  { id: "faq", label: "FAQ" }
];

const faqItems = [
  { q: "Can I see CPU/GPU usage instead?", a: "You can, but in-game feel + resolution test is often enough to pick the right direction." },
  { q: "What if both feel bad?", a: "Fix storage/RAM/pagefile first, then retest. Stutter can mask the true bottleneck." },
  { q: "Why does lowering resolution not help sometimes?", a: "Because the CPU (or server load) is limiting frame production, not the GPU." },
  { q: "Should I upgrade CPU or GPU first?", a: "Run the test. If resolution changes FPS a lot → GPU. If not → CPU or system bottleneck." },
  { q: "Where’s the full settings list?", a: "Use the performance guide’s “top levers” table and decision rules." }
];
---

<BaseLayout
  title="CPU vs GPU Bottleneck Test (2 Minutes) | Star Citizen Beginner"
  description="Not sure what to upgrade or which settings matter? This 2‑minute test tells you if you’re CPU‑bound or GPU‑bound — then gives the right next step."
  canonicalPath="/satellites/cpu-vs-gpu-bottleneck-test/"
  ogImage={heroImg}
  ogImageAlt="CPU vs GPU Bottleneck Test (2 Minutes) hero image"
  stickyCtaLabel="Create account + claim bonus"
  stickyCtaHref={referralLink}
  stickyCtaExternal={true}
  activeNav="guides"
>
  <main>
    <section class="hero guideHero">
      <img
        class="hero__img"
        src={heroImg}
        alt="CPU vs GPU Bottleneck Test (2 Minutes)"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1536"
        height="1024"
      />
      <div class="hero__overlay"></div>

      <div class="hero__content">
        <div class="guideHero__content">
          <div class="kicker"><span class="dot"></span> Starter Guide</div>
          <h1 class="h1">CPU vs GPU Bottleneck Test (2 Minutes)</h1>
          <p class="lead" style="max-width: 820px;">Not sure what to upgrade or which settings matter? This 2‑minute test tells you if you’re CPU‑bound or GPU‑bound — then gives the right next step.</p>

          <div class="hero__cta">
            <a class="btn primary" href="#quick-answer">Start here</a>
          </div>
        </div>

        <OnThisPage variant="hero" title="On this page" items={tocItems} />
      </div>
    </section>

    <ReferralBanner
      code={referralCode}
      bonus="50,000"
      ctaLabel="Create account + claim bonus"
      ctaHref={referralLink}
      ctaExternal={true}
    />

    <section id="quick-answer" class="section">
      <div class="container">
        <h2 class="h2">Quick answer</h2>
        <ul class="bullets">
          <li>If you’re <b>CPU‑bound</b>, lowering resolution won’t help much — you need CPU-friendly settings and smoother server/time choices.</li>
<li>If you’re <b>GPU‑bound</b>, resolution and GPU-heavy settings are your main levers.</li>
<li>This test is about <b>direction</b>: what to tweak first and what to ignore.</li>
        </ul>

        <div style="display:flex; flex-wrap:wrap; gap:10px; margin-top: 14px;">
          <a class="btn primary" href={referralLink} rel="nofollow noopener" target="_blank">Create account + claim bonus</a>
          <a class="btn ghost" href="/star-citizen-referral-code/">Where to paste the referral code →</a>
        </div>
      </div>
    </section>

    <section id="do-this-now" class="section alt">
      <div class="container">
        <h2 class="h2">Do this now</h2>
        <ol class="steps">
          <li><b>Pick a repeatable test scene</b> — Use the same location and camera angle for all tests.</li>
<li><b>Run at your normal settings</b> — Note how it feels (stutter vs steady low FPS).</li>
<li><b>Drop resolution / enable upscaling</b> — If FPS jumps a lot: likely GPU‑bound. If it barely moves: likely CPU‑bound.</li>
<li><b>Lower CPU-heavy settings</b> — Try shadows / crowd / draw distance style levers. If this helps: CPU‑bound signals.</li>
<li><b>Choose next action</b> — GPU‑bound → tweak resolution + GPU settings. CPU‑bound → tweak CPU settings + reduce background load.</li>
        </ol>
      </div>
    </section>

    <section id="common-mistakes" class="section">
      <div class="container">
        <h2 class="h2">Common mistakes (and exact fixes)</h2>
        <div class="tableWrap">
          <table class="table">
            <thead>
              <tr>
                <th>Mistake</th>
                <th>What happens</th>
                <th>Fix (exact)</th>
              </tr>
            </thead>
            <tbody>
              <tr><td><b>Testing different places each run</b></td><td>Different loads look like different bottlenecks.</td><td>Retest same scene.</td></tr>
<tr><td><b>Changing many settings at once</b></td><td>You can’t attribute the result.</td><td>Change one cluster per test.</td></tr>
<tr><td><b>Upgrading blindly</b></td><td>You spend money without knowing the limit.</td><td>Run the 2‑minute test first, then decide.</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section id="next-steps" class="section alt">
      <div class="container">
        <h2 class="h2">Next steps</h2>
        <ul class="bullets">
          <li><a href="/star-citizen-performance-guide/">Performance guide (best levers + requirements)</a></li>
<li><a href="/satellites/fix-stuttering/">Fix stuttering checklist</a></li>
<li><a href="/star-citizen-starter-packs/">Only buying? start minimum, upgrade later</a></li>
        </ul>
      </div>
    </section>

    <section id="faq" class="section">
      <div class="container">
        <h2 class="h2">FAQ</h2>
        <div class="faq" style="margin-top:12px;">
          {faqItems.map((item) => (
            <details class="faq__item">
              <summary class="faq__q">{item.q}</summary>
              <div class="faq__a">{item.a}</div>
            </details>
          ))}
        </div>

        <div style="display:flex; flex-wrap:wrap; gap:10px; margin-top: 18px;">
          <a class="btn primary" href={referralLink} rel="nofollow noopener" target="_blank">Create account + claim bonus</a>
          <a class="btn ghost" href="/star-citizen-referral-code/">Referral code guide →</a>
        </div>
      </div>

      <FaqSchema items={faqItems} />
    </section>
  </main>
</BaseLayout>
