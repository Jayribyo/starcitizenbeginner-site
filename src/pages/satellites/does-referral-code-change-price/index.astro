---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ReferralBanner from "../../../components/ReferralBanner.astro";
import OnThisPage from "../../../components/OnThisPage.astro";
import FaqSchema from "../../../components/FaqSchema.astro";
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { REFERRAL_CODE, REFERRAL_LINK, REFERRAL_INFO_PATH, REFERRAL_BONUS_UEC, FLY_FREE_URL } from "../../../config/site";

const referralCode = REFERRAL_CODE;
const referralLink = REFERRAL_LINK;

const heroImg = "/assets/img/referral/star-citizen-referral-code-50000-uec-bonus-hero.webp";

const tocItems = [
  { id: "quick-answer", label: "Shortest honest answer" },
  { id: "do-this-now", label: "What to do instead" },
  { id: "common-mistakes", label: "Common confusion" },
  { id: "next-steps", label: "Next steps" },
  { id: "faq", label: "FAQ" }
];

const faqItems = [
  { q: "So what does a referral code actually do?", a: "It’s an optional signup bonus. It doesn’t change store prices." },
  { q: "Does it affect what starter pack I should buy?", a: "No. Choose the pack based on your goal; the referral is separate." },
  { q: "Can I use it after I buy a pack?", a: "The reliable step is to enter it during account creation." },
  { q: "Is it safe to use?", a: "Yes — it’s part of the standard signup flow. It’s optional." },
  { q: "What should I do if I haven’t bought yet?", a: "Try Free Fly or read the buying guide, then buy the minimum starter pack if you keep coming back." }
];
---

<BaseLayout
  title="Does a Star Citizen Referral Code Change the Price? | Star Citizen Beginner"
  description="Does a Star Citizen referral code change the price? No. Use STAR-FSRJ-5N7Z during RSI signup to add the free +50,000 UEC start bonus."
  canonicalPath="/satellites/does-referral-code-change-price/"
  ogImage={heroImg}
  ogImageAlt="Does a Star Citizen Referral Code Change the Price? hero image"
  stickyCtaLabel="Create account + claim bonus"
  stickyCtaHref={referralLink}
  stickyCtaExternal={true}
  activeNav="guides"
>
  <main>

    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Answers', href: '/satellites/' }, { label: 'Answer', href: '/satellites/does-referral-code-change-price/' }]} />
    <section class="hero guideHero">
      <img
        class="hero__img"
        src={heroImg}
        alt="Does a Star Citizen Referral Code Change the Price?"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1536"
        height="1024"
      />
      <div class="hero__overlay"></div>

      <div class="hero__content">
        <div class="guideHero__content">
          <div class="kicker"><span class="dot"></span> Starter Guide</div>
          <h1 class="h1">Does a Star Citizen Referral Code Change the Price?</h1>
          <p class="lead" style="max-width: 820px;">Answer: Short answer: no. A referral code is optional and doesn’t change store prices — it’s simply a signup bonus. Here’s the no-fluff explanation.</p>

          <div class="hero__cta">
            <a class="btn primary" href="#quick-answer">Start here</a>
          </div>
        </div>

        <OnThisPage variant="hero" title="On this page" items={tocItems} />
      </div>
    </section>

    <ReferralBanner
      code={referralCode}
      bonus="50,000"
      ctaLabel="Create account + claim bonus"
      ctaHref={referralLink}
      ctaExternal={true}
    />

    <section id="quick-answer" class="section">
      <div class="container">
        <h2 class="h2">Quick answer</h2>

        <div class="card pad" style="margin-bottom:12px;">
          <div class="kicker"><span class="dot"></span>Answer</div>
          <p class="lead" style="margin-top:10px;">No. A referral code does not change store prices and is not a discount code.</p>
        </div>

        <ul class="bullets">
          <li>Use the code for the signup bonus, not because you expect a cheaper cart.</li>
          <li><b>No.</b> A referral code does not change store prices and is not a discount code.</li>
<li>It’s simply an optional signup bonus you enter during account creation.</li>
<li>If you want to buy smart, the real lever is: <b>pick the right starter pack</b> and don’t overspend early.</li>
        </ul>

        <div style="display:flex; flex-wrap:wrap; gap:10px; margin-top: 14px;">
          <a class="btn primary" href={referralLink} rel="nofollow noopener" target="_blank">Create account + claim bonus</a>
          <a class="btn ghost" href="/star-citizen-referral-code/">Where to paste the referral code →</a>
        </div>
      </div>
    </section>

    <section id="do-this-now" class="section alt">
      <div class="container">
        <h2 class="h2">Do this now</h2>
        <ol class="steps">
          <li><b>Create your RSI account with the referral code</b> — Enter it during signup so you never have to think about it again.</li>
<li><b>Try first if you are unsure</b> — Use Free Fly or the buying guide before spending money.</li>
<li><b>Buy the minimum that unlocks play</b> — Use the starter packs guide to avoid overbuying.</li>
        </ol>
      </div>
    </section>

    <section id="common-mistakes" class="section">
      <div class="container">
        <h2 class="h2">Common mistakes (and exact fixes)</h2>
        <div class="tableWrap">
          <table class="table">
            <thead>
              <tr>
                <th>Mistake</th>
                <th>What happens</th>
                <th>Fix (exact)</th>
              </tr>
            </thead>
            <tbody>
              <tr><td><b>Expecting a price reduction</b></td><td>You feel misled and stop trusting the page.</td><td>Treat referral as a signup bonus, not a discount.</td></tr>
<tr><td><b>Looking for a checkout field</b></td><td>You can’t find it and assume it failed.</td><td>Referral code is entered during <b>account creation</b>.</td></tr>
<tr><td><b>Buying extra ships early</b></td><td>You spend a lot before knowing your playstyle.</td><td>Start minimum → upgrade only after consistent play.</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section id="next-steps" class="section alt">
      <div class="container">
        <h2 class="h2">Next steps</h2>
        <ul class="bullets">
          <li><a href="/satellites/where-to-enter-referral-code/">Where to enter the referral code (exact step)</a></li>
<li><a href="/star-citizen-starter-packs/">Starter packs: what to buy first</a></li>
<li><a href="/should-you-buy-star-citizen/">Should you buy? 2‑minute test</a></li>
        
          <li><a href="/how-to-buy-star-citizen/">If you are still deciding what to buy, use the buying guide</a></li>
        </ul>
      </div>
    </section>

    <section id="faq" class="section">
      <div class="container">
        <h2 class="h2">FAQ</h2>
        <div class="faq" style="margin-top:12px;">
          {faqItems.map((item) => (
            <details class="faq__item">
              <summary class="faq__q">{item.q}</summary>
              <div class="faq__a">{item.a}</div>
            </details>
          ))}
        </div>

        <div style="display:flex; flex-wrap:wrap; gap:10px; margin-top: 18px;">
          <a class="btn primary" href={referralLink} rel="nofollow noopener" target="_blank">Create account + claim bonus</a>
          <a class="btn ghost" href="/star-citizen-referral-code/">Referral code guide →</a>
        </div>
      </div>

      <FaqSchema items={faqItems} />
    </section>
  </main>
</BaseLayout>
