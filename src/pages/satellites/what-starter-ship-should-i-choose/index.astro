---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ReferralBanner from "../../../components/ReferralBanner.astro";
import OnThisPage from "../../../components/OnThisPage.astro";
import FaqSchema from "../../../components/FaqSchema.astro";

const referralCode = "STAR-FSRJ-5N7Z";
const referralLink = `https://www.robertsspaceindustries.com/enlist?referral=${referralCode}`;

const heroImg = "/assets/img/star-citizen-starter-packs/star-citizen-starter-pack-guide-ship-selection-hero.webp";

const tocItems = [
  { id: "quick-answer", label: "Quick answer" },
  { id: "do-this-now", label: "Do this now" },
  { id: "common-mistakes", label: "Common mistakes" },
  { id: "next-steps", label: "Next steps" },
  { id: "faq", label: "FAQ" }
];

const faqItems = [
  { q: "Do I need the ‘best’ starter ship?", a: "No. You need the least friction to learn the loop." },
  { q: "Can I upgrade later?", a: "Yes. That’s the smart path: validate fun first, then upgrade." },
  { q: "Should I buy during Free Fly?", a: "Only if you know you’ll keep playing. Otherwise treat Free Fly as a trial." },
  { q: "Is a referral code required?", a: "No. It’s optional and only applies during signup." },
  { q: "Where do I go next?", a: "Use the Starter Packs guide to pick without wasting money." }
];
---

<BaseLayout
  title="What Starter Ship Should You Choose? (Simple Decision Guide) | Star Citizen Beginner"
  description="A fast decision guide for choosing a starter ship: what matters, what doesn’t, and how to avoid wasting money."
  canonicalPath="/satellites/what-starter-ship-should-i-choose/"
  ogImage={heroImg}
  ogImageAlt="What Starter Ship Should You Choose? (Simple Decision Guide)"
  stickyCtaLabel="Create account + claim bonus"
  stickyCtaHref={referralLink}
  stickyCtaExternal={true}
  activeNav="guides"
>
  <main>
    <section class="hero guideHero">
      <img
        class="hero__img"
        src={heroImg}
        alt="What Starter Ship Should You Choose? (Simple Decision Guide)"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1536"
        height="1024"
      />
      <div class="hero__overlay"></div>

      <div class="hero__content">
        <div class="guideHero__content">
          <div class="kicker"><span class="dot"></span> Starter Guide</div>
          <h1 class="h1">What Starter Ship Should You Choose? (Simple Decision Guide)</h1>
          <p class="lead" style="max-width: 820px;">A fast decision guide for choosing a starter ship: what matters, what doesn’t, and how to avoid wasting money.</p>

          <div class="hero__cta">
            <a class="btn primary" href="#quick-answer">Start here</a>
          </div>
        </div>

        <OnThisPage variant="hero" title="On this page" items={tocItems} />
      </div>
    </section>

    <ReferralBanner
      code={referralCode}
      bonus="50,000"
      ctaLabel="Claim your start bonus"
      ctaHref={referralLink}
      ctaExternal={true}
    />

    <section id="quick-answer" class="section">
      <div class="container">
        <h2 class="h2">Quick answer</h2>
        <ul class="bullets">
          <li>Choose a starter ship based on your <b>first 10 hours</b>, not your long-term dream fleet.</li>
<li>Beginner best practice: pick the option that reduces friction (easy flying, easy missions), then upgrade later only if you keep playing.</li>
<li>If you’re unsure, Free Fly first — then buy the minimum starter package.</li>
        </ul>
      </div>
    </section>

    <section id="do-this-now" class="section alt">
      <div class="container">
        <h2 class="h2">Do this now</h2>
        <ol class="steps">
          <li><b>Pick your first playstyle</b>: courier/explore vs combat vs ‘try everything’.</li>
<li><b>Prioritize low friction</b>: easy handling, simple mission flow, good survivability.</li>
<li><b>Buy the minimum starter package</b> that fits — don’t buy extra ships early.</li>
<li><b>Play 3–5 sessions</b> and only then consider upgrades.</li>
<li><b>Apply the referral code during signup</b> if you’re creating a brand-new account (optional bonus window).</li>
        </ol>
      </div>
    </section>

    <section id="common-mistakes" class="section">
      <div class="container">
        <h2 class="h2">Common mistakes (and exact fixes)</h2>
        <div class="tableWrap">
          <table class="table">
            <thead>
              <tr>
                <th>Mistake</th>
                <th>What happens</th>
                <th>Fix (exact)</th>
              </tr>
            </thead>
            <tbody>
              <tr><td><b>Buying based on hype</b></td><td>You get a ship that doesn’t match your loop.</td><td>Buy for your first 10 hours (easy missions).</td></tr>
<tr><td><b>Spending beyond minimum early</b></td><td>You pay before you know your style.</td><td>Start small; upgrade after consistent play.</td></tr>
<tr><td><b>Ignoring performance realities</b></td><td>You buy then struggle with FPS.</td><td>Run the performance checklist before judging.</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section id="next-steps" class="section alt">
      <div class="container">
        <h2 class="h2">Next steps</h2>
        <ul class="bullets">
          <li><a href="/star-citizen-starter-packs/">Starter packs (full buying guide)</a></li>
<li><a href="/should-you-buy-star-citizen/">Should you buy? (decision test)</a></li>
<li><a href="/star-citizen-referral-code/">Referral code (where to paste it)</a></li>
        </ul>
      </div>
    </section>

    <section id="faq" class="section">
      <div class="container">
        <h2 class="h2">FAQ</h2>
        <div class="faq" style="margin-top:12px;">
          {faqItems.map((item) => (
            <details class="faq__item">
              <summary class="faq__q">{item.q}</summary>
              <div class="faq__a">{item.a}</div>
            </details>
          ))}
        </div>
        <div style="display:flex; flex-wrap:wrap; gap:10px; margin-top: 18px;">
  <a class="btn primary" href="https://www.robertsspaceindustries.com/enlist?referral=STAR-FSRJ-5N7Z" rel="nofollow noopener" target="_blank">Create account + claim signup bonus</a>
  <a class="btn ghost" href="/star-citizen-referral-code/">Where to paste the referral code →</a>
</div>
      </div>

      <FaqSchema items={faqItems} />
    </section>
  </main>
</BaseLayout>
