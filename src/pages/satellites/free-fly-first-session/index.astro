---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReferralBanner from "../../components/ReferralBanner.astro";
import OnThisPage from "../../components/OnThisPage.astro";
import FaqSchema from "../../components/FaqSchema.astro";

const referralCode = "STAR-FSRJ-5N7Z";
const referralLink = `https://www.robertsspaceindustries.com/enlist?referral=${referralCode}`;

const heroImg = "/assets/img/free-fly/star-citizen-free-fly-hero.webp";

const tocItems = [
  { id: "quick-answer", label: "Quick answer" },
  { id: "do-this-now", label: "Do this now" },
  { id: "common-mistakes", label: "Common mistakes" },
  { id: "next-steps", label: "Next steps" },
  { id: "faq", label: "FAQ" }
];

const faqItems = [
  { q: "Can I do this without buying a package?", a: "Yes during Free Fly. Outside Free Fly you need a starter package to keep playing." },
  { q: "What’s the safest first contract type?", a: "Single pickup → single dropoff courier/delivery is the least confusing starter loop." },
  { q: "What if I can’t find my ship?", a: "Use an ASOP terminal to retrieve it; if it’s destroyed, use Claim." },
  { q: "Should I play solo or with people?", a: "Solo is fine for the first loop. Playing with one experienced friend reduces confusion dramatically." },
  { q: "When should I decide to buy?", a: "After you’ve completed one clean loop and performance isn’t blocking your fun." }
];
---

<BaseLayout
  title="Free Fly: First Session Route (Beginner-Proof Checklist) | Star Citizen Beginner"
  description="A beginner-proof Free Fly first session route: what to do in order, what to avoid, and how to judge the game fairly."
  canonicalPath="/satellites/free-fly-first-session/"
  ogImage={heroImg}
  ogImageAlt="Free Fly: First Session Route (Beginner-Proof Checklist)"
  stickyCtaLabel="Create account + claim bonus"
  stickyCtaHref={referralLink}
  stickyCtaExternal={true}
  activeNav="guides"
>
  <main>
    <section class="hero guideHero">
      <img
        class="hero__img"
        src={heroImg}
        alt="Free Fly: First Session Route (Beginner-Proof Checklist)"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1536"
        height="1024"
      />
      <div class="hero__overlay"></div>

      <div class="hero__content">
        <div class="guideHero__content">
          <div class="kicker"><span class="dot"></span> Starter Guide</div>
          <h1 class="h1">Free Fly: First Session Route (Beginner-Proof Checklist)</h1>
          <p class="lead" style="max-width: 820px;">A beginner-proof Free Fly first session route: what to do in order, what to avoid, and how to judge the game fairly.</p>

          <div class="hero__cta">
            <a class="btn primary" href="#quick-answer">Start here</a>
          </div>
        </div>

        <OnThisPage variant="hero" title="On this page" items={tocItems} />
      </div>
    </section>

    <ReferralBanner
      code={referralCode}
      bonus="50,000"
      ctaLabel="Claim your start bonus"
      ctaHref={referralLink}
      ctaExternal={true}
    />

    <section id="quick-answer" class="section">
      <div class="container">
        <h2 class="h2">Quick answer</h2>
        <ul class="bullets">
          <li>Your goal in Free Fly is <b>one clean loop</b>: spawn → claim ship → fly → finish one simple contract → log out without drama.</li>
<li>Avoid “hard mode” first: <b>don’t start with FPS bunkers</b>, complicated cargo, or long multi-stop routes.</li>
<li>Judge the game fairly: test once in a heavy hub, then once in a calmer location. If FPS/stutter dominates, fix performance first.</li>
        </ul>
      </div>
    </section>

    <section id="do-this-now" class="section alt">
      <div class="container">
        <h2 class="h2">Do this now</h2>
        <ol class="steps">
          <li><b>Set your spawn</b> (so you don’t repeat the worst spawn walk).</li>
<li><b>Claim a ship at the ASOP terminal</b> and do a short takeoff/landing practice.</li>
<li><b>Run one simple courier/delivery contract</b> (single pickup → single dropoff).</li>
<li><b>Cash out and stop</b>: after one completed loop, decide if you want to try combat or exploration next.</li>
<li><b>If it felt rough</b>, don’t quit yet — do the 10-minute performance baseline and retest in the same place.</li>
        </ol>
      </div>
    </section>

    <section id="common-mistakes" class="section">
      <div class="container">
        <h2 class="h2">Common mistakes (and exact fixes)</h2>
        <div class="tableWrap">
          <table class="table">
            <thead>
              <tr>
                <th>Mistake</th>
                <th>What happens</th>
                <th>Fix (exact)</th>
              </tr>
            </thead>
            <tbody>
              <tr><td><b>Starting with FPS bunkers</b></td><td>You lose gear fast and think the game is “impossible”.</td><td>Do one courier loop first; treat FPS as your second session.</td></tr>
<tr><td><b>Changing goals every 5 minutes</b></td><td>No learning curve → no fun.</td><td>Repeat the same simple loop once more before switching.</td></tr>
<tr><td><b>Judging the game on one chaotic moment</b></td><td>You get a distorted impression.</td><td>Retest in the same location after any fix.</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section id="next-steps" class="section alt">
      <div class="container">
        <h2 class="h2">Next steps</h2>
        <ul class="bullets">
          <li><a href="/free-fly/">Free Fly guide (full checklist)</a></li>
<li><a href="/should-you-buy-star-citizen/">Should you buy? (2-minute decision test)</a></li>
<li><a href="/star-citizen-performance-guide/">Performance guide (fix stutter / low FPS)</a></li>
        </ul>
      </div>
    </section>

    <section id="faq" class="section">
      <div class="container">
        <h2 class="h2">FAQ</h2>
        <div class="faq" style="margin-top:12px;">
          {faqItems.map((item) => (
            <details class="faq__item">
              <summary class="faq__q">{item.q}</summary>
              <div class="faq__a">{item.a}</div>
            </details>
          ))}
        </div>
        
      </div>

      <FaqSchema items={faqItems} />
    </section>
  </main>
</BaseLayout>
