---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ReferralBanner from "../../../components/ReferralBanner.astro";
import OnThisPage from "../../../components/OnThisPage.astro";
import FaqSchema from "../../../components/FaqSchema.astro";
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { REFERRAL_CODE, REFERRAL_LINK, REFERRAL_INFO_PATH, REFERRAL_BONUS_UEC, FLY_FREE_URL } from "../../../config/site";

const referralCode = REFERRAL_CODE;
const referralLink = REFERRAL_LINK;

const heroImg = "/assets/img/referral/star-citizen-referral-signup-field.webp";

const tocItems = [
  { id: "quick-answer", label: "Where to paste it" },
  { id: "do-this-now", label: "Exact steps" },
  { id: "common-mistakes", label: "Mistakes to avoid" },
  { id: "next-steps", label: "Next steps" },
  { id: "faq", label: "FAQ" }
];

const faqItems = [
  { q: "Do I have to use a referral code?", a: "No. It’s optional. If you use one, do it during account creation so you don’t have to think about it again." },
  { q: "Does it cost money?", a: "No. Entering a code is free." },
  { q: "Does it change the price of a starter pack?", a: "No. It doesn’t affect store pricing." },
  { q: "Can I use it during Free Fly?", a: "Yes — create the account first (with the code), then play Free Fly later." },
  { q: "What if I already created my account?", a: "In practice, you should assume it won’t apply later. Use Free Fly or the buying guide and keep moving instead of chasing the bonus." }
];
---

<BaseLayout
  title="Where to Enter a Star Citizen Referral Code (Exact Signup Step) | Star Citizen Beginner"
  description="Where to enter the referral code: paste STAR-FSRJ-5N7Z on the RSI account-creation page (not after). Includes the exact field cues."
  canonicalPath="/satellites/where-to-enter-referral-code/"
  ogImage={heroImg}
  ogImageAlt="Where to Enter a Star Citizen Referral Code (Exact Signup Step) hero image"
  stickyCtaLabel="Create account + claim bonus"
  stickyCtaHref={referralLink}
  stickyCtaExternal={true}
  activeNav="guides"
>
  <main>

    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Answers', href: '/satellites/' }, { label: 'Answer', href: '/satellites/where-to-enter-referral-code/' }]} />
    <section class="hero guideHero">
      <img
        class="hero__img"
        src={heroImg}
        alt="Where to Enter a Star Citizen Referral Code (Exact Signup Step)"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1536"
        height="1024"
      />
      <div class="hero__overlay"></div>

      <div class="hero__content">
        <div class="guideHero__content">
          <div class="kicker"><span class="dot"></span> Starter Guide</div>
          <h1 class="h1">Where to Enter a Star Citizen Referral Code (Exact Signup Step)</h1>
          <p class="lead" style="max-width: 820px;">Answer: enter the referral code on the RSI account creation page — before you create the account. This page shows the exact moment and the common mistakes.</p>

          <div class="hero__cta">
            <a class="btn primary" href="#quick-answer">Start here</a>
          </div>
        </div>

        <OnThisPage variant="hero" title="On this page" items={tocItems} />
      </div>
    </section>

    <ReferralBanner
      code={referralCode}
      bonus="50,000"
      ctaLabel="Create account + claim bonus"
      ctaHref={referralLink}
      ctaExternal={true}
    />

    <section id="quick-answer" class="section">
      <div class="container">
        <h2 class="h2">Quick answer</h2>

        <div class="card pad" style="margin-bottom:12px;">
          <div class="kicker"><span class="dot"></span>Answer</div>
          <p class="lead" style="margin-top:10px;">Enter the referral code during RSI account creation — before you submit the signup form.</p>
        </div>

        <ul class="bullets">
          <li><b>Enter the referral code during RSI account creation</b> — before you submit the signup form.</li>
<li>It’s a one-time window: <b>do it first</b>, then create the account, then test Free Fly / buy later.</li>
<li>Use this page if you want zero guessing: you’ll do the exact step once and be done.</li>
        </ul>

        <div style="display:flex; flex-wrap:wrap; gap:10px; margin-top: 14px;">
          <a class="btn primary" href={referralLink} rel="nofollow noopener" target="_blank">Create account + claim bonus</a>
          <a class="btn ghost" href="/star-citizen-referral-code/">Where to paste the referral code →</a>
        </div>
      </div>
    </section>

    <section id="do-this-now" class="section alt">
      <div class="container">
        <h2 class="h2">Do this now</h2>
        <ol class="steps">
          <li><b>Open the RSI signup page</b> — Use the official account creation flow (new account).</li>
<li><b>Find the referral code field</b> — It’s on the signup form — enter the code before you submit.</li>
<li><b>Create the account</b> — Submit the signup form normally.</li>
<li><b>Verify once</b> — Log into your RSI account and confirm the referral/signup bonus status if visible.</li>
        </ol>
      </div>
    </section>

    <section id="common-mistakes" class="section">
      <div class="container">
        <h2 class="h2">Common mistakes (and exact fixes)</h2>
        <div class="tableWrap">
          <table class="table">
            <thead>
              <tr>
                <th>Mistake</th>
                <th>What happens</th>
                <th>Fix (exact)</th>
              </tr>
            </thead>
            <tbody>
              <tr><td><b>Creating the account first</b></td><td>You miss the reliable signup window.</td><td>Enter the code <b>before</b> you submit the signup form.</td></tr>
<tr><td><b>Typing the code with missing characters</b></td><td>The code won’t apply.</td><td>Copy/paste the code; avoid extra spaces.</td></tr>
<tr><td><b>Expecting the bonus to change store pricing</b></td><td>It doesn’t change what you pay.</td><td>Think of it as a small starting credit boost, not a discount.</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section id="next-steps" class="section alt">
      <div class="container">
        <h2 class="h2">Next steps</h2>
        <ul class="bullets">
          <li><a href="/star-citizen-referral-code/">Full referral code guide (benefits, mistakes, FAQ)</a></li>
<li><a href="/satellites/does-referral-code-change-price/">Does a referral code change the price? (no)</a></li>
<li><a href="/free-fly/">Try Star Citizen without buying (Free Fly guide)</a></li>
<li><a href="/star-citizen-starter-packs/">If you buy: starter packs guide</a></li>
        </ul>
      </div>
    </section>

    <section id="faq" class="section">
      <div class="container">
        <h2 class="h2">FAQ</h2>
        <div class="faq" style="margin-top:12px;">
          {faqItems.map((item) => (
            <details class="faq__item">
              <summary class="faq__q">{item.q}</summary>
              <div class="faq__a">{item.a}</div>
            </details>
          ))}
        </div>

        <div style="display:flex; flex-wrap:wrap; gap:10px; margin-top: 18px;">
          <a class="btn primary" href={referralLink} rel="nofollow noopener" target="_blank">Create account + claim bonus</a>
          <a class="btn ghost" href="/star-citizen-referral-code/">Referral code guide →</a>
        </div>
      </div>

      <FaqSchema items={faqItems} />
    </section>
  </main>
</BaseLayout>
