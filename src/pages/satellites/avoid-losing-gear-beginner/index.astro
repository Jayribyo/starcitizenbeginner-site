---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ReferralBanner from "../../../components/ReferralBanner.astro";
import OnThisPage from "../../../components/OnThisPage.astro";
import FaqSchema from "../../../components/FaqSchema.astro";
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { REFERRAL_CODE, REFERRAL_LINK, REFERRAL_INFO_PATH, REFERRAL_BONUS_UEC, FLY_FREE_URL } from "../../../config/site";

const referralCode = REFERRAL_CODE;
const referralLink = REFERRAL_LINK;

const heroImg = "/assets/img/make-money-fast/star-citizen-earn-auec-fast-mining-trade-profit-hero.webp";

const tocItems = [
  { id: "quick-answer", label: "Stop the money leak" },
  { id: "do-this-now", label: "Gear discipline" },
  { id: "common-mistakes", label: "Mistakes that bleed credits" },
  { id: "next-steps", label: "Next steps" },
  { id: "faq", label: "FAQ" }
];

const faqItems = [
  { q: "Do I need expensive armor to start?", a: "No. A cheap, repeatable kit beats a perfect kit you can’t replace." },
  { q: "What’s the #1 habit to stay rich?", a: "Always keep enough credits to rebuy your default kit multiple times." },
  { q: "When should I start carrying more gear?", a: "After you’ve had a few sessions where your income is stable." },
  { q: "How does this relate to making money fast?", a: "Gear discipline keeps your profit real; then you can scale with better loops." },
  { q: "Where should I go next?", a: "Use make-money-fast to pick the best next path, then optimize performance if needed." }
];
---

<BaseLayout
  title="How to Avoid Losing Gear in Star Citizen as a Beginner | Star Citizen Beginner"
  description="Stop losing gear to bugs and death: what to store, what to keep cheap, and how to log out safely as a new Star Citizen player."
  canonicalPath="/satellites/avoid-losing-gear-beginner/"
  ogImage={heroImg}
  ogImageAlt="How to Avoid Losing Gear as a Beginner hero image"
  stickyCtaLabel="Create account + claim bonus"
  stickyCtaHref={referralLink}
  stickyCtaExternal={true}
  activeNav="guides"
>
  <main>

    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Answers', href: '/satellites/' }, { label: 'Answer', href: '/satellites/avoid-losing-gear-beginner/' }]} />
    <section class="hero guideHero">
      <img
        class="hero__img"
        src={heroImg}
        alt="How to Avoid Losing Gear as a Beginner"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1536"
        height="1024"
      />
      <div class="hero__overlay"></div>

      <div class="hero__content">
        <div class="guideHero__content">
          <div class="kicker"><span class="dot"></span> Starter Guide</div>
          <h1 class="h1">How to Avoid Losing Gear as a Beginner</h1>
          <p class="lead" style="max-width: 820px;">Answer: The fastest way to go broke is re-buying gear. This guide shows a simple gear discipline that keeps you progressing without frustration.</p>

          <div class="hero__cta">
            <a class="btn primary" href="#quick-answer">Start here</a>
          </div>
        </div>

        <OnThisPage variant="hero" title="On this page" items={tocItems} />
      </div>
    </section>

    <ReferralBanner
      code={referralCode}
      bonus="50,000"
      ctaLabel="Create account + claim bonus"
      ctaHref={referralLink}
      ctaExternal={true}
    />

    <section id="quick-answer" class="section">
      <div class="container">
        <h2 class="h2">Quick answer</h2>

        <div class="card pad" style="margin-bottom:12px;">
          <div class="kicker"><span class="dot"></span>Answer</div>
          <p class="lead" style="margin-top:10px;">earn in light gear until you can replace a loadout multiple times without caring.</p>
        </div>

        <ul class="bullets">
          <li>Beginner rule: <b>earn in light gear</b> until you can replace a loadout multiple times without caring.</li>
<li>Treat gear as consumable. The real progress is <b>stable loops</b>, not fancy loadouts.</li>
<li>If you keep rebuying gear, your income looks worse than it is.</li>
        </ul>

        <div style="display:flex; flex-wrap:wrap; gap:10px; margin-top: 14px;">
          <a class="btn primary" href={referralLink} rel="nofollow noopener" target="_blank">Create account + claim bonus</a>
          <a class="btn ghost" href="/star-citizen-referral-code/">Where to paste the referral code →</a>
        </div>
      </div>
    </section>

    <section id="do-this-now" class="section alt">
      <div class="container">
        <h2 class="h2">Do this now</h2>
        <ol class="steps">
          <li><b>Create a ‘cheap default kit’</b> — A minimal kit you can rebuy instantly without thinking.</li>
<li><b>Store extras, don’t carry everything</b> — Carry only what the mission requires.</li>
<li><b>Run one loop, then upgrade slowly</b> — Earn first, then add one comfort item at a time.</li>
<li><b>When you die, reset fast</b> — Rebuy the default kit and get back to earning.</li>
        </ol>
      </div>
    </section>

    <section id="common-mistakes" class="section">
      <div class="container">
        <h2 class="h2">Common mistakes (and exact fixes)</h2>
        <div class="tableWrap">
          <table class="table">
            <thead>
              <tr>
                <th>Mistake</th>
                <th>What happens</th>
                <th>Fix (exact)</th>
              </tr>
            </thead>
            <tbody>
              <tr><td><b>Taking your ‘best kit’ every time</b></td><td>You rage-quit after one death.</td><td>Keep a cheap default kit.</td></tr>
<tr><td><b>Looting forever before earning</b></td><td>You waste time and still die.</td><td>Earn first; loot with purpose later.</td></tr>
<tr><td><b>Buying upgrades before repeatable income</b></td><td>You drain the wallet.</td><td>Upgrade only after consistent loops.</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section id="next-steps" class="section alt">
      <div class="container">
        <h2 class="h2">Next steps</h2>
        <ul class="bullets">
          <li><a href="/make-money-fast/">Make money fast (paths + scaling)</a></li>
<li><a href="/satellites/best-beginner-mission-to-earn-credits/">Best beginner mission loop (safe start)</a></li>
<li><a href="/star-citizen-starter-packs/">If you buy: start minimum, upgrade later</a></li>
        </ul>
      </div>
    </section>

    <section id="faq" class="section">
      <div class="container">
        <h2 class="h2">FAQ</h2>
        <div class="faq" style="margin-top:12px;">
          {faqItems.map((item) => (
            <details class="faq__item">
              <summary class="faq__q">{item.q}</summary>
              <div class="faq__a">{item.a}</div>
            </details>
          ))}
        </div>

        <div style="display:flex; flex-wrap:wrap; gap:10px; margin-top: 18px;">
          <a class="btn primary" href={referralLink} rel="nofollow noopener" target="_blank">Create account + claim bonus</a>
          <a class="btn ghost" href="/star-citizen-referral-code/">Referral code guide →</a>
        </div>
      </div>

      <FaqSchema items={faqItems} />
    </section>
  </main>
</BaseLayout>
