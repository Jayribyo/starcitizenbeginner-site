---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ReferralBanner from "../../../components/ReferralBanner.astro";
import OnThisPage from "../../../components/OnThisPage.astro";
import FaqSchema from "../../../components/FaqSchema.astro";
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { REFERRAL_CODE, REFERRAL_LINK, REFERRAL_INFO_PATH, REFERRAL_BONUS_UEC, FLY_FREE_URL } from "../../../config/site";

const referralCode = REFERRAL_CODE;
const referralLink = REFERRAL_LINK;

const heroImg = "/assets/img/make-money-fast/star-citizen-earn-auec-fast-mining-trade-profit-hero.webp";

const tocItems = [
  { id: "quick-answer", label: "Quick answer" },
  { id: "do-this-now", label: "Do this now" },
  { id: "common-mistakes", label: "Common mistakes" },
  { id: "next-steps", label: "Next steps" },
  { id: "faq", label: "FAQ" }
];

const faqItems = [
  { q: "Is this viable during Free Fly?", a: "Yes — it’s one of the best Free Fly tests." },
  { q: "Do I need special gear?", a: "No. That’s why courier is beginner-safe." },
  { q: "How do I scale from here?", a: "Add bounties or mining after you can complete deliveries consistently." },
  { q: "What if I crash my ship?", a: "Simplify routes, practice landing, and keep contracts short." },
  { q: "Where’s the full money guide?", a: "Use Make Money Fast for the complete path table." }
];
---

<BaseLayout
  title="Courier Missions: Beginner Route (Safe, Repeatable Money Loop) (Beginner checklist) | Star Citizen Beginner"
  description="A beginner-proof courier route: where to start, what to accept, and how to run 2–3 deliveries without getting stuck or losing gear."
  canonicalPath="/satellites/courier-missions-beginner-route/"
  ogImage={heroImg}
  ogImageAlt="Courier Missions: Beginner Route (Safe, Repeatable Money Loop)"
  stickyCtaLabel="Create account + claim bonus"
  stickyCtaHref={referralLink}
  stickyCtaExternal={true}
  activeNav="guides"
>
  <main>

    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Answers', href: '/satellites/' }, { label: 'Answer', href: '/satellites/courier-missions-beginner-route/' }]} />
    <section class="hero guideHero">
      <img
        class="hero__img"
        src={heroImg}
        alt="Courier Missions: Beginner Route (Safe, Repeatable Money Loop)"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1536"
        height="1024"
      />
      <div class="hero__overlay"></div>

      <div class="hero__content">
        <div class="guideHero__content">
          <div class="kicker"><span class="dot"></span> Starter Guide</div>
          <h1 class="h1">Courier Missions: Beginner Route (Safe, Repeatable Money Loop)</h1>
          <p class="lead" style="max-width: 820px;">Answer: A safe courier loop that builds confidence and credits: what to accept, what to avoid, and how to scale.</p>

          <div class="hero__cta">
            <a class="btn primary" href="#quick-answer">Start here</a>
          </div>
        </div>

        <OnThisPage variant="hero" title="On this page" items={tocItems} />
      </div>
    </section>

    <ReferralBanner
      code={referralCode}
      bonus="50,000"
      ctaLabel="Claim your start bonus"
      ctaHref={referralLink}
      ctaExternal={true}
    />

    <section id="quick-answer" class="section">
      <div class="container">
        <h2 class="h2">Quick answer</h2>

        <div class="card pad" style="margin-bottom:12px;">
          <div class="kicker"><span class="dot"></span>Answer</div>
          <p class="lead" style="margin-top:10px;">Courier missions are the safest ‘fast money’ loop because they teach navigation and consistency with low risk.</p>
        </div>

        <ul class="bullets">
          <li>Courier missions are the safest ‘fast money’ loop because they teach navigation and consistency with low risk.</li>
<li>Your first goal: complete <b>one</b> clean delivery loop — then repeat it once before upgrading.</li>
<li>Avoid multi-stop or confusing jobs until the basic loop feels automatic.</li>
        </ul>
      </div>
    </section>

    <section id="do-this-now" class="section alt">
      <div class="container">
        <h2 class="h2">Do this now</h2>
        <ol class="steps">
          <li><b>Accept a single pickup → single dropoff courier contract</b>.</li>
<li><b>Fly directly to pickup</b>, grab the package, then go straight to dropoff.</li>
<li><b>Complete and cash out</b>, then repeat the same type once.</li>
<li><b>Scale</b> only after consistency: faster ship handling, better route discipline, then bigger loops.</li>
<li><b>If you keep failing</b>, simplify: shorter distance, fewer steps.</li>
        </ol>
      </div>
    </section>

    <section id="common-mistakes" class="section">
      <div class="container">
        <h2 class="h2">Common mistakes (and exact fixes)</h2>
        <div class="tableWrap">
          <table class="table">
            <thead>
              <tr>
                <th>Mistake</th>
                <th>What happens</th>
                <th>Fix (exact)</th>
              </tr>
            </thead>
            <tbody>
              <tr><td><b>Taking multi-stop delivery immediately</b></td><td>You get lost and waste time.</td><td>Start single pickup/dropoff only.</td></tr>
<tr><td><b>Looting and detouring mid-contract</b></td><td>You fail and earn nothing.</td><td>Finish the loop first; detour later.</td></tr>
<tr><td><b>Changing loops too fast</b></td><td>No mastery → slow progress.</td><td>Repeat a proven loop 2–3 times before switching.</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section id="next-steps" class="section alt">
      <div class="container">
        <h2 class="h2">Next steps</h2>
        <ul class="bullets">
          <li><a href="/make-money-fast/">Make money fast (all beginner loops)</a></li>
<li><a href="/satellites/avoid-losing-gear-beginner/">Avoid losing gear (beginner rules)</a></li>
<li><a href="/star-citizen-performance-guide/">Performance guide (if FPS ruins combat)</a></li>
        </ul>
      </div>
    </section>

    <section id="faq" class="section">
      <div class="container">
        <h2 class="h2">FAQ</h2>
        <div class="faq" style="margin-top:12px;">
          {faqItems.map((item) => (
            <details class="faq__item">
              <summary class="faq__q">{item.q}</summary>
              <div class="faq__a">{item.a}</div>
            </details>
          ))}
        </div>
        
      </div>

      <FaqSchema items={faqItems} />
    </section>
  </main>
</BaseLayout>
