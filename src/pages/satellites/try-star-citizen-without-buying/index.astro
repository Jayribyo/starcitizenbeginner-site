---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ReferralBanner from "../../../components/ReferralBanner.astro";
import OnThisPage from "../../../components/OnThisPage.astro";
import FaqSchema from "../../../components/FaqSchema.astro";
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { REFERRAL_CODE, REFERRAL_LINK, REFERRAL_INFO_PATH, REFERRAL_BONUS_UEC, FLY_FREE_URL } from "../../../config/site";

const referralCode = REFERRAL_CODE;
const referralLink = REFERRAL_LINK;

const heroImg = "/assets/img/free-fly/star-citizen-free-fly-event-hero.webp";

const tocItems = [
  { id: "quick-answer", label: "Try without buying" },
  { id: "do-this-now", label: "Free Fly test plan" },
  { id: "common-mistakes", label: "Traps to avoid" },
  { id: "next-steps", label: "Next steps" },
  { id: "faq", label: "FAQ" }
];

const faqItems = [
  { q: "Do I need to buy anything to play Free Fly?", a: "No. Free Fly is designed for trying the game without buying." },
  { q: "What should I do in my first Free Fly hour?", a: "One simple mission loop: spawn → claim ship → complete one contract → log out cleanly." },
  { q: "What if the game runs badly?", a: "Fix performance first (SSD/RAM/settings). Otherwise you can’t judge the experience fairly." },
  { q: "When should I buy a starter pack?", a: "Only after you’ve had at least a couple sessions you want to repeat." },
  { q: "Where does the referral code fit in?", a: "If you want the signup bonus, enter it during account creation before you play Free Fly." }
];
---

<BaseLayout
  title="Try Star Citizen Without Buying | Star Citizen Beginner"
  description="Try Star Citizen without buying: the fastest Free Fly test plan to get one good session and decide if the game is for you." 
  canonicalPath="/satellites/try-star-citizen-without-buying/"
  ogImage={heroImg}
  ogImageAlt="Try Star Citizen Without Buying (Free Fly Shortcut Guide) hero image"
  stickyCtaLabel="Create account + claim bonus"
  stickyCtaHref={referralLink}
  stickyCtaExternal={true}
  activeNav="guides"
>
  <main>

    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Answers', href: '/satellites/' }, { label: 'Answer', href: '/satellites/try-star-citizen-without-buying/' }]} />
    <section class="hero guideHero">
      <img
        class="hero__img"
        src={heroImg}
        alt="Try Star Citizen Without Buying (Free Fly Shortcut Guide)"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1536"
        height="1024"
      />
      <div class="hero__overlay"></div>

      <div class="hero__content">
        <div class="guideHero__content">
          <div class="kicker"><span class="dot"></span> Starter Guide</div>
          <h1 class="h1">Try Star Citizen without buying</h1>
          <p class="lead" style="max-width: 820px;">Answer: Want to try Star Citizen without paying? This is the fastest way to do a Free Fly test run and decide if it’s worth buying.</p>

          <div class="hero__cta">
            <a class="btn primary" href="#quick-answer">Start here</a>
          </div>
        </div>

        <OnThisPage variant="hero" title="On this page" items={tocItems} />
      </div>
    </section>

    <ReferralBanner
      code={referralCode}
      bonus="50,000"
      ctaLabel="Create account + claim bonus"
      ctaHref={referralLink}
      ctaExternal={true}
    />

    <section id="quick-answer" class="section">
      <div class="container">
        <h2 class="h2">Quick answer</h2>

        <div class="card pad" style="margin-bottom:12px;">
          <div class="kicker"><span class="dot"></span>Answer</div>
          <p class="lead" style="margin-top:10px;">Free Fly is the easiest way to try Star Citizen without buying. Your goal is not to do everything — it is to answer one simple question: “Do I enjoy this?”</p>
        </div>

        <ul class="bullets">
          <li>Use Free Fly to judge the feel of the game, not to force every system into one weekend.</li>
          <li><b>Free Fly is the easiest way to try Star Citizen without buying.</b> Your goal is not to do everything — it is to answer one simple question: “Do I enjoy this?”</li>
<li>A good test session has 3 parts: <b>spawn → claim a ship → complete one simple contract</b>.</li>
<li>If performance ruins the test, fix that first — otherwise your impression will not be fair.</li>
        </ul>

        <div style="display:flex; flex-wrap:wrap; gap:10px; margin-top: 14px;">
          <a class="btn primary" href={referralLink} rel="nofollow noopener" target="_blank">Create account + claim bonus</a>
          <a class="btn ghost" href="/star-citizen-referral-code/">Where to paste the referral code →</a>
        </div>
      </div>
    </section>

    <section id="do-this-now" class="section alt">
      <div class="container">
        <h2 class="h2">Do this now</h2>
        <ol class="steps">
          <li><b>Create an RSI account (optional bonus)</b> — Create your account first. If you want the signup bonus, enter the referral code during signup.</li>
<li><b>Download + install on SSD</b> — Install on SSD/NVMe. Avoid HDD for a fair first impression.</li>
<li><b>Run one simple loop</b> — Spawn → claim ship → take a basic delivery/entry mission → complete it once.</li>
<li><b>Decide with clarity</b> — If you enjoyed the loop and will play again, a minimum starter pack makes sense.</li>
        </ol>
      </div>
    </section>

    <section id="common-mistakes" class="section">
      <div class="container">
        <h2 class="h2">Common mistakes (and exact fixes)</h2>
        <div class="tableWrap">
          <table class="table">
            <thead>
              <tr>
                <th>Mistake</th>
                <th>What happens</th>
                <th>Fix (exact)</th>
              </tr>
            </thead>
            <tbody>
              <tr><td><b>Trying to “see everything” in one session</b></td><td>You get overwhelmed and quit.</td><td>Do one simple loop first. Expand later.</td></tr>
<tr><td><b>Judging the game from a laggy session</b></td><td>You mistake performance issues for gameplay.</td><td>Run the performance 10‑minute fix before deciding.</td></tr>
<tr><td><b>Buying before you tested</b></td><td>You spend money before you know your tolerance for a sandbox.</td><td>Try Free Fly first if you’re unsure.</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section id="next-steps" class="section alt">
      <div class="container">
        <h2 class="h2">Next steps</h2>
        <ul class="bullets">
          <li><a href="/free-fly/">Full Free Fly guide (first session + traps)</a></li>
<li><a href="/satellites/first-session/">First good session guide</a></li>
<li><a href="/star-citizen-performance-guide/">Performance guide (10-minute fixes)</a></li>
<li><a href="/should-you-buy-star-citizen/">Quick reality check</a></li>
<li><a href="/star-citizen-starter-packs/">Starter packs: buy the minimum, upgrade later</a></li>
        
          <li><a href="/how-to-buy-star-citizen/">If the trial feels good, this is the simplest buying path next</a></li>
        </ul>
      </div>
    </section>

    <section id="faq" class="section">
      <div class="container">
        <h2 class="h2">FAQ</h2>
        <div class="faq" style="margin-top:12px;">
          {faqItems.map((item) => (
            <details class="faq__item">
              <summary class="faq__q">{item.q}</summary>
              <div class="faq__a">{item.a}</div>
            </details>
          ))}
        </div>

        <div style="display:flex; flex-wrap:wrap; gap:10px; margin-top: 18px;">
          <a class="btn primary" href={referralLink} rel="nofollow noopener" target="_blank">Create account + claim bonus</a>
          <a class="btn ghost" href="/star-citizen-referral-code/">Referral code guide →</a>
        </div>
      </div>

      <FaqSchema items={faqItems} />
    </section>
  </main>
</BaseLayout>
