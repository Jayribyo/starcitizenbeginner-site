---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReferralBanner from "../../components/ReferralBanner.astro";
import OnThisPage from "../../components/OnThisPage.astro";
import FaqSchema from "../../components/FaqSchema.astro";

const referralCode = "STAR-FSRJ-5N7Z";
const referralLink = `https://www.robertsspaceindustries.com/enlist?referral=${referralCode}`;

const heroImg = "/assets/img/make-money-fast/star-citizen-earn-auec-fast-mining-trade-profit-hero.webp";

const tocItems = [
  { id: "quick-answer", label: "Quick answer" },
  { id: "do-this-now", label: "Do this now" },
  { id: "common-mistakes", label: "Common mistakes" },
  { id: "next-steps", label: "Next steps" },
  { id: "faq", label: "FAQ" }
];

const faqItems = [
  { q: "What mission type is best first?", a: "Single pickup → single dropoff courier/delivery." },
  { q: "Can I do missions during Free Fly?", a: "Yes — it’s a great way to test if the loop clicks." },
  { q: "What if I fail the mission?", a: "Pick another simple one. The point is learning the loop, not perfection." },
  { q: "When should I try bounties?", a: "After you’ve completed at least one clean delivery contract." },
  { q: "Where do I go next?", a: "Use Make Money Fast for safe loops and scaling paths." }
];
---

<BaseLayout
  title="Your First Mission in Star Citizen (Beginner Route That Always Works) | Star Citizen Beginner"
  description="A beginner-proof first mission route: what to pick, how to finish it, and how to avoid the early frustration traps."
  canonicalPath="/satellites/star-citizen-first-mission-guide/"
  ogImage={heroImg}
  ogImageAlt="Your First Mission in Star Citizen (Beginner Route That Always Works)"
  stickyCtaLabel="Create account + claim bonus"
  stickyCtaHref={referralLink}
  stickyCtaExternal={true}
  activeNav="guides"
>
  <main>
    <section class="hero guideHero">
      <img
        class="hero__img"
        src={heroImg}
        alt="Your First Mission in Star Citizen (Beginner Route That Always Works)"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1536"
        height="1024"
      />
      <div class="hero__overlay"></div>

      <div class="hero__content">
        <div class="guideHero__content">
          <div class="kicker"><span class="dot"></span> Starter Guide</div>
          <h1 class="h1">Your First Mission in Star Citizen (Beginner Route That Always Works)</h1>
          <p class="lead" style="max-width: 820px;">A beginner-proof first mission route: what to pick, how to finish it, and how to avoid the early frustration traps.</p>

          <div class="hero__cta">
            <a class="btn primary" href="#quick-answer">Start here</a>
          </div>
        </div>

        <OnThisPage variant="hero" title="On this page" items={tocItems} />
      </div>
    </section>

    <ReferralBanner
      code={referralCode}
      bonus="50,000"
      ctaLabel="Claim your start bonus"
      ctaHref={referralLink}
      ctaExternal={true}
    />

    <section id="quick-answer" class="section">
      <div class="container">
        <h2 class="h2">Quick answer</h2>
        <ul class="bullets">
          <li>Your first mission should be <b>short</b>, <b>low-risk</b>, and teach the core loop: accept → travel → complete → get paid.</li>
<li>Beginner best practice: start with <b>single-step courier/delivery</b> before combat or multi-stop jobs.</li>
<li>Finish one clean contract first — then scale.</li>
        </ul>
      </div>
    </section>

    <section id="do-this-now" class="section alt">
      <div class="container">
        <h2 class="h2">Do this now</h2>
        <ol class="steps">
          <li><b>Accept one simple courier/delivery</b> (single pickup → single dropoff).</li>
<li><b>Travel to the pickup</b> and grab the package.</li>
<li><b>Deliver to the dropoff</b> and confirm mission completion.</li>
<li><b>Cash out</b> (see the payout) and repeat once to build confidence.</li>
<li>Only then try combat (bounties) or FPS missions.</li>
        </ol>
      </div>
    </section>

    <section id="common-mistakes" class="section">
      <div class="container">
        <h2 class="h2">Common mistakes (and exact fixes)</h2>
        <div class="tableWrap">
          <table class="table">
            <thead>
              <tr>
                <th>Mistake</th>
                <th>What happens</th>
                <th>Fix (exact)</th>
              </tr>
            </thead>
            <tbody>
              <tr><td><b>Choosing a complex mission first</b></td><td>You get lost and think the game is ‘too much’.</td><td>Start with single pickup/dropoff.</td></tr>
<tr><td><b>Trying FPS missions with no plan</b></td><td>You lose gear and progress.</td><td>Do courier first; treat FPS as second session.</td></tr>
<tr><td><b>Switching contracts mid-way</b></td><td>You end up with nothing.</td><td>Finish one contract before experimenting.</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section id="next-steps" class="section alt">
      <div class="container">
        <h2 class="h2">Next steps</h2>
        <ul class="bullets">
          <li><a href="/satellites/first-session-checklist/">First session checklist (beginner route)</a></li>
<li><a href="/make-money-fast/">Make money fast (safe loops)</a></li>
<li><a href="/free-fly/">Free Fly guide (try without buying)</a></li>
        </ul>
      </div>
    </section>

    <section id="faq" class="section">
      <div class="container">
        <h2 class="h2">FAQ</h2>
        <div class="faq" style="margin-top:12px;">
          {faqItems.map((item) => (
            <details class="faq__item">
              <summary class="faq__q">{item.q}</summary>
              <div class="faq__a">{item.a}</div>
            </details>
          ))}
        </div>
        
      </div>

      <FaqSchema items={faqItems} />
    </section>
  </main>
</BaseLayout>
