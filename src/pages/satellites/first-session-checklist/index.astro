---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ReferralBanner from "../../../components/ReferralBanner.astro";
import OnThisPage from "../../../components/OnThisPage.astro";
import FaqSchema from "../../../components/FaqSchema.astro";
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { REFERRAL_CODE, REFERRAL_LINK, REFERRAL_INFO_PATH, REFERRAL_BONUS_UEC, FLY_FREE_URL } from "../../../config/site";

const referralCode = REFERRAL_CODE;
const referralLink = REFERRAL_LINK;

const heroImg = "/assets/img/home/scb-home-hero.webp";

const tocItems = [
  { id: "quick-answer", label: "The shortest good plan" },
  { id: "do-this-now", label: "First session steps" },
  { id: "common-mistakes", label: "Mistakes that waste sessions" },
  { id: "next-steps", label: "Next steps" },
  { id: "faq", label: "FAQ" }
];

const faqItems = [
  { q: "What’s the best first mission type?", a: "A simple delivery/entry mission: low risk, clear objective, good for learning basic flow." },
  { q: "Do I need to buy gear in my first session?", a: "No. Buy only the minimum required for your chosen activity." },
  { q: "How do I avoid getting overwhelmed?", a: "Pick one loop and finish it once. Expand only after a successful run." },
  { q: "What if I’m lagging or stuttering?", a: "Fix performance first (SSD/RAM/settings). It’s the fastest way to improve your first impression." },
  { q: "Where does earning money fit in?", a: "After your first clean loop, switch to the make-money-fast page for repeatable money ideas." }
];
---

<BaseLayout
  title="Star Citizen First Session Checklist (Quick Version) | Star Citizen Beginner"
  description="A short first-session checklist for Star Citizen beginners. Use the full first-session guide for the clearer walkthrough and extra explanations."
  canonicalPath="/satellites/first-session/"
  robots="noindex,follow"
  ogImage={heroImg}
  ogImageAlt="Star Citizen first session checklist hero image"
  stickyCtaLabel="Create account + claim bonus"
  stickyCtaHref={referralLink}
  stickyCtaExternal={true}
  activeNav="guides"
>
  <main>

    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Answers', href: '/satellites/' }, { label: 'Answer', href: '/satellites/first-session-checklist/' }]} />
    <section class="hero guideHero">
      <img
        class="hero__img"
        src={heroImg}
        alt="Star Citizen first session checklist"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1536"
        height="1024"
      />
      <div class="hero__overlay"></div>

      <div class="hero__content">
        <div class="guideHero__content">
          <div class="kicker"><span class="dot"></span> Starter Guide</div>
          <h1 class="h1">Star Citizen first session checklist (quick version)</h1>
          <p class="lead" style="max-width: 820px;">Answer: This is the short version. If you want the fuller beginner walkthrough with more explanation, use the main first-session guide.</p>

          <div class="hero__cta">
            <a class="btn primary" href="#quick-answer">Start here</a>
          </div>
        </div>

        <OnThisPage variant="hero" title="On this page" items={tocItems} />
      </div>
    </section>

    <ReferralBanner
      code={referralCode}
      bonus="50,000"
      ctaLabel="Create account + claim bonus"
      ctaHref={referralLink}
      ctaExternal={true}
    />

    <section id="quick-answer" class="section">
      <div class="container">
        <h2 class="h2">Quick answer</h2>

        <div class="callout" style="margin-bottom:12px;">
          <div class="kicker"><span class="dot"></span>Main guide</div>
          <p class="muted" style="margin-top:10px;">This page is the short checklist. For the fuller version with more context and beginner help, use <a href="/satellites/first-session/">Your first good Star Citizen session</a>.</p>
        </div>

        <div class="card pad" style="margin-bottom:12px;">
          <div class="kicker"><span class="dot"></span>Answer</div>
          <p class="lead" style="margin-top:10px;">Your first goal is simple: get in, finish one easy loop, and end the session feeling like things make sense.</p>
        </div>

        <ul class="bullets">
          <li>A good first session is one complete loop, not a perfect session.</li>
          <li>Your first goal is <b>one simple run</b>: spawn, find your ship, finish one easy contract, get paid.</li>
<li>Skip the deeper systems in session one. You do not need everything at once.</li>
<li>If the game stutters badly or loads forever, fix performance first.</li>
        </ul>

        <div style="display:flex; flex-wrap:wrap; gap:10px; margin-top: 14px;">
          <a class="btn primary" href={referralLink} rel="nofollow noopener" target="_blank">Create account + claim bonus</a>
          <a class="btn ghost" href="/star-citizen-referral-code/">Where to paste the referral code →</a>
        </div>
      </div>
    </section>

    <section id="do-this-now" class="section alt">
      <div class="container">
        <h2 class="h2">Do this now</h2>
        <ol class="steps">
          <li><b>Spawn and choose your home location</b> — do not worry about ten settings yet.</li>
<li><b>Claim your ship and leave the hangar once</b> — skip shopping for now.</li>
<li><b>Accept one simple contract</b> — pick something you can finish in one run.</li>
<li><b>Finish it and get paid</b> — a small win matters more than perfect profit.</li>
<li><b>Log out cleanly</b> — end the session in a way you can understand when you come back.</li>
        </ol>
      </div>
    </section>

    <section id="common-mistakes" class="section">
      <div class="container">
        <h2 class="h2">Common mistakes (and exact fixes)</h2>
        <div class="tableWrap">
          <table class="table">
            <thead>
              <tr>
                <th>Mistake</th>
                <th>What happens</th>
                <th>Fix (exact)</th>
              </tr>
            </thead>
            <tbody>
              <tr><td><b>Shopping and looting first</b></td><td>You burn your session on inventory friction.</td><td>Do one contract first; shop later with a goal.</td></tr>
<tr><td><b>Changing 20 settings at once</b></td><td>You do not know what actually helped.</td><td>Change one group of settings at a time after your first loop.</td></tr>
<tr><td><b>Starting with high-risk combat</b></td><td>You die, lose gear, and get frustrated.</td><td>Earn a clean win first; scale risk later.</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section id="next-steps" class="section alt">
      <div class="container">
        <h2 class="h2">Next steps</h2>
        <ul class="bullets">
          <li><a href="/satellites/first-session/">Full first-session guide</a> — the better next read if you want more explanation.</li>
<li><a href="/make-money-fast/">Make money fast (easy beginner loops)</a></li>
<li><a href="/star-citizen-performance-guide/">Performance guide (stutter fixes)</a></li>
<li><a href="/free-fly/">Free Fly guide (try without buying)</a></li>
<li><a href="/should-you-buy-star-citizen/">Should you buy? 2‑minute test</a></li>
        
          <li><a href="/satellites/how-to-claim-your-ship-asop-terminal/">Ship terminal confusing? Use the ASOP guide next</a></li>
        </ul>
      </div>
    </section>

    <section id="faq" class="section">
      <div class="container">
        <h2 class="h2">FAQ</h2>
        <div class="faq" style="margin-top:12px;">
          {faqItems.map((item) => (
            <details class="faq__item">
              <summary class="faq__q">{item.q}</summary>
              <div class="faq__a">{item.a}</div>
            </details>
          ))}
        </div>

        <div style="display:flex; flex-wrap:wrap; gap:10px; margin-top: 18px;">
          <a class="btn primary" href={referralLink} rel="nofollow noopener" target="_blank">Create account + claim bonus</a>
          <a class="btn ghost" href="/star-citizen-referral-code/">Referral code guide →</a>
        </div>
      </div>

      <FaqSchema items={faqItems} />
    </section>
  </main>
</BaseLayout>
