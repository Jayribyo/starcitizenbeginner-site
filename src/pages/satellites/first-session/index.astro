---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ReferralBanner from "../../../components/ReferralBanner.astro";
import OnThisPage from "../../../components/OnThisPage.astro";
import FaqSchema from "../../../components/FaqSchema.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import { REFERRAL_CODE, REFERRAL_LINK, REFERRAL_INFO_PATH, REFERRAL_BONUS_UEC, FLY_FREE_URL } from "../../../config/site";

const referralCode = REFERRAL_CODE;
const referralLink = REFERRAL_LINK;

const heroImg = "/assets/img/home/scb-home-hero.webp";

const tocItems = [
  { id: "quick-answer", label: "Quick answer" },
  { id: "do-this-now", label: "First 60 minutes" },
  { id: "mistakes", label: "Avoid the traps" },
  { id: "next-steps", label: "Next steps" },
  { id: "faq", label: "FAQ" }
];

const faqItems = [
  {
    "q": "What’s the fastest first goal?",
    "a": "Complete one simple contract end-to-end, then log out cleanly. That single loop removes most beginner overwhelm."
  },
  {
    "q": "Do I need to buy to do this?",
    "a": "No. Use this guide during Free Fly, or after you buy a starter pack."
  },
  {
    "q": "What if I can’t find my ship?",
    "a": "Go to an ASOP terminal in the hangar and retrieve it. If it’s destroyed, use Claim."
  },
  {
    "q": "What if performance is bad?",
    "a": "Fix stutter/FPS first—otherwise every step feels worse than it should."
  },
  {
    "q": "What’s the easiest first mission type?",
    "a": "Courier/delivery style contracts: low risk, teaches navigation, and pays consistently."
  },
  {
    "q": "Do I need gear right away?",
    "a": "Only the basics (undersuit + helmet). Buy more after your first stable loop."
  },
  {
    "q": "What’s the biggest beginner mistake?",
    "a": "Trying five systems at once: ships, gear, FPS, money, exploring. Pick one loop first."
  },
  {
    "q": "How do I not lose progress?",
    "a": "End the session in a safe location and log out normally. Avoid risky inventory shuffles in the field."
  },
  {
    "q": "When should I team up?",
    "a": "After you can complete the guide solo once. Then friends make everything faster."
  },
  {
    "q": "What should I do next?",
    "a": "Pick one next step: making credits, fixing performance, or deciding whether to buy—and follow the linked page."
  }
];
---

<BaseLayout
  title="Star Citizen First Session Checklist (Beginner Route) | Star Citizen Beginner"
  description="A simple first-session guide for new players: ship → contract → payout → safe log out, with clear steps and the common mistakes to avoid."
  canonicalPath="/satellites/first-session/"
  ogImage={heroImg}
  ogImageAlt="Star Citizen first session checklist hero image"
  activeNav="guides"
>
  <main>
    <section class="hero">
      <div class="container">
        <Breadcrumbs items={[
          { label: "Home", href: "/" },
          { label: "Starter guides", href: "/" },
          { label: "First session", href: "/satellites/first-session/" }
        ]} />
        <div class="hero__inner">
          <div class="kicker"><span class="dot"></span>Starter guide</div>
          <h1 class="h1">Your first good Star Citizen session</h1>
          <p class="hero__lead">One simple first-session plan to remove overwhelm: ship → contract → payout → safe log out.</p>
          <div class="hero__cta">
            <a class="btn primary" href="#do-this-now">See the first-session plan</a>
          </div>
        </div>

        <OnThisPage items={tocItems} />
      </div>
    </section>

    <ReferralBanner />

    <section id="quick-answer" class="section">
      <div class="container">
        <h2 class="h2">Quick answer</h2>

        <div class="card pad" style="margin-bottom:12px;">
          <div class="kicker"><span class="dot"></span>Answer</div>
          <p class="lead" style="margin-top:10px;">If you finish <b>one</b> complete loop in your first session, the game gets much easier to read. This guide is built to get you there without extra stress.</p>
        </div>

        <ul class="bullets">
          <li>Goal: complete one simple contract from start to finish (the payout shows you the loop works).</li>
          <li>Keep gear light. Your first win is <b>stability</b>, not loot.</li>
          <li>Your home location matters because it becomes your first base and where many starting items live.</li>
          <li>If FPS/stutter ruins the session, fix performance first: <a class="link" href="/star-citizen-performance-guide/">10‑minute performance guide</a>.</li>
        </ul>
      </div>
    </section>

    <section id="do-this-now" class="section">
      <div class="container">
        <h2 class="h2">Do this now</h2>

        <div class="card pad">
          <div class="grid-2">
            <div>
              <h3 class="h3">First 60 minutes plan</h3>
              <ol class="steps">
                <li>Spawn and set your home location. This becomes your first base, so do not click through it blindly.</li>
                <li>Go to the hangar area and find an <b>ASOP terminal</b>.</li>
                <li>Retrieve your ship. If needed, use <b>Claim</b> to restore it.</li>
                <li>Accept a simple <b>courier/delivery</b> style contract.</li>
                <li>Complete the contract end‑to‑end and collect the payout.</li>
                <li>Return to a safe location and log out normally.</li>
              </ol>
              <p class="muted" style="margin-top:10px;">Verify: you completed one contract and ended the session without losing your basic kit. Your home location will also be where many of your starting items live.</p>
              <div class="callout" style="margin-top:12px;">
                <div class="kicker"><span class="dot"></span>What is normal on day one</div>
                <ul class="list" style="margin-top:10px;">
                  <li>Feeling a little lost in the spaceport for the first few minutes.</li>
                  <li>Needing an ASOP terminal before you see your ship.</li>
                  <li>Taking longer to leave the hangar than the contract itself.</li>
                </ul>
              </div>
            </div>
            <div>
              <h3 class="h3">If you’re trying Free Fly</h3>
              <ul class="bullets">
                <li>Use this guide to see if the game feels right for you before spending money.</li>
                <li>If you decide to buy, keep it simple: one game package, then check My Hangar, install through the launcher, and come back here for the first session.</li>
              </ul>
              <div style="display:flex; flex-wrap:wrap; gap:10px; margin-top: 12px;">
                <a class="btn" href="/free-fly/">Free Fly guide</a>
                <a class="btn primary" href={referralLink} rel="nofollow noopener" target="_blank">Create account + claim bonus</a>
              </div>
              <p class="muted" style="margin-top:10px;">Already have an account? Use the referral guide to avoid dead ends.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="mistakes" class="section">
      <div class="container">
        <h2 class="h2">Avoid the traps</h2>

        <div class="table-wrap">
          <table class="table">
            <thead>
              <tr><th>Mistake</th><th>What happens</th><th>Fix (exact)</th></tr>
            </thead>
            <tbody>
              <tr><td>Trying multiple systems at once</td><td>You feel lost and progress stalls.</td><td>Commit to one loop: retrieve ship → simple contract → payout.</td></tr>
              <tr><td>Over-buying gear</td><td>You bleed credits and fear losing items.</td><td>Run light gear until your income is stable.</td></tr>
              <tr><td>Judging the game while stuttering</td><td>The experience feels worse than it should.</td><td>Do the 10‑minute performance fixes first.</td></tr>
              <tr><td>Not knowing where your ship is</td><td>You waste time and get frustrated.</td><td>Use ASOP; if needed, use Claim and retrieve again.</td></tr>
              <tr><td>Picking a home location without thinking</td><td>Your first items and trips feel more awkward than they need to.</td><td>Pause for ten seconds and choose the place you actually want to learn from.</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section id="next-steps" class="section">
      <div class="container">
        <h2 class="h2">Next steps</h2>
        <div class="grid-3">
          <a class="card pad linkcard" href="/make-money-fast/">
            <div class="kicker"><span class="dot"></span>Progress</div>
            <h3 class="h3">Make money fast</h3>
            <p class="muted">Turn your first win into consistent credits and upgrades.</p>
          </a>
          <a class="card pad linkcard" href="/should-you-buy-star-citizen/">
            <div class="kicker"><span class="dot"></span>Decide</div>
            <h3 class="h3">Should you buy?</h3>
            <p class="muted">A simple way to decide what to do next without buying too much too early.</p>
          </a>
          <a class="card pad linkcard" href="/satellites/glossary/">
            <div class="kicker"><span class="dot"></span>Understand</div>
            <h3 class="h3">Beginner glossary</h3>
            <p class="muted">Quick definitions of the terms you’ll see everywhere.</p>
          </a>
        </div>
      </div>
    </section>

    <section id="faq" class="section">
      <div class="container">
        <h2 class="h2">FAQ</h2>
        <div class="faq">
          {faqItems.map((item) => (
            <details class="faq__item">
              <summary class="faq__q"><span class="faq__icon">+</span>{item.q}</summary>
              <div class="faq__a"><p>{item.a}</p></div>
            </details>
          ))}
        </div>

        <div style="display:flex; flex-wrap:wrap; gap:10px; margin-top: 14px;">
          <a class="btn" href="/star-citizen-performance-guide/">Performance guide</a>
          <a class="btn primary" href={referralLink} rel="nofollow noopener" target="_blank">Create account + claim bonus</a>
        </div>
      </div>
    </section>

    <FaqSchema items={faqItems} />
  </main>
</BaseLayout>
