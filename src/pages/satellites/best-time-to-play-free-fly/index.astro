---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ReferralBanner from "../../../components/ReferralBanner.astro";
import OnThisPage from "../../../components/OnThisPage.astro";
import FaqSchema from "../../../components/FaqSchema.astro";
import Breadcrumbs from '../../../components/Breadcrumbs.astro';

const referralCode = "STAR-FSRJ-5N7Z";
const referralLink = `https://www.robertsspaceindustries.com/enlist?referral=${referralCode}`;

const heroImg = "/assets/img/free-fly/star-citizen-free-fly-hero.webp";

const tocItems = [
  { id: "quick-answer", label: "Quick answer" },
  { id: "do-this-now", label: "Do this now" },
  { id: "common-mistakes", label: "Common mistakes" },
  { id: "next-steps", label: "Next steps" },
  { id: "faq", label: "FAQ" }
];

const faqItems = [
  { q: "Do regions matter?", a: "Often yes. Try your closest region first, then the next closest if the session is unstable." },
  { q: "Are queues always a PC problem?", a: "No. Queues are server-side; PC tuning won’t remove queues." },
  { q: "How do I get a fair performance test?", a: "Retest the same short loop after each change." },
  { q: "What’s the best first activity during Free Fly?", a: "A short courier loop is the cleanest signal." },
  { q: "Should I avoid events?", a: "For your first session, avoid anything that forces crowded hubs or long waits." }
];
---

<BaseLayout
  title="What's the Time to Play Free Fly (Get a Fair First Impression)? (Beginner checklist) | Star Citizen Beginner"
  description="Best time to play Star Citizen Free Fly: simple timing rules to dodge queues and server lag, plus the quickest fallback steps when it’s still rough."
  canonicalPath="/satellites/best-time-to-play-free-fly/"
  ogImage={heroImg}
  ogImageAlt="Best Time to Play Free Fly (Get a Fair First Impression)"
  stickyCtaLabel="Create account + claim bonus"
  stickyCtaHref={referralLink}
  stickyCtaExternal={true}
  activeNav="guides"
>
  <main>

    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Answers', href: '/satellites/' }, { label: 'Answer', href: '/satellites/best-time-to-play-free-fly/' }]} />
    <section class="hero guideHero">
      <img
        class="hero__img"
        src={heroImg}
        alt="Best Time to Play Free Fly (Get a Fair First Impression)"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1536"
        height="1024"
      />
      <div class="hero__overlay"></div>

      <div class="hero__content">
        <div class="guideHero__content">
          <div class="kicker"><span class="dot"></span> Starter Guide</div>
          <h1 class="h1">Best Time to Play Free Fly (Get a Fair First Impression)</h1>
          <p class="lead" style="max-width: 820px;">Answer: A practical, evergreen way to pick a good time/server for Free Fly so you avoid the worst queues and lag — without relying on dates.</p>

          <div class="hero__cta">
            <a class="btn primary" href="#quick-answer">Start here</a>
          </div>
        </div>

        <OnThisPage variant="hero" title="On this page" items={tocItems} />
      </div>
    </section>

    <ReferralBanner
      code={referralCode}
      bonus="50,000"
      ctaLabel="Claim your start bonus"
      ctaHref={referralLink}
      ctaExternal={true}
    />

    <section id="quick-answer" class="section">
      <div class="container">
        <h2 class="h2">Quick answer</h2>

        <div class="card pad" style="margin-bottom:12px;">
          <div class="kicker"><span class="dot"></span>Answer</div>
          <p class="lead" style="margin-top:10px;">You can’t control global server load — but you can choose conditions that usually feel smoother.</p>
        </div>

        <ul class="bullets">
          <li>You can’t control global server load — but you <b>can</b> choose conditions that usually feel smoother.</li>
<li>Best principle: do your first session when you can <b>take your time</b> and avoid the biggest crowds.</li>
<li>If queues/lag dominate, treat it as a test variable: switch region, pick a calmer starting area, and try again.</li>
        </ul>
      </div>
    </section>

    <section id="do-this-now" class="section alt">
      <div class="container">
        <h2 class="h2">Do this now</h2>
        <ol class="steps">
          <li><b>Pick a region closest to you</b> first, then try the next best region if the session feels unstable.</li>
<li><b>Avoid the busiest hubs for your first loop</b> — start where you can reach the spaceport quickly and leave.</li>
<li><b>Do one short contract</b> so you can restart if the session is bad (don’t commit to long routes).</li>
<li><b>If the server feels rough</b>, hop: new server session, or new region, then repeat the same short loop.</li>
<li><b>Only then</b> decide if the game “runs well enough” on your setup.</li>
        </ol>
      </div>
    </section>

    <section id="common-mistakes" class="section">
      <div class="container">
        <h2 class="h2">Common mistakes (and exact fixes)</h2>
        <div class="tableWrap">
          <table class="table">
            <thead>
              <tr>
                <th>Mistake</th>
                <th>What happens</th>
                <th>Fix (exact)</th>
              </tr>
            </thead>
            <tbody>
              <tr><td><b>Testing only during peak chaos</b></td><td>You conclude the game is always like this.</td><td>Retry with a short loop on a different region/session.</td></tr>
<tr><td><b>Staying in a bad session too long</b></td><td>You waste an hour and get nothing.</td><td>Abort early; repeat a 10–15 minute loop instead.</td></tr>
<tr><td><b>Using performance as a “yes/no” without retest</b></td><td>You mix server issues with PC issues.</td><td>If stutter persists everywhere, run the performance checklist.</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section id="next-steps" class="section alt">
      <div class="container">
        <h2 class="h2">Next steps</h2>
        <ul class="bullets">
          <li><a href="/free-fly/">Free Fly guide (full checklist)</a></li>
<li><a href="/should-you-buy-star-citizen/">Should you buy? (2-minute decision test)</a></li>
<li><a href="/star-citizen-performance-guide/">Performance guide (fix stutter / low FPS)</a></li>
        </ul>
      </div>
    </section>

    <section id="faq" class="section">
      <div class="container">
        <h2 class="h2">FAQ</h2>
        <div class="faq" style="margin-top:12px;">
          {faqItems.map((item) => (
            <details class="faq__item">
              <summary class="faq__q">{item.q}</summary>
              <div class="faq__a">{item.a}</div>
            </details>
          ))}
        </div>
        
      </div>

      <FaqSchema items={faqItems} />
    </section>
  </main>
</BaseLayout>
