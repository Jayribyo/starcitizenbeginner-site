---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ReferralBanner from "../../../components/ReferralBanner.astro";
import OnThisPage from "../../../components/OnThisPage.astro";
import FaqSchema from "../../../components/FaqSchema.astro";
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { REFERRAL_CODE, REFERRAL_LINK, REFERRAL_INFO_PATH, REFERRAL_BONUS_UEC, FLY_FREE_URL } from "../../../config/site";

const referralCode = REFERRAL_CODE;
const referralLink = REFERRAL_LINK;

const heroImg = "/assets/img/star-citizen-performance-guide/star-citizen-best-settings-performance-optimization-hero.webp";

const tocItems = [
  { id: "quick-answer", label: "Quick answer" },
  { id: "do-this-now", label: "Do this now" },
  { id: "common-mistakes", label: "Common mistakes" },
  { id: "next-steps", label: "Next steps" },
  { id: "faq", label: "FAQ" }
];

const faqItems = [
  { q: "What’s the best single setting to lower?", a: "Volumetric clouds is a common high-impact lever." },
  { q: "Do textures affect FPS?", a: "Mostly VRAM pressure; too high can cause hitching/stutter." },
  { q: "Should I cap FPS?", a: "If tearing or spikes bother you, a cap can improve feel. Test it." },
  { q: "Do I need to reinstall?", a: "Usually no. Start with settings + storage/RAM checks." },
  { q: "Where’s the full list?", a: "Use the main performance guide for the complete levers table." }
];
---

<BaseLayout
  title="Star Citizen Low-End PC Settings: What to Lower First | Star Citizen Beginner"
  description="Star Citizen low-end PC settings: what to lower first, what to leave alone, and how to get a smoother test without wasting time on tiny tweaks."
  canonicalPath="/satellites/best-settings-for-low-end-pc-star-citizen/"
  ogImage={heroImg}
  ogImageAlt="Best Star Citizen Settings for Low-End PCs"
  stickyCtaLabel="Create account + claim bonus"
  stickyCtaHref={referralLink}
  stickyCtaExternal={true}
  activeNav="guides"
>
  <main>

    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Answers', href: '/satellites/' }, { label: 'Answer', href: '/satellites/best-settings-for-low-end-pc-star-citizen/' }]} />
    <section class="hero guideHero">
      <img
        class="hero__img"
        src={heroImg}
        alt="Best Settings for Low-End PCs (Playability First)"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1536"
        height="1024"
      />
      <div class="hero__overlay"></div>

      <div class="hero__content">
        <div class="guideHero__content">
          <div class="kicker"><span class="dot"></span> Starter Guide</div>
          <h1 class="h1">Star Citizen low-end PC settings: what to lower first</h1>
          <p class="lead" style="max-width: 820px;">Answer: If your PC is on the weak side, start with the settings that actually move the needle first. This page shows what to lower, what to leave alone, and how to test each change properly.</p>

          <div class="hero__cta">
            <a class="btn primary" href="#quick-answer">Start here</a>
          </div>
        </div>

        <OnThisPage variant="hero" title="On this page" items={tocItems} />
      </div>
    </section>

    <ReferralBanner
      code={referralCode}
      bonus="50,000"
      ctaLabel="Claim your start bonus"
      ctaHref={referralLink}
      ctaExternal={true}
    />

    <section id="quick-answer" class="section">
      <div class="container">
        <h2 class="h2">Quick answer</h2>

        <div class="card pad" style="margin-bottom:12px;">
          <div class="kicker"><span class="dot"></span>Answer</div>
          <p class="lead" style="margin-top:10px;">Low-end goal is playability: stable frametime and fewer stutters, not perfect visuals.</p>
        </div>

        <ul class="bullets">
          <li>Test in the same place after each change, or you will not know what actually helped.</li>
          <li>Low-end goal is <b>playability</b>: stable frametime and fewer stutters, not perfect visuals.</li>
<li>Start with the biggest levers (clouds/volumetrics/shadows/upscaling) before micro-tweaks.</li>
<li>Change one cluster at a time and verify in the same scene.</li>
        </ul>
      </div>
    </section>

    <section id="do-this-now" class="section alt">
      <div class="container">
        <h2 class="h2">Do this now</h2>
        <ol class="steps">
          <li><b>Use upscaling</b> (if available) to reduce render cost while keeping readability.</li>
<li><b>Lower volumetric clouds</b> first — it’s a common heavy setting.</li>
<li><b>Reduce shadows</b> (quality + distance) before touching minor post effects.</li>
<li><b>Keep textures sensible</b> based on VRAM headroom (avoid max if you stutter).</li>
<li><b>Verify</b> in the same location and measure ‘feel’ (stutter, camera hitching) not just average FPS.</li>
        </ol>
      </div>
    </section>

    <section id="common-mistakes" class="section">
      <div class="container">
        <h2 class="h2">Common mistakes (and exact fixes)</h2>
        <div class="tableWrap">
          <table class="table">
            <thead>
              <tr>
                <th>Mistake</th>
                <th>What happens</th>
                <th>Fix (exact)</th>
              </tr>
            </thead>
            <tbody>
              <tr><td><b>Turning everything to Low blindly</b></td><td>You may lose clarity without fixing the real bottleneck.</td><td>Start with the top levers; keep what doesn’t hurt performance.</td></tr>
<tr><td><b>Changing 10 settings at once</b></td><td>You can’t tell what helped.</td><td>Change one cluster, retest, then continue.</td></tr>
<tr><td><b>Ignoring storage/RAM bottlenecks</b></td><td>Settings won’t fix streaming issues.</td><td>Use the stutter checklist (SSD/RAM/pagefile).</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section id="next-steps" class="section alt">
      <div class="container">
        <h2 class="h2">Next steps</h2>
        <ul class="bullets">
          <li><a href="/star-citizen-performance-guide/">Open the full performance guide</a></li>
<li><a href="/satellites/fix-stuttering/">Still hitching? Use the stutter checklist next</a></li>
<li><a href="/satellites/cpu-vs-gpu-bottleneck-test/">Not sure what is limiting you? Run the bottleneck test</a></li>
        </ul>
      </div>
    </section>

    <section id="faq" class="section">
      <div class="container">
        <h2 class="h2">FAQ</h2>
        <div class="faq" style="margin-top:12px;">
          {faqItems.map((item) => (
            <details class="faq__item">
              <summary class="faq__q">{item.q}</summary>
              <div class="faq__a">{item.a}</div>
            </details>
          ))}
        </div>
        
      </div>

      <FaqSchema items={faqItems} />
    </section>
  </main>
</BaseLayout>
