---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ReferralBanner from "../../../components/ReferralBanner.astro";
import OnThisPage from "../../../components/OnThisPage.astro";
import FaqSchema from "../../../components/FaqSchema.astro";
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { REFERRAL_CODE, REFERRAL_LINK, REFERRAL_INFO_PATH, REFERRAL_BONUS_UEC, FLY_FREE_URL } from "../../../config/site";

const referralCode = REFERRAL_CODE;
const referralLink = REFERRAL_LINK;

const heroImg = "/assets/img/make-money-fast/star-citizen-earn-auec-fast-mining-trade-profit-hero.webp";

const tocItems = [
  { id: "quick-answer", label: "Quick answer" },
  { id: "do-this-now", label: "Do this now" },
  { id: "common-mistakes", label: "Common mistakes" },
  { id: "next-steps", label: "Next steps" },
  { id: "faq", label: "FAQ" }
];

const faqItems = [
  { q: "What’s the safest way to start earning with gear risk?", a: "Do courier missions first; add FPS later." },
  { q: "Do I need armor to make money?", a: "Not for courier/bounties. FPS missions are the main gear-risk path." },
  { q: "How do I stop losing money?", a: "Use cheap kit + bank wins + scale only after consistency." },
  { q: "What should I upgrade first?", a: "Quality-of-life upgrades that reduce friction, not flashy gear." },
  { q: "Where does this fit into money-making?", a: "Use Make Money Fast to choose loops that match your risk tolerance." }
];
---

<BaseLayout
  title="Inventory & Gear Basics (Don’t Lose Your Kit) (Beginner checklist) | Star Citizen Beginner"
  description="Inventory & gear basics: what to buy, where to store it, how insurance works, and how to avoid losing everything to a random death."
  canonicalPath="/satellites/inventory-and-gear-beginner-basics/"
  ogImage={heroImg}
  ogImageAlt="Inventory & Gear Basics (Don’t Lose Your Kit)"
  stickyCtaLabel="Create account + claim bonus"
  stickyCtaHref={referralLink}
  stickyCtaExternal={true}
  activeNav="guides"
>
  <main>

    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Answers', href: '/satellites/' }, { label: 'Answer', href: '/satellites/inventory-and-gear-beginner-basics/' }]} />
    <section class="hero guideHero">
      <img
        class="hero__img"
        src={heroImg}
        alt="Inventory & Gear Basics (Don’t Lose Your Kit)"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1536"
        height="1024"
      />
      <div class="hero__overlay"></div>

      <div class="hero__content">
        <div class="guideHero__content">
          <div class="kicker"><span class="dot"></span> Starter Guide</div>
          <h1 class="h1">Inventory & Gear Basics (Don’t Lose Your Kit)</h1>
          <p class="lead" style="max-width: 820px;">Answer: The beginner rules for inventory, gear, and safe loadouts so you stop losing money to avoidable mistakes.</p>

          <div class="hero__cta">
            <a class="btn primary" href="#quick-answer">Start here</a>
          </div>
        </div>

        <OnThisPage variant="hero" title="On this page" items={tocItems} />
      </div>
    </section>

    <ReferralBanner
      code={referralCode}
      bonus="50,000"
      ctaLabel="Claim your start bonus"
      ctaHref={referralLink}
      ctaExternal={true}
    />

    <section id="quick-answer" class="section">
      <div class="container">
        <h2 class="h2">Quick answer</h2>

        <div class="card pad" style="margin-bottom:12px;">
          <div class="kicker"><span class="dot"></span>Answer</div>
          <p class="lead" style="margin-top:10px;">Gear loss is one of the biggest beginner money sinks. You don’t need perfect gear — you need repeatable rules.</p>
        </div>

        <ul class="bullets">
          <li>Gear loss is one of the biggest beginner money sinks. You don’t need perfect gear — you need <b>repeatable rules</b>.</li>
<li>Your first goal is to avoid spending credits twice: buy cheap kit, survive, and scale only after consistency.</li>
<li>Use these rules before you touch riskier FPS missions.</li>
        </ul>
      </div>
    </section>

    <section id="do-this-now" class="section alt">
      <div class="container">
        <h2 class="h2">Do this now</h2>
        <ol class="steps">
          <li><b>Run cheap kit early</b> (replaceable). Don’t bring your ‘best’ gear to your first FPS run.</li>
<li><b>Carry only what you’ll use</b> — less inventory friction, less loss.</li>
<li><b>Bank your wins</b>: sell/secure loot after a successful run before you chase more.</li>
<li><b>Upgrade one piece at a time</b> after you’ve done a few clean missions.</li>
<li><b>If you keep dying</b>, switch to courier/bounties until movement and awareness improve.</li>
        </ol>
      </div>
    </section>

    <section id="common-mistakes" class="section">
      <div class="container">
        <h2 class="h2">Common mistakes (and exact fixes)</h2>
        <div class="tableWrap">
          <table class="table">
            <thead>
              <tr>
                <th>Mistake</th>
                <th>What happens</th>
                <th>Fix (exact)</th>
              </tr>
            </thead>
            <tbody>
              <tr><td><b>Bringing expensive gear immediately</b></td><td>You pay repeatedly for learning mistakes.</td><td>Run cheap kit until you can complete missions reliably.</td></tr>
<tr><td><b>Loot greed</b></td><td>You die during extraction and lose everything.</td><td>Extract early, bank the win, repeat.</td></tr>
<tr><td><b>Doing FPS while performance is bad</b></td><td>You miss shots and lose fights unfairly.</td><td>Fix FPS first; then judge FPS missions.</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section id="next-steps" class="section alt">
      <div class="container">
        <h2 class="h2">Next steps</h2>
        <ul class="bullets">
          <li><a href="/satellites/first-session-checklist/">First session checklist (beginner route)</a></li>
<li><a href="/make-money-fast/">Make money fast (safe loops)</a></li>
<li><a href="/free-fly/">Free Fly guide (try without buying)</a></li>
        </ul>
      </div>
    </section>

    <section id="faq" class="section">
      <div class="container">
        <h2 class="h2">FAQ</h2>
        <div class="faq" style="margin-top:12px;">
          {faqItems.map((item) => (
            <details class="faq__item">
              <summary class="faq__q">{item.q}</summary>
              <div class="faq__a">{item.a}</div>
            </details>
          ))}
        </div>
        
      </div>

      <FaqSchema items={faqItems} />
    </section>
  </main>
</BaseLayout>
