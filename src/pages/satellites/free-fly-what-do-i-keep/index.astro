---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ReferralBanner from "../../../components/ReferralBanner.astro";
import OnThisPage from "../../../components/OnThisPage.astro";
import FaqSchema from "../../../components/FaqSchema.astro";
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { REFERRAL_CODE, REFERRAL_LINK, REFERRAL_INFO_PATH, REFERRAL_BONUS_UEC, FLY_FREE_URL, FREE_FLY_HUB_PATH, SHOULD_YOU_BUY_PATH, PERFORMANCE_GUIDE_PATH } from "../../../config/site";

const referralCode = REFERRAL_CODE;
const referralLink = REFERRAL_LINK;

const heroImg = "/assets/img/free-fly/star-citizen-free-fly-hero.webp";

const tocItems = [
  { id: "quick-answer", label: "Quick answer" },
  { id: "do-this-now", label: "Do this now" },
  { id: "common-mistakes", label: "Common mistakes" },
  { id: "next-steps", label: "Next steps" },
  { id: "faq", label: "FAQ" }
];

const faqItems = [
  { q: "Do I need a game package to play?", a: "Yes outside Free Fly. Free Fly is the exception that lets you play temporarily." },
  { q: "Should I create an account during Free Fly?", a: "Yes — it’s the cleanest way to keep your identity and options if you buy later." },
  { q: "Can I use the same account if I buy later?", a: "Yes. That’s the point: trial first, then buy smart." },
  { q: "Does Free Fly help me decide?", a: "Yes, if you run a structured first session route instead of random chaos." },
  { q: "Where do referral codes fit?", a: "They’re optional and only apply during signup — use them only if you’re creating a brand-new account." }
];
---

<BaseLayout
  title="Free Fly: What Do You Keep? (Progress, Items, Accounts) | Star Citizen Beginner"
  description="What do you keep after Free Fly? A clear breakdown of what carries over when you later buy (account, settings, progress) and what doesn’t."
  canonicalPath="/satellites/free-fly-what-do-i-keep/"
  ogImage={heroImg}
  ogImageAlt="Free Fly: What Do You Keep? (Progress, Items, Accounts)"
  stickyCtaLabel="Create account + claim bonus"
  stickyCtaHref={referralLink}
  stickyCtaExternal={true}
  activeNav="guides"
>
  <main>

    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Answers', href: '/satellites/' }, { label: 'Answer', href: '/satellites/free-fly-what-do-i-keep/' }]} />
    <section class="hero guideHero">
      <img
        class="hero__img"
        src={heroImg}
        alt="Free Fly: What Do You Keep? (Progress, Items, Accounts)"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1536"
        height="1024"
      />
      <div class="hero__overlay"></div>

      <div class="hero__content">
        <div class="guideHero__content">
          <div class="kicker"><span class="dot"></span> Starter Guide</div>
          <h1 class="h1">Free Fly: What Do You Keep? (Progress, Items, Accounts)</h1>
          <p class="lead" style="max-width: 820px;">Answer: A clear, evergreen explanation of what Free Fly does and doesn’t give you, and what carries over when you later buy a starter pack.</p>

          <div class="hero__cta">
            <a class="btn primary" href="#quick-answer">Start here</a>
          </div>
        </div>

        <OnThisPage variant="hero" title="On this page" items={tocItems} />
      </div>
    </section>

    <ReferralBanner
      code={referralCode}
      bonus="50,000"
      ctaLabel="Claim your start bonus"
      ctaHref={referralLink}
      ctaExternal={true}
    />

    <section id="quick-answer" class="section">
      <div class="container">
        <h2 class="h2">Quick answer</h2>

        <div class="card pad" style="margin-bottom:12px;">
          <div class="kicker"><span class="dot"></span>Answer</div>
          <p class="lead" style="margin-top:10px;">Free Fly lets you play temporarily without buying a package — it’s the safest way to test the game.</p>
        </div>

        <ul class="bullets">
          <li>Free Fly lets you <b>play temporarily</b> without buying a package — it’s the safest way to test the game.</li>
<li>Your account can still matter later: if you create it correctly, you can keep using it when you buy a starter pack.</li>
<li>Use this page to set expectations so you don’t make the wrong purchase decision.</li>
        </ul>
      </div>
    </section>

    <section id="do-this-now" class="section alt">
      <div class="container">
        <h2 class="h2">Do this now</h2>
        <ol class="steps">
          <li><b>Create an account</b> (optional: apply referral code during signup to claim the bonus window).</li>
<li><b>Play Free Fly</b> like a trial: run one clean loop, then test one extra activity you care about.</li>
<li><b>Don’t over-optimize</b> during Free Fly — first confirm the game clicks for you.</li>
<li><b>If you decide to buy</b>, start with the minimum starter package and upgrade later only if you keep playing.</li>
        </ol>
      </div>
    </section>

    <section id="common-mistakes" class="section">
      <div class="container">
        <h2 class="h2">Common mistakes (and exact fixes)</h2>
        <div class="tableWrap">
          <table class="table">
            <thead>
              <tr>
                <th>Mistake</th>
                <th>What happens</th>
                <th>Fix (exact)</th>
              </tr>
            </thead>
            <tbody>
              <tr><td><b>Assuming Free Fly is the “full” experience</b></td><td>You expect polished stability and get frustrated.</td><td>Treat it as a trial and focus on one clean loop.</td></tr>
<tr><td><b>Buying extra ships immediately</b></td><td>You spend money before you know your playstyle.</td><td>Start with minimum package; upgrade later.</td></tr>
<tr><td><b>Judging based on one bad session</b></td><td>You confuse server conditions with your PC.</td><td>Retest and use the performance checklist if needed.</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section id="next-steps" class="section alt">
      <div class="container">
        <h2 class="h2">Next steps</h2>
        <ul class="bullets">
          <li><a href={FREE_FLY_HUB_PATH} data-scb-role="free-fly-satellite-back-to-hub">Free Fly guide (full checklist)</a></li>
          <li><a href={SHOULD_YOU_BUY_PATH} data-scb-role="free-fly-satellite-buy-test">Should you buy? (2-minute decision test)</a></li>
          <li><a href={PERFORMANCE_GUIDE_PATH} data-scb-role="free-fly-satellite-performance">Performance guide (fix stutter / low FPS)</a></li>
          <li><a href={REFERRAL_INFO_PATH} data-scb-role="free-fly-satellite-referral-guide">Referral code guide (enter it during signup)</a></li>
        </ul>
      </div>
    </section>

    <section id="faq" class="section">
      <div class="container">
        <h2 class="h2">FAQ</h2>
        <div class="faq" style="margin-top:12px;">
          {faqItems.map((item) => (
            <details class="faq__item">
              <summary class="faq__q">{item.q}</summary>
              <div class="faq__a">{item.a}</div>
            </details>
          ))}
        </div>
        
      </div>

      <FaqSchema items={faqItems} />
    </section>
  </main>
</BaseLayout>
