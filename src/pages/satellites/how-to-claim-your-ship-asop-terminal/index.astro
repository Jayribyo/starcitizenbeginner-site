---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ReferralBanner from "../../../components/ReferralBanner.astro";
import OnThisPage from "../../../components/OnThisPage.astro";
import FaqSchema from "../../../components/FaqSchema.astro";
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { REFERRAL_CODE, REFERRAL_LINK, REFERRAL_INFO_PATH, REFERRAL_BONUS_UEC, FLY_FREE_URL } from "../../../config/site";

const referralCode = REFERRAL_CODE;
const referralLink = REFERRAL_LINK;

const heroImg = "/assets/img/home/scb-home-hero.webp";

const tocItems = [
  { id: "quick-answer", label: "Quick answer" },
  { id: "do-this-now", label: "Do this now" },
  { id: "common-mistakes", label: "Common mistakes" },
  { id: "next-steps", label: "Next steps" },
  { id: "faq", label: "FAQ" }
];

const faqItems = [
  { q: "What does ‘Claim’ do?", a: "It requests a replacement when your ship is destroyed/missing." },
  { q: "Do I lose my ship if I claim it?", a: "No — you’re not deleting ownership; you’re requesting a replacement." },
  { q: "Where do I find the hangar number?", a: "The terminal shows it after you retrieve the ship." },
  { q: "Why can’t I retrieve a ship?", a: "It may already be spawned, or the session is unstable. Try another terminal or relog." },
  { q: "What should I do next?", a: "Run a short first mission to practice the loop end-to-end." }
];
---

<BaseLayout
  title="How to Claim Your Ship at the ASOP Terminal | Star Citizen Beginner"
  description="ASOP terminal guide: where to find it, how to claim/spawn your ship, what 'retrieve' vs 'claim' means, and common fixes."
  canonicalPath="/satellites/how-to-claim-your-ship-asop-terminal/"
  ogImage={heroImg}
  ogImageAlt="How to Claim Your Ship at the ASOP Terminal (Fast, No Confusion)"
  stickyCtaLabel="Create account + claim bonus"
  stickyCtaHref={referralLink}
  stickyCtaExternal={true}
  activeNav="guides"
>
  <main>

    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Answers', href: '/satellites/' }, { label: 'Answer', href: '/satellites/how-to-claim-your-ship-asop-terminal/' }]} />
    <section class="hero guideHero">
      <img
        class="hero__img"
        src={heroImg}
        alt="How to Claim Your Ship at the ASOP Terminal (Fast, No Confusion)"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1536"
        height="1024"
      />
      <div class="hero__overlay"></div>

      <div class="hero__content">
        <div class="guideHero__content">
          <div class="kicker"><span class="dot"></span> Starter Guide</div>
          <h1 class="h1">How to claim your ship at the ASOP terminal</h1>
          <p class="lead" style="max-width: 820px;">Answer: Step-by-step: where to find the ASOP terminal, how to retrieve/claim a ship, and what to do if your ship is destroyed.</p>

          <div class="hero__cta">
            <a class="btn primary" href="#quick-answer">Start here</a>
          </div>
        </div>

        <OnThisPage variant="hero" title="On this page" items={tocItems} />
      </div>
    </section>

    <ReferralBanner
      code={referralCode}
      bonus="50,000"
      ctaLabel="Claim your start bonus"
      ctaHref={referralLink}
      ctaExternal={true}
    />

    <section id="quick-answer" class="section">
      <div class="container">
        <h2 class="h2">Quick answer</h2>

        <div class="card pad" style="margin-bottom:12px;">
          <div class="kicker"><span class="dot"></span>Answer</div>
          <p class="lead" style="margin-top:10px;">ASOP terminals are the ship kiosks where you retrieve and claim ships at spaceports.</p>
        </div>

        <ul class="bullets">
          <li>ASOP terminals are the <b>ship kiosks</b> where you retrieve and claim ships at spaceports.</li>
<li>If your ship is destroyed or missing, <b>Claim</b> is usually the correct action for beginners.</li>
<li>This is a core beginner bottleneck — once you can do this fast, everything else gets easier.</li>
        </ul>
      </div>
    </section>

    <section id="do-this-now" class="section alt">
      <div class="container">
        <h2 class="h2">Do this now</h2>
        <ol class="steps">
          <li><b>Go to the spaceport</b> area and find an <b>ASOP terminal</b> (ship retrieval kiosk).</li>
<li><b>Retrieve</b> your ship to assign it to a hangar/pad.</li>
<li><b>Follow the hangar/pad number</b> and board your ship.</li>
<li>If your ship is not available, select it and press <b>Claim</b> (then wait for it to be ready).</li>
<li>If you still can’t get it, try a different terminal or relog.</li>
        </ol>
      </div>
    </section>

    <section id="common-mistakes" class="section">
      <div class="container">
        <h2 class="h2">Common mistakes (and exact fixes)</h2>
        <div class="tableWrap">
          <table class="table">
            <thead>
              <tr>
                <th>Mistake</th>
                <th>What happens</th>
                <th>Fix (exact)</th>
              </tr>
            </thead>
            <tbody>
              <tr><td><b>Running around looking for your ship</b></td><td>You waste time and think you’re stuck.</td><td>Use ASOP: retrieve → go to assigned hangar/pad.</td></tr>
<tr><td><b>Not using Claim when needed</b></td><td>You wait forever for a ship that won’t spawn.</td><td>Use Claim when the ship is destroyed/missing.</td></tr>
<tr><td><b>Changing many things at once</b></td><td>You can’t diagnose the issue.</td><td>Try another terminal, then relog — simple resets first.</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section id="next-steps" class="section alt">
      <div class="container">
        <h2 class="h2">Next steps</h2>
        <ul class="bullets">
          <li><a href="/satellites/first-session-checklist/">First session checklist</a></li>
<li><a href="/make-money-fast/">Make money fast (safe loops)</a></li>
<li><a href="/free-fly/">Free Fly guide (try without buying)</a></li>
        </ul>
      </div>
    </section>

    <section id="faq" class="section">
      <div class="container">
        <h2 class="h2">FAQ</h2>
        <div class="faq" style="margin-top:12px;">
          {faqItems.map((item) => (
            <details class="faq__item">
              <summary class="faq__q">{item.q}</summary>
              <div class="faq__a">{item.a}</div>
            </details>
          ))}
        </div>
        
      </div>

      <FaqSchema items={faqItems} />
    </section>
  </main>
</BaseLayout>
