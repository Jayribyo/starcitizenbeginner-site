---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReferralBanner from "../../components/ReferralBanner.astro";
import OnThisPage from "../../components/OnThisPage.astro";
import FaqSchema from "../../components/FaqSchema.astro";

const referralCode = "STAR-FSRJ-5N7Z";
const referralLink = `https://www.robertsspaceindustries.com/enlist?referral=${referralCode}`;

const heroImg = "/assets/img/referral/star-citizen-referral-signup-field.webp";

const tocItems = [
  { id: "quick-answer", label: "Fast diagnosis" },
  { id: "do-this-now", label: "Fix checklist" },
  { id: "common-mistakes", label: "Common causes" },
  { id: "next-steps", label: "Next steps" },
  { id: "faq", label: "FAQ" }
];

const faqItems = [
  { q: "I entered the code but don’t see anything — what now?", a: "First verify timing and the exact code. Then check your RSI account status. If the code wasn’t entered at signup, assume it won’t apply later." },
  { q: "Does the referral bonus reduce store prices?", a: "No." },
  { q: "Can I fix it by buying a starter pack?", a: "Buying later doesn’t retroactively apply the signup bonus." },
  { q: "Should I contact support?", a: "If you entered the code during signup and can show it didn’t apply, support may clarify. If you did not enter it during signup, support usually can’t retroactively add it." },
  { q: "What’s the safest path if I’m still undecided?", a: "Play Free Fly (or follow the first-session checklist) and only buy the minimum starter pack if you keep coming back." }
];
---

<BaseLayout
  title="Referral Code Not Working? Quick Fix Checklist | Star Citizen Beginner"
  description="If your referral bonus didn’t apply, don’t guess. Use this checklist to verify the code, the timing, and the account status in a few minutes."
  canonicalPath="/satellites/referral-code-not-working/"
  ogImage={heroImg}
  ogImageAlt="Referral Code Not Working? Quick Fix Checklist hero image"
  stickyCtaLabel="Create account + claim bonus"
  stickyCtaHref={referralLink}
  stickyCtaExternal={true}
  activeNav="guides"
>
  <main>
    <section class="hero guideHero">
      <img
        class="hero__img"
        src={heroImg}
        alt="Referral Code Not Working? Quick Fix Checklist"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1536"
        height="1024"
      />
      <div class="hero__overlay"></div>

      <div class="hero__content">
        <div class="guideHero__content">
          <div class="kicker"><span class="dot"></span> Starter Guide</div>
          <h1 class="h1">Referral Code Not Working? Quick Fix Checklist</h1>
          <p class="lead" style="max-width: 820px;">If your referral bonus didn’t apply, don’t guess. Use this checklist to verify the code, the timing, and the account status in a few minutes.</p>

          <div class="hero__cta">
            <a class="btn primary" href="#quick-answer">Start here</a>
          </div>
        </div>

        <OnThisPage variant="hero" title="On this page" items={tocItems} />
      </div>
    </section>

    <ReferralBanner
      code={referralCode}
      bonus="50,000"
      ctaLabel="Create account + claim bonus"
      ctaHref={referralLink}
      ctaExternal={true}
    />

    <section id="quick-answer" class="section">
      <div class="container">
        <h2 class="h2">Quick answer</h2>
        <ul class="bullets">
          <li>Most “not working” cases are one of three things: <b>code entered after signup</b>, <b>typo/spacing</b>, or <b>expecting an instant in‑game change</b>.</li>
<li>Fix by verifying <b>timing → correctness → account status</b> in that order.</li>
<li>If the account was created without a code, assume it won’t apply retroactively — focus on the beginner path instead.</li>
        </ul>

        <div style="display:flex; flex-wrap:wrap; gap:10px; margin-top: 14px;">
          <a class="btn primary" href={referralLink} rel="nofollow noopener" target="_blank">Create account + claim bonus</a>
          <a class="btn ghost" href="/star-citizen-referral-code/">Where to paste the referral code →</a>
        </div>
      </div>
    </section>

    <section id="do-this-now" class="section alt">
      <div class="container">
        <h2 class="h2">Do this now</h2>
        <ol class="steps">
          <li><b>Confirm when you entered the code</b> — If it was not during account creation, it likely won’t apply.</li>
<li><b>Confirm the exact code</b> — Copy/paste. No extra spaces. Correct characters.</li>
<li><b>Check your RSI account page</b> — Look for referral / signup bonus status if available.</li>
<li><b>Manage expectations</b> — The bonus is a signup credit. It doesn’t affect store pricing or instantly change gameplay.</li>
        </ol>
      </div>
    </section>

    <section id="common-mistakes" class="section">
      <div class="container">
        <h2 class="h2">Common mistakes (and exact fixes)</h2>
        <div class="tableWrap">
          <table class="table">
            <thead>
              <tr>
                <th>Mistake</th>
                <th>What happens</th>
                <th>Fix (exact)</th>
              </tr>
            </thead>
            <tbody>
              <tr><td><b>Mixing up store promo codes with referral codes</b></td><td>You look in the wrong place and assume it failed.</td><td>Referral codes are entered during <b>account creation</b>, not at checkout.</td></tr>
<tr><td><b>Checking only in-game and not on RSI account</b></td><td>You miss the actual status signal.</td><td>Verify via RSI account first; then play normally.</td></tr>
<tr><td><b>Creating multiple accounts to “fix it”</b></td><td>You create a messy ownership situation.</td><td>Keep one account. Use the correct step next time.</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section id="next-steps" class="section alt">
      <div class="container">
        <h2 class="h2">Next steps</h2>
        <ul class="bullets">
          <li><a href="/star-citizen-referral-code/">Referral code guide: exact steps + FAQ</a></li>
<li><a href="/satellites/can-you-add-referral-code-after-signup/">Can you add it after signup? (short answer)</a></li>
<li><a href="/should-you-buy-star-citizen/">2‑minute decision test (buy vs try)</a></li>
        </ul>
      </div>
    </section>

    <section id="faq" class="section">
      <div class="container">
        <h2 class="h2">FAQ</h2>
        <div class="faq" style="margin-top:12px;">
          {faqItems.map((item) => (
            <details class="faq__item">
              <summary class="faq__q">{item.q}</summary>
              <div class="faq__a">{item.a}</div>
            </details>
          ))}
        </div>

        <div style="display:flex; flex-wrap:wrap; gap:10px; margin-top: 18px;">
          <a class="btn primary" href={referralLink} rel="nofollow noopener" target="_blank">Create account + claim bonus</a>
          <a class="btn ghost" href="/star-citizen-referral-code/">Referral code guide →</a>
        </div>
      </div>

      <FaqSchema items={faqItems} />
    </section>
  </main>
</BaseLayout>
