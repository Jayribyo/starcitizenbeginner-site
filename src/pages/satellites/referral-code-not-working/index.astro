---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ReferralBanner from "../../../components/ReferralBanner.astro";
import OnThisPage from "../../../components/OnThisPage.astro";
import FaqSchema from "../../../components/FaqSchema.astro";
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { REFERRAL_CODE, REFERRAL_LINK, REFERRAL_INFO_PATH, REFERRAL_BONUS_UEC, FLY_FREE_URL } from "../../../config/site";

const referralCode = REFERRAL_CODE;
const referralLink = REFERRAL_LINK;

const heroImg = "/assets/img/referral/star-citizen-referral-signup-field.webp";

const tocItems = [
  { id: "quick-answer", label: "Fast diagnosis" },
  { id: "do-this-now", label: "Fix checklist" },
  { id: "common-mistakes", label: "Common causes" },
  { id: "next-steps", label: "Next steps" },
  { id: "faq", label: "FAQ" }
];

const faqItems = [
  { q: "I entered the code but don’t see anything — what now?", a: "First verify timing and the exact code. Then check your RSI account status. If the account is brand-new, RSI’s current referral FAQ also mentions a short backup window in the account summary." },
  { q: "Does the referral bonus reduce store prices?", a: "No." },
  { q: "Can I fix it by buying a starter pack?", a: "Buying later doesn’t retroactively apply the signup bonus." },
  { q: "Should I contact support?", a: "If you entered the code during signup and can show it didn’t apply, support may clarify. If you did not enter it during signup, support usually can’t retroactively add it." },
  { q: "What should I do if I am still undecided?", a: "Play Free Fly (or follow the first-session checklist) and only buy the minimum starter pack if you keep coming back." }
];
---

<BaseLayout
  title="Referral Code Not Working? Quick Fix Checklist | Star Citizen Beginner"
  description="Referral code not working? Check the signup step, code entry, and account status first. This page walks through the usual causes and fixes."
  canonicalPath="/satellites/referral-code-not-working/"
  ogImage={heroImg}
  ogImageAlt="Referral Code Not Working? Quick Fix Checklist hero image"
  stickyCtaLabel="Create account + claim bonus"
  stickyCtaHref={referralLink}
  stickyCtaExternal={true}
  activeNav="guides"
>
  <main>

    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Answers', href: '/satellites/' }, { label: 'Answer', href: '/satellites/referral-code-not-working/' }]} />
    <section class="hero guideHero">
      <img
        class="hero__img"
        src={heroImg}
        alt="Referral Code Not Working? Quick Fix Checklist"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1536"
        height="1024"
      />
      <div class="hero__overlay"></div>

      <div class="hero__content">
        <div class="guideHero__content">
          <div class="kicker"><span class="dot"></span> Starter Guide</div>
          <h1 class="h1">Referral Code Not Working? Quick Fix Checklist</h1>
          <p class="lead" style="max-width: 820px;">Answer: If your referral bonus didn’t apply, don’t guess. Use this checklist to verify the code, the timing, and the account status in a few minutes.</p>

          <div class="hero__cta">
            <a class="btn primary" href="#quick-answer">Start here</a>
          </div>
        </div>

        <OnThisPage variant="hero" title="On this page" items={tocItems} />
      </div>
    </section>

    <ReferralBanner
      code={referralCode}
      bonus="50,000"
      ctaLabel="Create account + claim bonus"
      ctaHref={referralLink}
      ctaExternal={true}
    />

    <section id="quick-answer" class="section">
      <div class="container">
        <h2 class="h2">Quick answer</h2>

        <div class="card pad" style="margin-bottom:12px;">
          <div class="kicker"><span class="dot"></span>Answer</div>
          <p class="lead" style="margin-top:10px;">Most “not working” cases are one of three things: code entered after signup, typo/spacing, or expecting an instant in‑game change.</p>
        </div>

        <ul class="bullets">
          <li>If the account is brand-new, check the RSI account summary right away because the current referral FAQ mentions a short backup window there.</li>
          <li>Most “not working” cases are one of three things: <b>code entered after signup</b>, <b>typo/spacing</b>, or <b>expecting an instant in‑game change</b>.</li>
<li>Fix by verifying <b>timing → correctness → account status</b> in that order.</li>
<li>If the field is already gone, stop troubleshooting loops and focus on the normal beginner path instead.</li>
        </ul>

        <div style="display:flex; flex-wrap:wrap; gap:10px; margin-top: 14px;">
          <a class="btn primary" href={referralLink} rel="nofollow noopener" target="_blank">Create account + claim bonus</a>
          <a class="btn ghost" href={REFERRAL_INFO_PATH}>Where to paste the referral code →</a>
        </div>
      </div>
    </section>

    <section id="do-this-now" class="section alt">
      <div class="container">
        <h2 class="h2">Do this now</h2>
        <ol class="steps">
          <li><b>Confirm when you entered the code</b> — If it was not during account creation, the normal signup path was already missed.</li>
<li><b>Confirm the exact code</b> — Copy/paste. No extra spaces. Correct characters.</li>
<li><b>Check your RSI account summary</b> — If the account is still brand-new, look for the short referral entry option RSI mentions in the current FAQ.</li>
<li><b>Manage expectations</b> — The bonus is a signup credit. It doesn’t affect store pricing or instantly change gameplay.</li>
        </ol>
      </div>
    </section>

    <section id="common-mistakes" class="section">
      <div class="container">
        <h2 class="h2">Common mistakes (and exact fixes)</h2>
        <div class="tableWrap">
          <table class="table">
            <thead>
              <tr>
                <th>Mistake</th>
                <th>What happens</th>
                <th>Fix (exact)</th>
              </tr>
            </thead>
            <tbody>
              <tr><td><b>Mixing up store promo codes with referral codes</b></td><td>You look in the wrong place and assume it failed.</td><td>Referral codes are entered during <b>account creation</b>, not at checkout.</td></tr>
<tr><td><b>Checking only in-game and not on RSI account</b></td><td>You miss the actual status signal.</td><td>Verify via RSI account first; then play normally.</td></tr>
<tr><td><b>Creating multiple accounts to “fix it”</b></td><td>You create a messy ownership situation.</td><td>Keep one account. Use the correct step next time.</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section id="next-steps" class="section alt">
      <div class="container">
        <h2 class="h2">Next steps</h2>
        <ul class="bullets">
          <li><a href={REFERRAL_INFO_PATH}>Main referral guide</a> — exact steps, backup window, and FAQ.</li>
<li><a href="/referral-bonus-checklist/">Referral bonus checklist</a> — the shortest path for avoiding this problem next time.</li>
<li><a href="/satellites/can-you-add-referral-code-after-signup/">Can you add it after signup? (short answer)</a></li>
<li><a href="/should-you-buy-star-citizen/">Quick reality check (buy vs try)</a></li>
<li><a href="/how-to-buy-star-citizen/">Moving on without the bonus? Use the buying guide from here</a></li>
        </ul>
      </div>
    </section>

    <section id="faq" class="section">
      <div class="container">
        <h2 class="h2">FAQ</h2>
        <div class="faq" style="margin-top:12px;">
          {faqItems.map((item) => (
            <details class="faq__item">
              <summary class="faq__q">{item.q}</summary>
              <div class="faq__a">{item.a}</div>
            </details>
          ))}
        </div>

        <div style="display:flex; flex-wrap:wrap; gap:10px; margin-top: 18px;">
          <a class="btn primary" href={referralLink} rel="nofollow noopener" target="_blank">Create account + claim bonus</a>
          <a class="btn ghost" href={REFERRAL_INFO_PATH}>Referral code guide →</a>
        </div>
      </div>

      <FaqSchema items={faqItems} />
    </section>
  </main>
</BaseLayout>
