---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ReferralBanner from "../../../components/ReferralBanner.astro";
import OnThisPage from "../../../components/OnThisPage.astro";
import FaqSchema from "../../../components/FaqSchema.astro";
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { REFERRAL_CODE, REFERRAL_LINK, REFERRAL_INFO_PATH, REFERRAL_BONUS_UEC, FLY_FREE_URL } from "../../../config/site";

const referralCode = REFERRAL_CODE;
const referralLink = REFERRAL_LINK;

const heroImg = "/assets/img/home/scb-home-hero.webp";

const tocItems = [
  { id: "quick-answer", label: "Quick answer" },
  { id: "do-this-now", label: "Do this now" },
  { id: "common-mistakes", label: "Common mistakes" },
  { id: "next-steps", label: "Next steps" },
  { id: "faq", label: "FAQ" }
];

const faqItems = [
  { q: "How do I pick where to go?", a: "Use a mission marker as your single source of truth for that loop." },
  { q: "Do I need to learn everything at once?", a: "No. Learn one loop; add complexity later." },
  { q: "What if I lose my ship?", a: "Use ASOP terminals to retrieve/claim it." },
  { q: "Is navigation easier with a friend?", a: "Yes — but you can still do it solo if you stick to one loop." },
  { q: "Where should I start?", a: "Use the first-session checklist and run one simple mission." }
];
---

<BaseLayout
  title="How to Not Get Lost in Star Citizen | Star Citizen Beginner"
  description="Don't get lost: navigation rules, elevator and metro shortcuts, route setup, and the 3 places beginners waste the most time."
  canonicalPath="/satellites/how-to-not-get-lost-in-star-citizen/"
  ogImage={heroImg}
  ogImageAlt="How to Not Get Lost in Star Citizen (Navigation Basics for Beginners)"
  stickyCtaLabel="Create account + claim bonus"
  stickyCtaHref={referralLink}
  stickyCtaExternal={true}
  activeNav="guides"
>
  <main>

    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Answers', href: '/satellites/' }, { label: 'Answer', href: '/satellites/how-to-not-get-lost-in-star-citizen/' }]} />
    <section class="hero guideHero">
      <img
        class="hero__img"
        src={heroImg}
        alt="How to Not Get Lost in Star Citizen (Navigation Basics for Beginners)"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1536"
        height="1024"
      />
      <div class="hero__overlay"></div>

      <div class="hero__content">
        <div class="guideHero__content">
          <div class="kicker"><span class="dot"></span> Starter Guide</div>
          <h1 class="h1">How to not get lost in Star Citizen</h1>
          <p class="lead" style="max-width: 820px;">Answer: Simple navigation rules that prevent 80% of beginner confusion: markers, quantum travel basics, and choosing one hub.</p>

          <div class="hero__cta">
            <a class="btn primary" href="#quick-answer">Start here</a>
          </div>
        </div>

        <OnThisPage variant="hero" title="On this page" items={tocItems} />
      </div>
    </section>

    <ReferralBanner
      code={referralCode}
      bonus="50,000"
      ctaLabel="Claim your start bonus"
      ctaHref={referralLink}
      ctaExternal={true}
    />

    <section id="quick-answer" class="section">
      <div class="container">
        <h2 class="h2">Quick answer</h2>

        <div class="card pad" style="margin-bottom:12px;">
          <div class="kicker"><span class="dot"></span>Answer</div>
          <p class="lead" style="margin-top:10px;">Most beginner confusion comes from doing too much at once. The fix is simple: one hub, one objective, one loop.</p>
        </div>

        <ul class="bullets">
          <li>Pick one destination at a time; most beginner confusion comes from stacking too many steps at once.</li>
          <li>Most beginner confusion comes from doing too much at once. The fix is simple: <b>one hub, one objective, one loop</b>.</li>
<li>Use markers and quantum travel like a system, not guesswork.</li>
<li>This page gives you navigation rules that stay true even as the game changes.</li>
        </ul>
      </div>
    </section>

    <section id="do-this-now" class="section alt">
      <div class="container">
        <h2 class="h2">Do this now</h2>
        <ol class="steps">
          <li><b>Pick one hub</b> for your session (don’t bounce between cities).</li>
<li><b>Use mission markers</b> to choose your next destination.</li>
<li><b>Quantum travel in steps</b>: hub → objective → return/sell (don’t chain random detours).</li>
<li><b>If you’re lost</b>, reset to a known point: spaceport → ASOP → simple mission.</li>
<li><b>Repeat one loop</b> until it feels automatic.</li>
        </ol>
      </div>
    </section>

    <section id="common-mistakes" class="section">
      <div class="container">
        <h2 class="h2">Common mistakes (and exact fixes)</h2>
        <div class="tableWrap">
          <table class="table">
            <thead>
              <tr>
                <th>Mistake</th>
                <th>What happens</th>
                <th>Fix (exact)</th>
              </tr>
            </thead>
            <tbody>
              <tr><td><b>Taking 3 goals at once</b></td><td>You forget what you were doing.</td><td>Write one objective and follow it end-to-end.</td></tr>
<tr><td><b>Detouring constantly</b></td><td>You never complete anything.</td><td>Commit to one mission loop; detours later.</td></tr>
<tr><td><b>Skipping the ‘return’ step</b></td><td>You end with half-finished tasks.</td><td>Return, cash out, then choose the next activity.</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section id="next-steps" class="section alt">
      <div class="container">
        <h2 class="h2">Next steps</h2>
        <ul class="bullets">
          <li><a href="/satellites/first-session-checklist/">First session checklist</a></li>
<li><a href="/make-money-fast/">Make money fast (safe loops)</a></li>
<li><a href="/free-fly/">Free Fly guide (try without buying)</a></li>
        
          <li><a href="/satellites/star-citizen-first-mission-guide/">Want one simple contract to use these nav basics? Start here</a></li>
        </ul>
      </div>
    </section>

    <section id="faq" class="section">
      <div class="container">
        <h2 class="h2">FAQ</h2>
        <div class="faq" style="margin-top:12px;">
          {faqItems.map((item) => (
            <details class="faq__item">
              <summary class="faq__q">{item.q}</summary>
              <div class="faq__a">{item.a}</div>
            </details>
          ))}
        </div>
        
      </div>

      <FaqSchema items={faqItems} />
    </section>
  </main>
</BaseLayout>
