---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ReferralBanner from "../../../components/ReferralBanner.astro";
import OnThisPage from "../../../components/OnThisPage.astro";
import FaqSchema from "../../../components/FaqSchema.astro";
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { REFERRAL_CODE, REFERRAL_LINK, REFERRAL_INFO_PATH, REFERRAL_BONUS_UEC, FLY_FREE_URL } from "../../../config/site";

const referralCode = REFERRAL_CODE;
const referralLink = REFERRAL_LINK;

const heroImg = "/assets/img/make-money-fast/star-citizen-earn-auec-fast-mining-trade-profit-hero.webp";

const tocItems = [
  { id: "quick-answer", label: "Quick answer" },
  { id: "do-this-now", label: "Do this now" },
  { id: "common-mistakes", label: "Common mistakes" },
  { id: "next-steps", label: "Next steps" },
  { id: "faq", label: "FAQ" }
];

const faqItems = [
  { q: "Do I need a combat ship?", a: "Not immediately. Start low-tier and learn the loop first." },
  { q: "How do I know when to upgrade?", a: "When you finish multiple contracts cleanly and consistently." },
  { q: "What should I do if bounties feel too hard?", a: "Courier missions to build control and confidence." },
  { q: "Is this good during Free Fly?", a: "Yes — but start low and keep expectations realistic." },
  { q: "Where do I scale from here?", a: "Use Make Money Fast for the full scaling table." }
];
---

<BaseLayout
  title="PvE Bounties Beginner Setup | Star Citizen Beginner"
  description="Beginner bounty hunting setup: which ship/loadout to use, how to accept contracts, and how to move from VLRT to MRT without making things harder than they need to be."
  canonicalPath="/satellites/bounties-beginner-setup/"
  ogImage={heroImg}
  ogImageAlt="PvE bounties beginner setup"
  stickyCtaLabel="Create account + claim bonus"
  stickyCtaHref={referralLink}
  stickyCtaExternal={true}
  activeNav="guides"
>
  <main>

    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Answers', href: '/satellites/' }, { label: 'Answer', href: '/satellites/bounties-beginner-setup/' }]} />
    <section class="hero guideHero">
      <img
        class="hero__img"
        src={heroImg}
        alt="PvE bounties beginner setup"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1536"
        height="1024"
      />
      <div class="hero__overlay"></div>

      <div class="hero__content">
        <div class="guideHero__content">
          <div class="kicker"><span class="dot"></span> Starter Guide</div>
          <h1 class="h1">PvE bounties beginner setup</h1>
          <p class="lead" style="max-width: 820px;">Answer: A clear beginner bounty setup: what to start with, how to build up, and what mistakes waste time and money.</p>

          <div class="hero__cta">
            <a class="btn primary" href="#quick-answer">Start here</a>
          </div>
        </div>

        <OnThisPage variant="hero" title="On this page" items={tocItems} />
      </div>
    </section>

    <ReferralBanner
      code={referralCode}
      bonus="50,000"
      ctaLabel="Claim your start bonus"
      ctaHref={referralLink}
      ctaExternal={true}
    />

    <section id="quick-answer" class="section">
      <div class="container">
        <h2 class="h2">Quick answer</h2>

        <div class="card pad" style="margin-bottom:12px;">
          <div class="kicker"><span class="dot"></span>Answer</div>
          <p class="lead" style="margin-top:10px;">PvE bounties scale reliably: start low, build skill, then move up only when you finish cleanly.</p>
        </div>

        <ul class="bullets">
          <li>If bounty combat feels rough right away, step back to simpler contracts first and come back later.</li>
          <li>PvE bounties scale reliably: start low, build skill, then move up only when you finish cleanly.</li>
<li>The beginner bottleneck is not ‘best ship’ — it’s <b>consistency</b>: target discipline, avoiding damage, and finishing contracts.</li>
<li>If FPS is low, fix performance first or bounties will feel unfair.</li>
        </ul>
      </div>
    </section>

    <section id="do-this-now" class="section alt">
      <div class="container">
        <h2 class="h2">Do this now</h2>
        <ol class="steps">
          <li><b>Start with the lowest bounty tier</b> and complete 2–3 clean contracts.</li>
<li><b>Focus on survival</b>: avoid taking damage rather than maximizing speed.</li>
<li><b>Upgrade only one variable</b> at a time (weapons, components, or ship choice).</li>
<li><b>Move up a tier</b> only after you can finish without panic.</li>
<li><b>If you get melted</b>, step down again and practice positioning.</li>
        </ol>
      </div>
    </section>

    <section id="common-mistakes" class="section">
      <div class="container">
        <h2 class="h2">Common mistakes (and exact fixes)</h2>
        <div class="tableWrap">
          <table class="table">
            <thead>
              <tr>
                <th>Mistake</th>
                <th>What happens</th>
                <th>Fix (exact)</th>
              </tr>
            </thead>
            <tbody>
              <tr><td><b>Jumping tiers too fast</b></td><td>You get destroyed and waste time.</td><td>Stay low until clean completions are consistent.</td></tr>
<tr><td><b>Blaming ship before skill</b></td><td>You overspend early.</td><td>Scale skill and one upgrade at a time.</td></tr>
<tr><td><b>Playing bounties with bad FPS</b></td><td>You lose fights unfairly.</td><td>Fix performance baseline, then retest.</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section id="next-steps" class="section alt">
      <div class="container">
        <h2 class="h2">Next steps</h2>
        <ul class="bullets">
          <li><a href="/make-money-fast/">Make money fast (all beginner loops)</a></li>
<li><a href="/satellites/avoid-losing-gear-beginner/">Avoid losing gear (beginner rules)</a></li>
<li><a href="/star-citizen-performance-guide/">Performance guide (if FPS ruins combat)</a></li>
        
          <li><a href="/satellites/star-citizen-first-mission-guide/">Need an easier first loop first? Start with one simple mission</a></li>
        </ul>
      </div>
    </section>

    <section id="faq" class="section">
      <div class="container">
        <h2 class="h2">FAQ</h2>
        <div class="faq" style="margin-top:12px;">
          {faqItems.map((item) => (
            <details class="faq__item">
              <summary class="faq__q">{item.q}</summary>
              <div class="faq__a">{item.a}</div>
            </details>
          ))}
        </div>
        
      </div>

      <FaqSchema items={faqItems} />
    </section>
  </main>
</BaseLayout>
