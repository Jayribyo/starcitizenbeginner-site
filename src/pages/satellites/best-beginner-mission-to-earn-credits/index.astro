---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ReferralBanner from "../../../components/ReferralBanner.astro";
import OnThisPage from "../../../components/OnThisPage.astro";
import FaqSchema from "../../../components/FaqSchema.astro";

const referralCode = "STAR-FSRJ-5N7Z";
const referralLink = `https://www.robertsspaceindustries.com/enlist?referral=${referralCode}`;

const heroImg = "/assets/img/make-money-fast/star-citizen-earn-auec-fast-mining-trade-profit-hero.webp";

const tocItems = [
  { id: "quick-answer", label: "Best beginner loop" },
  { id: "do-this-now", label: "Run it once" },
  { id: "common-mistakes", label: "Mistakes that lose money" },
  { id: "next-steps", label: "Next steps" },
  { id: "faq", label: "FAQ" }
];

const faqItems = [
  { q: "Is delivery really good money?", a: "It’s good starter money because it’s reliable and teaches core flow." },
  { q: "What if I want combat money?", a: "Start with low-risk bounties after you’ve done a clean loop." },
  { q: "Do I need a big ship to earn credits?", a: "No. Consistency matters more than cargo size early." },
  { q: "How do I scale faster?", a: "Once you can repeat a loop, use the make-money-fast page to choose the next best path." },
  { q: "Where does the referral bonus help?", a: "It’s a small starting boost if you enter it during signup — useful but not required." }
];
---

<BaseLayout
  title="Best Beginner Mission to Earn Credits (Fast, Safe Loop) | Star Citizen Beginner"
  description="You don’t need complex routes to start earning. This page gives one beginner-safe mission loop you can repeat immediately."
  canonicalPath="/satellites/best-beginner-mission-to-earn-credits/"
  ogImage={heroImg}
  ogImageAlt="Best Beginner Mission to Earn Credits (Fast, Safe Loop) hero image"
  stickyCtaLabel="Create account + claim bonus"
  stickyCtaHref={referralLink}
  stickyCtaExternal={true}
  activeNav="guides"
>
  <main>
    <section class="hero guideHero">
      <img
        class="hero__img"
        src={heroImg}
        alt="Best Beginner Mission to Earn Credits (Fast, Safe Loop)"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1536"
        height="1024"
      />
      <div class="hero__overlay"></div>

      <div class="hero__content">
        <div class="guideHero__content">
          <div class="kicker"><span class="dot"></span> Starter Guide</div>
          <h1 class="h1">Best Beginner Mission to Earn Credits (Fast, Safe Loop)</h1>
          <p class="lead" style="max-width: 820px;">You don’t need complex routes to start earning. This page gives one beginner-safe mission loop you can repeat immediately.</p>

          <div class="hero__cta">
            <a class="btn primary" href="#quick-answer">Start here</a>
          </div>
        </div>

        <OnThisPage variant="hero" title="On this page" items={tocItems} />
      </div>
    </section>

    <ReferralBanner
      code={referralCode}
      bonus="50,000"
      ctaLabel="Create account + claim bonus"
      ctaHref={referralLink}
      ctaExternal={true}
    />

    <section id="quick-answer" class="section">
      <div class="container">
        <h2 class="h2">Quick answer</h2>
        <ul class="bullets">
          <li>Best first money loop: <b>one simple delivery/entry contract you can complete reliably</b>.</li>
<li>The goal is not max profit — it’s <b>repeatability</b> (finish → payout → repeat).</li>
<li>Once you can repeat a loop, scaling becomes easy (better ship/tools later).</li>
        </ul>

        <div style="display:flex; flex-wrap:wrap; gap:10px; margin-top: 14px;">
          <a class="btn primary" href={referralLink} rel="nofollow noopener" target="_blank">Create account + claim bonus</a>
          <a class="btn ghost" href="/star-citizen-referral-code/">Where to paste the referral code →</a>
        </div>
      </div>
    </section>

    <section id="do-this-now" class="section alt">
      <div class="container">
        <h2 class="h2">Do this now</h2>
        <ol class="steps">
          <li><b>Pick a low-risk contract</b> — Choose something you can finish in one trip without combat.</li>
<li><b>Fly one clean run</b> — Take off → objective → return → payout.</li>
<li><b>Repeat once</b> — Two successful runs teach more than one risky “big” run.</li>
<li><b>Scale only after consistency</b> — When you can repeat, move to the make-money-fast decision table for faster paths.</li>
        </ol>
      </div>
    </section>

    <section id="common-mistakes" class="section">
      <div class="container">
        <h2 class="h2">Common mistakes (and exact fixes)</h2>
        <div class="tableWrap">
          <table class="table">
            <thead>
              <tr>
                <th>Mistake</th>
                <th>What happens</th>
                <th>Fix (exact)</th>
              </tr>
            </thead>
            <tbody>
              <tr><td><b>Chasing the highest payout immediately</b></td><td>You fail more often and earn less.</td><td>Pick reliability first.</td></tr>
<tr><td><b>Buying lots of gear early</b></td><td>You lose money to deaths and rebuys.</td><td>Run light; buy only what you need.</td></tr>
<tr><td><b>Switching activity every 10 minutes</b></td><td>You never build a repeatable loop.</td><td>Commit to one loop for one session.</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section id="next-steps" class="section alt">
      <div class="container">
        <h2 class="h2">Next steps</h2>
        <ul class="bullets">
          <li><a href="/make-money-fast/">Make money fast (decision table + scaling paths)</a></li>
<li><a href="/satellites/avoid-losing-gear-beginner/">Avoid losing gear (stop the money leak)</a></li>
<li><a href="/star-citizen-performance-guide/">Performance fixes (if stutter slows your runs)</a></li>
        </ul>
      </div>
    </section>

    <section id="faq" class="section">
      <div class="container">
        <h2 class="h2">FAQ</h2>
        <div class="faq" style="margin-top:12px;">
          {faqItems.map((item) => (
            <details class="faq__item">
              <summary class="faq__q">{item.q}</summary>
              <div class="faq__a">{item.a}</div>
            </details>
          ))}
        </div>

        <div style="display:flex; flex-wrap:wrap; gap:10px; margin-top: 18px;">
          <a class="btn primary" href={referralLink} rel="nofollow noopener" target="_blank">Create account + claim bonus</a>
          <a class="btn ghost" href="/star-citizen-referral-code/">Referral code guide →</a>
        </div>
      </div>

      <FaqSchema items={faqItems} />
    </section>
  </main>
</BaseLayout>
