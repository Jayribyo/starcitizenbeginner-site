---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReferralCTA from "../../components/ReferralCTA.astro";

import { DEFAULT_LANGUAGE_PATHS, REFERRAL_CODE } from "../../config/site";

const paths = DEFAULT_LANGUAGE_PATHS;
const referralCode = REFERRAL_CODE;

const t = {
  title: "Star Citizen Anfänger Guide | Quick Start + Referral Bonus",
  desc: "Ein anfängerfreundlicher Star Citizen Quick-Start mit wichtigen Schritten, POIs und einer klaren Erklärung zum Referral-Bonus.",
  heroKicker: "Für neue Piloten",
  heroH1: "Schnell & stressfrei ins Verse starten.",
  heroLead: "Ein klarer Einsteiger-Guide, der dir den Start erleichtert — inkl. sauberer Erklärung des Referral-Bonus (ohne nervige Werbung).",
  qsTitle: "Quick Start (5 Minuten)",
  qs1: "RSI-Account erstellen (Referral-Code bei der Registrierung nutzen).",
  qs2: "Starter-Paket wählen, das du wirklich fliegen kannst (Upgrades später möglich).",
  qs3: "Installieren, starten, erste einfache Mission — Navigation & Landung lernen.",
  poiTitle: "Points of Interest (Einsteiger-Auswahl)",
  poiLead: "Ein paar Orte, die leicht verständlich und früh nützlich sind:",
  poi: ["Area18 (ArcCorp) – guter Hub für Shopping & Transit", "New Babbage (microTech) – übersichtlich, ideal zum Lernen", "Lorville (Hurston) – klassischer City-Hub", "Orison (Crusader) – wunderschön, aber FPS-lastiger"],
  faqTitle: "FAQ (Referral-Code)",
  faq1q: "Kostet mich ein Referral-Code etwas?",
  faq1a: "Nein. Es ist eine normale Registrierung – du bekommst nur den Bonus, wenn du mit Code/Link erstellst.",
  faq2q: "Wo gebe ich den Code ein?",
  faq2a: "Während der Account-Erstellung auf der RSI-Seite. Wenn du den Referral-Link nutzt, wird er automatisch gesetzt.",
  disclaimer: "Inoffizieller Community-Guide. Keine Verbindung zu Cloud Imperium Games oder Roberts Space Industries."
};
---
<BaseLayout lang="de" title={t.title} description={t.desc} canonicalPath="/de/" brand="Star Citizen Beginner" paths={paths}>
  <main class="langPage">
    <section class="section section--heroWidth">
      <div class="grid">
        <section class="card langPage__heroCard">
          <div class="kicker">{t.heroKicker}</div>
          <h1 class="h1">{t.heroH1}</h1>
          <p class="lead">{t.heroLead}</p>

          <div class="badge">Referral-Code: <strong style="color:#fff;">{referralCode}</strong></div>

          <hr class="sep" />

          <div id="quickstart" class="langPage__stack">
            <div>
              <h2 class="section__title">{t.qsTitle}</h2>
              <ol class="steps muted">
                <li>{t.qs1}</li>
                <li>{t.qs2}</li>
                <li>{t.qs3}</li>
              </ol>
            </div>

            <div>
              <h2 class="section__title">{t.poiTitle}</h2>
              <p class="lead">{t.poiLead}</p>
              <ul class="bullets muted">
                {t.poi.map(x => <li>{x}</li>)}
              </ul>
            </div>
          </div>

          <div class="miniNote">
            {t.disclaimer}
          </div>
        </section>

        <aside class="langPage__asideStack">
          <ReferralCTA
            title={"Bonus beim Account-Start"}
            blurb={"Wenn du neu registrierst, gibt dir ein Referral-Code/Link den Bonus. Hier bleibt der Fokus auf echtem Mehrwert für Anfänger."}
            ctaPrimary={"Account erstellen (Referral aktiv)"}
            ctaSecondary={"Quick Start lesen"}
          />

          <div class="card pad">
            <div class="kicker">Nächster Schritt</div>
            <h2 class="section__title">Starter packs & performance</h2>
            <p class="muted">Als Nächstes lohnt sich ein sauberer Starter-Pack-Vergleich und ein Performance-Guide — das sind die stärksten nächsten Schritte für neue Spieler.</p>
          </div>
        </aside>
      </div>
    </section>

    <section class="section">
      <div class="card pad">
        <h2 class="section__title">{t.faqTitle}</h2>
        <div class="faq">
          <details class="faq__item">
            <summary class="faq__q">{t.faq1q}</summary>
            <div class="faq__a"><p>{t.faq1a}</p></div>
          </details>
          <details class="faq__item">
            <summary class="faq__q">{t.faq2q}</summary>
            <div class="faq__a"><p>{t.faq2a}</p></div>
          </details>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>