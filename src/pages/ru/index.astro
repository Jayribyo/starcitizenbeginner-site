---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReferralCTA from "../../components/ReferralCTA.astro";

const paths = { en:"/", de:"/de/", es:"/es/", fr:"/fr/", ru:"/ru/", zh:"/zh/" };

const t = {
  title: "Гайд для новичков Star Citizen | Быстрый старт + реферальный бонус",
  desc: "Понятный гайд для новичков Star Citizen: ключевые шаги, полезные места и как получить бонус по реферальному коду.",
  heroKicker: "Для новых пилотов",
  heroH1: "Начни правильно в Verse.",
  heroLead: "Чёткий гайд без спама: как быстро зайти в игру и понять основы — плюс простое объяснение реферального бонуса.",
  qsTitle: "Быстрый старт (5 минут)",
  qs1: "Создай аккаунт RSI (используй реферальный код при регистрации).",
  qs2: "Выбери стартовый пакет, на котором реально летать (апгрейды можно позже).",
  qs3: "Установи игру, запусти и возьми первый простой контракт, чтобы освоить навигацию и посадку.",
  poiTitle: "Точки интереса (для новичков)",
  poiLead: "Несколько мест, которые легко понять и полезны на старте:",
  poi: [
    "Area18 (ArcCorp) — удобный хаб для магазинов и транспорта",
    "New Babbage (microTech) — понятная структура, удобно учиться",
    "Lorville (Hurston) — классический индустриальный город-хаб",
    "Orison (Crusader) — красиво, но может просаживать FPS"
  ],
  faqTitle: "FAQ (реферальный код)",
  faq1q: "Реферальный код стоит денег?",
  faq1a: "Нет. Регистрация обычная. Просто бонус начисляется, если создать аккаунт с кодом/ссылкой.",
  faq2q: "Куда вводить код?",
  faq2a: "Во время создания аккаунта на сайте RSI. Если используешь реферальную ссылку — код применится автоматически.",
  disclaimer: "Неофициальный гайд сообщества. Не связан с Cloud Imperium Games или Roberts Space Industries."
};
---
<BaseLayout lang="ru" title={t.title} description={t.desc} canonicalPath="/ru/" brand="Star Citizen Beginner" paths={paths}>
  <main class="container">
    <div class="grid">
      <section class="card">
        <div class="kicker">{t.heroKicker}</div>
        <h1 class="h1">{t.heroH1}</h1>
        <p class="lead">{t.heroLead}</p>

        <div class="badge">Реферальный код: <strong style="color:#fff;">STAR-FSRJ-5N7Z</strong></div>

        <hr class="sep" />

        <div id="quickstart">
          <h2 style="margin:0 0 10px;">{t.qsTitle}</h2>
          <ol style="margin:0; padding-left: 18px; color: rgba(255,255,255,.82);">
            <li>{t.qs1}</li>
            <li>{t.qs2}</li>
            <li>{t.qs3}</li>
          </ol>
        </div>

        <hr class="sep" />

        <h2 style="margin:0 0 10px;">{t.poiTitle}</h2>
        <p class="lead" style="margin-top:0;">{t.poiLead}</p>
        <ul style="margin:0; padding-left: 18px; color: rgba(255,255,255,.82);">
          {t.poi.map(x => <li>{x}</li>)}
        </ul>

        <footer>
          <p style="margin:16px 0 0;">{t.disclaimer}</p>
        </footer>
      </section>

      <aside>
        <ReferralCTA
          title="Получить бонус при регистрации"
          blurb="Если ты создаёшь новый аккаунт, реферальный код/ссылка даёт бонус. Здесь всё объяснено просто и по делу — с фокусом на новичков."
          ctaPrimary="Создать аккаунт (реферал применён)"
          ctaSecondary="Читать быстрый старт"
        />

        <div style="height:14px;"></div>

        <div class="card">
          <div class="kicker">Дальше</div>
          <h2 style="margin:10px 0 8px; font-size: 20px;">Стартовые пакеты и FPS</h2>
          <p style="margin:0; color: rgba(255,255,255,.78);">
            Добавим сравнение стартовых пакетов и гайд по настройкам/производительности (сильная SEO-тема).
          </p>
        </div>
      </aside>
    </div>

    <div style="height:18px;"></div>

    <section class="card">
      <h2 style="margin:0 0 10px;">{t.faqTitle}</h2>

      <details style="padding:10px 0; border-top:1px solid rgba(255,255,255,.12);">
        <summary style="cursor:pointer; font-weight:800;">{t.faq1q}</summary>
        <p style="margin:8px 0 0; color: rgba(255,255,255,.78);">{t.faq1a}</p>
      </details>

      <details style="padding:10px 0; border-top:1px solid rgba(255,255,255,.12);">
        <summary style="cursor:pointer; font-weight:800;">{t.faq2q}</summary>
        <p style="margin:8px 0 0; color: rgba(255,255,255,.78);">{t.faq2a}</p>
      </details>
    </section>
  </main>
</BaseLayout>