---
import "../styles/global.css";

const {
  showFooter = true,
  lang = "en",
  title = "Star Citizen Beginner (SCB)",
  description = "",
  canonicalPath = "/",
  ogImage = "/assets/img/home/scb-home-hero.webp",
  ogImageAlt = "Star Citizen Beginner – guide preview image",
  robots = "index,follow",
  stickyCtaLabel = "",
  stickyCtaHref = "",
  stickyCtaExternal = false,
} = Astro.props;

/* We assume `site` is correctly set in astro.config.mjs */
const site = Astro.site.toString().replace(/\/$/, "");

// Ensure canonicalPath always starts with /
const safePath = canonicalPath?.startsWith("/")
  ? canonicalPath
  : `/${canonicalPath ?? ""}`;

// Build absolute canonical URL
const canonical = new URL(safePath, site).toString();

// Absolute OG image URL
const ogImageAbs = ogImage?.startsWith("http")
  ? ogImage
  : new URL(
      ogImage.startsWith("/") ? ogImage : `/${ogImage}`,
      site
    ).toString();

// Fallback description
const desc =
  description?.trim() ||
  "Structured Star Citizen beginner guides: referral code bonus, Free Fly events, starter packs, early aUEC loops, and performance tips.";

// OG locale mapping
const ogLocaleMap = {
  en: "en_US",
  de: "de_DE",
  fr: "fr_FR",
  es: "es_ES",
  zh: "zh_CN",
};
const ogLocale = ogLocaleMap[lang] ?? "en_US";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={desc} />
    <meta name="robots" content={robots} />

    <link rel="canonical" href={canonical} />

    <link rel="icon" type="image/svg+xml" href="/assets/img/global/scb-logo.svg" />

    <!-- Open Graph -->
    <meta property="og:site_name" content="Star Citizen Beginner (SCB)" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:image:alt" content={ogImageAlt} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={ogImageAbs} />

    <slot name="head" />
  </head>

  <body>
    <div id="top" aria-hidden="true"></div>

    <slot />

    {showFooter && (
      <footer class="footer">
        <div class="container">
          <div class="footer__inner">
            <div class="footer__brand">SCB — Unofficial Star Citizen guide.</div>
            <div class="footer__legal">
              Not affiliated with Cloud Imperium Games or Roberts Space Industries. Star Citizen® and related marks are trademarks of their respective owners.
            </div>
          </div>
        </div>
      </footer>
    )}

    {(stickyCtaLabel && stickyCtaHref) && (
      <div class="stickyCta" id="stickyCta" aria-hidden="true">
        <a
          class="btn primary stickyCta__btn"
          href={stickyCtaHref}
          {...(stickyCtaExternal ? { target: "_blank", rel: "noopener noreferrer" } : {})}
        >
          {stickyCtaLabel}
        </a>
      </div>
    )}


    <a class="backToTop" id="backToTop" href="#top" aria-label="Back to top">
      ↑
    </a>

    <script is:inline>
      const btn = document.getElementById("backToTop");

      const setVisibility = () => {
        if (!btn) return;
        btn.classList.toggle("is-visible", window.scrollY > 650);
      };

      window.addEventListener("scroll", setVisibility, { passive: true });
      window.addEventListener("resize", setVisibility, { passive: true });
      setVisibility();

      if (btn) {
        btn.addEventListener("click", (e) => {
          e.preventDefault();
          window.scrollTo({ top: 0, behavior: "smooth" });
        });
      }

      // Sticky CTA (mobile only)
      const sticky = document.getElementById("stickyCta");
      const setSticky = () => {
        if (!sticky) return;
        const isMobile = window.matchMedia("(max-width: 1023px)").matches;
        const show = isMobile && window.scrollY > (window.innerHeight * 0.30);
        sticky.classList.toggle("is-visible", show);
        sticky.setAttribute("aria-hidden", show ? "false" : "true");
      };

      window.addEventListener("scroll", setSticky, { passive: true });
      window.addEventListener("resize", setSticky, { passive: true });
      setSticky();
    </script>

    <!-- Global: copy referral codes anywhere they appear (buttons with .js-copyCode) -->
    <script is:inline>
      const bindCopyButtons = () => {
        const els = document.querySelectorAll(".js-copyCode");
        els.forEach((el) => {
          if (!(el instanceof HTMLElement)) return;
          if (el.dataset.copyBound === "true") return;
          el.dataset.copyBound = "true";

          el.addEventListener("click", async () => {
            const text = el.dataset.copy || el.textContent?.trim() || "";
            if (!text) return;

            try {
              await navigator.clipboard.writeText(text);
            } catch {
              // Fallback for older browsers / restricted contexts
              const ta = document.createElement("textarea");
              ta.value = text;
              ta.setAttribute("readonly", "");
              ta.style.position = "fixed";
              ta.style.top = "-9999px";
              document.body.appendChild(ta);
              ta.select();
              document.execCommand("copy");
              document.body.removeChild(ta);
            }

            const host = el.closest(".js-copyHost") || el.parentElement;
            const status = host?.querySelector?.(".js-copyStatus");
            if (status instanceof HTMLElement) {
              status.textContent = "Copied";
              status.setAttribute("data-show", "true");
              window.clearTimeout(status._copyT);
              status._copyT = window.setTimeout(() => {
                status.setAttribute("data-show", "false");
              }, 1400);
            }
          });
        });
      };

      // Run once on load
      bindCopyButtons();

      // If Astro swaps content later, re-bind safely
      document.addEventListener("astro:page-load", bindCopyButtons);
    </script>
  </body>
</html>
