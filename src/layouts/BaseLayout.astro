---
import "../styles/global.css";

const {
  lang = "en",
  title = "Star Citizen Beginner (SCB)",
  description = "",
  canonicalPath = "/",
  ogImage = "/assets/img/home/scb-home-hero.webp",
} = Astro.props;

// TODO: ersetzen mit echter Domain (z.B. https://starcitizenbeginner.com)
const canonical = `https://YOUR_DOMAIN${canonicalPath}`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" type="image/svg+xml" href="/assets/img/global/scb-logo.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />

    <title>{title}</title>
  </head>

  <body>
    <!-- Anchor target for "back to top" -->
    <div id="top"></div>

    <slot />

    <!-- Back to top (global) -->
    <a class="backToTop" href="#top" aria-label="Back to top" title="Back to top">
      ↑
    </a>

    <script>
      // Show button only when the top navigation/header is no longer visible.
      // Works for both .siteHeader (new) and .topbar (legacy).
      (() => {
        const btn = document.querySelector(".backToTop");
        if (!btn) return;

        const header = document.querySelector(".siteHeader") || document.querySelector(".topbar");
        if (!header) {
          // fallback: show after some scroll
          const onScrollFallback = () => {
            btn.classList.toggle("is-visible", window.scrollY > 500);
          };
          window.addEventListener("scroll", onScrollFallback, { passive: true });
          onScrollFallback();
          return;
        }

        const io = new IntersectionObserver(
          (entries) => {
            const visible = entries[0]?.isIntersecting;
            btn.classList.toggle("is-visible", !visible);
          },
          { threshold: 0.05 }
        );

        io.observe(header);
      })();
    </script>
  </body>
</html>
