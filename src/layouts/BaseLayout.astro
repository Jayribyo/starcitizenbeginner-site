---
import "../styles/global.css";
import SiteHeader from "../components/SiteHeader.astro";

const {
  showFooter = true,
  activeNav = "",
  lang = "en",
  title = "Star Citizen Beginner (SCB)",
  description = "",
  canonicalPath = "/",
  ogImage = "/assets/img/home/scb-home-hero.webp",
  ogImageAlt = "Star Citizen Beginner – guide preview image",
  robots = "index,follow",
  stickyCtaLabel = "",
  stickyCtaHref = "",
  stickyCtaExternal = false,
  paths = null,
} = Astro.props;

const site = Astro.site.toString().replace(/\/$/, "");
const safePath = canonicalPath?.startsWith("/") ? canonicalPath : `/${canonicalPath ?? ""}`;
const canonical = new URL(safePath, site).toString();
const ogImageAbs = ogImage?.startsWith("http")
  ? ogImage
  : new URL(ogImage.startsWith("/") ? ogImage : `/${ogImage}`, site).toString();

const desc =
  description?.trim() ||
  "Structured Star Citizen beginner guides: referral code bonus, Free Fly events, starter packs, early aUEC loops, and performance tips.";

const ogLocaleMap = {
  en: "en_US",
  de: "de_DE",
  fr: "fr_FR",
  es: "es_ES",
  zh: "zh_CN",
};
const ogLocale = ogLocaleMap[lang] ?? "en_US";

const CF_WA_TOKEN = import.meta.env.PUBLIC_CF_WEB_ANALYTICS_TOKEN;

const alternateEntries = paths && typeof paths === "object"
  ? Object.entries(paths).filter(([, href]) => typeof href === "string" && href.startsWith("/"))
  : [];

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Star Citizen Beginner",
  alternateName: "SCB",
  url: site,
  inLanguage: lang,
  description: desc,
};

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Star Citizen Beginner",
  url: site,
  logo: new URL("/assets/img/global/scb-logo.png", site).toString(),
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={desc} />
    <meta name="robots" content={robots} />

    {CF_WA_TOKEN ? (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={JSON.stringify({ token: CF_WA_TOKEN })}
      />
    ) : null}

    <link rel="canonical" href={canonical} />
    {alternateEntries.map(([locale, href]) => (
      <link rel="alternate" hreflang={locale} href={new URL(href, site).toString()} />
    ))}
    {alternateEntries.length > 0 && (
      <link rel="alternate" hreflang="x-default" href={new URL((paths?.en && typeof paths.en === "string" ? paths.en : "/"), site).toString()} />
    )}

    <link rel="icon" type="image/svg+xml" href="/assets/img/global/scb-logo.svg" />
    <link rel="icon" type="image/png" sizes="96x96" href="/assets/img/global/scb-logo.png" />
    <link rel="apple-touch-icon" sizes="96x96" href="/assets/img/global/scb-logo.png" />

    <meta property="og:site_name" content="Star Citizen Beginner (SCB)" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:image:alt" content={ogImageAlt} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={ogImageAbs} />

    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)}></script>

    <slot name="head" />
  </head>

  <body>
    <div id="top" aria-hidden="true"></div>

    <SiteHeader active={activeNav} currentPath={safePath} lang={lang} paths={paths} />

    <slot />

    {showFooter && (
      <footer class="footer">
        <div class="container">
          <div class="footer__inner">
            <div class="footer__brand">SCB — Unofficial Star Citizen guide.</div>
            <div class="footer__legal">
              Not affiliated with Cloud Imperium Games or Roberts Space Industries. Star Citizen® and related marks are trademarks of their respective owners.
            </div>
          </div>
        </div>
      </footer>
    )}

    {(stickyCtaLabel && stickyCtaHref) && (
      <div class="stickyCta" id="stickyCta" aria-hidden="true">
        <a
          class="btn primary stickyCta__btn"
          href={stickyCtaHref}
          {...(stickyCtaExternal ? { target: "_blank", rel: "noopener noreferrer" } : {})}
        >
          {stickyCtaLabel}
        </a>
      </div>
    )}

    <a class="backToTop" id="backToTop" href="#top" aria-label="Back to top">
      ↑
    </a>

    <script is:inline>
      const btn = document.getElementById("backToTop");

      const setVisibility = () => {
        if (!btn) return;
        btn.classList.toggle("is-visible", window.scrollY > 650);
      };

      window.addEventListener("scroll", setVisibility, { passive: true });
      window.addEventListener("resize", setVisibility, { passive: true });
      setVisibility();

      const SCB_LIVE_HOSTS = new Set(["starcitizenbeginner.com", "www.starcitizenbeginner.com"]);
      const scbIsLiveHost = SCB_LIVE_HOSTS.has(window.location.hostname);

      const scbPlacement = (el) => {
        if (!el || !el.closest) return "unknown";
        if (el.closest("#stickyCta")) return "sticky_cta";
        if (el.closest(".refOffer")) return "referral_banner";
        if (el.closest(".hero")) return "hero";
        if (el.closest('[data-scb-component="referral-cta"]')) return "referral_cta_box";
        if (el.closest(".topNav") || el.closest(".mobileNav")) return "nav";
        return "body";
      };

      const scbTrack = (eventName, props = {}) => {
        if (!scbIsLiveHost) return;
        try {
          if (window.zaraz && typeof window.zaraz.track === "function") {
            window.zaraz.track(eventName, props);
          }
        } catch (_) {}
      };

      if (btn) {
        btn.addEventListener("click", (e) => {
          e.preventDefault();
          window.scrollTo({ top: 0, behavior: "smooth" });
        });
      }

      const sticky = document.getElementById("stickyCta");
      const setSticky = () => {
        if (!sticky) return;
        const isMobile = window.matchMedia("(max-width: 1023px)").matches;
        const show = isMobile && window.scrollY > window.innerHeight * 0.3;
        sticky.classList.toggle("is-visible", show);
        sticky.setAttribute("aria-hidden", show ? "false" : "true");
      };

      window.addEventListener("scroll", setSticky, { passive: true });
      window.addEventListener("resize", setSticky, { passive: true });
      setSticky();
    </script>

    <div id="copyToast" class="copyToast" role="status" aria-live="polite">Copied</div>

    <script>
      (() => {
        const FALLBACK_CODE = "STAR-FSRJ-5N7Z";
        const toast = document.getElementById("copyToast");
        let t;

        async function copyText(str) {
          try {
            if (navigator.clipboard && window.isSecureContext) {
              await navigator.clipboard.writeText(str);
              return true;
            }
          } catch (e) {}

          try {
            const ta = document.createElement("textarea");
            ta.value = str;
            ta.setAttribute("readonly", "");
            ta.style.position = "fixed";
            ta.style.left = "-9999px";
            document.body.appendChild(ta);
            ta.select();
            const ok = document.execCommand("copy");
            document.body.removeChild(ta);
            return ok;
          } catch (e) {
            return false;
          }
        }

        function showToast(msg) {
          if (!toast) return;
          toast.textContent = msg;
          toast.classList.add("is-visible");
          window.clearTimeout(t);
          t = window.setTimeout(() => toast.classList.remove("is-visible"), 1200);
        }

        document.addEventListener(
          "click",
          async (e) => {
            const trigger = e.target.closest("[data-copy-referral], [data-copy], .js-copyCode");
            if (!trigger) return;

            const code =
              trigger.getAttribute("data-copy-referral") ||
              trigger.getAttribute("data-copy") ||
              trigger.textContent?.trim() ||
              document.documentElement.getAttribute("data-referral-code") ||
              FALLBACK_CODE;

            const ok = await copyText(code);
            showToast(ok ? "Copied" : "Copy failed");

            if (ok) {
              trigger.setAttribute("data-copied", "true");
              window.setTimeout(() => trigger.removeAttribute("data-copied"), 1200);
            }

            const status =
              trigger.parentElement?.querySelector?.(".copyStatus, .js-copyStatus") ||
              trigger.closest?.(".refOffer, [data-scb-component='referral-cta'], .card")?.querySelector?.(".copyStatus, .js-copyStatus");

            if (status) {
              status.textContent = ok ? "Copied" : "Copy failed";
              status.setAttribute("data-show", ok ? "true" : "false");
              window.setTimeout(() => status.removeAttribute("data-show"), 1200);
            }

            scbTrack("referral_code_copied", {
              code,
              placement: scbPlacement(trigger),
              path: window.location.pathname,
            });
          },
          { passive: true }
        );

        document.addEventListener(
          "click",
          (e) => {
            const a = e.target.closest("a[href]");
            if (!a) return;

            const href = a.getAttribute("href") || "";
            const placement = scbPlacement(a);

            if (href.includes("robertsspaceindustries.com") || href.includes("cloudimperiumgames.com")) {
              scbTrack("outbound_rsi_click", {
                href,
                placement,
                path: window.location.pathname,
                text: (a.textContent || "").trim().slice(0, 120),
              });
            }

            if (
              a.matches('[data-scb-role="where-to-paste"]') ||
              href.includes("#how-to-enter") ||
              href.includes("#how-to-use") ||
              href.includes("where-to-enter-referral-code")
            ) {
              scbTrack("where_to_paste_click", {
                href,
                placement,
                path: window.location.pathname,
              });
            }
          },
          { passive: true }
        );
      })();
    </script>
  </body>
</html>
