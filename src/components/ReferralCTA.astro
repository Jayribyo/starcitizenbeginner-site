---
import { REFERRAL_CODE, REFERRAL_LINK } from "../config/site";
const referralCode = REFERRAL_CODE;
const referralLink = REFERRAL_LINK;

const { title, blurb, ctaPrimary, ctaSecondary, ctaSecondaryHref = "#quickstart" } = Astro.props;
---
<div class="card pad referralCta" data-scb-component="referral-cta">
  <div class="kicker">Referral bonus</div>
  <h2 class="referralCta__title">{title}</h2>
  <p class="referralCta__body">{blurb}</p>

  <div class="referralCta__meta">
    <span class="badge">
      Code: <strong class="referralCta__code">{referralCode}</strong>
    </span>
    <button class="btn secondary js-copyCode" type="button" data-copy={referralCode}>Copy code</button>
  </div>

  <div class="referralCta__actions">
    <a class="btn primary" data-scb-role="referral-cta" href={referralLink} rel="nofollow noopener" target="_blank">{ctaPrimary}</a>
    <a class="btn secondary" href={ctaSecondaryHref}>{ctaSecondary}</a>
  </div>
</div>
