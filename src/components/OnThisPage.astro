---
/**
 * SCB OnThisPage (TOC) component
 *
 * Props:
 *  - items: Array<{ label: string, href: string }>
 *  - title: string
 *  - ariaLabel: string
 */
const {
  items = [],
  title = "On this page",
  ariaLabel = "On this page",
  variant = "section", // "section" | "hero"
} = Astro.props;
---

{variant === "hero" ? (
  <div class="hero__toc" aria-label={ariaLabel}>
    <div class="container">
      <div class:list={["card", "pad", "hero__tocCard", variant === "hero" && "hero__tocCard--hero"]}>
        <div class="kicker"><span class="dot"></span> {title}</div>
        <div class:list={["toc", variant === "hero" && "toc--hero", variant !== "hero" && "toc--section"]}>
          {items.map((it) => (
            <a href={it.href}>{it.label}</a>
          ))}
        </div>
      </div>
    </div>
  </div>
) : (
  <section class="section" aria-label={ariaLabel}>
    <div class="card pad">
      <div class="kicker"><span class="dot"></span> {title}</div>
      <div class:list={["toc", variant === "hero" && "toc--hero", variant !== "hero" && "toc--section"]}>
        {items.map((it) => (
          <a href={it.href}>{it.label}</a>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .toc{
    display:flex;
    flex-wrap:wrap;
    gap:10px 14px;
    margin-top:10px;
    font-weight:800;
    font-size:13px;
    opacity:.92;
  }

  .toc a{
    border:1px solid rgba(255,255,255,.10);
    background: rgba(255,255,255,.04);
    padding:8px 10px;
    border-radius:12px;
    transition: background .15s ease, border-color .15s ease, transform .15s ease, color .15s ease;
  }

  .toc a:hover{
    background: rgba(255,255,255,.07);
    border-color: rgba(255,255,255,.14);
    transform: translateY(-1px);
  }

  .hero__tocCard--hero{
    background: rgba(255,255,255,.035);
    border-color: rgba(255,255,255,.08);
    box-shadow: 0 12px 28px rgba(0,0,0,.28);
  }

  .toc--hero{
    gap: 8px 10px;
    margin-top: 9px;
    font-size: 12px;
    opacity: .88;
  }

  .toc--hero a{
    padding: 7px 10px;
    border-color: rgba(255,255,255,.08);
    background: rgba(255,255,255,.03);
  }

  .toc--hero a:hover{
    background: rgba(255,255,255,.055);
    border-color: rgba(255,255,255,.12);
  }
</style>
