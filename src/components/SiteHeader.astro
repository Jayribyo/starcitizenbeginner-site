---
import { DEFAULT_LANGUAGE_PATHS, LANGUAGE_OPTIONS, REFERRAL_BONUS_UEC } from "../config/site";

const { active = "", currentPath = "/", lang = "en", paths = null } = Astro.props;

const SHOW_LANG = import.meta.env.PUBLIC_SHOW_LANG_SWITCHER !== "0";

const guides = [
  { href: "/beginner-tips/", label: "Beginner Tips" },
  { href: "/star-citizen-starter-packs/", label: "Best Starter Packs" },
  { href: "/star-citizen-performance-guide/", label: "Performance Guide" },
  { href: "/make-money-fast/", label: "Make Money Fast" },
  { href: "/should-you-buy-star-citizen/", label: "Should You Buy Star Citizen?" },
  { href: "/how-to-buy-star-citizen/", label: "How to Buy Star Citizen" },
];

const normalizedLang = typeof lang === "string" && lang ? lang : "en";
const currentLang = LANGUAGE_OPTIONS.find((item) => item.key === normalizedLang)?.code ?? "EN";

const languages = LANGUAGE_OPTIONS
  .map((item) => {
    const explicitHref = paths && typeof paths === "object" ? paths[item.key] : null;
    const href = typeof explicitHref === "string" && explicitHref.startsWith("/")
      ? explicitHref
      : DEFAULT_LANGUAGE_PATHS[item.key];

    return { ...item, href };
  })
  .filter((item) => typeof item.href === "string" && item.href.startsWith("/"));
---

<header class="siteHeader" data-siteheader>
  <div class="container siteHeader__inner">
    <a class="brand" href="/" aria-label="Star Citizen Beginner Home" data-scb-role="brand-home">
      <img src="/assets/img/global/scb-logo.svg" alt="SCB logo" width="32" height="32" />
      <span>Star Citizen Beginner</span>
    </a>

    <nav class="topNav topNav--desktop" aria-label="Primary navigation">
      <a class:list={["topNav__link", active === "home" && "is-active"]} href="/" data-scb-role="nav-home">Home</a>

      <div class:list={["topNav__dd", active === "guides" && "is-active"]}>
        <a class="topNav__link topNav__trigger" href="/beginner-tips/" aria-haspopup="true" data-scb-role="nav-starter-guides">
          Starter Guides <span class="topNav__chev" aria-hidden="true">▾</span>
        </a>
        <div class="topNav__menu" role="menu" aria-label="Starter Guides">
          {guides.map((g) => (
            <a class="topNav__item" role="menuitem" href={g.href} data-scb-role="nav-guide-link">{g.label}</a>
          ))}
        </div>
      </div>

      <a class:list={["topNav__link", active === "referral" && "is-active"]} href="/star-citizen-referral-code/" data-scb-role="nav-referral">Referral Code <span class="topNav__pill topNav__pill--bonus">+{REFERRAL_BONUS_UEC} UEC</span></a>
      <a class:list={["topNav__link", active === "free-fly" && "is-active"]} href="/free-fly/" data-scb-role="nav-free-fly">Free Fly</a>

      {SHOW_LANG && languages.length > 1 && (
        <div class="topNav__dd topNav__dd--right">
          <button class="topNav__link topNav__trigger" type="button" aria-haspopup="true">
            Languages <span class="topNav__pill">{currentLang}</span>
            <span class="topNav__chev" aria-hidden="true">▾</span>
          </button>
          <div class="topNav__menu topNav__menu--right" role="menu" aria-label="Languages">
            {languages.map((l) => (
              <a class="topNav__item" role="menuitem" href={l.href} data-scb-role="nav-language-link" aria-current={normalizedLang === l.key ? "page" : undefined}>
                <span class="topNav__langCode">{l.code}</span>
                <span>{l.label}</span>
              </a>
            ))}
          </div>
        </div>
      )}
    </nav>

    <button class="navBurger" type="button" aria-label="Open menu" aria-controls="mobileDrawer" aria-expanded="false" data-navburger>
      <span class="navBurger__lines" aria-hidden="true"></span>
    </button>
  </div>

  <div class="mobileNavBackdrop" data-mobilebackdrop hidden></div>

  <aside class="mobileNavDrawer" id="mobileDrawer" data-mobiledrawer hidden aria-label="Mobile navigation">
    <div class="mobileNavDrawer__top">
      <span class="mobileNavDrawer__title">Menu</span>
      <button class="mobileNavDrawer__close" type="button" aria-label="Close menu" data-mobilenavclose>✕</button>
    </div>

    <nav class="mobileNav" aria-label="Mobile primary">
      <a class="mobileNav__link" href="/" data-close-on-nav data-scb-role="mobile-nav-home">Home</a>
      <a class="mobileNav__link" href="/star-citizen-referral-code/" data-close-on-nav data-scb-role="mobile-nav-referral">Referral Code <span class="topNav__pill topNav__pill--bonus">+{REFERRAL_BONUS_UEC} UEC</span></a>
      <a class="mobileNav__link" href="/free-fly/" data-close-on-nav data-scb-role="mobile-nav-free-fly">Free Fly</a>

      <details class="mobileNav__details">
        <summary class="mobileNav__summary">Starter Guides</summary>
        <div class="mobileNav__panel">
          {guides.map((g) => (
            <a class="mobileNav__sublink" href={g.href} data-close-on-nav data-scb-role="mobile-nav-guide-link">{g.label}</a>
          ))}
        </div>
      </details>

      {SHOW_LANG && languages.length > 1 && (
        <details class="mobileNav__details">
          <summary class="mobileNav__summary">Languages</summary>
          <div class="mobileNav__panel">
            {languages.map((l) => (
              <a class="mobileNav__langlink" href={l.href} data-close-on-nav data-scb-role="mobile-nav-language-link" aria-current={normalizedLang === l.key ? "page" : undefined}>
                <span class="topNav__langCode">{l.code}</span>
                <span>{l.label}</span>
              </a>
            ))}
          </div>
        </details>
      )}
    </nav>
  </aside>

  <script is:inline>
    (() => {
      const burger = document.querySelector('[data-navburger]');
      const drawer = document.querySelector('[data-mobiledrawer]');
      const backdrop = document.querySelector('[data-mobilebackdrop]');
      const closeBtn = document.querySelector('[data-mobilenavclose]');
      if (!burger || !drawer || !backdrop || !closeBtn) return;

      const open = () => {
        drawer.hidden = false;
        backdrop.hidden = false;
        document.body.classList.add('nav-open');

        requestAnimationFrame(() => {
          drawer.classList.add('is-open');
          backdrop.classList.add('is-open');
          burger.setAttribute('aria-expanded', 'true');
          burger.classList.add('is-active');
        });
      };

      const close = () => {
        drawer.classList.remove('is-open');
        backdrop.classList.remove('is-open');
        burger.setAttribute('aria-expanded', 'false');
        burger.classList.remove('is-active');
        document.body.classList.remove('nav-open');

        window.setTimeout(() => {
          drawer.hidden = true;
          backdrop.hidden = true;
        }, 160);
      };

      burger.addEventListener('click', () => {
        const expanded = burger.getAttribute('aria-expanded') === 'true';
        expanded ? close() : open();
      });

      closeBtn.addEventListener('click', close);
      backdrop.addEventListener('click', close);

      drawer.addEventListener('click', (e) => {
        const t = e.target;
        if (t && t.matches('[data-close-on-nav]')) close();
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && burger.getAttribute('aria-expanded') === 'true') close();
      });
    })();
  </script>
</header>
