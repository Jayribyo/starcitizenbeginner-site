---
const { active = "" } = Astro.props;

const guides = [
  { href: "/beginner-tips/", label: "Beginner Tips" },
  { href: "/starter-pack/", label: "Starter Pack" },
  { href: "/make-money-fast/", label: "Make Money Fast" },
  { href: "/performance-settings/", label: "Performance & FPS" },
];

// Languages: RU removed; order fixed as requested
const languages = [
  { href: "/", label: "English", code: "EN" },
  { href: "/de/", label: "Deutsch", code: "DE" },
  { href: "/fr/", label: "Français", code: "FR" },
  { href: "/es/", label: "Español", code: "ES" },
  { href: "/zh/", label: "中文", code: "中文" },
];

// For now static; later can be computed globally from Astro.url.pathname (no page edits needed).
const currentLang = "EN";
---

<header class="siteHeader" data-siteheader>
  <div class="container siteHeader__inner">
    <!-- SCB logo stays top-left as Home button -->
    <a class="brand" href="/" aria-label="Star Citizen Beginner Home">
      <img src="/assets/img/global/scb-logo.svg" alt="SCB logo" />
      <span>Star Citizen Beginner</span>
    </a>

    <!-- Desktop nav (unchanged structure/classes for CSS compatibility) -->
    <nav class="topNav topNav--desktop" aria-label="Primary navigation">
      <a class:list={["topNav__link", active === "home" && "is-active"]} href="/">Home</a>

      <!-- Guides dropdown (hover/focus) -->
      <div class:list={["topNav__dd", active === "guides" && "is-active"]}>
        <a class="topNav__link topNav__trigger" href="/beginner-tips/" aria-haspopup="true">
          Guides <span class="topNav__chev" aria-hidden="true">▾</span>
        </a>
        <div class="topNav__menu" role="menu" aria-label="Guides">
          {guides.map((g) => (
            <a class="topNav__item" role="menuitem" href={g.href}>{g.label}</a>
          ))}
        </div>
      </div>

      <a
        class:list={["topNav__link", active === "referral" && "is-active"]}
        href="/star-citizen-referral-code/"
      >
        Referral Code
      </a>

      <a
        class:list={["topNav__link", active === "free-fly" && "is-active"]}
        href="/free-fly/"
      >
        Free Fly
      </a>

      <!-- Languages dropdown (hover/focus) -->
      <div class="topNav__dd topNav__dd--right">
        <button class="topNav__link topNav__trigger" type="button" aria-haspopup="true">
          Languages <span class="topNav__pill">{currentLang}</span>
          <span class="topNav__chev" aria-hidden="true">▾</span>
        </button>
        <div class="topNav__menu topNav__menu--right" role="menu" aria-label="Languages">
          {languages.map((l) => (
            <a class="topNav__item" role="menuitem" href={l.href}>
              <span class="topNav__langCode">{l.code}</span>
              <span>{l.label}</span>
            </a>
          ))}
        </div>
      </div>
    </nav>

    <!-- Mobile burger (new; desktop unaffected) -->
    <button
      class="navBurger"
      type="button"
      aria-label="Open menu"
      aria-controls="mobileDrawer"
      aria-expanded="false"
      data-navburger
    >
      <span class="navBurger__lines" aria-hidden="true"></span>
    </button>
  </div>

  <!-- Mobile drawer (new) -->
  <div class="mobileNavBackdrop" data-mobilebackdrop hidden></div>

  <aside class="mobileNavDrawer" id="mobileDrawer" data-mobiledrawer hidden aria-label="Mobile navigation">
    <div class="mobileNavDrawer__top">
      <span class="mobileNavDrawer__title">Menu</span>
      <button class="mobileNavDrawer__close" type="button" aria-label="Close menu" data-mobilenavclose>✕</button>
    </div>

    <nav class="mobileNav" aria-label="Mobile primary">
      <a class="mobileNav__link" href="/" data-close-on-nav>Home</a>
      <a class="mobileNav__link" href="/star-citizen-referral-code/" data-close-on-nav>Referral Code</a>
      <a class="mobileNav__link" href="/free-fly/" data-close-on-nav>Free Fly</a>

      <details class="mobileNav__details">
        <summary class="mobileNav__summary">Guides</summary>
        <div class="mobileNav__panel">
          {guides.map((g) => (
            <a class="mobileNav__sublink" href={g.href} data-close-on-nav>{g.label}</a>
          ))}
        </div>
      </details>

      <details class="mobileNav__details">
        <summary class="mobileNav__summary">Languages</summary>
        <div class="mobileNav__panel">
          {languages.map((l) => (
            <a class="mobileNav__langlink" href={l.href} data-close-on-nav>
              <span class="topNav__langCode">{l.code}</span>
              <span>{l.label}</span>
            </a>
          ))}
        </div>
      </details>
    </nav>
  </aside>

  <script is:inline>
    (() => {
      const burger = document.querySelector('[data-navburger]');
      const drawer = document.querySelector('[data-mobiledrawer]');
      const backdrop = document.querySelector('[data-mobilebackdrop]');
      const closeBtn = document.querySelector('[data-mobilenavclose]');
      if (!burger || !drawer || !backdrop || !closeBtn) return;

  const open = () => {
  drawer.hidden = false;
  backdrop.hidden = false;

  // body scroll lock
  document.body.classList.add('nav-open');

  requestAnimationFrame(() => {
    drawer.classList.add('is-open');
    backdrop.classList.add('is-open');
    burger.setAttribute('aria-expanded', 'true');
    burger.classList.add('is-active'); // for burger animation
  });
};

const close = () => {
  drawer.classList.remove('is-open');
  backdrop.classList.remove('is-open');
  burger.setAttribute('aria-expanded', 'false');
  burger.classList.remove('is-active');

  // remove body scroll lock
  document.body.classList.remove('nav-open');

  window.setTimeout(() => {
    drawer.hidden = true;
    backdrop.hidden = true;
  }, 160);
};
      burger.addEventListener('click', () => {
        const expanded = burger.getAttribute('aria-expanded') === 'true';
        expanded ? close() : open();
      });

      closeBtn.addEventListener('click', close);
      backdrop.addEventListener('click', close);

      drawer.addEventListener('click', (e) => {
        const t = e.target;
        if (t && t.matches('[data-close-on-nav]')) close();
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && burger.getAttribute('aria-expanded') === 'true') close();
      });
    })();
  </script>
</header>


