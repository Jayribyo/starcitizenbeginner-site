---
const { items = [] } = Astro.props;
const site = Astro.site?.toString()?.replace(/\/$/, "") ?? "";

const schema =
  items?.length > 0 && site
    ? JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: items.map((it, idx) => ({
          "@type": "ListItem",
          position: idx + 1,
          name: it.label,
          item: new URL(it.href, site).toString(),
        })),
      })
    : "";
---

{items?.length > 0 && (
  <>
    <script type="application/ld+json" set:html={schema}></script>
    <nav class="crumbs" aria-label="Breadcrumb">
      <div class="container">
        <ol class="crumbs__list">
          {items.map((it, idx) => (
            <li class="crumbs__item">
              {idx < items.length - 1 ? (
                <a class="crumbs__link" href={it.href}>{it.label}</a>
              ) : (
                <span class="crumbs__current" aria-current="page">{it.label}</span>
              )}
              {idx < items.length - 1 && <span class="crumbs__sep" aria-hidden="true">›</span>}
            </li>
          ))}
        </ol>
      </div>
    </nav>
  </>
)}
