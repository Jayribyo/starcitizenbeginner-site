---
const { lang = "en", paths = {} } = Astro.props;

const langs = [
  { key: "en", label: "EN" },
  { key: "de", label: "DE" },
  { key: "es", label: "ES" },
  { key: "fr", label: "FR" },
  { key: "zh", label: "中文" },
].filter((item) => typeof paths[item.key] === "string" && paths[item.key]);
---
<nav aria-label="Language switcher">
  <div class="badge">
    <span style="opacity:.8;">Lang:</span>
    <div style="display:flex; gap:8px; flex-wrap:wrap;">
      {langs.map((item) => (
        <a
          href={paths[item.key]}
          style={`text-decoration:none; font-weight:800; opacity:${item.key === lang ? 1 : .7};`}
          aria-current={item.key === lang ? "page" : undefined}
        >
          {item.label}
        </a>
      ))}
    </div>
  </div>
</nav>
