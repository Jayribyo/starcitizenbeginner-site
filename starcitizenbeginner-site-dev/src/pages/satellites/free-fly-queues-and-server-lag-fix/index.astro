---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ReferralBanner from "../../../components/ReferralBanner.astro";
import OnThisPage from "../../../components/OnThisPage.astro";
import FaqSchema from "../../../components/FaqSchema.astro";
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { REFERRAL_CODE, REFERRAL_LINK, REFERRAL_INFO_PATH, REFERRAL_BONUS_UEC, FLY_FREE_URL } from "../../../config/site";

const referralCode = REFERRAL_CODE;
const referralLink = REFERRAL_LINK;

const heroImg = "/assets/img/free-fly/star-citizen-free-fly-hero.webp";

const tocItems = [
  { id: "quick-answer", label: "Quick answer" },
  { id: "do-this-now", label: "Do this now" },
  { id: "common-mistakes", label: "Common mistakes" },
  { id: "next-steps", label: "Next steps" },
  { id: "faq", label: "FAQ" }
];

const faqItems = [
  { q: "Can I fix queues with settings?", a: "No. Queues are server-side." },
  { q: "Is lag always the server?", a: "Often, but not always. If it happens everywhere, check PC performance too." },
  { q: "How do I know if it’s my PC?", a: "Retest the same scene after a performance change; server issues won’t respond to your settings." },
  { q: "What’s the fastest way to get a fair test?", a: "Short loop + session/region hop if needed." },
  { q: "Where should I go next?", a: "Use the Free Fly guide’s full checklist and the performance guide if stutter persists." }
];
---

<BaseLayout
  title="Free Fly Queues and Server Lag: What You Can Control | Star Citizen Beginner"
  description="Free Fly queues and server lag: what you can control, what you cannot, and how to turn a rough session into a fair test without overthinking it."
  canonicalPath="/satellites/free-fly-queues-and-server-lag-fix/"
  ogImage={heroImg}
  ogImageAlt="Free Fly Queues & Server Lag (Beginner-Safe Fixes)"
  stickyCtaLabel="Create account + claim bonus"
  stickyCtaHref={referralLink}
  stickyCtaExternal={true}
  activeNav="guides"
>
  <main>

    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Answers', href: '/satellites/' }, { label: 'Answer', href: '/satellites/free-fly-queues-and-server-lag-fix/' }]} />
    <section class="hero guideHero">
      <img
        class="hero__img"
        src={heroImg}
        alt="Free Fly Queues & Server Lag (Beginner-Safe Fixes)"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1536"
        height="1024"
      />
      <div class="hero__overlay"></div>

      <div class="hero__content">
        <div class="guideHero__content">
          <div class="kicker"><span class="dot"></span> Starter Guide</div>
          <h1 class="h1">Free Fly queues and server lag fixes</h1>
          <p class="lead" style="max-width: 820px;">Answer: If Free Fly feels rough, this page shows what you can still control right now: region choice, session hopping, crowded hubs, and when to stop blaming your PC.</p>

          <div class="hero__cta">
            <a class="btn primary" href="#quick-answer">Start here</a>
          </div>
        </div>

        <OnThisPage variant="hero" title="On this page" items={tocItems} />
      </div>
    </section>

    <ReferralBanner
      code={referralCode}
      bonus="50,000"
      ctaLabel="Claim your start bonus"
      ctaHref={referralLink}
      ctaExternal={true}
    />

    <section id="quick-answer" class="section">
      <div class="container">
        <h2 class="h2">Quick answer</h2>

        <div class="card pad" style="margin-bottom:12px;">
          <div class="kicker"><span class="dot"></span>Answer</div>
          <p class="lead" style="margin-top:10px;">Queues and lag are mostly server-side. Your PC tuning won’t remove queues — but you can still get a fair test session.</p>
        </div>

        <ul class="bullets">
          <li>Do not judge the whole game by one bad queue hour or one overloaded city.</li>
          <li>Queues and lag are mostly <b>server-side</b>. Your PC tuning won’t remove queues — but you can still get a fair test session.</li>
<li>Beginner rule: don’t waste an hour in a bad session. Run short loops and switch sessions/regions if needed.</li>
<li>If performance feels bad everywhere, then it’s time for the PC checklist.</li>
        </ul>
      </div>
    </section>

    <section id="do-this-now" class="section alt">
      <div class="container">
        <h2 class="h2">Do this now</h2>
        <ol class="steps">
          <li><b>Pick a short objective</b> (10–15 min): claim ship → fly → finish one short contract.</li>
<li><b>If the session is rough</b>, switch to a new server session and repeat the same short objective.</li>
<li><b>If it’s still rough</b>, try another region and repeat the same short objective.</li>
<li><b>Avoid crowded hubs</b> for your first loop — leave the city quickly.</li>
<li><b>If stutter persists</b> even in calmer scenes, run the performance baseline and retest.</li>
        </ol>
      </div>
    </section>

    <section id="common-mistakes" class="section">
      <div class="container">
        <h2 class="h2">Common mistakes (and exact fixes)</h2>
        <div class="tableWrap">
          <table class="table">
            <thead>
              <tr>
                <th>Mistake</th>
                <th>What happens</th>
                <th>Fix (exact)</th>
              </tr>
            </thead>
            <tbody>
              <tr><td><b>Waiting out a bad session</b></td><td>You lose time and learn nothing.</td><td>Abort early; repeat a short loop elsewhere.</td></tr>
<tr><td><b>Mixing server lag with PC performance</b></td><td>You blame the wrong thing.</td><td>Retest: different session/region vs same scene after fixes.</td></tr>
<tr><td><b>Starting in the busiest place every time</b></td><td>You get the worst-case experience.</td><td>Get airborne fast; test in a calmer area too.</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section id="next-steps" class="section alt">
      <div class="container">
        <h2 class="h2">Next steps</h2>
        <ul class="bullets">
          <li><a href="/free-fly/">Open the full Free Fly guide</a></li>
<li><a href="/satellites/best-time-to-play-free-fly/">Still trying to find a calmer session window? Use this next</a></li>
<li><a href="/star-citizen-performance-guide/">If the game feels rough everywhere, check performance next</a></li>
        </ul>
      </div>
    </section>

    <section id="faq" class="section">
      <div class="container">
        <h2 class="h2">FAQ</h2>
        <div class="faq" style="margin-top:12px;">
          {faqItems.map((item) => (
            <details class="faq__item">
              <summary class="faq__q">{item.q}</summary>
              <div class="faq__a">{item.a}</div>
            </details>
          ))}
        </div>
        
      </div>

      <FaqSchema items={faqItems} />
    </section>
  </main>
</BaseLayout>
