{
  "name": "starcitizenbeginner-site",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node ./scripts/generate-sitemap.mjs",
    "preview": "astro preview",
    "check": "astro check",
    "validate:links": "node ./scripts/validate-internal-links.mjs",
    "validate:site": "node ./scripts/validate-site-config.mjs",
    "validate:free-fly": "node ./scripts/validate-free-fly-cluster.mjs",
    "ci:check": "astro check && pnpm run validate:links && pnpm run validate:site && pnpm run validate:free-fly && pnpm run validate:public",
    "validate:public": "node ./scripts/validate-public-artifacts.mjs"
  },
  "dependencies": {
    "astro": "^4.16.0"
  },
  "engines": {
    "node": ">=20 <23"
  },
  "packageManager": "pnpm@9.15.4"
}
